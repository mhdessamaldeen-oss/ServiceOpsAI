{
  "name": "Shape: FILTER (list with conditions, default catch-all)",
  "version": "1.0",
  "description": "Filtered listing. Tests InjectLookupValueFilterFromQuestionPhase, NegationFilterPhase, MultiValueInFilterPhase (when added), RewriteEmptyToIsNullPhase, ApplyConceptPatternsPhase.",
  "Scenarios": [
    { "Code": "FLT-SIMPLE-1", "Question": "open tickets", "Category": "shape:FILTER/lookup-value", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "TicketStatuses.Name", "Op": "eq", "Value": "Open" }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-SIMPLE-2", "Question": "unpaid bills", "Category": "shape:FILTER/lookup-value-multi", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Bills.Status", "Op": "in", "Value": ["Issued", "Overdue"] }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-SIMPLE-3", "Question": "active outages", "Category": "shape:FILTER/concept", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Outages.EndedAt", "Op": "isnull" }], "MaxLatencyMs": 180000 },

    { "Code": "FLT-MEDIUM-1", "Question": "open tickets in Damascus", "Category": "shape:FILTER/value+region", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "TicketStatuses.Name", "Op": "eq", "Value": "Open" }, { "Column": "Regions.NameEn", "Op": "eq", "Value": "Damascus" }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-MEDIUM-2", "Question": "unpaid water bills", "Category": "shape:FILTER/value+service", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Bills.Status", "Op": "in", "Value": ["Issued", "Overdue"] }, { "Column": "ServiceTypes.Code", "Op": "eq", "Value": "Water" }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-MEDIUM-3", "Question": "tickets in last 30 days", "Category": "shape:FILTER/temporal", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Tickets.CreatedAt", "Op": "gte", "Value": "@days:-30" }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-MEDIUM-4", "Question": "bills with amount above 50000", "Category": "shape:FILTER/range", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Bills.TotalAmount", "Op": "gt", "Value": 50000 }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-MEDIUM-5", "Question": "bills between 5000 and 10000", "Category": "shape:FILTER/range-between", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Bills.TotalAmount", "Op": "gte", "Value": 5000 }, { "Column": "Bills.TotalAmount", "Op": "lte", "Value": 10000 }], "MaxLatencyMs": 180000 },

    { "Code": "FLT-HARD-1", "Question": "high-priority unresolved electricity complaints from Aleppo created this week", "Category": "shape:FILTER/compound-multifilter", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "TicketPriorities.Name", "Op": "eq", "Value": "High" }, { "Column": "Tickets.ResolvedAt", "Op": "isnull" }, { "Column": "ServiceTypes.Code", "Op": "eq", "Value": "Electricity" }, { "Column": "Regions.NameEn", "Op": "eq", "Value": "Aleppo" }, { "Column": "Tickets.CreatedAt", "Op": "gte", "Value": "@week_start" }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-HARD-2", "Question": "tickets with title containing electricity", "Category": "shape:FILTER/text-search", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Tickets.Title", "Op": "like", "Value": "%electricity%" }], "MaxLatencyMs": 180000 },

    { "Code": "FLT-MULTI-1", "Question": "tickets that are open or in progress", "Category": "shape:FILTER/multi-value-in", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "TicketStatuses.Name", "Op": "in", "Value": ["Open", "In Progress"] }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-MULTI-2", "Question": "tickets in Damascus or Aleppo", "Category": "shape:FILTER/multi-value-in-region", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Regions.NameEn", "Op": "in", "Value": ["Damascus", "Aleppo"] }], "MaxLatencyMs": 180000 },

    { "Code": "FLT-NEG-1", "Question": "tickets not in Damascus", "Category": "shape:FILTER/negation", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Regions.NameEn", "Op": "neq", "Value": "Damascus" }], "MaxLatencyMs": 180000 },
    { "Code": "FLT-NEG-2", "Question": "bills excluding paid ones", "Category": "shape:FILTER/negation-exclude", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "Bills.Status", "Op": "neq", "Value": "Paid" }], "MaxLatencyMs": 180000 },

    { "Code": "FLT-AR-1", "Question": "التذاكر المفتوحة في دمشق", "Category": "shape:FILTER/arabic", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "LIST", "ExpectedFilters": [{ "Column": "TicketStatuses.Name", "Op": "eq", "Value": "Open" }, { "Column": "Regions.NameEn", "Op": "eq", "Value": "Damascus" }], "MaxLatencyMs": 180000 },

    { "Code": "FLT-EDGE-1", "Question": "give me the overdue stuff", "Category": "shape:FILTER/edge-casual", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedOperation": "LIST", "MaxLatencyMs": 180000 }
  ]
}
