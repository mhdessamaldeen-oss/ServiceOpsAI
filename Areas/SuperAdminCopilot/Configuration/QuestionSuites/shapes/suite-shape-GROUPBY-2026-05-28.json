{
  "name": "Shape: GROUPBY (faceted aggregation, non-time)",
  "version": "1.0",
  "description": "Faceted aggregation grouped by a categorical dimension (region / service / status / category) — distinct from TIMESERIES (date-bucketed) and TOPN (limited). Tests the canonical SELECT label, COUNT/SUM/AVG, GROUP BY label shape. Spider/BIRD reference: ~25% of analytic questions fall in this band.",
  "Scenarios": [
    { "Code": "GRP-SIMPLE-1", "Question": "tickets per region", "Category": "shape:GROUPBY/count-by-dim", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["Regions.NameEn"], "ExpectedFields": ["Regions.NameEn"], "MaxLatencyMs": 180000 },
    { "Code": "GRP-SIMPLE-2", "Question": "bills per service type", "Category": "shape:GROUPBY/count-by-dim", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["ServiceTypes.NameEn"], "MaxLatencyMs": 180000 },
    { "Code": "GRP-SIMPLE-3", "Question": "outages by service type", "Category": "shape:GROUPBY/count-by-dim", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["ServiceTypes.NameEn"], "MaxLatencyMs": 180000 },
    { "Code": "GRP-SIMPLE-4", "Question": "tickets by status", "Category": "shape:GROUPBY/count-by-status", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["TicketStatuses.Name"], "MaxLatencyMs": 180000 },

    { "Code": "GRP-MEDIUM-1", "Question": "total revenue per region", "Category": "shape:GROUPBY/sum-by-dim", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "SUM", "column": "Bills.TotalAmount" }], "ExpectedGroupBy": ["Regions.NameEn"], "MaxLatencyMs": 180000 },
    { "Code": "GRP-MEDIUM-2", "Question": "average bill amount per service type", "Category": "shape:GROUPBY/avg-by-dim", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "AVG", "column": "Bills.TotalAmount" }], "ExpectedGroupBy": ["ServiceTypes.NameEn"], "MaxLatencyMs": 180000 },
    { "Code": "GRP-MEDIUM-3", "Question": "outage count per region this year", "Category": "shape:GROUPBY/count-by-dim+temporal", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["Regions.NameEn"], "ExpectedFilters": [{ "Column": "Outages.StartedAt", "Op": "gte", "Value": "@year_start" }], "MaxLatencyMs": 180000 },
    { "Code": "GRP-MEDIUM-4", "Question": "tickets per priority for open tickets", "Category": "shape:GROUPBY/count-by-dim+filter", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["TicketPriorities.Name"], "ExpectedFilters": [{ "Column": "TicketStatuses.Name", "Op": "eq", "Value": "Open" }], "MaxLatencyMs": 180000 },

    { "Code": "GRP-HARD-1", "Question": "average resolution time per department", "Category": "shape:GROUPBY/avg-derived-by-dim", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "AVG", "column": "DATEDIFF(HOUR, Tickets.CreatedAt, Tickets.ResolvedAt)" }], "ExpectedGroupBy": ["Departments.NameEn"], "ExpectedFilters": [{ "Column": "Tickets.ResolvedAt", "Op": "notnull" }], "MaxLatencyMs": 180000 },
    { "Code": "GRP-HARD-2", "Question": "outage MTTR by service type in hours", "Category": "shape:GROUPBY/mttr-by-dim", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "AVG", "column": "DATEDIFF(HOUR, Outages.StartedAt, Outages.EndedAt)" }], "ExpectedGroupBy": ["ServiceTypes.NameEn"], "ExpectedFilters": [{ "Column": "Outages.EndedAt", "Op": "notnull" }], "MaxLatencyMs": 180000 },
    { "Code": "GRP-HARD-3", "Question": "total billed amount per customer for paid bills this year", "Category": "shape:GROUPBY/sum-by-dim+multifilter", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "SUM", "column": "Bills.TotalAmount" }], "ExpectedGroupBy": ["Customers.FullNameEn"], "ExpectedFilters": [{ "Column": "Bills.Status", "Op": "eq", "Value": "Paid" }, { "Column": "Bills.IssuedAt", "Op": "gte", "Value": "@year_start" }], "MaxLatencyMs": 180000 },
    { "Code": "GRP-HARD-4", "Question": "ticket count per category in Damascus this month", "Category": "shape:GROUPBY/count-by-dim+region+temporal", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["TicketCategories.Name"], "ExpectedFilters": [{ "Column": "Regions.NameEn", "Op": "eq", "Value": "Damascus" }, { "Column": "Tickets.CreatedAt", "Op": "gte", "Value": "@month_start" }], "MaxLatencyMs": 180000 },

    { "Code": "GRP-AR-1", "Question": "التذاكر حسب المنطقة", "Category": "shape:GROUPBY/arabic-by-region", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["Regions.NameEn"], "MaxLatencyMs": 180000 },
    { "Code": "GRP-AR-2", "Question": "إجمالي الفواتير حسب نوع الخدمة", "Category": "shape:GROUPBY/arabic-sum-by-service", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "SUM", "column": "Bills.TotalAmount" }], "ExpectedGroupBy": ["ServiceTypes.NameEn"], "MaxLatencyMs": 180000 },

    { "Code": "GRP-EDGE-1", "Question": "break down tickets by source", "Category": "shape:GROUPBY/edge-paraphrase", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "GROUPBY", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["TicketSources.Name"], "MaxLatencyMs": 180000 }
  ]
}
