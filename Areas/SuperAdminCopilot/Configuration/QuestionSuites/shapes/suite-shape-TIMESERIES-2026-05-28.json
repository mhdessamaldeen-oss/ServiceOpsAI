{
  "name": "Shape: TIMESERIES (date-bucketed grouping)",
  "version": "1.0",
  "description": "Date-bucketed grouping by day/week/month/quarter/year. Tests InjectTimeSeriesBucketingPhase (verb-aware date column selection added 2026-05-28), SELECT/GROUP BY consistency, and DATEADD round-trip ordering.",
  "Scenarios": [
    { "Code": "TS-SIMPLE-1", "Question": "tickets created per month", "Category": "shape:TIMESERIES/monthly", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(month, DATEDIFF(month, 0, Tickets.CreatedAt), 0)"], "MaxLatencyMs": 180000 },
    { "Code": "TS-SIMPLE-2", "Question": "bills issued per quarter", "Category": "shape:TIMESERIES/quarterly", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(quarter, DATEDIFF(quarter, 0, Bills.IssuedAt), 0)"], "MaxLatencyMs": 180000 },
    { "Code": "TS-SIMPLE-3", "Question": "outages per week", "Category": "shape:TIMESERIES/weekly", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(week, DATEDIFF(week, 0, Outages.StartedAt), 0)"], "MaxLatencyMs": 180000 },
    { "Code": "TS-SIMPLE-4", "Question": "outages by year", "Category": "shape:TIMESERIES/yearly", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["YEAR(Outages.StartedAt)"], "MaxLatencyMs": 180000 },

    { "Code": "TS-MEDIUM-1", "Question": "tickets opened per day this week", "Category": "shape:TIMESERIES/daily+temporal", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["CAST(Tickets.CreatedAt AS DATE)"], "ExpectedFilters": [{ "Column": "Tickets.CreatedAt", "Op": "gte", "Value": "@week_start" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-MEDIUM-2", "Question": "bills issued per month last year", "Category": "shape:TIMESERIES/monthly+temporal", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(month, DATEDIFF(month, 0, Bills.IssuedAt), 0)"], "ExpectedFilters": [{ "Column": "Bills.IssuedAt", "Op": "gte", "Value": "@last_year_start" }, { "Column": "Bills.IssuedAt", "Op": "lt", "Value": "@year_start" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-MEDIUM-3", "Question": "outages per week last quarter", "Category": "shape:TIMESERIES/weekly+temporal", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(week, DATEDIFF(week, 0, Outages.StartedAt), 0)"], "ExpectedFilters": [{ "Column": "Outages.StartedAt", "Op": "gte", "Value": "@last_quarter_start" }, { "Column": "Outages.StartedAt", "Op": "lt", "Value": "@quarter_start" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-MEDIUM-4", "Question": "trend of bill payments over time", "Category": "shape:TIMESERIES/trend-default-monthly", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedFilters": [{ "Column": "Bills.Status", "Op": "eq", "Value": "Paid" }], "MaxLatencyMs": 180000 },

    { "Code": "TS-HARD-1", "Question": "monthly trend of resolved electricity tickets", "Category": "shape:TIMESERIES/monthly+verb-resolved+lookup-filter", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(month, DATEDIFF(month, 0, Tickets.ResolvedAt), 0)"], "ExpectedFilters": [{ "Column": "ServiceTypes.Code", "Op": "eq", "Value": "Electricity" }, { "Column": "Tickets.ResolvedAt", "Op": "notnull" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-HARD-2", "Question": "weekly outages in Aleppo this quarter", "Category": "shape:TIMESERIES/weekly+region+temporal", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Outages", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedFilters": [{ "Column": "Regions.NameEn", "Op": "eq", "Value": "Aleppo" }, { "Column": "Outages.StartedAt", "Op": "gte", "Value": "@quarter_start" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-HARD-3", "Question": "monthly bill totals for gas service customers", "Category": "shape:TIMESERIES/monthly+sum+lookup-filter", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "SUM", "column": "Bills.TotalAmount" }], "ExpectedFilters": [{ "Column": "ServiceTypes.Code", "Op": "eq", "Value": "Gas" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-HARD-4", "Question": "cumulative tickets resolved per quarter", "Category": "shape:TIMESERIES/cumulative-window", "Difficulty": "Hard", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "TIMESERIES_WINDOW", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedFilters": [{ "Column": "Tickets.ResolvedAt", "Op": "notnull" }], "MaxLatencyMs": 180000 },

    { "Code": "TS-AR-1", "Question": "التذاكر شهريا", "Category": "shape:TIMESERIES/arabic-monthly", "Difficulty": "Easy", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Tickets", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "MaxLatencyMs": 180000 },
    { "Code": "TS-AR-2", "Question": "اتجاه الفواتير الشهري", "Category": "shape:TIMESERIES/arabic-trend", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "MaxLatencyMs": 180000 },

    { "Code": "TS-EDGE-1", "Question": "weekly customer signups", "Category": "shape:TIMESERIES/weekly+signup-verb", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Customers", "ExpectedOperation": "TIMESERIES", "ExpectedAggregations": [{ "function": "COUNT", "column": "*" }], "ExpectedGroupBy": ["DATEADD(week, DATEDIFF(week, 0, Customers.SignupAt), 0)"], "MaxLatencyMs": 180000 },
    { "Code": "TS-EDGE-2", "Question": "show me the bill trend", "Category": "shape:TIMESERIES/edge-vague", "Difficulty": "Medium", "ExpectedIntent": "DataQuery", "ExpectedPrimaryEntity": "Bills", "ExpectedOperation": "TIMESERIES", "MaxLatencyMs": 180000 }
  ]
}
