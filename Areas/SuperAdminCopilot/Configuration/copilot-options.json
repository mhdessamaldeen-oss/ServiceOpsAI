{
  // SuperAdminCopilot — single-source runtime settings.
  //
  // This file is the ONLY place runtime knobs live. Edit a value, restart the host,
  // see the effect. Properties NOT listed here fall back to the C# defaults defined in
  // Areas/SuperAdminCopilot/Configuration/CopilotOptions.cs (full schema there).
  //
  // Operator quick-toggle path: the SystemSettings DB table is overlaid AFTER this file
  // via HostCopilotOptionsConfigurator. Use SystemSettings for admin-UI changes;
  // use this file for engineering-owned baselines.
  //
  // Profile (Phase 4): selects a preset overlay applied to threshold properties.
  // See "Profiles" block at the bottom. Profile values shadow the explicit values above.

  "SuperAdminCopilot": {

    // ── Profile selector ─────────────────────────────────────────────────────────
    // One of: "Cloud" | "LocalMedium" | "LocalSmall". Each preset overlays the
    // threshold properties below. Set to null/empty to use the explicit values as-is.
    "Profile": "LocalMedium",

    // ── Thresholds (overlaid by Profile) ─────────────────────────────────────────
    // Defaults are tuned for cloud models; lower for local models that can't hit 0.90.
    "IntentClassifierDecisiveConfidence": 0.78,
    "VerifiedQueryMinSimilarity":         0.80,
    "PastQuestionRagMinSimilarity":       0.72,
    "OutOfScopeSchemaFloor":              0.20,
    "OutOfScopeVerifiedQueryFloor":       0.55,
    "ResolverMinConfidence":              0.60,

    // ── Retrieval / RAG ──────────────────────────────────────────────────────────
    "UseVectorRetriever": true,
    "UsePastQuestionRag": false,
    "RetrieverTopK":      5,
    "FewShotTopK":        3,
    "SpecPromptMaxTables":      6,        // Phase 3: was hardcoded in SpecExtractor:149
    "VqFewShotMinSimilarity":   0.65,     // Phase 3: was hardcoded in SpecExtractor:181
    "VqFewShotTopK":            3,        // Phase 3: was hardcoded in SpecExtractor:181
    "ScopeGateRetrieverTopK":   1,        // Phase 3: was hardcoded in ScopeConfidenceGate:74

    // ── Limits ───────────────────────────────────────────────────────────────────
    "MaxRows":                     1000,
    "CommandTimeoutSeconds":       30,
    "MaxLlmCallsPerQuestion":      7,
    "MaxQuestionWallClockSeconds": 1800,
    "LlmCallTimeoutSeconds":       900,
    "MaxSelfCorrectionRetries":    1,

    // ── Feature toggles ──────────────────────────────────────────────────────────
    "EnableScopeConfidenceGate": true,
    "EnableDecomposer":          true,
    "EnableCoverageChecker":     true,
    "EnableResultCache":         true,
    "ResultCacheTtlSeconds":     60,
    "EnableCostGate":            false,

    // ── Safety ───────────────────────────────────────────────────────────────────
    "KillSwitch":                           false,
    "RateLimitMaxRequestsPerWindow":        30,
    "RateLimitWindowSeconds":               60,
    "EnableSchemaIntrospection":            true,
    "RestrictMetadataToConfiguredEntities": false,
    "FailFastOnSchemaDrift":                false,

    // ── Schema visibility (what tables the Copilot can see) ──────────────────────
    // C# defaults are EMPTY by convention — this file is the single source. To port to
    // a new app, edit ONLY these lists. Wildcard syntax: "*" matches any sequence.
    "RetrieverHiddenTables": [
      "CopilotAssessmentRunSummaries",
      "CopilotTraceHistories",
      "CopilotChatMessages",
      "CopilotChatSessions",
      "CopilotToolDefinitions",
      "SystemSettings",
      "GeminiApiKeys",
      "GroqApiKeys",
      "ExternalApiSettings",
      "CustomThemes",
      "RetrievalBenchmarkRuns",
      "TicketAiAnalyses",
      "TicketAiAnalysisLogs",
      "TicketSemanticEmbeddings"
    ],
    "RetrieverHiddenTablePatterns": [
      "__*",        // EF Core migration tables
      "AspNet*",    // ASP.NET Identity tables (override per host if needed)
      "*ApiKey*",   // API-key stores (Groq, Gemini, future providers) — never user-queryable
      "*Benchmark*" // model-eval / retrieval-benchmark tables — not domain data
    ],

    // ── Access denylist (hard blocks, applied to every Copilot layer) ────────────
    "BlockedTables": [
      "__EFMigrationsHistory"
    ],
    "BlockedTablePatterns": [
      "Audit*",
      "*Secret*",
      "*Token*"
    ],

    // ── Sensitive column denylist (SECURITY-CRITICAL) ────────────────────────────
    // C# defaults are EMPTY. If you remove an entry here, sensitive columns CAN leak.
    // The patterns below cover ASP.NET Identity + common secret-bearing column names —
    // a new host should retain them and ADD any host-specific secret columns.
    "BlockedColumns": [
      "*.PasswordHash",
      "*.SecurityStamp",
      "*.ConcurrencyStamp",
      "*.AuthenticatorKey",
      "*.RecoveryCode",
      "*.ApiKey",
      "*.Secret",
      "*.Token",
      "*.Password"
    ],

    // ── Profile presets (Phase 4 — applied by CopilotOptionsLoader) ──────────────
    // When "Profile" above matches one of these keys, the inner properties OVERLAY
    // the explicit values above. Leaves anything not listed alone. Add new profiles
    // (e.g., "LocalTiny") by adding new keys to this block — no code change.
    "Profiles": {
      "Cloud": {
        "IntentClassifierDecisiveConfidence": 0.90,
        "VerifiedQueryMinSimilarity":         0.90,
        "PastQuestionRagMinSimilarity":       0.82
      },
      "LocalMedium": {
        "IntentClassifierDecisiveConfidence": 0.78,
        "VerifiedQueryMinSimilarity":         0.88,
        "PastQuestionRagMinSimilarity":       0.72
      },
      "LocalSmall": {
        "IntentClassifierDecisiveConfidence": 0.65,
        "VerifiedQueryMinSimilarity":         0.70,
        "PastQuestionRagMinSimilarity":       0.65
      }
    }
  }
}
