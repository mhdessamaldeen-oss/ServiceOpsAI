@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.CustomerDto>

@{
    ViewData["Title"] = "Customers Management";
    var request = Model.Request;
    var customersTable = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Customer Registry",
        Subtitle = "External subscribers of the utility services — bills and tickets attach to these records.",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#customersTable",
        TablePartialName = "~/Views/Customers/_CustomersTable.cshtml",
        TableModel = Model,
        PaginationModel = Model
    };
    var customersHeader = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Customers",
        Subtitle = "200 Syrian utility subscribers — bilingual names, district-level addresses, status lifecycle.",
        IconClass = "bi bi-people-fill",
        Actions = new()
        {
            new() {
                Text = "New Customer",
                Href = Url.Action("Create", "Customers") ?? "#",
                IconClass = "bi bi-plus-circle",
                CssClass = "btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm"
            }
        }
    };
}

<partial name="_PageHeader" model="customersHeader" />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger bg-danger-subtle text-danger border-0 d-flex align-items-center mb-4 rounded-3">
        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
        <div>
            <strong>Deletion Prevented:</strong> @TempData["Error"]
        </div>
    </div>
}

<div class="card border-0 shadow-sm mb-4" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-10">
                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Search Customer</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--border-color) !important;"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="request.SearchString" class="form-control border-start-0 bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;" placeholder="Name (EN/AR), national ID, or phone..." value="@request.SearchString">
                </div>
            </div>
            <div class="col-lg-2">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-filter"></i> Apply
                </button>
            </div>
        </form>
    </div>
</div>

<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="customersTable" />
