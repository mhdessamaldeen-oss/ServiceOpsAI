@model List<ServiceOpsAI.Models.Customer>
@{
    ViewData["Title"] = "Customers";
    var total = (int)ViewBag.Total;
    var page = (int)ViewBag.Page;
    var pageSize = (int)ViewBag.PageSize;
    var search = (string?)ViewBag.Search;
    var totalPages = (int)Math.Ceiling(total / (double)pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people-fill"></i> Customers <small class="text-muted">(@total)</small></h2>
    <a class="btn btn-primary" href="@Url.Action("Create")"><i class="bi bi-plus-circle"></i> New Customer</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]</div>
}

<form method="get" class="mb-3 d-flex gap-2">
    <input type="text" name="search" class="form-control" placeholder="Search by name, national ID, or phone..." value="@search" />
    <button type="submit" class="btn btn-secondary">Search</button>
    @if (!string.IsNullOrEmpty(search))
    {
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Clear</a>
    }
</form>

<table class="table table-hover table-sm align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name (EN)</th>
            <th>Name (AR)</th>
            <th>National ID</th>
            <th>Phone</th>
            <th>Region</th>
            <th>Status</th>
            <th>Signup</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.FullNameEn</td>
                <td dir="rtl">@c.FullNameAr</td>
                <td><code>@c.NationalId</code></td>
                <td>@c.Phone</td>
                <td>@(c.Region?.NameEn ?? "—")</td>
                <td>
                    <span class="badge bg-@(c.Status == ServiceOpsAI.Models.CustomerStatus.Active ? "success" : c.Status == ServiceOpsAI.Models.CustomerStatus.Churned ? "danger" : "warning")">@c.Status</span>
                </td>
                <td class="small">@c.SignupAt.ToString("yyyy-MM-dd")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-info" href="@Url.Action("Details", new { id = c.Id })"><i class="bi bi-eye"></i></a>
                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Edit", new { id = c.Id })"><i class="bi bi-pencil"></i></a>
                    <form method="post" action="@Url.Action("Delete", new { id = c.Id })" class="d-inline" onsubmit="return confirm('Delete this customer?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (var p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = p, pageSize, search })">@p</a>
                </li>
            }
        </ul>
    </nav>
}
