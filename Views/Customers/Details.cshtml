@model ServiceOpsAI.Models.Customer
@{ ViewData["Title"] = $"Customer #{Model.Id}"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-circle"></i> @Model.FullNameEn <span class="text-muted small" dir="rtl">@Model.FullNameAr</span></h2>
    <div>
        <a class="btn btn-outline-primary" href="@Url.Action("Edit", new { id = Model.Id })"><i class="bi bi-pencil"></i> Edit</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">National ID</dt>             <dd class="col-sm-9"><code>@Model.NationalId</code></dd>
    <dt class="col-sm-3">Phone</dt>                   <dd class="col-sm-9">@Model.Phone</dd>
    <dt class="col-sm-3">Email</dt>                   <dd class="col-sm-9">@(Model.Email ?? "—")</dd>
    <dt class="col-sm-3">Region</dt>                  <dd class="col-sm-9">@(Model.Region?.NameEn ?? "—") <span class="text-muted small">@(Model.Region?.NameAr ?? "")</span></dd>
    <dt class="col-sm-3">Address (EN)</dt>            <dd class="col-sm-9">@(Model.AddressLineEn ?? "—")</dd>
    <dt class="col-sm-3">Address (AR)</dt>            <dd class="col-sm-9" dir="rtl">@(Model.AddressLineAr ?? "—")</dd>
    <dt class="col-sm-3">Status</dt>                  <dd class="col-sm-9"><span class="badge bg-@(Model.Status == ServiceOpsAI.Models.CustomerStatus.Active ? "success" : Model.Status == ServiceOpsAI.Models.CustomerStatus.Churned ? "danger" : "warning")">@Model.Status</span></dd>
    <dt class="col-sm-3">Signed up</dt>               <dd class="col-sm-9">@Model.SignupAt.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Churned at</dt>              <dd class="col-sm-9">@(Model.ChurnedAt?.ToString("yyyy-MM-dd") ?? "—")</dd>
    <dt class="col-sm-3">Notes</dt>                   <dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
</dl>
