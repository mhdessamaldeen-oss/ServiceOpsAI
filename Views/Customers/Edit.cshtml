@model ServiceOpsAI.Models.Customer
@{ ViewData["Title"] = $"Edit Customer #{Model.Id}"; }

<h2><i class="bi bi-pencil-square"></i> Edit Customer #@Model.Id</h2>

<form asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="FullNameEn" class="form-label">Full Name (English)</label>
        <input asp-for="FullNameEn" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="FullNameAr" class="form-label">Full Name (Arabic)</label>
        <input asp-for="FullNameAr" class="form-control" dir="rtl" />
    </div>
    <div class="col-md-6">
        <label asp-for="NationalId" class="form-label">National ID</label>
        <input asp-for="NationalId" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Phone" class="form-label">Phone</label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="RegionId" class="form-label">Region (district)</label>
        <select asp-for="RegionId" class="form-select" asp-items="ViewBag.Regions"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="AddressLineEn" class="form-label">Address (English)</label>
        <input asp-for="AddressLineEn" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="AddressLineAr" class="form-label">Address (Arabic)</label>
        <input asp-for="AddressLineAr" class="form-control" dir="rtl" />
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select">
            @foreach (var s in Enum.GetValues<ServiceOpsAI.Models.CustomerStatus>())
            {
                <option value="@s" selected="@(s == Model.Status)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="SignupAt" class="form-label">Signed up</label>
        <input asp-for="SignupAt" type="date" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ChurnedAt" class="form-label">Churned at (if any)</label>
        <input asp-for="ChurnedAt" type="date" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
    </div>
</form>
