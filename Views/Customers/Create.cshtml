@model ServiceOpsAI.Models.Customer
@{ ViewData["Title"] = "New Customer"; }

<h2><i class="bi bi-person-plus"></i> New Customer</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="FullNameEn" class="form-label">Full Name (English)</label>
        <input asp-for="FullNameEn" class="form-control" placeholder="Ahmad Al-Hamwi" />
        <span asp-validation-for="FullNameEn" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="FullNameAr" class="form-label">Full Name (Arabic)</label>
        <input asp-for="FullNameAr" class="form-control" dir="rtl" placeholder="أحمد الحموي" />
        <span asp-validation-for="FullNameAr" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="NationalId" class="form-label">National ID</label>
        <input asp-for="NationalId" class="form-control" placeholder="11 digits" />
        <span asp-validation-for="NationalId" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Phone" class="form-label">Phone</label>
        <input asp-for="Phone" class="form-control" placeholder="+963 9XX XXX XXX" />
        <span asp-validation-for="Phone" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Email" class="form-label">Email (optional)</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="RegionId" class="form-label">Region (district)</label>
        <select asp-for="RegionId" class="form-select" asp-items="ViewBag.Regions">
            <option value="">— Select district —</option>
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="AddressLineEn" class="form-label">Address (English)</label>
        <input asp-for="AddressLineEn" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="AddressLineAr" class="form-label">Address (Arabic)</label>
        <input asp-for="AddressLineAr" class="form-control" dir="rtl" />
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select">
            @foreach (var s in Enum.GetValues<ServiceOpsAI.Models.CustomerStatus>())
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="SignupAt" class="form-label">Signed up</label>
        <input asp-for="SignupAt" type="date" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
    </div>
</form>
