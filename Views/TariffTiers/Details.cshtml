@model ServiceOpsAI.Models.TariffTier
@{ ViewData["Title"] = "Tariff Tier Details"; }

<h2><i class="bi bi-layers-fill"></i> Tier #@Model.TierNumber</h2>

<div class="card shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Tariff</dt><dd class="col-sm-9">@Model.Tariff?.ServiceType?.NameEn / @(Model.Tariff?.Region?.NameEn ?? "Country-wide") — Effective @Model.Tariff?.EffectiveFrom.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Tier #</dt><dd class="col-sm-9">@Model.TierNumber</dd>
            <dt class="col-sm-3">Bracket</dt><dd class="col-sm-9">@Model.FromUnit.ToString("N0") – @(Model.ToUnit?.ToString("N0") ?? "∞") units</dd>
            <dt class="col-sm-3">Rate per Unit</dt><dd class="col-sm-9 fw-bold">@Model.RatePerUnit.ToString("N4") SYP</dd>
            <dt class="col-sm-3">Label (EN)</dt><dd class="col-sm-9">@Model.LabelEn</dd>
            <dt class="col-sm-3">Label (AR)</dt><dd class="col-sm-9" dir="rtl">@Model.LabelAr</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>
