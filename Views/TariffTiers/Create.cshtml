@model ServiceOpsAI.Models.TariffTier
@{ ViewData["Title"] = "New Tariff Tier"; }

<h2><i class="bi bi-plus-circle"></i> New Tariff Tier</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6"><label asp-for="TariffId" class="form-label">Tariff</label><select asp-for="TariffId" class="form-select" asp-items="ViewBag.Tariffs"><option value="">— Select tariff —</option></select></div>
    <div class="col-md-2"><label asp-for="TierNumber" class="form-label">Tier #</label><input asp-for="TierNumber" type="number" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="FromUnit" class="form-label">From Unit</label><input asp-for="FromUnit" type="number" step="0.01" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="ToUnit" class="form-label">To Unit (∞ = blank)</label><input asp-for="ToUnit" type="number" step="0.01" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="RatePerUnit" class="form-label">Rate per Unit (SYP)</label><input asp-for="RatePerUnit" type="number" step="0.0001" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="LabelEn" class="form-label">Label (EN)</label><input asp-for="LabelEn" class="form-control" placeholder="Lifeline / Standard / Premium" /></div>
    <div class="col-md-3"><label asp-for="LabelAr" class="form-label">Label (AR)</label><input asp-for="LabelAr" class="form-control" dir="rtl" /></div>
    <div class="col-12"><button type="submit" class="btn btn-primary">Create</button> <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a></div>
</form>
