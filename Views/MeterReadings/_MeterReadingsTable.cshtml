@model List<ServiceOpsAI.Models.MeterReading>

<div class="table-responsive">
    <table id="meterReadingsTable" class="table table-hover align-middle mb-0 datatable-premium" data-column-search="true">
        <thead>
            <tr>
                <th class="ps-4 py-3">Date</th>
                <th class="py-3">Customer</th>
                <th class="py-3">Service</th>
                <th class="py-3">Meter #</th>
                <th class="text-end py-3">Reading</th>
                <th class="text-end py-3">Consumption</th>
                <th class="py-3 no-sort">Type</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td class="ps-4 small">@m.ReadingDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center me-2"
                                 style="width: 30px; height: 30px; background: rgba(var(--primary-color-rgb, 16,185,129), 0.1) !important; color: var(--primary-color) !important; border: 1px solid rgba(var(--primary-color-rgb), 0.2) !important;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span style="color: var(--text-main) !important;">@m.Customer?.FullNameEn</span>
                        </div>
                    </td>
                    <td>
                        @{
                            var (svcBg, svcColor) = (m.ServiceType?.NameEn ?? "") switch
                            {
                                "Electricity" => ("rgba(245,158,11,0.10)", "#f59e0b"),
                                "Internet"    => ("rgba(56,189,248,0.10)", "#38bdf8"),
                                "Water"       => ("rgba(96,165,250,0.10)", "#60a5fa"),
                                "Gas"         => ("rgba(248,113,113,0.10)", "#f87171"),
                                _             => ("rgba(148,163,184,0.10)", "#94a3b8")
                            };
                        }
                        <span class="badge px-3 py-2 rounded-pill" style="background: @svcBg !important; color: @svcColor !important; border: 1px solid @svcColor !important;">@m.ServiceType?.NameEn</span>
                    </td>
                    <td><code class="small">@m.MeterNumber</code></td>
                    <td class="text-end fw-bold">@m.Value.ToString("N2")</td>
                    <td class="text-end">@(m.Consumption?.ToString("N2") ?? "—") <span class="text-muted small">@m.ServiceType?.Unit</span></td>
                    <td>
                        @{
                            var typeColor = m.ReaderType == ServiceOpsAI.Models.MeterReadingType.Actual
                                ? "var(--primary-color)"
                                : m.ReaderType == ServiceOpsAI.Models.MeterReadingType.Estimated ? "#f59e0b" : "#94a3b8";
                        }
                        <span class="badge px-3 py-2 rounded-pill" style="background: rgba(0,0,0,0.05) !important; color: @typeColor !important; border: 1px solid @typeColor !important;">@m.ReaderType</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {
        <div class="text-center p-5 text-muted">
            <i class="bi bi-inbox fs-1 mb-3"></i>
            <h6>No meter readings recorded.</h6>
        </div>
    }
</div>
