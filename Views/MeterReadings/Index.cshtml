@model List<ServiceOpsAI.Models.MeterReading>
@{
    ViewData["Title"] = "Meter Readings";
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Meter Readings",
        Subtitle = $"Periodic consumption readings (read-only). {ViewBag.Total} total. Used for anomaly detection and bill verification.",
        IconClass = "bi bi-speedometer2"
    };
    var shell = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Reading Registry",
        Subtitle = "Cumulative and per-period consumption per (Customer, ServiceType).",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#meterReadingsTable",
        TablePartialName = "~/Views/MeterReadings/_MeterReadingsTable.cshtml",
        TableModel = Model
    };
}

<partial name="_PageHeader" model="header" />
<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="shell" />
