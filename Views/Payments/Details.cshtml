@model ServiceOpsAI.Models.Payment
@{ ViewData["Title"] = "Payment Details"; }

<h2><i class="bi bi-cash-coin"></i> @Model.PaymentReference</h2>

<div class="card shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Reference</dt><dd class="col-sm-9"><code>@Model.PaymentReference</code></dd>
            <dt class="col-sm-3">Bill</dt><dd class="col-sm-9"><code>@Model.Bill?.BillNumber</code></dd>
            <dt class="col-sm-3">Service Account</dt><dd class="col-sm-9"><code>@Model.ServiceAccount?.AccountNumber</code></dd>
            <dt class="col-sm-3">Method</dt><dd class="col-sm-9">@Model.PaymentMethod?.NameEn</dd>
            <dt class="col-sm-3">Currency</dt><dd class="col-sm-9">@Model.Currency?.Code (@Model.Currency?.Symbol)</dd>
            <dt class="col-sm-3">Amount</dt><dd class="col-sm-9 fw-bold">@Model.Currency?.Symbol @Model.Amount.ToString("N2")</dd>
            <dt class="col-sm-3">Exchange Rate</dt><dd class="col-sm-9">@Model.ExchangeRateToBase.ToString("N6")</dd>
            <dt class="col-sm-3">Amount in SYP</dt><dd class="col-sm-9 fw-bold">@Model.AmountInBase.ToString("N2")</dd>
            <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Paid At</dt><dd class="col-sm-9">@Model.PaidAt.ToString("yyyy-MM-dd HH:mm")</dd>
            <dt class="col-sm-3">External TXN</dt><dd class="col-sm-9"><code>@Model.ExternalTransactionId</code></dd>
            <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@Model.Notes</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>
