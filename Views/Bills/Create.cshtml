@model ServiceOpsAI.Models.Bill
@{ ViewData["Title"] = "New Bill"; }

<h2><i class="bi bi-receipt"></i> New Bill</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-4">
        <label asp-for="BillNumber" class="form-label">Bill Number</label>
        <input asp-for="BillNumber" class="form-control" placeholder="ELEC-2026-05-000123" />
    </div>
    <div class="col-md-4">
        <label asp-for="CustomerId" class="form-label">Customer</label>
        <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.Customers">
            <option value="">— Select —</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="DepartmentId" class="form-label">Department</label>
        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments">
            <option value="">— Select —</option>
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="ServiceTypeId" class="form-label">Service Type</label>
        <select asp-for="ServiceTypeId" class="form-select" asp-items="ViewBag.ServiceTypes">
            <option value="">— Select —</option>
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="PeriodStart" class="form-label">Period Start</label>
        <input asp-for="PeriodStart" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="PeriodEnd" class="form-label">Period End</label>
        <input asp-for="PeriodEnd" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select">
            @foreach (var s in Enum.GetValues<ServiceOpsAI.Models.BillStatus>()) { <option value="@s">@s</option> }
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="BaseAmount" class="form-label">Base (SYP)</label>
        <input asp-for="BaseAmount" type="number" step="0.01" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="UsageAmount" class="form-label">Usage (SYP)</label>
        <input asp-for="UsageAmount" type="number" step="0.01" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Taxes" class="form-label">Taxes (SYP)</label>
        <input asp-for="Taxes" type="number" step="0.01" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="TotalAmount" class="form-label">Total (SYP)</label>
        <input asp-for="TotalAmount" type="number" step="0.01" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="UsageQuantity" class="form-label">Usage Qty</label>
        <input asp-for="UsageQuantity" type="number" step="0.01" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="UsageUnit" class="form-label">Usage Unit</label>
        <input asp-for="UsageUnit" class="form-control" placeholder="kWh / GB / m³ / cyl" />
    </div>
    <div class="col-md-3">
        <label asp-for="IssuedAt" class="form-label">Issued</label>
        <input asp-for="IssuedAt" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="DueDate" class="form-label">Due Date</label>
        <input asp-for="DueDate" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="PaidAt" class="form-label">Paid At</label>
        <input asp-for="PaidAt" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
        <input asp-for="PaymentMethod" class="form-control" placeholder="Card / Cash / Transfer / Wallet" />
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create</button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a>
    </div>
</form>
