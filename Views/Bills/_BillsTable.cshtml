@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.BillDto>

<div class="table-responsive">
    <table id="billsTable" class="table table-hover align-middle mb-0 datatable-premium" data-column-search="true">
        <thead>
            <tr>
                <th class="ps-4 py-3">Bill #</th>
                <th class="py-3">Customer</th>
                <th class="py-3">Service</th>
                <th class="py-3">Department</th>
                <th class="py-3">Period</th>
                <th class="text-end py-3">Total (SYP)</th>
                <th class="py-3">Status</th>
                <th class="py-3">Due</th>
                <th class="text-end pe-4 py-3 no-sort">Controls</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="ps-4 fw-bold">
                        <code style="color: var(--primary-color) !important;">@item.BillNumber</code>
                    </td>
                    <td style="color: var(--text-main) !important;">@item.CustomerName</td>
                    <td>
                        @{
                            var (svcBg, svcColor) = item.ServiceType switch
                            {
                                "Electricity" => ("rgba(245,158,11,0.10)", "#f59e0b"),
                                "Internet"    => ("rgba(56,189,248,0.10)", "#38bdf8"),
                                "Water"       => ("rgba(96,165,250,0.10)", "#60a5fa"),
                                "Gas"         => ("rgba(248,113,113,0.10)", "#f87171"),
                                _             => ("rgba(148,163,184,0.10)", "#94a3b8")
                            };
                        }
                        <span class="badge px-3 py-2 rounded-pill" style="background: @svcBg !important; color: @svcColor !important; border: 1px solid @svcColor !important;">@item.ServiceType</span>
                    </td>
                    <td class="small text-muted">@item.DepartmentName</td>
                    <td class="small">@item.PeriodStart.ToString("yyyy-MM")</td>
                    <td class="text-end fw-bold" style="color: var(--text-main) !important;">@item.TotalAmount.ToString("N0")</td>
                    <td>
                        @{
                            var (statusBg, statusColor) = item.Status switch
                            {
                                "Paid"      => ("rgba(var(--primary-color-rgb), 0.1)", "var(--primary-color)"),
                                "Overdue"   => ("rgba(var(--danger-color-rgb), 0.1)", "var(--danger-color)"),
                                "Disputed"  => ("rgba(245,158,11,0.1)", "#f59e0b"),
                                "Cancelled" => ("rgba(148,163,184,0.1)", "#94a3b8"),
                                _           => ("rgba(56,189,248,0.1)", "#38bdf8")
                            };
                        }
                        <span class="badge px-3 py-2 rounded-pill" style="background: @statusBg !important; color: @statusColor !important; border: 1px solid @statusColor !important;">@item.Status</span>
                    </td>
                    <td class="small text-muted">@item.DueDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end pe-4">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-soft-info shadow-none" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft-primary shadow-none">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this bill?');" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-soft-danger shadow-none">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Items.Any())
    {
        <div class="text-center p-5 text-muted">
            <i class="bi bi-inbox fs-1 mb-3"></i>
            <h6>No bills match the current filter.</h6>
        </div>
    }
</div>
