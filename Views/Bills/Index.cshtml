@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.BillDto>

@{
    ViewData["Title"] = "Bills Management";
    var request = Model.Request;
    var status = (string?)ViewBag.Status;
    var service = (string?)ViewBag.Service;
    var billsTable = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Bill Registry",
        Subtitle = "All utility bills across the four service types — issued by departments, paid by customers.",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#billsTable",
        TablePartialName = "~/Views/Bills/_BillsTable.cshtml",
        TableModel = Model,
        PaginationModel = Model
    };
    var billsHeader = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Bills",
        Subtitle = "24 months of history for electricity, internet, water, and gas — amounts in SYP.",
        IconClass = "bi bi-receipt",
        Actions = new()
        {
            new() {
                Text = "New Bill",
                Href = Url.Action("Create", "Bills") ?? "#",
                IconClass = "bi bi-plus-circle",
                CssClass = "btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm"
            }
        }
    };
}

<partial name="_PageHeader" model="billsHeader" />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger bg-danger-subtle text-danger border-0 d-flex align-items-center mb-4 rounded-3">
        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
        <div>
            <strong>Deletion Prevented:</strong> @TempData["Error"]
        </div>
    </div>
}

<div class="card border-0 shadow-sm mb-4" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <input type="hidden" name="request.PageNumber" value="1" />
            <div class="col-lg-5">
                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--border-color) !important;"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="request.SearchString" class="form-control border-start-0 bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;" placeholder="Bill number, customer name, or national ID..." value="@request.SearchString">
                </div>
            </div>
            <div class="col-lg-3">
                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Service Type</label>
                <select name="service" class="form-select bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                    <option value="">All services</option>
                    @{
                        var svcTypes = ViewBag.ServiceTypes as IEnumerable<ServiceOpsAI.Models.ServiceType>;
                        if (svcTypes != null)
                        {
                            foreach (var s in svcTypes)
                            {
                                <option value="@s.Code" selected="@(service == s.Code)">@s.NameEn</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Status</label>
                <select name="status" class="form-select bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                    <option value="">All statuses</option>
                    @foreach (var s in Enum.GetValues<ServiceOpsAI.Models.BillStatus>())
                    {
                        <option value="@s" selected="@(status == s.ToString())">@s</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-filter"></i> Apply
                </button>
            </div>
        </form>
    </div>
</div>

<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="billsTable" />
