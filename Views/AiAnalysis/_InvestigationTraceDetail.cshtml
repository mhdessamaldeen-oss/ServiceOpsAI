@model ServiceOpsAI.Models.AI.AdminCopilotExecutionDetails
@using ServiceOpsAI.Models.AI
@using System.Text.Json
@{
    string traceId = Convert.ToString(ViewBag.Trace?.Id) ?? "current";
    var storyToggleId = $"trace-story-{traceId}";
    var treeToggleId = $"trace-tree-{traceId}";
    var traceRootId = $"trace-detail-{traceId}";
    var traceGraphKey = "trace_" + new string(traceId.ToCharArray().Select(ch => char.IsLetterOrDigit(ch) ? ch : '_').ToArray());
    var defaultTraceView = string.Equals(Convert.ToString(ViewData["DefaultTraceView"] ?? ViewBag.DefaultTraceView), "tree", StringComparison.OrdinalIgnoreCase) ? "tree" : "story";


    List<CopilotExecutionStep> GetAllSteps(IEnumerable<CopilotExecutionStep> roots)
    {
        var all = new List<CopilotExecutionStep>();
        foreach (var root in roots)
        {
            all.Add(root);
            all.AddRange(GetAllSteps(root.SubSteps));
        }
        return all;
    }

    List<CopilotExecutionStep> GetLogicalRoots(IEnumerable<CopilotExecutionStep> roots, params CopilotExecutionLayer[] layers)
    {
        return roots.Where(r => layers.Contains(r.Layer) || GetAllSteps(r.SubSteps).Any(s => layers.Contains(s.Layer))).ToList();
    }

    var allTraceSteps = GetAllSteps(Model.Steps);
    var contextSteps = Model.Steps.Where(step => step.Layer == CopilotExecutionLayer.Context).ToList();
    var routerSteps = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.Router);
    var executorSteps = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.Executor);
    var completeSteps = Model.Steps.Where(step => step.Layer == CopilotExecutionLayer.Complete).ToList();

    var queryPlans = Model.QueryPlans.Any()
        ? Model.QueryPlans
        : Model.QueryPlan != null
            ? new List<AdminCopilotDynamicTicketQueryPlan> { Model.QueryPlan }
            : new List<AdminCopilotDynamicTicketQueryPlan>();
    var catalogExecutions = Model.SubExecutions
        .Where(sub => sub.IntentPlan != null || sub.QueryModel != null || !string.IsNullOrWhiteSpace(sub.GeneratedSql))
        .ToList();

    var prettyJsonOptions = new JsonSerializerOptions { WriteIndented = true };

    string CleanActionLabel(string? action, string fallback)
    {
        if (string.IsNullOrWhiteSpace(action))
        {
            return fallback;
        }

        var cleaned = System.Text.RegularExpressions.Regex.Replace(action, @"\s*\[[^\]]+\]", string.Empty).Trim();
        return string.IsNullOrWhiteSpace(cleaned) ? fallback : cleaned;
    }

    string ResolveStructuredPlanName(AdminCopilotDynamicTicketQueryPlan plan)
        => !string.IsNullOrWhiteSpace(plan.TargetView)
            ? plan.TargetView
            : !string.IsNullOrWhiteSpace(plan.EntityName)
                ? $"{plan.EntityName} data"
                : "Structured data";

    string ResolveCatalogExecutionName(AdminCopilotDynamicTicketQueryExecution execution)
        => !string.IsNullOrWhiteSpace(execution.QueryModel?.PrimaryEntity)
            ? execution.QueryModel.PrimaryEntity
            : !string.IsNullOrWhiteSpace(execution.IntentPlan?.PrimaryEntity)
                ? execution.IntentPlan.PrimaryEntity
                : ResolveStructuredPlanName(execution.Plan);

    string ResolveCatalogExecutionOperation(AdminCopilotDynamicTicketQueryExecution execution)
        => !string.IsNullOrWhiteSpace(execution.QueryModel?.Operation)
            ? execution.QueryModel.Operation
            : !string.IsNullOrWhiteSpace(execution.IntentPlan?.Operation)
                ? execution.IntentPlan.Operation
                : execution.Plan.Intent.ToString();

    string ShortText(string? value, int maxLength = 160)
    {
        var text = (value ?? string.Empty).Trim();
        return text.Length > maxLength ? text[..maxLength] + "..." : text;
    }

    string JoinOrNone(IEnumerable<string?> values, string emptyText = "None")
    {
        var list = values
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(8)
            .ToList();

        return list.Any() ? string.Join(", ", list) : emptyText;
    }

    string DescribeCatalogColumns(AdminCopilotDynamicTicketQueryExecution execution)
    {
        if (execution.QueryModel?.Projections.Any() == true)
        {
            return JoinOrNone(execution.QueryModel.Projections.Select(projection =>
            {
                var source = JoinOrNone(new[] { projection.SourceEntity, projection.SourceField }, string.Empty).Replace(", ", ".");
                var expression = !string.IsNullOrWhiteSpace(source) ? source : projection.SqlExpression;
                return string.IsNullOrWhiteSpace(projection.OutputName) ? expression : $"{projection.OutputName} <= {expression}";
            }));
        }

        if (execution.IntentPlan?.Fields.Any() == true)
        {
            return JoinOrNone(execution.IntentPlan.Fields);
        }

        if (execution.Plan.SelectedColumns.Any())
        {
            return JoinOrNone(execution.Plan.SelectedColumns);
        }

        return "Default catalog projection";
    }

    string DescribeCatalogFilters(AdminCopilotDynamicTicketQueryExecution execution)
    {
        if (execution.QueryModel != null)
        {
            var predicates = execution.QueryModel.Predicates
                .Concat(execution.QueryModel.HavingPredicates)
                .Select(predicate =>
                {
                    var parameters = predicate.Parameters.Any()
                        ? $" ({string.Join(", ", predicate.Parameters.Select(parameter => $"{parameter.Name}={parameter.Value}"))})"
                        : string.Empty;
                    return $"{predicate.SqlFragment}{parameters}";
                });

            return JoinOrNone(predicates);
        }

        if (execution.IntentPlan != null)
        {
            var filters = execution.IntentPlan.Filters
                .Concat(execution.IntentPlan.HavingFilters)
                .Select(filter => $"{filter.Entity}.{filter.Field} {filter.Operator} {filter.Value}");

            return JoinOrNone(filters);
        }

        return JoinOrNone(execution.Plan.GlobalFilters.Select(filter => $"{filter.Key} = {filter.Value}"));
    }

    string DescribeCatalogJoins(AdminCopilotDynamicTicketQueryExecution execution)
    {
        if (execution.QueryModel?.JoinFragments.Any() == true)
        {
            return JoinOrNone(execution.QueryModel.JoinFragments);
        }

        if (execution.IntentPlan?.Joins.Any() == true)
        {
            return JoinOrNone(execution.IntentPlan.Joins.Select(join => $"{join.FromEntity} -> {join.ToEntity} ({join.Relationship})"));
        }

        return "No joins";
    }

    string DescribeCatalogGrouping(AdminCopilotDynamicTicketQueryExecution execution)
    {
        if (execution.QueryModel?.GroupBy.Any() == true)
        {
            return JoinOrNone(execution.QueryModel.GroupBy);
        }

        if (execution.IntentPlan?.GroupBy.Any() == true)
        {
            return JoinOrNone(execution.IntentPlan.GroupBy);
        }

        return !string.IsNullOrWhiteSpace(execution.Plan.GroupByField) ? execution.Plan.GroupByField : "No grouping";
    }

    string DescribeCatalogSort(AdminCopilotDynamicTicketQueryExecution execution)
    {
        if (execution.QueryModel?.OrderBy.Any() == true)
        {
            return JoinOrNone(execution.QueryModel.OrderBy.Select(order => $"{order.SqlExpression} {order.Direction}"));
        }

        if (execution.IntentPlan?.Sorts.Any() == true)
        {
            return JoinOrNone(execution.IntentPlan.Sorts.Select(sort => $"{sort.Entity}.{sort.Field} {sort.Direction}"));
        }

        return $"{execution.Plan.SortBy} {execution.Plan.SortDirection}";
    }

    string DescribeSqlParameters(AdminCopilotDynamicTicketQueryExecution execution)
        => execution.SqlParameters.Any()
            ? string.Join(", ", execution.SqlParameters.Select(parameter => $"{parameter.Name}={parameter.Value}"))
            : "No parameters";

    string DescribeCatalogDecision(AdminCopilotDynamicTicketQueryExecution execution)
        => $"Entity: {ResolveCatalogExecutionName(execution)}\nOperation: {ResolveCatalogExecutionOperation(execution)}\nOutput: {execution.QueryModel?.OutputShape ?? execution.IntentPlan?.OutputShape ?? execution.Plan.TargetView ?? "default"}\nLimit: {execution.QueryModel?.Limit ?? execution.IntentPlan?.Limit ?? execution.Plan.MaxResults}";

    string SerializeStepPayload(object payload)
        => JsonSerializer.Serialize(payload, prettyJsonOptions);

    object CreateInspectorStep(string layer, string action, string input, string output, string detail = "", string status = "Ok", string technicalData = "")
        => new
        {
            layer,
            action,
            detail = $"Input: {input}\nOutput: {output}{(string.IsNullOrWhiteSpace(detail) ? string.Empty : $"\nDetails: {detail}")}",
            status,
            elapsedMs = 0,
            technicalData,
            subSteps = new List<object>()
        };

    List<object> BuildCatalogExecutionSteps(AdminCopilotDynamicTicketQueryExecution execution)
    {
        var requestSummary = execution.IntentPlan?.Explanation ?? execution.Plan.Summary;
        var sqlText = string.IsNullOrWhiteSpace(execution.GeneratedSql) ? "No SQL captured" : execution.GeneratedSql;
        var decisionPayload = new
        {
            primaryEntity = ResolveCatalogExecutionName(execution),
            operation = ResolveCatalogExecutionOperation(execution),
            outputShape = execution.QueryModel?.OutputShape ?? execution.IntentPlan?.OutputShape ?? execution.Plan.TargetView,
            limit = execution.QueryModel?.Limit ?? execution.IntentPlan?.Limit ?? execution.Plan.MaxResults,
            plannerSource = execution.PlannerSource.ToString(),
            explanation = execution.IntentPlan?.Explanation
        };
        var shapePayload = new
        {
            columns = DescribeCatalogColumns(execution),
            intentFields = execution.IntentPlan?.Fields,
            queryProjections = execution.QueryModel?.Projections,
            structuredColumns = execution.StructuredColumns
        };
        var constraintPayload = new
        {
            filters = DescribeCatalogFilters(execution),
            joins = DescribeCatalogJoins(execution),
            groupBy = DescribeCatalogGrouping(execution),
            sort = DescribeCatalogSort(execution),
            intentFilters = execution.IntentPlan?.Filters,
            intentHavingFilters = execution.IntentPlan?.HavingFilters,
            queryPredicates = execution.QueryModel?.Predicates,
            queryHavingPredicates = execution.QueryModel?.HavingPredicates,
            queryJoinFragments = execution.QueryModel?.JoinFragments,
            queryOrderBy = execution.QueryModel?.OrderBy
        };

        return new List<object>
        {
            CreateInspectorStep(
                "Input",
                "Read sub-question intent",
                ViewBag.Trace.Question?.ToString() ?? string.Empty,
                string.IsNullOrWhiteSpace(requestSummary) ? "No explicit sub-question text was recorded." : requestSummary,
                technicalData: SerializeStepPayload(new
                {
                    question = ViewBag.Trace.Question?.ToString() ?? string.Empty,
                    subRequest = requestSummary,
                    traceId
                })),
            CreateInspectorStep(
                "Planner",
                "Select entity and operation",
                requestSummary,
                DescribeCatalogDecision(execution),
                $"Planner: {execution.PlannerSource}",
                technicalData: SerializeStepPayload(decisionPayload)),
            CreateInspectorStep(
                "Planner",
                "Select columns",
                DescribeCatalogDecision(execution),
                DescribeCatalogColumns(execution),
                technicalData: SerializeStepPayload(shapePayload)),
            CreateInspectorStep(
                "Planner",
                "Apply filters, joins, grouping, and sort",
                $"Entity: {ResolveCatalogExecutionName(execution)}",
                $"Filters: {DescribeCatalogFilters(execution)}\nJoins: {DescribeCatalogJoins(execution)}\nGroup by: {DescribeCatalogGrouping(execution)}\nSort: {DescribeCatalogSort(execution)}",
                technicalData: SerializeStepPayload(constraintPayload)),
            CreateInspectorStep(
                "SQL",
                "Build SQL command",
                "Validated catalog query model",
                ShortText(sqlText, 700),
                $"Parameters: {DescribeSqlParameters(execution)}",
                technicalData: SerializeStepPayload(new
                {
                    sql = execution.GeneratedSql,
                    parameters = execution.SqlParameters,
                    queryModel = execution.QueryModel
                })),
            CreateInspectorStep(
                "Executor",
                "Execute SQL and shape rows",
                "SQL command plus parameters",
                $"{execution.TotalCount} row(s) returned. Evidence: {execution.EvidenceStrength}. Route: {execution.ExecutionRoute}",
                execution.Summary,
                technicalData: SerializeStepPayload(new
                {
                    rowCount = execution.TotalCount,
                    requestedLimit = execution.RequestedLimit,
                    evidence = execution.EvidenceStrength.ToString(),
                    route = execution.ExecutionRoute.ToString(),
                    structuredColumns = execution.StructuredColumns,
                    structuredRows = execution.StructuredRows.Take(10),
                    summary = execution.Summary,
                    answerShapeGateMessage = execution.AnswerShapeGateMessage
                }))
        };
    }

    string SerializeCatalogExecution(AdminCopilotDynamicTicketQueryExecution execution)
        => JsonSerializer.Serialize(new
        {
            intentPlan = execution.IntentPlan,
            queryModel = execution.QueryModel,
            sql = execution.GeneratedSql,
            parameters = execution.SqlParameters,
            decision = new
            {
                primaryEntity = ResolveCatalogExecutionName(execution),
                operation = ResolveCatalogExecutionOperation(execution),
                outputShape = execution.QueryModel?.OutputShape ?? execution.IntentPlan?.OutputShape ?? execution.Plan.TargetView,
                limit = execution.QueryModel?.Limit ?? execution.IntentPlan?.Limit ?? execution.Plan.MaxResults,
                columns = DescribeCatalogColumns(execution),
                filters = DescribeCatalogFilters(execution),
                joins = DescribeCatalogJoins(execution),
                groupBy = DescribeCatalogGrouping(execution),
                sort = DescribeCatalogSort(execution)
            },
            plannerSource = execution.PlannerSource.ToString(),
            route = execution.ExecutionRoute.ToString(),
            evidence = execution.EvidenceStrength.ToString(),
            rowCount = execution.TotalCount
        }, prettyJsonOptions);

    string StepEvidence(CopilotExecutionStep step)
        => $"{step.Action} {step.Detail} {step.TechnicalData}".ToLowerInvariant();

    bool IsDecompositionStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("request decomposition")
            || evidence.Contains("subrequest")
            || evidence.Contains("subrequests");
    }

    bool IsCatalogDataPlanningStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("catalog data intent")
            || evidence.Contains("data intent")
            || evidence.Contains("primaryentity")
            || evidence.Contains("outputshape")
            || evidence.Contains("validationmessages");
    }

    bool IsCatalogDataExecutionStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("catalog query execution")
            || evidence.Contains("catalogsql")
            || evidence.Contains("querymodel")
            || evidence.Contains("select ")
            || evidence.Contains(" from ");
    }

    var decompositionSteps = Model.Steps.Where(IsDecompositionStep).ToList();
    var dataPlanningSteps = allTraceSteps.Where(IsCatalogDataPlanningStep).ToList();
    var dataExecutionSteps = allTraceSteps.Where(IsCatalogDataExecutionStep).ToList();

    bool IsKnowledgeStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("knowledge") || evidence.Contains("similar") || evidence.Contains("evidence") || evidence.Contains("grounded");
    }

    bool IsExternalStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("tool") || evidence.Contains("api") || evidence.Contains("http");
    }

    bool IsActionStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("action") || evidence.Contains("assign") || evidence.Contains("update status") || evidence.Contains("comment");
    }

    var knowledgeSteps = allTraceSteps.Where(IsKnowledgeStep).ToList();
    var externalSteps = allTraceSteps.Where(IsExternalStep).ToList();
    var actionSteps = allTraceSteps.Where(IsActionStep).ToList();

    var knowledgeRootSteps = Model.Steps.Where(r => IsKnowledgeStep(r) || GetAllSteps(r.SubSteps).Any(IsKnowledgeStep)).ToList();
    var externalRootSteps = Model.Steps.Where(r => IsExternalStep(r) || GetAllSteps(r.SubSteps).Any(IsExternalStep)).ToList();
    var actionRootSteps = Model.Steps.Where(r => IsActionStep(r) || GetAllSteps(r.SubSteps).Any(IsActionStep)).ToList();

    var dataPlannerRootSteps = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.DataPlanning);
    if (!dataPlannerRootSteps.Any())
    {
        dataPlannerRootSteps = Model.Steps.Where(r => GetAllSteps(r.SubSteps).Any(IsCatalogDataPlanningStep)).ToList();
    }

    var routeEvidence = string.Join(" ", new[]
    {
        Model.DetectedIntent,
        Model.RouteReason,
        Model.Summary,
        Model.SearchQuery,
        string.Join(" ", allTraceSteps.Select(step => $"{step.Action} {step.Detail} {step.TechnicalData}"))
    }).ToLowerInvariant();

    bool dataRoute = catalogExecutions.Any()
        || queryPlans.Any()
        || dataPlanningSteps.Any()
        || dataExecutionSteps.Any()
        || routeEvidence.Contains("dataquery")
        || routeEvidence.Contains("catalogsql")
        || routeEvidence.Contains("querymodel")
        || routeEvidence.Contains("catalog data intent")
        || routeEvidence.Contains("primaryentity")
        || routeEvidence.Contains("structured")
        || routeEvidence.Contains("outputshape")
        || routeEvidence.Contains("structuredrows")
        || routeEvidence.Contains("structuredcolumns");

    bool externalRoute = routeEvidence.Contains("tool")
        || routeEvidence.Contains("external")
        || routeEvidence.Contains("api")
        || routeEvidence.Contains("http");

    bool knowledgeRoute = routeEvidence.Contains("knowledge")
        || routeEvidence.Contains("similar")
        || routeEvidence.Contains("evidence")
        || routeEvidence.Contains("grounded")
        || routeEvidence.Contains("retrieval");

    bool actionRoute = Model.ActionPlan != null
        || routeEvidence.Contains("action")
        || routeEvidence.Contains("assign")
        || routeEvidence.Contains("update status")
        || routeEvidence.Contains("comment");

    bool generalRoute = !dataRoute && !externalRoute && !knowledgeRoute && !actionRoute;

    var actualPath = new List<string> { "Question" };
    if (contextSteps.Any()) { actualPath.Add(CleanActionLabel(contextSteps.First().Action, "Input normalization")); }
    if (decompositionSteps.Any()) { actualPath.Add(CleanActionLabel(decompositionSteps.First().Action, "Request decomposition")); }
    if (routerSteps.Any()) { actualPath.Add(CleanActionLabel(routerSteps.First().Action, "Intent routing")); }
    if (dataRoute) { actualPath.Add("Structured data planning"); }
    if (knowledgeRoute) { actualPath.Add("Knowledge retrieval"); }
    if (externalRoute) { actualPath.Add("Tool invocation"); }
    if (actionRoute) { actualPath.Add("Action planning"); }
    if (generalRoute) { actualPath.Add("Direct answer"); }
    if (executorSteps.Any()) { actualPath.Add(CleanActionLabel(executorSteps.First().Action, "Execution")); }
    if (catalogExecutions.Any() || queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any()) { actualPath.Add("SQL result"); }
    if (Model.ActionPlan != null) { actualPath.Add("Action result"); }
    if (completeSteps.Any()) { actualPath.Add(CleanActionLabel(completeSteps.First().Action, "Verification")); }
    actualPath.Add("Response");

    string SummarizeSteps(IEnumerable<CopilotExecutionStep> steps)
    {
        var parts = steps
            .Select(step => CleanActionLabel(step.Action, string.Empty))
            .Where(action => !string.IsNullOrWhiteSpace(action))
            .Distinct()
            .Take(3)
            .ToList();

        return parts.Any() ? string.Join(" • ", parts) : "No recorded step details.";
    }

    string SummarizeQueryPlans()
    {
        if (catalogExecutions.Any())
        {
            return string.Join(" • ", catalogExecutions
                .Select(execution => $"{ResolveCatalogExecutionName(execution)} / {ResolveCatalogExecutionOperation(execution)}")
                .Distinct()
                .Take(3));
        }

        if (dataPlanningSteps.Any())
        {
            return SummarizeSteps(dataPlanningSteps);
        }

        if (!queryPlans.Any())
        {
            return "No structured query plan was needed for this route.";
        }

        var planParts = queryPlans
            .Select(plan => $"{ResolveStructuredPlanName(plan)} / {plan.Intent}")
            .Distinct()
            .Take(3);

        return string.Join(" • ", planParts);
    }

    string AnswerPreview(string? answer)
    {
        var text = answer ?? string.Empty;
        return text.Length > 180 ? text[..180] + "..." : text;
    }

    string MermaidText(string? value)
    {
        return (value ?? string.Empty)
            .Replace("\\", "\\\\")
            .Replace("\"", "'")
            .Replace("\r", " ")
            .Replace("\n", " ")
            .Trim();
    }

    List<object> ToStepItems(IEnumerable<CopilotExecutionStep> steps)
    {
        return steps.Select(step => (object)new
        {
            layer = step.Layer.ToString(),
            action = step.Action,
            detail = step.Detail,
            status = step.Status.ToString(),
            elapsedMs = step.ElapsedMs,
            technicalData = step.TechnicalData ?? string.Empty,
            subSteps = ToStepItems(step.SubSteps)
        }).ToList();
    }

    List<string> ToTechnicalPayloads(IEnumerable<CopilotExecutionStep> steps)
    {
        var payloads = steps
            .Select(step => step.TechnicalData)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Cast<string>()
            .ToList();

        foreach(var step in steps)
        {
            payloads.AddRange(ToTechnicalPayloads(step.SubSteps));
        }

        return payloads.Distinct().ToList();
    }

    string GenerateSubPlanMermaid(AdminCopilotDynamicTicketQueryExecution sub, string key)
    {
        var intentSummary = sub.IntentPlan?.Explanation ?? sub.Plan.Summary;
        var entitySummary = $"{ResolveCatalogExecutionName(sub)} • {ResolveCatalogExecutionOperation(sub)}";
        var columnSummary = DescribeCatalogColumns(sub);
        var filterSummary = DescribeCatalogFilters(sub);
        var sqlSummary = string.IsNullOrWhiteSpace(sub.GeneratedSql) ? "No SQL captured" : ShortText(sub.GeneratedSql, 120);
        return $@"flowchart TD
    INPUT__{key}[""Input<br/>{MermaidText(ShortText(intentSummary, 90))}""]
    DECIDE__{key}[""Decision<br/>{MermaidText(entitySummary)}""]
    SHAPE__{key}[""Query shape<br/>{MermaidText(ShortText(columnSummary, 90))}""]
    FILTER__{key}[""Filters / joins<br/>{MermaidText(ShortText(filterSummary, 90))}""]
    SQL__{key}[""SQL<br/>{MermaidText(sqlSummary)}""]
    EXEC__{key}[""Output<br/>{sub.TotalCount} rows""]
    
    INPUT__{key} --> DECIDE__{key}
    DECIDE__{key} --> SHAPE__{key}
    SHAPE__{key} --> FILTER__{key}
    FILTER__{key} --> SQL__{key}
    SQL__{key} --> EXEC__{key}
    
    style INPUT__{key} fill:__INACTIVE_FILL__,stroke:__INACTIVE_STROKE__,color:__INACTIVE_TEXT__
    style DECIDE__{key} fill:__ACTIVE_FILL__,stroke:__ACTIVE_STROKE__,color:__ACTIVE_TEXT__
    style SHAPE__{key} fill:__ACTIVE_FILL__,stroke:__ACTIVE_STROKE__,color:__ACTIVE_TEXT__
    style FILTER__{key} fill:__ACTIVE_FILL__,stroke:__ACTIVE_STROKE__,color:__ACTIVE_TEXT__
    style SQL__{key} fill:__ACTIVE_FILL__,stroke:__ACTIVE_STROKE__,color:__ACTIVE_TEXT__
    style EXEC__{key} fill:__FINAL_FILL__,stroke:__FINAL_STROKE__,color:__FINAL_TEXT__
    
    click INPUT__{key} copilotTraceNodeClick
    click DECIDE__{key} copilotTraceNodeClick
    click SHAPE__{key} copilotTraceNodeClick
    click FILTER__{key} copilotTraceNodeClick
    click SQL__{key} copilotTraceNodeClick
    click EXEC__{key} copilotTraceNodeClick";
    }

    Dictionary<string, object> GenerateSubPlanNodeDetails(AdminCopilotDynamicTicketQueryExecution sub)
    {
        var dataSteps = BuildCatalogExecutionSteps(sub);
        var requestSummary = sub.IntentPlan?.Explanation ?? sub.Plan.Summary;
        var serializedExecution = SerializeCatalogExecution(sub);

        return new Dictionary<string, object>
        {
            ["INPUT"] = new { title = "Input", summary = "The specific data request that this query plan answered.", status = "Actual path", used = true, beforeLabel = "Question", beforeValue = ViewBag.Trace.Question?.ToString() ?? string.Empty, afterLabel = "Sub-request", afterValue = requestSummary, steps = dataSteps.Take(1).ToList(), payloads = new List<string> { serializedExecution } },
            ["DECIDE"] = new { title = "Decision", summary = "Planner decision: which entity, operation, output shape, and limit were selected.", status = "Actual path", used = true, beforeLabel = "Input", beforeValue = requestSummary, afterLabel = "Decision", afterValue = DescribeCatalogDecision(sub), steps = dataSteps.Take(2).ToList(), payloads = new List<string> { serializedExecution } },
            ["SHAPE"] = new { title = "Query shape", summary = "Columns and output fields selected for the SQL projection.", status = "Actual path", used = true, beforeLabel = "Entity", beforeValue = ResolveCatalogExecutionName(sub), afterLabel = "Columns", afterValue = DescribeCatalogColumns(sub), steps = dataSteps.Take(3).ToList(), payloads = new List<string> { serializedExecution } },
            ["FILTER"] = new { title = "Filters, joins, grouping, sort", summary = "Catalog constraints used to build WHERE, JOIN, GROUP BY, HAVING, and ORDER BY.", status = "Actual path", used = true, beforeLabel = "Query shape", beforeValue = DescribeCatalogColumns(sub), afterLabel = "Constraints", afterValue = $"Filters: {DescribeCatalogFilters(sub)}\nJoins: {DescribeCatalogJoins(sub)}\nGroup by: {DescribeCatalogGrouping(sub)}\nSort: {DescribeCatalogSort(sub)}", steps = dataSteps.Take(4).ToList(), payloads = new List<string> { serializedExecution } },
            ["SQL"] = new { title = "SQL", summary = $"Generated SQL with {sub.SqlParameters.Count} parameter(s).", status = "Actual path", used = true, beforeLabel = "Catalog model", beforeValue = DescribeCatalogDecision(sub), afterLabel = "SQL parameters", afterValue = DescribeSqlParameters(sub), steps = dataSteps.Take(5).ToList(), payloads = new List<string> { serializedExecution } },
            ["EXEC"] = new { title = "Output", summary = $"Query executed and shaped into the structured answer. Returned {sub.TotalCount} record(s).", status = "Actual path", used = true, beforeLabel = "SQL", beforeValue = ShortText(sub.GeneratedSql ?? "No SQL captured", 500), afterLabel = "Rows", afterValue = $"{sub.TotalCount} row(s). {sub.Summary}", steps = dataSteps, payloads = new List<string> { serializedExecution } }
        };
    }

    List<object> ToLegacyQueryPlanItems(IEnumerable<AdminCopilotDynamicTicketQueryPlan> plans, bool selected)
    {
        return plans.Select(plan => (object)new
        {
            layer = "Plan",
            action = ResolveStructuredPlanName(plan),
            detail = $"{plan.Intent} • max {plan.MaxResults} • sort {plan.SortBy} {plan.SortDirection}",
            status = selected ? "Ok" : "Skip",
            elapsedMs = 0,
            technicalData = string.Empty,
            subSteps = new List<object>()
        }).ToList();
    }

    var dataPlannerStepItems = ToStepItems(dataPlannerRootSteps);
    dataPlannerStepItems.AddRange(ToLegacyQueryPlanItems(queryPlans, dataRoute));
    dataPlannerStepItems.AddRange(catalogExecutions.SelectMany(BuildCatalogExecutionSteps));

    var queryStrategyRoots = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.DataPlanning, CopilotExecutionLayer.DataExecution);
    if (!queryStrategyRoots.Any())
    {
        queryStrategyRoots = Model.Steps.Where(r => GetAllSteps(r.SubSteps).Any(s => IsCatalogDataPlanningStep(s) || IsCatalogDataExecutionStep(s))).ToList();
    }
    var queryStrategyStepItems = ToStepItems(queryStrategyRoots);
    queryStrategyStepItems.AddRange(ToLegacyQueryPlanItems(queryPlans, catalogExecutions.Any() || queryPlans.Any()));
    queryStrategyStepItems.AddRange(catalogExecutions.SelectMany(BuildCatalogExecutionSteps));

    var dataPlannerPayloads = ToTechnicalPayloads(dataPlanningSteps);
    var queryStrategyPayloads = ToTechnicalPayloads(allTraceSteps.Where(s => IsCatalogDataPlanningStep(s) || IsCatalogDataExecutionStep(s)));
    dataPlannerPayloads.AddRange(catalogExecutions.Select(SerializeCatalogExecution));
    queryStrategyPayloads.AddRange(catalogExecutions.Select(SerializeCatalogExecution));

    var pathNodes = new List<(string Id, string Title, string Detail, string Style)>();
    void AddPathNode(string id, string title, string detail, string style = "active")
    {
        pathNodes.Add((id, title, detail, style));
    }

    AddPathNode("Q", "Question", ViewBag.Trace.Question?.ToString() ?? string.Empty);
    if (contextSteps.Any())
    {
        AddPathNode("PRE", "Normalize", SummarizeSteps(contextSteps));
    }

    AddPathNode("ROUTE", "Route decision", $"{(string.IsNullOrWhiteSpace(Model.DetectedIntent) ? "Intent not recorded" : Model.DetectedIntent)} • {Model.RouteReason}");

    if (dataRoute)
    {
        AddPathNode("DATA", "Data plan", SummarizeQueryPlans());
    }

    if (knowledgeRoute)
    {
        AddPathNode("KNOW", "Knowledge", knowledgeSteps.Any() ? SummarizeSteps(knowledgeSteps) : "Knowledge path selected");
    }

    if (externalRoute)
    {
        AddPathNode("EXT", "Tool", externalSteps.Any() ? SummarizeSteps(externalSteps) : "External tool path selected");
    }

    if (actionRoute)
    {
        AddPathNode("ACT", "Action plan", Model.ActionPlan?.Summary ?? SummarizeSteps(actionSteps));
    }

    if (generalRoute)
    {
        AddPathNode("GEN", "Direct answer", "No structured data, tool, or action route needed");
    }

    if (executorSteps.Any())
    {
        AddPathNode("EXEC", "Execute", SummarizeSteps(executorSteps));
    }

    if (catalogExecutions.Any() || queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any())
    {
        AddPathNode("PLAN", "SQL result", SummarizeQueryPlans());
    }

    if (Model.ActionPlan != null)
    {
        AddPathNode("ACTION", "Action result", Model.ActionPlan.Summary);
    }

    if (completeSteps.Any())
    {
        AddPathNode("VERIFY", "Validate", SummarizeSteps(completeSteps));
    }

    AddPathNode("RESP", "Answer", AnswerPreview(ViewBag.Trace.Answer as string), "final");

    var nodeLines = string.Join("\n", pathNodes.Select(node =>
        $"    {node.Id}__{traceGraphKey}[\"{MermaidText(node.Title)}<br/>{MermaidText(ShortText(node.Detail, 95))}\"]"));
    var edgeLines = string.Join("\n", pathNodes.Zip(pathNodes.Skip(1), (left, right) =>
        $"    {left.Id}__{traceGraphKey} --> {right.Id}__{traceGraphKey}"));
    var classLines = string.Join("\n", pathNodes.Select(node =>
        $"    class {node.Id}__{traceGraphKey} {node.Style};"));
    var clickLines = string.Join("\n", pathNodes.Select(node =>
        $"    click {node.Id}__{traceGraphKey} copilotTraceNodeClick"));
    
    var traceFlowDirection = Loc.IsRtl ? "RL" : "LR";
    var mermaidDefinition = $@"
flowchart {traceFlowDirection}
    classDef inactive fill:__INACTIVE_FILL__,stroke:__INACTIVE_STROKE__,color:__INACTIVE_TEXT__,stroke-width:1px;
    classDef active fill:__ACTIVE_FILL__,stroke:__ACTIVE_STROKE__,color:__ACTIVE_TEXT__,stroke-width:2px;
    classDef final fill:__FINAL_FILL__,stroke:__FINAL_STROKE__,color:__FINAL_TEXT__,stroke-width:2px;
    classDef error fill:#fee2e2,stroke:#ef4444,color:#b91c1c,stroke-width:2px;

{nodeLines}

{edgeLines}

{classLines}

    {(executorSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class EXEC__{traceGraphKey} error;" : string.Empty)}
    {(completeSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class VERIFY__{traceGraphKey} error;" : string.Empty)}
    {(contextSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class PRE__{traceGraphKey} error;" : string.Empty)}
    {(routerSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class ROUTE__{traceGraphKey} error;" : string.Empty)}

{clickLines}

    linkStyle default stroke:__LINK_ACTIVE__,stroke-width:2.5px,color:__LINK_ACTIVE__,opacity:0.95;
";
}

@{
    var nodeDetails = new Dictionary<string, object>
    {
