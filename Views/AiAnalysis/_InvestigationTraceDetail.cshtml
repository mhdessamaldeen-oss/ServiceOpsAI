            beforeLabel = "Before",
            beforeValue = string.Join(" → ", actualPath.Take(actualPath.IndexOf("Execution") >= 0 ? actualPath.IndexOf("Execution") : actualPath.Count)),
            afterLabel = "After",
            afterValue = SummarizeSteps(executorSteps),
            steps = ToStepItems(executorSteps),
            payloads = ToTechnicalPayloads(executorSteps)
        },
        ["RESULTGATE"] = new
        {
            title = "Result gate",
