            beforeLabel = "Before",
            beforeValue = Model.RouteReason,
            afterLabel = "After",
            afterValue = knowledgeSteps.Any() ? SummarizeSteps(knowledgeSteps) : (knowledgeRoute ? "Knowledge evidence path selected for this trace." : "This path was available but not selected."),
            steps = ToStepItems(knowledgeRootSteps),
            payloads = ToTechnicalPayloads(knowledgeSteps)
        },
        ["EXT"] = new
