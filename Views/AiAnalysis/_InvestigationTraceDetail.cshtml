}

<div id="@traceRootId" data-trace-graph-key="@traceGraphKey" data-default-trace-view="@defaultTraceView" class="glass-card mb-4 border-1 copilot-trace-detail-root" style="background: var(--bg-card); position: relative; overflow: visible;">
    <!-- Tech Background Pattern -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(rgba(var(--primary-color-rgb), 0.1) 1px, transparent 1px); background-size: 24px 24px; opacity: 0.4; pointer-events: none;"></div>
    
    <div class="glass-header d-flex justify-content-between align-items-center py-2 border-bottom position-relative z-1" style="background: rgba(var(--primary-color-rgb), 0.02); border-color: var(--border-color) !important;">
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-pill bg-primary bg-opacity-10 border border-primary border-opacity-25 shadow-sm d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="bi bi-shield-check text-primary fs-5"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-black text-main" style="letter-spacing: -0.02em; font-size: 1.1rem;">@Loc.Get("ExecutionStoryTrack")</h5>
                <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1em; font-size: 0.6rem;">@Loc.Get("ForensicAnalysisTrace")</div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
            <div class="badge bg-primary bg-opacity-10 border border-primary border-opacity-25 text-primary rounded-pill px-4 py-2 fs-6 fw-bold shadow-sm d-flex align-items-center gap-2">
                <i class="bi bi-stopwatch"></i>
                <span>@ViewBag.Trace.TotalElapsedMs <span class="opacity-75 fs-7">ms</span></span>
            </div>
        </div>
    </div>
    <div class="glass-body p-0 position-relative z-1">
        <div class="p-3 p-lg-4">
            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-4">
                <div class="copilot-tree-legend">
                    <span class="copilot-tree-legend-item copilot-tree-legend-item-active"><span class="copilot-tree-legend-dot"></span>@Loc.Get("ActualExecutedPath")</span>
                </div>
                <div class="copilot-trace-view-toggle" role="tablist" aria-label="@Loc.Get("TraceViewMode")">
                    <button type="button" id="@storyToggleId" class="copilot-trace-view-btn is-active" data-trace-view-target="story" aria-pressed="true">
                        <i class="bi bi-list-ul"></i> @Loc.Get("Story")
                    </button>
                    <button type="button" id="@treeToggleId" class="copilot-trace-view-btn" data-trace-view-target="tree" aria-pressed="false">
                        <i class="bi bi-diagram-3"></i> @Loc.Get("Tree")
                    </button>
                </div>
            </div>
            <div class="copilot-trace-view-shell">
                <div class="copilot-story-view">
                    <div class="copilot-story-timeline">
                
                        <!-- START NODE: THE QUESTION -->
                        <div class="copilot-story-step">
                            <div class="copilot-story-dot bg-primary bg-opacity-10 border border-primary border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                <i class="bi bi-person-fill text-primary" style="font-size: 1rem;"></i>
                            </div>
                            <div class="copilot-story-content shadow-sm border border-secondary border-opacity-10" style="background: var(--bg-card); border-radius: var(--radius-btn, 14px);">
                                <div class="small fw-bold text-uppercase text-muted mb-1" style="font-size: 0.65rem;">@Loc.Get("SystemInput")</div>
                                <div class="fw-bold mb-0" style="color: var(--text-main); font-size: 0.95rem;">@ViewBag.Trace.Question</div>
                            </div>
                        </div>

                        <!-- NEW: REASONING INTENT & PLAN -->
                        <div class="copilot-story-step">
                            <div class="copilot-story-dot bg-warning bg-opacity-10 border border-warning border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                <i class="bi bi-compass-fill text-warning" style="font-size: 1rem;"></i>
                            </div>
                            <div class="copilot-story-content shadow-sm border border-warning border-opacity-10" style="background: rgba(var(--secondary-color-rgb, 245, 158, 11), 0.02); border-radius: var(--radius-btn, 14px);">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-bold text-uppercase text-warning" style="font-size: 0.65rem;">@Loc.Get("ReasoningIntentPlan")</span>
                                    <span class="badge rounded-pill @(Model.PlannerConfidence == RoutingConfidence.High ? "bg-success" : Model.PlannerConfidence == RoutingConfidence.Medium ? "bg-warning" : "bg-danger") px-2" style="font-size: 0.6rem;">@Model.PlannerConfidence Confidence</span>
                                </div>
                                <div class="fw-bold mb-1" style="color: var(--text-main); font-size: 0.85rem;">@Model.RouteReason</div>
                                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                                {
                                    <div class="mt-2 text-muted xsmall" style="font-size: 0.75rem;">
                                        <i class="bi bi-search me-1"></i> <span class="opacity-75">@Loc.Get("InvestigationQuery"):</span> <span class="text-info">"@Model.SearchQuery"</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- MIDDLE NODES: THE REASONING STEPS -->
                        @{
                            void RenderStoryStep(CopilotExecutionStep step, int level = 0)
                            {
                                var stepId = $"step-{Guid.NewGuid():N}";
                                <div class="copilot-story-step @(level > 0 ? "is-sub-step" : "")" style="margin-left: @(level * 2)rem;">
                                    @if (level > 0)
                                    {
                                        <div class="copilot-story-connector" style="left: -1rem; width: 1rem;"></div>
                                    }
                                    <div class="copilot-story-dot" style="background: var(--bg-card); border-radius: 10px; width: @(level > 0 ? "26px" : "32px"); height: @(level > 0 ? "26px" : "32px"); z-index: 5;">
                                        @switch (step.Status)
                                        {
                                            case CopilotStepStatus.Ok:
                                                <i class="bi bi-check-circle-fill text-success" style="font-size: @(level > 0 ? "1rem" : "1.2rem");"></i>
                                                break;
                                            case CopilotStepStatus.Warn:
                                                <i class="bi bi-exclamation-circle-fill text-warning" style="font-size: @(level > 0 ? "1rem" : "1.2rem");"></i>
                                                break;
                                            case CopilotStepStatus.Error:
                                                <i class="bi bi-x-circle-fill text-danger" style="font-size: @(level > 0 ? "1rem" : "1.2rem");"></i>
                                                break;
                                            default:
                                                <i class="bi bi-circle text-muted"></i>
                                                break;
                                        }
                                    </div>
                                    <div class="copilot-story-content shadow-sm border border-secondary border-opacity-10" style="background: var(--bg-card); border-radius: 16px; transition: transform 0.2s ease;">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-soft-primary text-primary fw-bold px-2 py-1" style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em;">@step.Layer</span>
                                                @if (level > 0)
                                                {
                                                    <span class="badge bg-soft-secondary text-muted px-2 py-1" style="font-size: 0.6rem; text-transform: uppercase;">@Loc.Get("SubProcess")</span>
                                                }
                                            </div>
                                            <span class="copilot-story-time text-muted fw-bold" style="font-size: 0.7rem;">@step.ElapsedMs ms</span>
                                        </div>
                                        <div class="copilot-story-action fw-bold mb-1" style="color: var(--text-main); font-size: 0.9rem;">@step.Action</div>
                                        <div class="copilot-story-detail text-muted mb-2" style="line-height: 1.5; font-size: 0.85rem;">@step.Detail</div>
                                
                                        @if (!string.IsNullOrEmpty(step.TechnicalData))
                                        {
                                            <div class="mt-3">
                                                <button class="btn btn-soft-primary btn-xs rounded-pill px-3 fw-bold d-flex align-items-center gap-2" 
                                                        type="button" 
                                                        data-bs-toggle="collapse" 
                                                        data-bs-target="#@stepId" 
                                                        aria-expanded="false" 
                                                        style="font-size: 0.65rem;">
                                                    <i class="bi bi-code-slash"></i> @Loc.Get("InspectPayload")
                                                </button>
                                                <div class="collapse mt-2" id="@stepId">
                                                    <div class="copilot-story-payload-shell p-0 overflow-hidden" style="border-radius: 10px; border: 1px solid var(--border-color);">
                                                        <div class="bg-dark bg-opacity-5 px-3 py-2 border-bottom d-flex justify-content-between align-items-center" style="border-color: var(--border-color) !important;">
                                                            <span class="xsmall fw-bold text-muted text-uppercase" style="font-size: 0.6rem; letter-spacing: 0.1em;">@Loc.Get("TechnicalPayloads")</span>
                                                            <button class="btn btn-link btn-xs p-0 text-muted" onclick="copyToClipboard(this, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(step.TechnicalData))')">
                                                                <i class="bi bi-clipboard"></i>
                                                            </button>
                                                        </div>
                                                        <textarea class="copilot-story-payload-source d-none">@step.TechnicalData</textarea>
                                                        <div class="copilot-story-payload-host">
                                                            <div class="copilot-code-block p-0 m-0">
                                                                <pre class="m-0 p-3" style="font-size: 0.75rem; line-height: 1.5; background: var(--bg-elevated); color: var(--text-main); border: 1px solid var(--border-color); border-radius: 8px;"><code class="language-json">@step.TechnicalData</code></pre>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                if (step.SubSteps.Any())
                                {
                                    <div class="copilot-substeps-container position-relative">
                                        <div class="copilot-substeps-vertical-line" style="position: absolute; left: calc(@(level * 2)rem + 1rem); top: 0; bottom: 1.5rem; width: 2px; background: var(--border-color); opacity: 0.5;"></div>
                                        @foreach (var sub in step.SubSteps)
                                        {
                                            RenderStoryStep(sub, level + 1);
                                        }
                                    </div>
                                }
                            }
                        }

                        @foreach (var step in Model.Steps)
                        {
                            RenderStoryStep(step);
                        }
                
                        @if (Model.QueryPlan != null && !dataPlanningSteps.Any())
                        {
                            <div class="copilot-story-step">
                                <div class="copilot-story-dot bg-info bg-opacity-10 border border-info border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                    <i class="bi bi-database-fill-gear text-info" style="font-size: 1rem;"></i>
                                </div>
                                <div class="copilot-story-content shadow-sm border border-info border-opacity-10" style="background: rgba(var(--primary-color-rgb), 0.02); border-radius: var(--radius-btn, 14px);">
                                    <div class="small fw-bold text-uppercase text-info mb-1" style="font-size: 0.65rem;">@Loc.Get("AnalyticalQueryStrategy")</div>
                                    <div class="fw-bold mb-2" style="font-size: 0.85rem; color: var(--text-main);">@Model.QueryPlan.Summary</div>
                            
                                    <div class="row g-2">
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("Target")</div>
                                            <div class="small fw-bold">@ResolveStructuredPlanName(Model.QueryPlan)</div>
                                        </div>
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("Intent")</div>
                                            <div class="small fw-bold">@Model.QueryPlan.Intent</div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(Model.QueryPlan.EntityName)) {
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("Entity")</div>
                                            <div class="small fw-bold">@Model.QueryPlan.EntityName</div>
                                        </div>
                                        }
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("TimeRange")</div>
                                            <div class="small fw-bold">@Model.QueryPlan.RelativeDateRange</div>
                                        </div>
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("MaxResults")</div>
                                            <div class="small fw-bold">@Model.QueryPlan.MaxResults</div>
                                        </div>
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("SortLogic")</div>
                                            <div class="small fw-bold">@Model.QueryPlan.SortBy (@Model.QueryPlan.SortDirection)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (Model.ActionPlan != null)
                        {
                            <div class="copilot-story-step">
                                <div class="copilot-story-dot bg-success bg-opacity-10 border border-success border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                    <i class="bi bi-lightning-charge-fill text-success" style="font-size: 1rem;"></i>
                                </div>
                            <div class="copilot-story-content shadow-sm border border-primary border-opacity-25" style="background: rgba(var(--primary-color-rgb), 0.02); border-radius: var(--radius-btn, 14px);">
                                    <div class="small fw-bold text-uppercase text-success mb-1" style="font-size: 0.65rem;">@Loc.Get("PlatformActionSuggestion")</div>
                                    <div class="fw-bold mb-1" style="font-size: 0.85rem; color: var(--text-main);">@Model.ActionPlan.Summary</div>
                                    <div class="small text-muted">@Loc.Get("ActionIntent"): @Model.ActionPlan.Intent</div>
                                </div>
                            </div>
                        }

                        <!-- END NODE: THE ANSWER -->
                        <div class="copilot-story-step copilot-story-step-last">
                            <div class="copilot-story-dot bg-premium-gradient border-0 shadow-sm" style="border-radius: 10px; background: linear-gradient(135deg, var(--primary-color) 0%, var(--info-color) 100%);">
                                <i class="bi bi-stars" style="font-size: 1rem; color: var(--primary-contrast-text);"></i>
                            </div>
                            <div class="copilot-story-content shadow-sm border border-primary border-opacity-25" style="background: rgba(var(--primary-color-rgb), 0.05); border-radius: var(--radius-btn, 14px);">
                                <div class="small fw-bold text-uppercase text-primary mb-1" style="font-size: 0.65rem;">@Loc.Get("GeneratedResolution")</div>
                                <div class="mb-0" style="color: var(--text-main); font-size: 1rem; line-height: 1.6;">@ViewBag.Trace.Answer</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="copilot-tree-view">
                    <div class="copilot-tree-intro">
                        <div class="copilot-tree-intro-title">@Loc.Get("ExecutedRoute")</div>
                        <div class="copilot-tree-intro-text">@Loc.Get("ExecutedRouteHint")</div>
                    </div>

                    @if (catalogExecutions.Count > 1)
                    {
                        <div class="copilot-workflow-tabs mt-3 mb-4 d-flex gap-2">
                            <button type="button" class="copilot-workflow-tab is-active" data-workflow-tab="overview">@Loc.Get("GlobalOverview")</button>
                            @for (int i = 0; i < catalogExecutions.Count; i++)
                            {
                                var sub = catalogExecutions[i];
                                <button type="button" class="copilot-workflow-tab" data-workflow-tab="subplan-@i">
                                    @Loc.Get("SubPlanLabel") @(i + 1): @ResolveCatalogExecutionName(sub)
                                </button>
                            }
                        </div>
                    }

                    <div class="copilot-tree-path-bar">
                        <div class="copilot-tree-path-bar-label">@Loc.Get("ActualPathTaken")</div>
                        <div class="copilot-tree-path-bar-value">@string.Join(" → ", actualPath)</div>
                    </div>

                    @* Global Overview Shell *@
                    <div class="copilot-mermaid-shell" data-workflow-id="overview">
                        <div class="copilot-mermaid-toolbar">
                            <div class="copilot-mermaid-toolbar-title">
                                <i class="bi bi-diagram-3"></i>
                                <span>@Loc.Get("WorkflowDiagram") @Loc.Get("WorkflowDiagramGlobalSuffix")</span>
                            </div>
                            <div class="copilot-mermaid-toolbar-actions">
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="zoom-out"><i class="bi bi-dash-lg"></i></button>
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="zoom-in"><i class="bi bi-plus-lg"></i></button>
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="reset"><i class="bi bi-arrows-fullscreen"></i></button>
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="download"><i class="bi bi-download"></i></button>
                            </div>
                        </div>
                        <div class="copilot-mermaid-viewport">
                            <div class="copilot-mermaid-graph" data-trace-mermaid-id="trace-mermaid-@traceId-global"></div>
                        </div>
                        <pre class="copilot-mermaid-definition d-none">@mermaidDefinition</pre>
                        <script type="application/json" class="copilot-trace-node-data" data-workflow-id="overview">@Html.Raw(JsonSerializer.Serialize(nodeDetails))</script>
                    </div>

                    @* Sub-Plan Shells *@
                    @if (catalogExecutions.Any())
                    {
                        @for (int i = 0; i < catalogExecutions.Count; i++)
                        {
                            var sub = catalogExecutions[i];
                            var subKey = $"{traceGraphKey}_sub_{i}";
                            var subDef = GenerateSubPlanMermaid(sub, subKey);
                            var subDetails = GenerateSubPlanNodeDetails(sub);

                            <div class="copilot-mermaid-shell d-none" data-workflow-id="subplan-@i">
                                <div class="copilot-mermaid-toolbar">
                                    <div class="copilot-mermaid-toolbar-title">
                                        <i class="bi bi-diagram-3"></i>
                                        <span>@Loc.Get("WorkflowDiagram") (@Loc.Get("SubPlanLabel") @(i+1))</span>
                                    </div>
                                    <div class="copilot-mermaid-toolbar-actions">
                                        <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="zoom-out"><i class="bi bi-dash-lg"></i></button>
                                        <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="zoom-in"><i class="bi bi-plus-lg"></i></button>
                                        <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="reset"><i class="bi bi-arrows-fullscreen"></i></button>
                                        <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="download"><i class="bi bi-download"></i></button>
                                    </div>
                                </div>
                                <div class="copilot-mermaid-viewport">
                                    <div class="copilot-mermaid-graph" data-trace-mermaid-id="trace-mermaid-@traceId-sub-@i"></div>
                                </div>
                                <pre class="copilot-mermaid-definition d-none">@subDef</pre>
                                <script type="application/json" class="copilot-trace-node-data" data-workflow-id="subplan-@i">@Html.Raw(JsonSerializer.Serialize(subDetails))</script>
                            </div>
                        }
                    }
                    <div class="copilot-trace-node-panel d-none mt-4">
                        <div class="copilot-trace-node-panel-header">
                            <div>
                                <div class="copilot-trace-node-panel-label">@Loc.Get("StepInspector")</div>
                                <div class="copilot-trace-node-panel-title"></div>
                            </div>
                            <span class="copilot-trace-node-panel-status badge rounded-pill"></span>
                        </div>
                        <div class="copilot-trace-node-panel-summary"></div>
                        <div class="row g-3 mt-1">
                            <div class="col-12 col-lg-6">
                                <div class="copilot-trace-node-box">
                                    <div class="copilot-trace-node-box-label copilot-trace-node-before-label"></div>
                                    <div class="copilot-trace-node-box-value copilot-trace-node-before-value"></div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="copilot-trace-node-box">
                                    <div class="copilot-trace-node-box-label copilot-trace-node-after-label"></div>
                                    <div class="copilot-trace-node-box-value copilot-trace-node-after-value"></div>
                                </div>
                            </div>
                        </div>
                        <div class="copilot-trace-node-payloads mt-4 d-none">
                            <div class="copilot-trace-node-section-title d-flex align-items-center gap-2">
                                <i class="bi bi-box-seam"></i>
                                <span>@Loc.Get("SectionTechnicalData")</span>
                            </div>
                            <div class="copilot-trace-node-payloads-list mt-3"></div>
                        </div>
                        <div class="copilot-trace-node-substeps mt-4 d-none">
                            <div class="copilot-trace-node-section-title">@Loc.Get("RecordedSubsteps")</div>
                            <div class="copilot-trace-node-substeps-list"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>
        
        <!-- SEPARATE WORKFLOW BREAKDOWN SECTION -->
        @if (catalogExecutions.Any())
        {
            <div class="px-4 py-3 border-top border-secondary border-opacity-10 mt-4 position-relative z-1" style="background: rgba(var(--primary-color-rgb), 0.03);">
                <h6 class="fw-bold text-main mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-diagram-3-fill text-primary"></i>
                    @Loc.Get("SeparateWorkflows")
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill border border-primary border-opacity-25">@catalogExecutions.Count</span>
                </h6>
                <div class="row g-3">
                    @for (int i = 0; i < catalogExecutions.Count; i++)
                    {
                        var sub = catalogExecutions[i];
                        var queryModel = sub.QueryModel;
                        var intentPlan = sub.IntentPlan;
                        var projectionCount = queryModel?.Projections.Count ?? sub.Plan.SelectedColumns.Count;
                        var filterCount = (queryModel?.Predicates.Count ?? 0) + (queryModel?.HavingPredicates.Count ?? 0);
                        var sqlPreview = string.IsNullOrWhiteSpace(sub.GeneratedSql)
                            ? "No SQL captured."
                            : sub.GeneratedSql.Length > 160 ? sub.GeneratedSql[..160] + "..." : sub.GeneratedSql;
                        <div class="col-12">
                            <div class="card border-0 shadow-sm" style="background: var(--bg-card); border-left: 3px solid var(--primary-color) !important;">
                                <div class="card-header bg-transparent border-bottom border-secondary border-opacity-10 py-3 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                            <span class="fw-bold text-primary" style="font-size: 0.9rem;">@(i + 1)</span>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-main" style="font-size: 0.95rem;">@ResolveCatalogExecutionOperation(sub)</div>
                                            <div class="small text-muted">@ResolveCatalogExecutionName(sub) • @sub.TotalCount @Loc.Get("RowsReturned")</div>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-soft-primary rounded-pill" type="button" data-bs-toggle="collapse" data-bs-target="#workflow-@i" aria-expanded="false">
                                        <i class="bi bi-eye me-1"></i>@Loc.Get("ViewSteps")
                                    </button>
                                </div>
                                <div class="collapse" id="workflow-@i">
                                    <div class="card-body p-0">
                                        <!-- Workflow Overview -->
                                        <div class="p-3 border-bottom border-secondary border-opacity-10" style="background: rgba(var(--bg-main-rgb), 0.3);">
                                            <div class="row g-2 small">
                                                <div class="col-md-3"><span class="text-muted">@Loc.Get("Target"):</span> <span class="fw-semibold text-main">@ResolveCatalogExecutionName(sub)</span></div>
                                                <div class="col-md-3"><span class="text-muted">@Loc.Get("Intent"):</span> <span class="fw-semibold text-main">@ResolveCatalogExecutionOperation(sub)</span></div>
                                                <div class="col-md-3"><span class="text-muted">@Loc.Get("MaxResults"):</span> <span class="fw-semibold text-main">@(queryModel?.Limit ?? intentPlan?.Limit ?? sub.Plan.MaxResults)</span></div>
                                                <div class="col-md-3"><span class="text-muted">@Loc.Get("Columns"):</span> <span class="fw-semibold text-main">@projectionCount</span></div>
                                            </div>
                                        </div>
                                        <!-- Steps Tree -->
                                        <div class="p-3">
                                            <div class="workflow-steps-tree">
                                                <!-- Step 1: Input -->
                                                <div class="workflow-step">
                                                    <div class="d-flex align-items-start gap-2">
                                                        <div class="workflow-step-icon bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                            <i class="bi bi-1-circle-fill"></i>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <div class="fw-semibold text-main" style="font-size: 0.85rem;">@Loc.Get("SubRequestIntent")</div>
                                                            <div class="small text-muted">@(intentPlan?.Explanation ?? sub.Plan.Summary)</div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Step 2: Data Planning -->
                                                <div class="workflow-step mt-2">
                                                    <div class="d-flex align-items-start gap-2">
                                                        <div class="workflow-step-icon bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                            <i class="bi bi-2-circle-fill"></i>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <div class="fw-semibold text-main" style="font-size: 0.85rem;">@Loc.Get("ReasoningIntentPlan")</div>
                                                            <div class="small text-muted">@ResolveCatalogExecutionName(sub) • @ResolveCatalogExecutionOperation(sub) • @sub.PlannerSource</div>
                                                            <div class="mt-1">
                                                                <span class="badge bg-soft-secondary text-secondary rounded-pill" style="font-size: 0.65rem;">
                                                                    <i class="bi bi-list-check me-1"></i>@projectionCount @Loc.Get("Columns")
                                                                </span>
                                                                <span class="badge bg-soft-secondary text-secondary rounded-pill" style="font-size: 0.65rem;">
                                                                    <i class="bi bi-funnel me-1"></i>@filterCount @Loc.Get("Filters")
                                                                </span>
                                                                @if (queryModel?.JoinFragments.Any() == true)
                                                                {
                                                                    <span class="badge bg-soft-secondary text-secondary rounded-pill" style="font-size: 0.65rem;">
                                                                        <i class="bi bi-diagram-2 me-1"></i>@queryModel.JoinFragments.Count @Loc.Get("JoinsLabel")
                                                                    </span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Step 3: SQL Generation -->
                                                <div class="workflow-step mt-2">
                                                    <div class="d-flex align-items-start gap-2">
                                                        <div class="workflow-step-icon bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                            <i class="bi bi-3-circle-fill"></i>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <div class="fw-semibold text-main" style="font-size: 0.85rem;">@Loc.Get("SQLGeneration")</div>
                                                            <div class="small text-muted mb-1">@Loc.Get("TranslatedToQuery") • @sub.SqlParameters.Count @Loc.Get("ParametersSuffix")</div>
                                                            <div class="bg-dark bg-opacity-25 p-2 rounded" style="font-family: monospace; font-size: 0.75rem; overflow-x: auto;">
                                                                <code class="text-info">@sqlPreview</code>
                                                            </div>
                                                            @if (sub.SqlParameters.Any())
                                                            {
                                                                <div class="small text-muted mt-1">
                                                                    @string.Join(", ", sub.SqlParameters.Select(parameter => $"{parameter.Name}={parameter.Value}"))
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Step 4: Execution -->
                                                <div class="workflow-step mt-2">
                                                    <div class="d-flex align-items-start gap-2">
                                                        <div class="workflow-step-icon bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                            <i class="bi bi-4-circle-fill"></i>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <div class="fw-semibold text-main" style="font-size: 0.85rem;">@Loc.Get("Execution")</div>
                                                            <div class="small text-muted">@sub.TotalCount @Loc.Get("RowsReturned")</div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Step 5: Result Assembly -->
                                                <div class="workflow-step mt-2">
                                                    <div class="d-flex align-items-start gap-2">
                                                        <div class="workflow-step-icon bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                            <i class="bi bi-5-circle-fill"></i>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <div class="fw-semibold text-main" style="font-size: 0.85rem;">@Loc.Get("ResultAssembly")</div>
                                                            <div class="small text-muted">@sub.Summary</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Metadata Footer -->
        <div class="p-4 border-top border-secondary border-opacity-10 mt-4 position-relative z-1" style="background: rgba(var(--primary-color-rgb), 0.02);">
            <div class="row align-items-center text-center text-muted small fw-bold text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">
                <div class="col-4 border-end border-secondary border-opacity-10">
                    <div class="mb-1" style="color: var(--primary-color);"><i class="bi bi-cpu-fill me-1"></i> @Loc.Get("Model")</div>
                    <span class="text-main">@ViewBag.Trace.ModelName</span>
                </div>
                <div class="col-4 border-end border-secondary border-opacity-10">
                    <div class="mb-1" style="color: var(--primary-color);"><i class="bi bi-calendar-event me-1"></i> @Loc.Get("Timestamp")</div>
                    <span class="text-main">@ViewBag.Trace.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                </div>
                <div class="col-4">
                    <div class="mb-1" style="color: var(--primary-color);"><i class="bi bi-hash me-1"></i> @Loc.Get("StoryId")</div>
                    <span class="text-main badge bg-dark text-white rounded-pill border border-secondary border-opacity-25 px-3 py-1 shadow-sm">@ViewBag.Trace.Id</span>
                </div>
            </div>
        </div>
    </div>
</div>
