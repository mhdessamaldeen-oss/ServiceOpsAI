@inject AISupportAnalysisPlatform.Services.Infrastructure.ILocalizationService Loc

@*
    Copilot history-pane footer toolbar.

    Removed (2026-05-15): the "Admin Enterprise" role badge — duplicated the
    "Super Admin" pill already shown in the global app header. Also removed
    the SignalR status pill from this toolbar; live connection status is now
    surfaced as a small dot indicator at the top of the history pane in
    Copilot.cshtml (still uses id="copilot-signalr-status" for the JS).

    Buttons are split into two semantic groups by a divider:
      - Session actions (act on the current chat / archive)
      - Navigation (leave the chat for another admin surface)
    The Exit link is rendered in Copilot.cshtml after this partial because it
    needs the page-specific exitController/exitAction values.
*@

<div class="copilot-toolbar-group">
    <button type="button" class="btn-action-soft btn-action-sm" onclick="showGlobalStory()">
        <i class="bi bi-journal-check"></i><span>@Loc.Get("InvestigationStoriesAction")</span>
    </button>
    <button type="button" class="btn-action-ghost btn-action-sm" onclick="deleteCurrentConversation()">
        <i class="bi bi-eraser"></i><span>@Loc.Get("ClearCurrent")</span>
    </button>
    <button type="button" class="btn-action-soft btn-action-sm copilot-toolbar-danger" onclick="deleteAllConversations()">
        <i class="bi bi-trash"></i><span>@Loc.Get("ClearAll")</span>
    </button>
</div>

<div class="copilot-toolbar-divider" role="separator" aria-hidden="true"></div>

<div class="copilot-toolbar-group">
    <a class="btn-action-soft btn-action-sm copilot-toolbar-warning" asp-controller="AiAnalysis" asp-action="CopilotAssessment">
        <i class="bi bi-flask"></i><span>@Loc.Get("AssessmentLab")</span>
    </a>
</div>
