@model ServiceOpsAI.Models.AI.AdminCopilotExecutionDetails
@using ServiceOpsAI.Models.AI
@functions {
    // Pull a numeric / bool / string field out of a step's StepPayload "details" object.
    // Render-only, fully null-guarded — legacy v2 traces with no _payload simply return null,
    // so every ribbon/chip that consumes these degrades to "not shown" rather than throwing.
    private static System.Text.Json.JsonElement? PayloadDetails(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        var trimmed = raw!.TrimStart();
        if (!trimmed.StartsWith("{")) return null;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            var root = doc.RootElement;
            if (!root.TryGetProperty("_payload", out var ver) || ver.GetString() != "v1") return null;
            if (root.TryGetProperty("details", out var det)
                && det.ValueKind == System.Text.Json.JsonValueKind.Object)
                return det.Clone();   // Clone — the JsonDocument is disposed when this returns.
            return null;
        }
        catch { return null; }
    }

    private static double? GetDouble(System.Text.Json.JsonElement? details, string name)
    {
        if (details is { } d && d.TryGetProperty(name, out var el)
            && el.ValueKind == System.Text.Json.JsonValueKind.Number
            && el.TryGetDouble(out var v)) return v;
        return null;
    }

    private static string? GetString(System.Text.Json.JsonElement? details, string name)
    {
        if (details is { } d && d.TryGetProperty(name, out var el)
            && el.ValueKind == System.Text.Json.JsonValueKind.String) return el.GetString();
        return null;
    }

    private static bool GetBool(System.Text.Json.JsonElement? details, string name)
    {
        if (details is { } d && d.TryGetProperty(name, out var el)
            && (el.ValueKind == System.Text.Json.JsonValueKind.True
                || el.ValueKind == System.Text.Json.JsonValueKind.False))
            return el.GetBoolean();
        return false;
    }
}
@{
    var trace = ViewBag.Trace as CopilotTraceHistory;
    var allSteps = Model.Steps ?? new List<CopilotExecutionStep>();

    // Classify each step into one of four "kinds" for visual treatment. Drives the row
    // icon, the right-side badges, and which expand panels show.
    //   llm   — fired an LLM call (decomposer / spec / classifier / explainer)
    //   sql   — generated or executed SQL
    //   gate  — a guard / validator that either passed-through or refused
    //   info  — neutral wiring step (intake / formatter / etc.)
    static string ClassifyStep(string action)
    {
        var a = (action ?? string.Empty).ToLowerInvariant();
        if (a.Contains("decomposer") || a.Contains("specextractor") || a.Contains("specrefine")
            || a.Contains("intentclassifier") || a.Contains("explainer") || a.Contains("toolselector")
            || a.Contains("llm")) return "llm";
        if (a.Contains("compiler") || a.Contains("executor") || a.Contains("validator")
            || a.Contains("sqlintentguard")) return "sql";
        if (a.Contains("guard") || a.Contains("policy") || a.Contains("preflight")
            || a.Contains("rowshapesanity")) return "gate";
        return "info";
    }

    // Did the step actually have anything to surface? Used to demote "trivial pass" gate
    // rows into the collapsed footer instead of cluttering the timeline. Heuristic: a step
    // is "trivial" when it succeeded, has no technical data, and no detail beyond "ok"/"passed".
    static bool IsTrivialGate(CopilotExecutionStep s)
    {
        var kind = ClassifyStep(s.Action);
        if (kind != "gate") return false;
        if (s.Status != CopilotStepStatus.Ok) return false;
        if (!string.IsNullOrWhiteSpace(s.TechnicalData)) return false;
        var d = (s.Detail ?? string.Empty).Trim().ToLowerInvariant();
        return string.IsNullOrEmpty(d) || d == "ok" || d == "passed" || d == "pass";
    }

    // Sub-question rows split the timeline into swimlanes. Detect them by Action prefix.
    static bool IsSubQuestionRow(CopilotExecutionStep s) =>
        (s.Action ?? string.Empty).StartsWith("Sub-question", StringComparison.OrdinalIgnoreCase);

    static string StatusIcon(CopilotStepStatus s) => s switch
    {
        CopilotStepStatus.Ok    => "bi-check-circle-fill text-success",
        CopilotStepStatus.Warn  => "bi-exclamation-triangle-fill text-warning",
        CopilotStepStatus.Error => "bi-x-circle-fill text-danger",
        CopilotStepStatus.Skip  => "bi-skip-forward-fill text-muted",
        _ => "bi-circle text-muted",
    };

    static string KindBadge(string kind) => kind switch
    {
        "llm"  => "<span class=\"runtrace-kind-badge llm\"><i class=\"bi bi-cpu\"></i> LLM</span>",
        "sql"  => "<span class=\"runtrace-kind-badge sql\"><i class=\"bi bi-database\"></i> SQL</span>",
        "gate" => "<span class=\"runtrace-kind-badge gate\"><i class=\"bi bi-shield-check\"></i> GATE</span>",
        _ => string.Empty,
    };

    static string FormatMs(long ms) =>
        ms >= 1000 ? $"{ms / 1000.0:0.00}s" : $"{ms}ms";

    // Partition the steps into the main timeline (visible) and the collapsed-footer
    // trivial gates / skipped stages (still listed, just one-liner each).
    var visibleSteps = new List<CopilotExecutionStep>();
    var hiddenSteps = new List<CopilotExecutionStep>();
    foreach (var s in allSteps)
    {
        if (s.Status == CopilotStepStatus.Skip || IsTrivialGate(s)) hiddenSteps.Add(s);
        else visibleSteps.Add(s);
    }

    // Group consecutive Sub-question rows under one swimlane header. This is the
    // decomposer-fanout case: each sub-question row appears in the original step list as
    // its own entry; we render them as parallel columns of mini-steppers instead.
    var anySubQuestions = visibleSteps.Any(IsSubQuestionRow);

    // ── Decision-path ribbon model ──────────────────────────────────────────────
    // A horizontal cascade of the route stages, in pipeline order. A node "fired" when a
    // step whose Action maps to it exists in the trace. The deciding node shows its score
    // (ScopeGate→schemaTop, Tool/Semantic/Intent→their winner/cosine). Anchor lets a click
    // scroll to the matching timeline row. Wholly derived from the model — render-only.
    // Map a recorded step Action to a ribbon node key. Mirrors PipelineArchitecture.CanonicalNameOf
    // intent but kept inline + substring-tolerant so it works on legacy + any deployment's labels.
    static string? RibbonNodeOf(string action)
    {
        var a = (action ?? string.Empty).ToLowerInvariant();
        // Strip retry / sub-question index noise so retried variants collapse to one node.
        var rIdx = a.IndexOf(" (retry", StringComparison.Ordinal);
        if (rIdx > 0) a = a.Substring(0, rIdx);
        if (a.StartsWith("operationalguard") || a.StartsWith("writeintentguard")
            || (a.Contains("guard") && !a.Contains("outofscope") && !a.Contains("scope"))
            || a.Contains("preflight") || a.Contains("intake")) return "GUARDS";
        if (a.Contains("conversational")) return "CONV";
        if (a.Contains("knowledge")) return "KNOW";
        if (a.Contains("semanticsearch") || a.Contains("semantic search")) return "SEM";
        if (a.Contains("tooldispatch") || a.StartsWith("tool")) return "TOOL";
        if (a.Contains("verifiedquery") || a.Contains("trusted")) return "TRUST";
        if (a.Contains("intent")) return "INTENT";
        if (a.Contains("outofscope") || a.Contains("scope")) return "SCOPE";
        if (a.Contains("decompos") || a.StartsWith("sub-question")) return "DECOMP";
        if (a.Contains("schemalink") || a.Contains("schema link") || a.Contains("retriever")) return "LINK";
        if (a.Contains("grounding") || a.Contains("grounder")) return "GROUND";
        if (a.Contains("specextractor") || a.Contains("sqlgenerator") || a.Contains("sql generator")
            || a.Contains("llmdirectsql") || a.Contains("compiler") || a.Contains("emit")) return "EMIT";
        if (a.Contains("validator") || a.Contains("accesspolicy") || a.Contains("rowshape")
            || a.Contains("sqlintentguard")) return "VALIDATE";
        if (a.Contains("executor")) return "EXEC";
        if (a.Contains("explainer") || a.Contains("format") || a.Contains("coverage")) return "EXPLAIN";
        return null;
    }

    // Cascade order + label + icon, exactly as the mandate specifies.
    var ribbonStages = new (string Key, string Label, string Icon)[]
    {
        ("GUARDS",   "Guards",          "bi-shield-lock"),
        ("CONV",     "Conversational",  "bi-chat-heart"),
        ("KNOW",     "Knowledge",       "bi-book"),
        ("SEM",      "Semantic",        "bi-search"),
        ("TOOL",     "Tool",            "bi-cloud-arrow-down"),
        ("TRUST",    "Trusted",         "bi-patch-check"),
        ("INTENT",   "Intent",          "bi-bullseye"),
        ("SCOPE",    "Scope gate",      "bi-water"),
        ("DECOMP",   "Decompose",       "bi-diagram-2"),
        ("LINK",     "Schema link",     "bi-diagram-3"),
        ("GROUND",   "Ground",          "bi-pin-map"),
        ("EMIT",     "Emit SQL",        "bi-filetype-sql"),
        ("VALIDATE", "Validate",        "bi-shield-check"),
        ("EXEC",     "Execute",         "bi-database"),
        ("EXPLAIN",  "Explain",         "bi-chat-square-text"),
    };

    // For each node: did it fire, did it fail, and the first matching step (for anchor + score).
    var ribbonFired = new Dictionary<string, (bool Failed, string? Score, int FirstIdx)>();
    for (int i = 0; i < visibleSteps.Count; i++)
    {
        var s = visibleSteps[i];
        var node = RibbonNodeOf(s.Action);
        if (node is null) continue;
        var failed = s.Status == CopilotStepStatus.Error;
        // Deciding score: ScopeGate exposes schemaTop in its payload; routing stages carry a
        // winner score in Decisions[0]. Only set it on the FIRST fire so the ribbon stays terse.
        string? score = null;
        if (node == "SCOPE")
        {
            var sc = GetDouble(PayloadDetails(s.TechnicalData), "schemaTop");
            if (sc is { } v) score = v.ToString("0.00");
        }
        else if (node is "INTENT" or "TOOL" or "SEM" or "TRUST" or "LINK"
                 && s.Decisions is { Count: > 0 } && s.Decisions[0].WinnerScore is { } ws)
        {
            score = ws.ToString("0.00");
        }
        if (!ribbonFired.TryGetValue(node, out var ex))
            ribbonFired[node] = (failed, score, i);
        else
            ribbonFired[node] = (ex.Failed || failed, ex.Score ?? score, ex.FirstIdx);
    }

    // ── Scope-gate signal for the SCOPE header chip ─────────────────────────────
    // Read the cosines off whichever OutOfScopeGuard step exists (in-scope pass OR refusal).
    // v3 traces only — null-guarded so v2 traces simply omit the chip.
    var scopeStep = visibleSteps.FirstOrDefault(s => RibbonNodeOf(s.Action) == "SCOPE")
                 ?? allSteps.FirstOrDefault(s => RibbonNodeOf(s.Action) == "SCOPE");
    var scopeDetails = scopeStep is null ? null : PayloadDetails(scopeStep.TechnicalData);
    var scopeSchemaTop = GetDouble(scopeDetails, "schemaTop");
    var scopeSchemaFloor = GetDouble(scopeDetails, "schemaFloor");
    var scopeFailedOpen = GetBool(scopeDetails, "failedOpen");
    // In-scope when the gate passed (step Status Ok) — the refusal path records Status Failed.
    var scopeInScope = scopeStep is not null && scopeStep.Status != CopilotStepStatus.Error;

    // ── One-line run narration ──────────────────────────────────────────────────
    // A plain-English sentence describing what this run actually did, derived entirely
    // from the recorded steps so it stays truthful on any trace shape (small-talk /
    // knowledge / semantic / tool / data-query / refusal). Each route is first-class and
    // named correctly; clauses are appended only when the matching step fired. Fully
    // null-guarded so legacy traces with sparse steps degrade gracefully.
    string NarrAction(CopilotExecutionStep s) => (s.Action ?? string.Empty).ToLowerInvariant();
    bool NarrHas(string needle) => allSteps.Any(s => NarrAction(s).Contains(needle));
    string? NarrDetail(string needle) =>
        allSteps.FirstOrDefault(s => NarrAction(s).Contains(needle))?.Detail;

    var narrationParts = new List<string>();
    var narrationIcon = "bi-card-text";
    if (allSteps.Count == 0)
    {
        narrationParts.Add("No steps were recorded for this run.");
        narrationIcon = "bi-inbox";
    }
    else if (NarrHas("conversational"))
    {
        // SmallTalk route — a warm, templated-or-LLM reply, no data path.
        narrationIcon = "bi-chat-heart";
        var convLlm = allSteps.Any(s => NarrAction(s).Contains("conversational")
                                        && ((s.PromptTokens ?? 0) + (s.CompletionTokens ?? 0) > 0
                                            || !string.IsNullOrEmpty(s.LlmModelUsed)));
        narrationParts.Add(convLlm ? "Small-talk → 1 LLM warm reply" : "Small-talk → templated reply (no LLM)");
    }
    else if (NarrHas("knowledge"))
    {
        // Knowledge route — answered straight from the curated FAQ dictionary.
        narrationIcon = "bi-book";
        narrationParts.Add("Knowledge match → answered from the FAQ dictionary (no LLM)");
    }
    else if (NarrHas("tooldispatch") || allSteps.Any(s => NarrAction(s).StartsWith("tool")))
    {
        narrationIcon = "bi-cloud-arrow-down";
        narrationParts.Add("Tool dispatch → delegated to a registered tool");
    }
    else if (NarrHas("semanticsearch") || NarrHas("semantic search"))
    {
        narrationIcon = "bi-search";
        narrationParts.Add("Semantic search → matched indexed records by meaning");
    }
    else if (allSteps.Any(s => s.Status == CopilotStepStatus.Error
                               && (NarrAction(s).Contains("outofscope") || NarrAction(s).Contains("scope"))))
    {
        narrationIcon = "bi-shield-slash";
        narrationParts.Add("Refused — out of scope (scope-confidence gate)");
    }
    else
    {
        // Data-query narration: link → ground → validate → execute, with the salient numbers.
        narrationIcon = "bi-database";
        narrationParts.Add("Data query");
        var linkDetail = NarrDetail("schemalink") ?? NarrDetail("schema link");
        var tableMatch = linkDetail is null
            ? null
            : System.Text.RegularExpressions.Regex.Match(linkDetail, @"([A-Za-z_][A-Za-z0-9_]*)").Value;
        if (!string.IsNullOrEmpty(tableMatch)) narrationParts.Add($"linked {tableMatch}");
        var groundDetail = NarrDetail("grounding") ?? NarrDetail("grounder");
        if (groundDetail is not null && groundDetail.Contains("grounded fact"))
            narrationParts.Add(groundDetail.Replace("grounded fact(s)", "grounded facts"));
        if (NarrHas("validator")
            && !allSteps.Any(s => NarrAction(s).Contains("validator") && s.Status == CopilotStepStatus.Error))
            narrationParts.Add("read-only validated");
        if ((Model.ResultCount ?? 0) > 0)
            narrationParts.Add($"{Model.ResultCount} row{(Model.ResultCount == 1 ? "" : "s")} in {FormatMs(Model.TotalElapsedMs)}");
        else if (allSteps.Any(s => s.Status == CopilotStepStatus.Error))
            narrationParts.Add($"failed in {FormatMs(Model.TotalElapsedMs)}");
    }
    var narration = string.Join(" → ", narrationParts);
}

<div class="investigation-runtrace">

    @* ── Header strip ───────────────────────────────────────────────── *@
    <div class="runtrace-header">
        @{
            var headerStatus = Model.Steps?.Any(s => s.Status == CopilotStepStatus.Error) == true ? "error"
                : Model.Steps?.Any(s => s.Status == CopilotStepStatus.Warn) == true ? "warn"
                : "ok";
            var headerIcon = headerStatus switch
            {
                "error" => ("bi-x-circle-fill", "text-danger", Loc.Get("RunFailed")),
                "warn"  => ("bi-exclamation-triangle-fill", "text-warning", Loc.Get("RunCompletedWithWarnings")),
                _ => ("bi-check-circle-fill", "text-success", Loc.Get("RunCompletedSuccessfully")),
            };
        }
        <div class="runtrace-header-status @headerStatus">
            <i class="bi @headerIcon.Item1 @headerIcon.Item2"></i>
            <span class="fw-semibold">@headerIcon.Item3</span>
        </div>
        <div class="runtrace-header-stats">
            <span class="runtrace-stat" title="Total elapsed time">
                <i class="bi bi-stopwatch"></i><strong>@FormatMs(Model.TotalElapsedMs)</strong>
            </span>
            <span class="runtrace-stat" title="Pipeline stages executed">
                <i class="bi bi-list-ol"></i><strong>@visibleSteps.Count</strong> @Loc.Get("StepsWord")
            </span>
            @if (trace?.LlmCallCount is > 0)
            {
                <span class="runtrace-stat" title="LLM calls fired">
                    <i class="bi bi-cpu"></i><strong>@trace.LlmCallCount</strong> calls
                </span>
                <span class="runtrace-stat" title="Prompt + completion tokens">
                    <i class="bi bi-hash"></i><strong>@($"{(trace.TotalPromptTokens ?? 0):N0}+{(trace.TotalCompletionTokens ?? 0):N0}")</strong>
                </span>
                @if (trace.EstimatedCostUsd is { } cost)
                {
                    <span class="runtrace-stat @(cost == 0 ? "free" : "")" title="Estimated cost from ModelPricing">
                        <i class="bi bi-currency-dollar"></i>
                        <strong>@(cost == 0 ? "free" : (cost >= 0.01m ? cost.ToString("0.0000") : cost.ToString("0.000000")))</strong>
                    </span>
                }
            }
            @if (Model.ResultCount is > 0)
            {
                <span class="runtrace-stat">
                    <i class="bi bi-table"></i><strong>@Model.ResultCount</strong> rows
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.DetectedIntent))
            {
                <span class="runtrace-stat intent">
                    <i class="bi bi-bullseye"></i>@Model.DetectedIntent
                </span>
            }
            @* SCOPE chip — the moat verdict at a glance: green = in scope, red = refused.
               Shows schemaTop / floor when the v3 signals are present; degrades to a bare
               in/out-of-scope pill on traces that recorded the gate without cosines. *@
            @if (scopeStep is not null)
            {
                <span class="runtrace-stat scope @(scopeInScope ? "in" : "out")"
                      title="Scope-confidence gate: schema-link cosine vs floor (the refuse-vs-answer moat)">
                    <i class="bi @(scopeInScope ? "bi-water" : "bi-shield-slash")"></i>
                    @if (scopeFailedOpen)
                    {
                        <strong>fail-open</strong>
                    }
                    else if (scopeSchemaTop is { } st)
                    {
                        <strong>@st.ToString("0.00")</strong>
                        @if (scopeSchemaFloor is { } sf)
                        {
                            <span class="runtrace-stat-sub">/ @sf.ToString("0.00")</span>
                        }
                    }
                    else
                    {
                        <strong>@(scopeInScope ? "in scope" : "refused")</strong>
                    }
                </span>
            }
            @* BUDGET chip — single roll-up of how much LLM the answer cost (calls + $). *@
            @if (trace?.LlmCallCount is { } budgetCalls)
            {
                var budgetCost = trace.EstimatedCostUsd;
                <span class="runtrace-stat budget" title="LLM budget spent on this run (calls + estimated cost)">
                    <i class="bi bi-coin"></i>
                    <strong>@budgetCalls</strong> @(budgetCalls == 1 ? "call" : "calls")
                    @if (budgetCost is { } bc)
                    {
                        <span class="runtrace-stat-sub @(bc == 0 ? "free" : "")">· @(bc == 0 ? "free" : (bc >= 0.01m ? $"${bc:0.0000}" : $"${bc:0.000000}"))</span>
                    }
                </span>
            }
        </div>
    </div>

    @* ── One-line run narration — the whole run in a sentence ─────────────────
         A plain-English summary of what this trace did (route + key numbers),
         derived purely from the recorded steps so it's truthful on every trace
         shape. Sits ABOVE the decision-path ribbon as the first thing read. *@
    <div class="story-narration">
        <i class="bi @narrationIcon"></i>
        <span class="story-narration-text">@narration</span>
    </div>

    @* ── Decision-path ribbon ────────────────────────────────────────────────
         The whole pipeline cascade in one horizontal strip: Guards → Conversational
         → Knowledge → Semantic → Tool → Trusted → Intent → Scope → Decompose →
         Schema link → Ground → Emit → Validate → Execute → Explain. Stages that
         FIRED in this trace are lit (with the deciding score on the deciding node);
         stages that never ran are dimmed. Clicking a fired node scrolls to its step.
         Pure derive-from-model — degrades to "all dim" on an empty trace. *@
    @if (ribbonFired.Count > 0)
    {
        <div class="runtrace-ribbon" role="navigation" aria-label="Decision path">
            @for (int ri = 0; ri < ribbonStages.Length; ri++)
            {
                var stg = ribbonStages[ri];
                var fired = ribbonFired.TryGetValue(stg.Key, out var info);
                var stateCls = !fired ? "is-dim" : info.Failed ? "is-failed" : "is-fired";
                if (fired)
                {
                    <a class="runtrace-ribbon-node @stateCls" href="#ribbon-stage-@(stg.Key)"
                       title="@stg.Label — jump to this step">
                        <span class="runtrace-ribbon-dot"><i class="bi @stg.Icon"></i></span>
                        <span class="runtrace-ribbon-label">@stg.Label</span>
                        @if (!string.IsNullOrEmpty(info.Score))
                        {
                            <span class="runtrace-ribbon-score">@info.Score</span>
                        }
                    </a>
                }
                else
                {
                    <span class="runtrace-ribbon-node @stateCls" title="@stg.Label — did not run">
                        <span class="runtrace-ribbon-dot"><i class="bi @stg.Icon"></i></span>
                        <span class="runtrace-ribbon-label">@stg.Label</span>
                    </span>
                }
                @if (ri < ribbonStages.Length - 1)
                {
                    <span class="runtrace-ribbon-link @(fired ? "is-fired" : "")" aria-hidden="true"></span>
                }
            }
        </div>
    }

    @* ── Run metadata + generated query ──────────────────────────────────
         Everything the timeline rows can't carry: the routing verdict + why,
         answer provenance/confidence, and the actual SQL the pipeline emitted
         (plus the curated reference query, when this trace came from the
         assessment lab). Collapsed by default so the timeline stays the focus. *@
    @{
        bool HasMeta() =>
            !string.IsNullOrWhiteSpace(Model.RouteReason)
            || !string.IsNullOrWhiteSpace(Model.Provenance)
            || Model.Confidence.HasValue
            || !string.IsNullOrWhiteSpace(Model.SearchQuery)
            || !string.IsNullOrWhiteSpace(Model.Brain);
        var hasSql = !string.IsNullOrWhiteSpace(trace?.GeneratedScript);
        var hasExpected = !string.IsNullOrWhiteSpace(trace?.ExpectedScript);
    }
    @if (HasMeta() || hasSql || hasExpected)
    {
        <details class="runtrace-meta-panel" open>
            <summary>
                <i class="bi bi-info-square"></i>
                <span>Run metadata &amp; generated query</span>
                <i class="bi bi-chevron-down runtrace-meta-chevron"></i>
            </summary>
            <div class="runtrace-meta-body">
                @if (HasMeta())
                {
                    <div class="runtrace-facts-grid runtrace-meta-facts">
                        @if (!string.IsNullOrWhiteSpace(Model.DetectedIntent))
                        {
                            <div><span class="runtrace-k">Intent</span><span class="runtrace-v">@Model.DetectedIntent</span></div>
                        }
                        <div><span class="runtrace-k">Planner confidence</span><span class="runtrace-v">@Model.PlannerConfidence</span></div>
                        @if (!string.IsNullOrWhiteSpace(Model.Provenance))
                        {
                            <div><span class="runtrace-k">Provenance</span><span class="runtrace-v">@Model.Provenance</span></div>
                        }
                        @if (Model.Confidence is { } conf)
                        {
                            <div><span class="runtrace-k">Confidence</span><span class="runtrace-v">@conf.ToString("0.00")</span></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Brain))
                        {
                            <div><span class="runtrace-k">Brain</span><span class="runtrace-v">@Model.Brain</span></div>
                        }
                        @if (Model.PromptLength is { } pl && pl > 0)
                        {
                            <div><span class="runtrace-k">Prompt length</span><span class="runtrace-v">@($"{pl:N0}") chars</span></div>
                        }
                        @if (Model.ResultCount is { } rc)
                        {
                            <div><span class="runtrace-k">Result rows</span><span class="runtrace-v">@rc@(Model.IsTruncated ? " (truncated)" : "")</span></div>
                        }
                        <div><span class="runtrace-k">Trace schema</span><span class="runtrace-v">v@(Model.TraceSchemaVersion)</span></div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.RouteReason))
                    {
                        <div class="runtrace-section">
                            <div class="runtrace-section-label"><i class="bi bi-signpost-2"></i> Why this route</div>
                            <div class="runtrace-desc">@Model.RouteReason</div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                    {
                        <div class="runtrace-section">
                            <div class="runtrace-section-label"><i class="bi bi-search"></i> Search query</div>
                            <div class="runtrace-desc">@Model.SearchQuery</div>
                        </div>
                    }
                }
                @if (hasSql)
                {
                    <div class="runtrace-section">
                        <div class="runtrace-section-label">
                            <i class="bi bi-filetype-sql"></i> Generated SQL
                            <button type="button" class="runtrace-copy-btn"
                                    onclick="navigator.clipboard.writeText(this.closest('.runtrace-section').querySelector('code').innerText);this.classList.add('copied');this.textContent='Copied';setTimeout(()=>{this.classList.remove('copied');this.textContent='Copy';},1400);">Copy</button>
                        </div>
                        <pre class="runtrace-blob-pre runtrace-code language-sql"><code class="language-sql">@trace!.GeneratedScript</code></pre>
                    </div>
                }
                @* ── Filters applied — the literal grounded facts the answer filtered on,
                     pulled from the Grounding step's details.facts array. Lets the owner see
                     "Bills.Status = 'Overdue'" without parsing the SQL. v3 traces only. *@
                @{
                    var groundStep = allSteps.FirstOrDefault(s => RibbonNodeOf(s.Action) == "GROUND");
                    var groundDetails = groundStep is null ? null : PayloadDetails(groundStep.TechnicalData);
                    var groundFacts = new List<string>();
                    if (groundDetails is { } gd && gd.TryGetProperty("facts", out var factsEl)
                        && factsEl.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        foreach (var f in factsEl.EnumerateArray())
                        {
                            if (f.ValueKind == System.Text.Json.JsonValueKind.String)
                            {
                                var fs = f.GetString();
                                if (!string.IsNullOrWhiteSpace(fs)) groundFacts.Add(fs!);
                            }
                        }
                    }
                }
                @if (groundFacts.Count > 0)
                {
                    <div class="runtrace-section">
                        <div class="runtrace-section-label"><i class="bi bi-funnel"></i> Filters applied</div>
                        <div class="runtrace-filters">
                            @foreach (var f in groundFacts)
                            {
                                <span class="runtrace-filter-pill"><i class="bi bi-pin-angle"></i>@f</span>
                            }
                        </div>
                    </div>
                }
                @if (hasExpected)
                {
                    <div class="runtrace-section">
                        <div class="runtrace-section-label"><i class="bi bi-check2-square"></i> Reference SQL (expected)</div>
                        <pre class="runtrace-blob-pre runtrace-code language-sql"><code class="language-sql">@trace!.ExpectedScript</code></pre>
                    </div>
                }
            </div>
        </details>
    }

    @* ── Main timeline ───────────────────────────────────────────────── *@
    <div class="runtrace-timeline">
        @{
            var indexedSteps = visibleSteps.Select((s, i) => new { Step = s, Idx = i }).ToList();
            // Anchor map: the index of the FIRST visible step that lit each ribbon node →
            // the node key. The timeline wraps that step in <div id="ribbon-stage-KEY"> so a
            // ribbon-node click scrolls here. Render-only; identity-keyed so it's swimlane-safe.
            var anchorByStep = new Dictionary<CopilotExecutionStep, string>(ReferenceEqualityComparer.Instance);
            foreach (var kv in ribbonFired)
            {
                if (kv.Value.FirstIdx >= 0 && kv.Value.FirstIdx < visibleSteps.Count)
                    anchorByStep[visibleSteps[kv.Value.FirstIdx]] = kv.Key;
            }
            // Run total used by the per-stage timing bars (avoid divide-by-zero).
            var runTotalMs = Math.Max(1L, Model.TotalElapsedMs);

            // Build the per-step ViewData (run-total for the timing bar + the ribbon anchor key
            // on first-fire steps) once, keyed by step identity, so each render site is a one-liner.
            var rowViewData = new Dictionary<CopilotExecutionStep, ViewDataDictionary>(ReferenceEqualityComparer.Instance);
            ViewDataDictionary RowVd(CopilotExecutionStep step)
            {
                if (!rowViewData.TryGetValue(step, out var vd))
                {
                    vd = new ViewDataDictionary(ViewData) { ["RunTotalMs"] = runTotalMs };
                    if (anchorByStep.TryGetValue(step, out var anchorKey)) vd["RibbonAnchor"] = anchorKey;
                    rowViewData[step] = vd;
                }
                return vd;
            }
        }
        @if (anySubQuestions)
        {
            @* Swimlane layout: render pre-decomposition steps as a normal stack, then a
               swimlane block for sub-questions side-by-side. *@
            var preDecomp = visibleSteps.TakeWhile(s => !IsSubQuestionRow(s)).ToList();
            var subQ = visibleSteps.Where(IsSubQuestionRow).ToList();
            var postDecomp = visibleSteps.SkipWhile(s => !IsSubQuestionRow(s))
                                          .Where(s => !IsSubQuestionRow(s)).ToList();
            foreach (var step in preDecomp)
            {
                <partial name="_InvestigationRunTraceRow" model="step" view-data="RowVd(step)" />
            }
            <div class="runtrace-swimlane-block">
                <div class="runtrace-swimlane-header">
                    <i class="bi bi-arrow-right-square"></i>
                    @subQ.Count sub-questions in parallel
                </div>
                <div class="runtrace-swimlane-note">
                    <i class="bi bi-info-circle"></i>
                    This is <strong>one</strong> investigation trace. The decomposer split the question into
                    @subQ.Count sub-questions that ran their own link → ground → emit → execute pipelines
                    <strong>in parallel</strong>; their results are merged into the single final answer below — you do
                    not need to open a separate trace per sub-question.
                </div>
                <div class="runtrace-swimlanes" style="--lane-count: @subQ.Count;">
                    @foreach (var sq in subQ)
                    {
                        <div class="runtrace-swimlane">
                            <div class="runtrace-swimlane-title">
                                <i class="bi @StatusIcon(sq.Status).Split(' ')[0]"></i>
                                <span>@sq.Action</span>
                            </div>
                            <div class="runtrace-swimlane-detail">@sq.Detail</div>
                            <div class="runtrace-swimlane-time">@FormatMs(sq.ElapsedMs)</div>
                            @if (sq.SubSteps?.Count > 0)
                            {
                                <ol class="runtrace-swimlane-substeps">
                                    @foreach (var sub in sq.SubSteps)
                                    {
                                        <li>
                                            <i class="bi @StatusIcon(sub.Status).Split(' ')[0]"></i>
                                            <span>@sub.Action</span>
                                            <span class="text-muted ms-1">@FormatMs(sub.ElapsedMs)</span>
                                        </li>
                                    }
                                </ol>
                            }
                        </div>
                    }
                </div>
            </div>
            foreach (var step in postDecomp)
            {
                <partial name="_InvestigationRunTraceRow" model="step" view-data="RowVd(step)" />
            }
        }
        else
        {
            foreach (var step in visibleSteps)
            {
                <partial name="_InvestigationRunTraceRow" model="step" view-data="RowVd(step)" />
            }
        }
    </div>

    @* ── Collapsed footer for skipped / trivial gates ──────────────── *@
    @if (hiddenSteps.Count > 0)
    {
        <details class="runtrace-hidden">
            <summary>
                <i class="bi bi-three-dots"></i>
                @hiddenSteps.Count step(s) skipped or pass-through — @string.Join(", ", hiddenSteps.Select(s => s.Action).Distinct().Take(8))
            </summary>
            <ul class="runtrace-hidden-list">
                @foreach (var s in hiddenSteps)
                {
                    <li>
                        <i class="bi @StatusIcon(s.Status).Split(' ')[0]"></i>
                        <span>@s.Action</span>
                        @if (!string.IsNullOrWhiteSpace(s.Detail))
                        {
                            <span class="text-muted ms-2">— @s.Detail</span>
                        }
                    </li>
                }
            </ul>
        </details>
    }
</div>
