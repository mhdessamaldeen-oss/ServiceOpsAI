@model ServiceOpsAI.Models.AI.CopilotExecutionStep
@using ServiceOpsAI.Models.AI
@*
    Recursive step-metadata renderer. Renders EVERY metadata category a
    CopilotExecutionStep can carry — Where & when, LLM-call grid, structured
    payload (reason/input/output/details), per-call LLM cards, auto-fix phase
    diagnostics, routing decisions, and nested sub-steps — and recurses into
    each sub-step so a sub-step that is itself an LLM call (e.g. "LLM call
    (Explainer)") surfaces the same full detail as a top-level step.

    Shared by _InvestigationRunTraceRow (top-level step expand panel) and by
    itself (sub-steps). Keeps step / sub-step rendering at exact parity — the
    audit gap that previously left sub-steps without LlmCalls / Decisions /
    PhaseDiagnostics / Where-&-when.
*@
@functions {
    private static (string? Kind, string? Input, string? Output, string? Reason, string? DetailsJson)
        TryParsePayload(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return (null, null, null, null, null);
        var trimmed = raw!.TrimStart();
        if (!trimmed.StartsWith("{")) return (null, null, null, null, null);
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            var root = doc.RootElement;
            if (!root.TryGetProperty("_payload", out var ver) || ver.GetString() != "v1")
                return (null, null, null, null, null);
            string? Get(string n) => root.TryGetProperty(n, out var el) && el.ValueKind == System.Text.Json.JsonValueKind.String
                ? el.GetString() : null;
            string? detailsJson = null;
            if (root.TryGetProperty("details", out var det) && det.ValueKind != System.Text.Json.JsonValueKind.Null)
            {
                detailsJson = System.Text.Json.JsonSerializer.Serialize(det,
                    new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            }
            return (Get("kind"), Get("input"), Get("output"), Get("reason"), detailsJson);
        }
        catch { return (null, null, null, null, null); }
    }

    private static string? GuessCodeLang(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        var t = raw!.TrimStart();
        if (t.StartsWith("{") || t.StartsWith("["))
        {
            try { using var _ = System.Text.Json.JsonDocument.Parse(raw); return "json"; }
            catch { }
        }
        // Scan the WHOLE blob (not just the first 400 chars): a SELECT with a long
        // projection list pushes its FROM clause well past 400 chars, so the old
        // windowed check missed it and the SQL rendered as flat prose. Also catch
        // the "SQL:" label payloads use to introduce the generated query
        // (e.g. "Question: …\nSQL: SELECT …").
        var upper = t.ToUpperInvariant();
        var hasSqlLabel = upper.StartsWith("SQL:") || upper.Contains("\nSQL:");
        var hasSelectFrom = (upper.Contains("SELECT ") || upper.Contains("SELECT\n") || upper.StartsWith("WITH "))
            && (upper.Contains(" FROM ") || upper.Contains("\nFROM "));
        if (hasSqlLabel || hasSelectFrom)
            return "sql";
        return null;
    }
}
@{
    static string FormatMs(long ms) => ms >= 1000 ? $"{ms / 1000.0:0.00}s" : $"{ms}ms";
    static string StatusIcon(CopilotStepStatus s) => s switch
    {
        CopilotStepStatus.Ok    => "bi-check-circle-fill text-success",
        CopilotStepStatus.Warn  => "bi-exclamation-triangle-fill text-warning",
        CopilotStepStatus.Error => "bi-x-circle-fill text-danger",
        CopilotStepStatus.Skip  => "bi-skip-forward-fill text-muted",
        _ => "bi-circle text-muted",
    };
    static string CostString(decimal? c) => c is null ? "—"
        : c.Value == 0 ? "free"
        : c.Value >= 0.01m ? $"${c.Value:F4}" : $"${c.Value:F6}";

    const int RowBlobCap = 2048;
    Func<string, string> renderRowBlob = raw =>
    {
        if (string.IsNullOrEmpty(raw)) return string.Empty;
        var encoded = System.Net.WebUtility.HtmlEncode(raw);
        var lang = GuessCodeLang(raw);
        var langTag = lang is null ? "" : $" runtrace-code language-{lang}";
        var codeOpen = lang is null ? "" : $"<code class='language-{lang}'>";
        var codeClose = lang is null ? "" : "</code>";
        var sb = new System.Text.StringBuilder();
        sb.Append($"<div class='runtrace-blob' data-truncated='{(raw.Length > RowBlobCap ? "true" : "false")}'>");
        if (lang is not null)
        {
            // Icon beside the language tag so SQL / JSON code blocks are identifiable
            // at a glance without reading the label.
            var langIcon = lang == "sql" ? "bi-database" : lang == "json" ? "bi-braces" : "bi-code-slash";
            sb.Append($"<span class='runtrace-code-lang'><i class='bi {langIcon}'></i> {lang}</span>");
        }
        sb.Append($"<pre class='runtrace-blob-pre{langTag}'>{codeOpen}{encoded}{codeClose}</pre>");
        if (raw.Length > RowBlobCap)
        {
            sb.Append($"<button type='button' class='runtrace-blob-toggle' onclick=\"(function(b){{var p=b.parentElement;var on=p.getAttribute('data-truncated')==='true';p.setAttribute('data-truncated',on?'false':'true');b.textContent=on?'Show less':'Show full ({raw.Length:N0} chars)';}})(this)\">Show full ({raw.Length:N0} chars)</button>");
        }
        sb.Append("</div>");
        return sb.ToString();
    };

    var tokensSum = (Model.PromptTokens ?? 0) + (Model.CompletionTokens ?? 0);
    var isLlm = tokensSum > 0 || !string.IsNullOrEmpty(Model.LlmModelUsed);
    var payload = TryParsePayload(Model.TechnicalData);
}

@* ── Where & when — layer / location / wall-clock window / elapsed ─────── *@
<div class="runtrace-section">
    <div class="runtrace-section-label"><i class="bi bi-geo-alt"></i> Where &amp; when</div>
    <div class="runtrace-facts-grid">
        <div><span class="runtrace-k">Layer</span><span class="runtrace-v">@Model.Layer</span></div>
        <div><span class="runtrace-k">Location</span><span class="runtrace-v">@(string.IsNullOrWhiteSpace(Model.Location) ? "—" : Model.Location)</span></div>
        <div><span class="runtrace-k">Status</span><span class="runtrace-v">@Model.Status</span></div>
        <div><span class="runtrace-k">Started</span><span class="runtrace-v">@Model.StartedAt.ToLocalTime().ToString("HH:mm:ss.fff")</span></div>
        <div><span class="runtrace-k">Completed</span><span class="runtrace-v">@(Model.CompletedAt?.ToLocalTime().ToString("HH:mm:ss.fff") ?? "—")</span></div>
        <div><span class="runtrace-k">Elapsed</span><span class="runtrace-v"><i class="bi bi-stopwatch me-1 text-muted"></i>@FormatMs(Model.ElapsedMs)</span></div>
    </div>
</div>

@* ── LLM call breakdown (LLM steps only) ──────────────────────────────── *@
@if (isLlm && (tokensSum > 0 || !string.IsNullOrEmpty(Model.LlmModelUsed)))
{
    <div class="runtrace-section">
        <div class="runtrace-section-label"><i class="bi bi-cpu"></i> LLM call</div>
        <div class="runtrace-llm-grid">
            <div><span class="runtrace-k">Model</span><span class="runtrace-v">@(Model.LlmModelUsed ?? "—")</span></div>
            <div><span class="runtrace-k">Prompt</span><span class="runtrace-v">@($"{(Model.PromptTokens ?? 0):N0}") tok</span></div>
            <div><span class="runtrace-k">Completion</span><span class="runtrace-v">@($"{(Model.CompletionTokens ?? 0):N0}") tok</span></div>
            <div><span class="runtrace-k">Total tokens</span><span class="runtrace-v">@($"{tokensSum:N0}")</span></div>
            <div><span class="runtrace-k">Cost</span><span class="runtrace-v">@CostString(Model.EstimatedCostUsd)</span></div>
            <div><span class="runtrace-k">Elapsed</span><span class="runtrace-v"><i class="bi bi-stopwatch me-1 text-muted"></i>@FormatMs(Model.ElapsedMs)</span></div>
        </div>
    </div>
}

@* ── Structured payload (StepPayload v1: reason / input / output / details) ── *@
@if (payload.Kind is not null)
{
    @if (!string.IsNullOrEmpty(payload.Reason))
    {
        <div class="runtrace-section">
            <div class="runtrace-section-label"><i class="bi bi-signpost-split"></i> Decision rationale</div>
            <div class="runtrace-desc">@payload.Reason</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(payload.Input))
    {
        @* Blue accent = what went IN (for an LLM step this is the prompt sent to the model). *@
        <div class="runtrace-section runtrace-section-input">
            <div class="runtrace-section-label"><i class="bi bi-box-arrow-in-right"></i> Input</div>
            @Html.Raw(renderRowBlob(payload.Input))
        </div>
    }
    @if (!string.IsNullOrEmpty(payload.Output))
    {
        @* Green accent = what came OUT (for an LLM step this is the model's real reply). *@
        <div class="runtrace-section runtrace-section-output">
            <div class="runtrace-section-label"><i class="bi bi-box-arrow-right"></i> Output</div>
            @Html.Raw(renderRowBlob(payload.Output))
        </div>
    }
    @if (!string.IsNullOrEmpty(payload.DetailsJson))
    {
        <div class="runtrace-section">
            <div class="runtrace-section-label"><i class="bi bi-braces"></i> Details</div>
            @Html.Raw(renderRowBlob(payload.DetailsJson))
        </div>
    }
}
else if (!string.IsNullOrWhiteSpace(Model.TechnicalData))
{
    @* Legacy / non-v1 payload — preserve a raw fallback so older traces aren't blanked. *@
    <div class="runtrace-section">
        <div class="runtrace-section-label"><i class="bi bi-braces"></i> Technical data</div>
        @Html.Raw(renderRowBlob(Model.TechnicalData!))
    </div>
}

@* ── Per-call LLM cards (prompt + response previews, tokens, cost, retry) ── *@
@if (Model.LlmCalls is { Count: > 0 })
{
    <div class="runtrace-section">
        <div class="runtrace-section-label">
            <i class="bi bi-cpu"></i> LLM calls (@Model.LlmCalls.Count)
        </div>
        @foreach (var call in Model.LlmCalls)
        {
            var callOk = call.Success;
            var callTokens = (call.PromptTokens ?? 0) + (call.CompletionTokens ?? 0);
            // Prefer the FULL text (eval/assessment runs) and fall back to the preview (normal chat).
            var promptText = string.IsNullOrEmpty(call.PromptFull) ? call.PromptPreview : call.PromptFull;
            var responseText = string.IsNullOrEmpty(call.ResponseFull) ? call.ResponsePreview : call.ResponseFull;
            var promptIsFull = !string.IsNullOrEmpty(call.PromptFull);
            var responseIsFull = !string.IsNullOrEmpty(call.ResponseFull);
            var isEmbedding = string.Equals(call.Kind, "embedding", StringComparison.OrdinalIgnoreCase);
            <div class="runtrace-llm-call @(callOk ? "" : "failed")">
                <div class="runtrace-llm-call-head">
                    <span class="runtrace-llm-stage">
                        <i class="bi @(callOk ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger")"></i>
                        @call.Stage
                        @if (call.RetryAttempt > 0)
                        {
                            <span class="runtrace-meta-chip small warn">retry @call.RetryAttempt</span>
                        }
                    </span>
                    @if (isEmbedding)
                    {
                        <span class="runtrace-meta-chip small muted" title="vector embedding call (bge-m3) — no readable output"><i class="bi bi-vector-pen"></i> embedding</span>
                    }
                    @if (!string.IsNullOrEmpty(call.Provider))
                    {
                        <span class="runtrace-meta-chip small muted" title="provider">@call.Provider</span>
                    }
                    @if (!string.IsNullOrEmpty(call.Model))
                    {
                        <span class="runtrace-meta-chip small muted" title="model">@call.Model</span>
                    }
                    @if (callTokens > 0)
                    {
                        <span class="runtrace-meta-chip small"><i class="bi bi-hash"></i>@($"{call.PromptTokens:N0}+{call.CompletionTokens:N0}")</span>
                    }
                    @if (call.EstimatedCostUsd is { } cc)
                    {
                        <span class="runtrace-meta-chip small @(cc == 0 ? "free" : "")"><i class="bi bi-currency-dollar"></i>@CostString(cc)</span>
                    }
                    <span class="runtrace-meta-chip small @(call.ElapsedMs > 5000 ? "slow" : "muted")">
                        <i class="bi bi-stopwatch"></i>@FormatMs(call.ElapsedMs)
                    </span>
                </div>
                @if (!callOk && !string.IsNullOrEmpty(call.Error))
                {
                    <div class="runtrace-llm-error">
                        <i class="bi bi-exclamation-octagon"></i>
                        @call.Error
                    </div>
                }
                @if (!string.IsNullOrEmpty(promptText))
                {
                    var promptLang = GuessCodeLang(promptText);
                    var shownLen = promptText!.Length;
                    <details class="runtrace-llm-detail runtrace-llm-detail-prompt">
                        <summary>
                            <i class="bi bi-box-arrow-in-right"></i> @(isEmbedding ? "Text embedded" : "Prompt") <span class="runtrace-io-note">— @(isEmbedding ? "input to the embedder" : "sent to model")</span>
                            @if (promptIsFull)
                            {
                                <span class="runtrace-meta-chip small free">full · @($"{shownLen:N0}") chars</span>
                            }
                            else if (call.PromptFullLength is { } pl && pl > shownLen)
                            {
                                <span class="runtrace-meta-chip small muted">preview @($"{shownLen:N0}/{pl:N0}")</span>
                            }
                        </summary>
                        @if (promptLang is not null)
                        {
                            <pre class="runtrace-blob-pre runtrace-code language-@promptLang"><code class="language-@promptLang">@promptText</code></pre>
                        }
                        else
                        {
                            <pre class="runtrace-blob-pre">@promptText</pre>
                        }
                    </details>
                }
                @if (!string.IsNullOrEmpty(responseText))
                {
                    var respLang = GuessCodeLang(responseText);
                    var shownRLen = responseText!.Length;
                    <details class="runtrace-llm-detail runtrace-llm-detail-response">
                        <summary>
                            <i class="bi bi-box-arrow-right"></i> @(isEmbedding ? "Vector" : "Response") <span class="runtrace-io-note">— @(isEmbedding ? "embedding result" : "real reply from model")</span>
                            @if (responseIsFull)
                            {
                                <span class="runtrace-meta-chip small free">full · @($"{shownRLen:N0}") chars</span>
                            }
                            else if (call.ResponseFullLength is { } rl && rl > shownRLen)
                            {
                                <span class="runtrace-meta-chip small muted">preview @($"{shownRLen:N0}/{rl:N0}")</span>
                            }
                        </summary>
                        @if (respLang is not null)
                        {
                            <pre class="runtrace-blob-pre runtrace-code language-@respLang"><code class="language-@respLang">@responseText</code></pre>
                        }
                        else
                        {
                            <pre class="runtrace-blob-pre">@responseText</pre>
                        }
                    </details>
                }
            </div>
        }
    </div>
}

@* ── SpecRepair phase diagnostics ──────────────────────────────────────── *@
@if (Model.PhaseDiagnostics is { Count: > 0 })
{
    <div class="runtrace-section">
        <div class="runtrace-section-label">
            <i class="bi bi-magic"></i> Auto-fix phases (@Model.PhaseDiagnostics.Count)
        </div>
        <ul class="runtrace-phase-list">
            @foreach (var diag in Model.PhaseDiagnostics)
            {
                <li class="runtrace-phase-row @(diag.IsWarning ? "warn" : "ok")">
                    <i class="bi @(diag.IsWarning ? "bi-exclamation-triangle-fill text-warning" : "bi-check2-circle text-success")"></i>
                    <strong>@diag.PhaseName</strong>
                    <span class="runtrace-phase-detail">@diag.Detail</span>
                </li>
            }
        </ul>
    </div>
}

@* ── Routing decisions (winner + scored alternatives) ───────────────────── *@
@if (Model.Decisions is { Count: > 0 })
{
    <div class="runtrace-section">
        <div class="runtrace-section-label">
            <i class="bi bi-signpost-split"></i> Decisions (@Model.Decisions.Count)
        </div>
        @foreach (var dec in Model.Decisions)
        {
            <div class="runtrace-decision">
                <div class="runtrace-decision-head">
                    <span class="runtrace-meta-chip">@dec.DecisionType</span>
                    <span class="runtrace-decision-winner">
                        <i class="bi bi-trophy-fill text-warning"></i>
                        <strong>@dec.WinnerName</strong>
                        @if (dec.WinnerScore is { } ws)
                        {
                            <span class="runtrace-meta-chip small">@ws.ToString("0.000")</span>
                        }
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(dec.Reason))
                {
                    <div class="runtrace-decision-reason">@dec.Reason</div>
                }
                @if (dec.Alternatives is { Count: > 0 })
                {
                    <ol class="runtrace-decision-alts">
                        @foreach (var alt in dec.Alternatives)
                        {
                            <li>
                                <span>@alt.Name</span>
                                @if (alt.Score is { } s)
                                {
                                    <span class="runtrace-meta-chip small muted">@s.ToString("0.000")</span>
                                }
                                @if (!string.IsNullOrEmpty(alt.Note))
                                {
                                    <span class="text-muted ms-1">— @alt.Note</span>
                                }
                            </li>
                        }
                    </ol>
                }
            </div>
        }
    </div>
}

@* ── Sub-steps — each rendered as a card whose body recurses into THIS
     partial, so a sub-step gets the exact same full metadata treatment
     (Where & when, LLM grid, payload, LlmCalls, Decisions, PhaseDiagnostics,
     and its own deeper sub-steps). *@
@if (Model.SubSteps is { Count: > 0 })
{
    <div class="runtrace-section">
        <div class="runtrace-section-label"><i class="bi bi-diagram-2"></i> Sub-steps (@Model.SubSteps.Count)</div>
        <ol class="runtrace-row-substeps">
            @foreach (var sub in Model.SubSteps)
            {
                var subOk = sub.Status == CopilotStepStatus.Ok;
                var subTokens = (sub.PromptTokens ?? 0) + (sub.CompletionTokens ?? 0);
                <li class="runtrace-substep @(subOk ? "ok" : "err")">
                    <div class="runtrace-substep-row">
                        <i class="bi @StatusIcon(sub.Status).Split(' ')[0]"></i>
                        <span class="runtrace-substep-name">@sub.Action</span>
                        @if (!string.IsNullOrWhiteSpace(sub.Detail))
                        {
                            <span class="runtrace-substep-detail">— @sub.Detail</span>
                        }
                        @if (!string.IsNullOrEmpty(sub.LlmModelUsed))
                        {
                            <span class="runtrace-meta-chip small muted" title="model used">@sub.LlmModelUsed</span>
                        }
                        @if (subTokens > 0)
                        {
                            <span class="runtrace-meta-chip small"><i class="bi bi-hash"></i>@($"{subTokens:N0} tok")</span>
                        }
                        @if (sub.EstimatedCostUsd is { } subCost)
                        {
                            <span class="runtrace-meta-chip small @(subCost == 0 ? "free" : "")"><i class="bi bi-currency-dollar"></i>@CostString(subCost)</span>
                        }
                        <span class="runtrace-substep-time">@FormatMs(sub.ElapsedMs)</span>
                    </div>
                    <div class="runtrace-substep-body">
                        <partial name="_InvestigationStepMeta" model="sub" />
                    </div>
                </li>
            }
        </ol>
    </div>
}
