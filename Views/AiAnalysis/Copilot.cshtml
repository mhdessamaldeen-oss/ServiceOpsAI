    function _applyLensToLast(lensId, btn) {
        const lens = _readCopilotLenses().find(l => l.id === lensId);
        const lastPanel = document.querySelector('#copilot-thread .copilot-message-assistant:last-of-type .copilot-chart-panel');
        if (!lens || !lastPanel) { _showCopilotToast('No recent chart to apply the lens to.', 'error'); return; }
        applyCopilotLens(lastPanel, lens);
        btn.closest('.copilot-pin-modal-backdrop')?.remove();
        _showCopilotToast(`Applied lens "${lens.name}".`, 'success');
