    // ── ▶ Replay mode — animate the conversation step by step
    function replayCopilotConversation(menuBtn) {
        document.getElementById('copilot-lab-menu')?.setAttribute('hidden', '');
        const msgs = Array.from(document.querySelectorAll('#copilot-thread .copilot-message'));
        if (msgs.length === 0) { _showCopilotToast('No conversation to replay yet.', 'info'); return; }
        // Hide all, then reveal one at a time with a smooth scroll.
        msgs.forEach(m => { m.dataset.replayPrevDisplay = m.style.display; m.style.display = 'none'; });
        _showCopilotToast(`Replaying ${msgs.length} message${msgs.length === 1 ? '' : 's'}…`, 'info');
        const delayPerStep = 1200;
        msgs.forEach((m, i) => {
            setTimeout(() => {
                m.style.display = m.dataset.replayPrevDisplay || '';
                m.scrollIntoView({ behavior: 'smooth', block: 'center' });
                if (i === msgs.length - 1) {
                    setTimeout(() => msgs.forEach(x => delete x.dataset.replayPrevDisplay), 500);
                }
            }, i * delayPerStep);
        });
    }

    // ── 🧩 Saved lenses — chart preset library (type + label + measure + threshold + flags)
    function _readCopilotLenses() {
        try { return JSON.parse(localStorage.getItem('copilot-saved-lenses') || '[]'); }
        catch { return []; }
    }
    function _writeCopilotLenses(lenses) {
        try { localStorage.setItem('copilot-saved-lenses', JSON.stringify(lenses)); return true; }
        catch (e) { console.error('[Lens] write failed', e); return false; }
    }
    function saveCopilotLensFromPanel(panelOrBtn) {
        const panel = panelOrBtn.closest?.('.copilot-chart-panel') || panelOrBtn;
        if (!panel) { _showCopilotToast('Open a chart first, then save it as a lens.', 'error'); return; }
        const name = prompt('Name this lens (e.g. "Time-series with target"):');
        if (!name || !name.trim()) return;
        const lens = {
            id: 'lens-' + Date.now(),
            name: name.trim(),
            savedAt: new Date().toISOString(),
            chartType: panel.querySelector('select.copilot-chart-type')?.value || 'bar',
            sortByValue: panel.dataset.sortByValue === '1',
            dataLabels: panel.dataset.dataLabels === '1',
            cbPalette: panel.dataset.cbPalette === '1',
            smoothing: panel.dataset.smoothing === '1',
            logScale: panel.dataset.logScale === '1',
            trendLine: panel.dataset.trendLine === '1',
            movingAvg: panel.dataset.movingAvg === '1',
            threshold: panel.dataset.threshold || ''
        };
        const lenses = _readCopilotLenses();
        lenses.unshift(lens);
        if (lenses.length > 30) lenses.length = 30;
        if (!_writeCopilotLenses(lenses)) { _showCopilotToast('Save failed — localStorage blocked.', 'error'); return; }
        _showCopilotToast(`Saved lens "${lens.name}" · ${lenses.length} total. Apply via Lab ▾ → My saved lenses.`, 'success');
    }
    function applyCopilotLens(panel, lens) {
        if (!panel || !lens) return;
        const setSel = (cls, v) => { const s = panel.querySelector(`select.${cls}`); if (s) s.value = v; };
        setSel('copilot-chart-type', lens.chartType);
        ['sortByValue', 'dataLabels', 'cbPalette', 'smoothing', 'logScale', 'trendLine', 'movingAvg'].forEach(k => {
            panel.dataset[k] = lens[k] ? '1' : '';
            // Flip the matching toggle button's is-active state.
            const btn = panel.querySelector(`button[onclick*="'${k}'"]`);
            if (btn) btn.classList.toggle('is-active', !!lens[k]);
        });
        const ti = panel.querySelector('input.copilot-chart-threshold');
        if (ti) ti.value = lens.threshold || '';
        panel.dataset.threshold = lens.threshold || '';
        renderCopilotChart(panel);
    }
    function openCopilotLensLibrary(menuBtn) {
        document.getElementById('copilot-lab-menu')?.setAttribute('hidden', '');
        const lenses = _readCopilotLenses();
        const wrap = document.createElement('div');
        wrap.className = 'copilot-pin-modal-backdrop';
        wrap.addEventListener('click', e => { if (e.target === wrap) wrap.remove(); });
        const list = lenses.length === 0
            ? '<div class="text-muted text-center py-4">No saved lenses yet.<br><span class="small">Open any chart, configure type/labels/threshold/palette, then choose Tools ▾ → Save as lens.</span></div>'
            : `<div class="copilot-lens-grid">${lenses.map(l => `
                <div class="copilot-lens-card">
                    <div class="copilot-lens-card-name">${escapeHtml(l.name)}</div>
                    <div class="copilot-lens-card-meta">${escapeHtml(l.chartType)} · ${[l.sortByValue && 'sort', l.dataLabels && 'labels', l.cbPalette && 'cb-palette', l.logScale && 'log', l.trendLine && 'trend', l.movingAvg && 'MA', l.threshold && ('target=' + l.threshold)].filter(Boolean).join(' · ') || 'plain'}</div>
                    <div class="copilot-lens-card-actions">
                        <button class="btn btn-sm btn-outline-primary" onclick="_applyLensToLast('${l.id}', this)"><i class="bi bi-eye me-1"></i>Apply to last chart</button>
                        <button class="btn btn-sm btn-outline-danger" onclick="_removeLens('${l.id}', this)"><i class="bi bi-trash"></i></button>
                    </div>
