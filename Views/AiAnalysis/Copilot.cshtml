        wrap.innerHTML = `
            <div class="copilot-pin-modal" style="max-width: 56rem;">
                <div class="copilot-pin-modal-header">
                    <div><i class="bi bi-eyeglasses text-success"></i> <strong>My saved lenses</strong>
                        <span class="text-muted ms-2">${lenses.length} saved</span></div>
                    <button class="btn btn-sm btn-outline-secondary" onclick="this.closest('.copilot-pin-modal-backdrop').remove()">Close</button>
                </div>
