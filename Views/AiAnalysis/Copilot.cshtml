    // ── 📰 Auto-narrative — turn the whole conversation into an analyst report
    async function generateCopilotNarrative(menuBtn) {
        document.getElementById('copilot-lab-menu')?.setAttribute('hidden', '');
        const assistantTables = [];
        document.querySelectorAll('.copilot-message-assistant').forEach(msg => {
            const idx = parseInt(msg.dataset.msgIdx, 10);
            const userQ = !isNaN(idx) && idx > 0 ? (copilotHistory[idx - 1]?.content || '') : '';
            msg.querySelectorAll('table.copilot-inline-table').forEach(table => {
                const headers = Array.from(table.querySelectorAll('thead tr:first-child th')).map(th => th.textContent.trim());
                const rows = Array.from(table.querySelectorAll('tbody tr')).slice(0, 50).map(tr =>
                    Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim()));
                assistantTables.push({ question: userQ, columns: headers, rows });
            });
        });
        if (assistantTables.length === 0) {
            _showCopilotToast('Nothing to narrate yet — ask a question first.', 'info');
            return;
        }
        _showCopilotToast('Writing your narrative…', 'info');
        // Reuse the existing Explain endpoint but pass a combined "investigation" payload.
        // Server sees one (question + columns + rows) — so we stitch them into a synthetic
        // question that includes prior Q+A pairs as context.
        const synthQuestion = 'Write a tight analyst narrative based on the following investigation. Use the data verbatim — do not invent numbers. Structure: TL;DR (1 sentence) · Key findings (3-5 bullets) · Caveats (1-2 lines). Investigation: ' +
            assistantTables.map((t, i) => `Q${i+1}: ${t.question}\nResult: ${t.columns.join(' | ')}\n${t.rows.slice(0, 10).map(r => r.join(' | ')).join('\n')}${t.rows.length > 10 ? `\n... (+${t.rows.length - 10} more rows)` : ''}`).join('\n\n');
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const last = assistantTables[assistantTables.length - 1];
            const res = await fetch('@Url.Action("ExplainResult", "AiAnalysis")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ question: synthQuestion, columns: last.columns, rows: last.rows.slice(0, 30) }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data?.message || 'Narrative failed');
            _showCopilotNarrativeModal(data.explanation || '(no narrative returned)', assistantTables.length);
        } catch (e) {
            _showCopilotToast(`Narrative failed: ${e.message || e}`, 'error');
        }
    }
    function _showCopilotNarrativeModal(text, sourceCount) {
        const wrap = document.createElement('div');
        wrap.className = 'copilot-pin-modal-backdrop';
        wrap.addEventListener('click', e => { if (e.target === wrap) wrap.remove(); });
        wrap.innerHTML = `
            <div class="copilot-pin-modal copilot-trust-modal" style="max-width: 48rem;">
                <div class="copilot-pin-modal-header">
                    <div><i class="bi bi-file-earmark-text text-success"></i> <strong>Analyst narrative</strong>
                        <span class="text-muted ms-2">from ${sourceCount} table${sourceCount === 1 ? '' : 's'} in this conversation</span></div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="(function(b){navigator.clipboard?.writeText(b.dataset.text); const i=b.querySelector('i'); const p=i.className; i.className='bi bi-check2'; setTimeout(()=>i.className=p,1200);})(this)" data-text="${escapeHtml(text)}"><i class="bi bi-clipboard me-1"></i>Copy</button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="this.closest('.copilot-pin-modal-backdrop').remove()">Close</button>
                    </div>
                </div>
