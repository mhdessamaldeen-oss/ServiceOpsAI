    function _removeLens(lensId, btn) {
        const lenses = _readCopilotLenses().filter(l => l.id !== lensId);
        _writeCopilotLenses(lenses);
        const card = btn.closest('.copilot-lens-card');
        card?.remove();
        _showCopilotToast('Lens removed.', 'info');
