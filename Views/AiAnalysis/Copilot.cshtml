    // ── 🔁 Auto-promote suggester — tracks question frequency and surfaces a
    // suggestion banner above the composer once a question crosses the threshold.
    function _autoPromoteTrack(question) {
        if (!question || !question.trim()) return;
        const key = 'copilot-question-frequency';
        let map;
        try { map = JSON.parse(localStorage.getItem(key) || '{}'); }
        catch { map = {}; }
        const norm = question.trim().toLowerCase().replace(/[^\w\s]/g, '').replace(/\s+/g, ' ');
        map[norm] = (map[norm] || 0) + 1;
        try { localStorage.setItem(key, JSON.stringify(map)); } catch {}
        if (map[norm] >= 3) _maybeShowAutoPromoteBanner(question.trim(), map[norm]);
    }
    function _maybeShowAutoPromoteBanner(question, count) {
        if (document.getElementById('copilot-autopromote-banner')) return; // one at a time
        const banner = document.createElement('div');
        banner.id = 'copilot-autopromote-banner';
        banner.className = 'copilot-autopromote-banner';
        banner.innerHTML = `
            <i class="bi bi-shield-check"></i>
            <span>You've asked <strong>"${escapeHtml(question.length > 60 ? question.slice(0, 60) + '…' : question)}"</strong> ${count} times. Promote a verified answer to the <strong>Trusted Query</strong> store to make it sub-second for everyone.</span>
            <button class="btn btn-sm btn-success" onclick="(function(b){const sql=document.querySelector('.copilot-message-assistant:last-of-type .copilot-trust-btn'); sql?.click(); b.parentElement.remove();})(this)"><i class="bi bi-shield-fill-check me-1"></i>Promote now</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>`;
        const composer = document.querySelector('.copilot-composer');
        composer?.parentElement?.insertBefore(banner, composer);
    }

    // Shared toast helper — visible top-center notification, auto-dismisses.
    // Used by Pin / Trust / Save lens / etc. when the side-effects aren't
    // immediately obvious from the button itself.
    function _showCopilotToast(message, kind = 'success') {
        document.getElementById('copilot-toast')?.remove();
        const toast = document.createElement('div');
        toast.id = 'copilot-toast';
        toast.className = `copilot-toast copilot-toast-${kind}`;
        const icon = kind === 'error' ? 'bi-exclamation-triangle-fill'
                   : kind === 'info'  ? 'bi-info-circle-fill'
                                       : 'bi-check-circle-fill';
        toast.innerHTML = `<i class="bi ${icon}"></i> <span>${escapeHtml(message)}</span>`;
        document.body.appendChild(toast);
        requestAnimationFrame(() => toast.classList.add('is-shown'));
        setTimeout(() => { toast.classList.remove('is-shown'); setTimeout(() => toast.remove(), 300); }, 4500);
    }

    function pinCopilotChart(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        const bubble = btn.closest('.copilot-message-assistant');
        if (!table) {
            _showCopilotToast('Pin failed — no table found to capture.', 'error');
            return;
        }
        let question = '';
        if (bubble) {
            let n = bubble.previousElementSibling;
            while (n && !n.classList.contains('copilot-message-user')) n = n.previousElementSibling;
            if (n) question = (n.querySelector('.copilot-message-body')?.textContent || n.textContent || '').trim();
        }
        if (!question) question = ([...copilotHistory].reverse().find(m => m.role === 'user' && !m.isQueued))?.content || '(unnamed)';
        const columns = Array.from(table.querySelectorAll('thead tr:first-child th')).map(th => th.textContent.trim());
        const rows = Array.from(table.querySelectorAll('tbody tr')).map(tr =>
            Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim()));
        const panel = wrap.querySelector('.copilot-chart-panel');
        const chartType = panel?.querySelector('.copilot-chart-type')?.value || 'table';

        const pins = readCopilotPins();
        pins.unshift({
            id: 'pin-' + Date.now(),
            pinnedAt: new Date().toISOString(),
            question, columns, rows, chartType,
        });
        // Cap at 30 to keep localStorage manageable; drop the oldest beyond that.
        if (pins.length > 30) pins.length = 30;
        const ok = writeCopilotPins(pins);
        if (!ok) {
            // Surface the failure visibly — silent failures were the user-reported "Pin
            // changes color then nothing happens" bug.
            _showCopilotToast('Pin failed — browser blocked localStorage (incognito / private mode?). Open DevTools console for details.', 'error');
            console.error('[Pin] writeCopilotPins returned false — localStorage unavailable or full.');
            return;
        }
        btn.classList.add('is-active');
        btn.innerHTML = '<i class="bi bi-pin-angle-fill me-1"></i>Pinned';
        setTimeout(() => { btn.classList.remove('is-active'); btn.innerHTML = '<i class="bi bi-pin-angle me-1"></i>Pin'; }, 1800);
        refreshCopilotPinButton();
        // Confirm in two ways: a toast (always visible) AND the floating FAB
        // (in case z-index/positioning hides one or the other on a given theme).
        _showCopilotToast(`Pinned · ${pins.length} chart${pins.length === 1 ? '' : 's'} saved. Click the floating pin (bottom-right) to open dashboard.`, 'success');
        console.log('[Pin] OK. Total pins now:', pins.length, '· FAB element:', document.getElementById('copilot-pin-fab'));
    }

    function readCopilotPins() {
        try { return JSON.parse(localStorage.getItem('copilot-pinned-charts') || '[]'); }
        catch (e) { console.warn('[Pin] readCopilotPins failed:', e); return []; }
    }
    function writeCopilotPins(pins) {
        try {
            localStorage.setItem('copilot-pinned-charts', JSON.stringify(pins));
            return true;
        } catch (e) {
            console.error('[Pin] writeCopilotPins failed:', e);
            return false;
        }
    }

    // ────────────────────────────────────────────────────────────────────────
    // Group-by — reflow tbody into group-header rows + member rows. Each header
    // shows the group value, member count, and per-column subtotals (numeric).
    // Click the header to collapse / expand. Passing colIdx = -1 ungroups.
    // ────────────────────────────────────────────────────────────────────────
    function copilotTableGroupBy(menuItem, colIdx) {
        const wrap = menuItem.closest('.copilot-inline-table-wrap');
        const tbody = wrap?.querySelector('table.copilot-inline-table tbody');
        if (!tbody) return;
        // Auto-close the dropdown after a click.
        document.querySelectorAll('.copilot-export-menu').forEach(m => m.setAttribute('hidden', ''));

        // Strip any existing group headers + member flags. Restore original
        // row order (each tr was stamped with data-orig-idx on first group).
        tbody.querySelectorAll('tr.copilot-group-header').forEach(el => el.remove());
        tbody.querySelectorAll('tr').forEach(tr => {
            tr.classList.remove('copilot-group-member', 'copilot-group-collapsed');
            delete tr.dataset.groupKey;
        });

        if (colIdx < 0) {
            // Ungroup → restore original order.
            const rows = Array.from(tbody.querySelectorAll('tr'));
            rows.forEach((r, i) => { if (!r.dataset.origIdx) r.dataset.origIdx = String(i); });
            rows.sort((a, b) => parseInt(a.dataset.origIdx, 10) - parseInt(b.dataset.origIdx, 10));
            rows.forEach(r => tbody.appendChild(r));
            delete wrap.dataset.groupByCol;
            _copilotTableRenderPage(wrap);
            return;
        }

        wrap.dataset.groupByCol = String(colIdx);
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.forEach((r, i) => { if (!r.dataset.origIdx) r.dataset.origIdx = String(i); });
        // Sort rows by the group-by column's text so members cluster.
        rows.sort((a, b) => {
            const av = (a.children[colIdx]?.textContent || '').trim();
            const bv = (b.children[colIdx]?.textContent || '').trim();
            return av.localeCompare(bv, undefined, { numeric: true, sensitivity: 'base' });
        });

        // Identify numeric columns for subtotal computation.
        const table = wrap.querySelector('table.copilot-inline-table');
        const ths = table.querySelectorAll('thead tr:first-child th');
        const numericCols = [];
        ths.forEach((th, i) => { if (th.classList.contains('copilot-th-kind-numeric')) numericCols.push(i); });

        // Group by value → list of rows. Stable insertion order (already sorted).
        const groups = new Map();
        rows.forEach(r => {
            const v = (r.children[colIdx]?.textContent || '(empty)').trim() || '(empty)';
            if (!groups.has(v)) groups.set(v, []);
            groups.get(v).push(r);
        });

        const fragment = document.createDocumentFragment();
        const colCount = rows[0]?.children.length || ths.length;
        let groupIdx = 0;
        groups.forEach((members, key) => {
            const headerTr = document.createElement('tr');
            headerTr.className = 'copilot-group-header';
            headerTr.dataset.groupKey = key;
            // Build cells: group label + subtotals in numeric columns. Other
            // cells are empty so the layout stays in sync with the body grid.
            const cells = [];
            for (let i = 0; i < colCount; i++) {
                if (i === colIdx) {
                    cells.push(`<td class="copilot-group-label"><i class="bi bi-chevron-down copilot-group-chevron"></i> <strong>${escapeHtml(key)}</strong> <span class="copilot-group-count">${members.length}</span></td>`);
                } else if (numericCols.includes(i)) {
                    const sum = members.reduce((s, m) => {
                        const n = Number((m.children[i]?.textContent || '0').replace(/,/g, ''));
                        return s + (isNaN(n) ? 0 : n);
                    }, 0);
                    cells.push(`<td class="copilot-group-subtotal">Σ ${sum.toLocaleString()}</td>`);
                } else {
                    cells.push('<td></td>');
                }
            }
            headerTr.innerHTML = cells.join('');
            headerTr.addEventListener('click', () => copilotTableToggleGroup(headerTr));
            fragment.appendChild(headerTr);
            members.forEach(m => {
                m.classList.add('copilot-group-member');
                m.dataset.groupKey = key;
                fragment.appendChild(m);
            });
            groupIdx++;
        });
        // Atomic replace — single reflow.
        tbody.innerHTML = '';
        tbody.appendChild(fragment);
        // Pager runs over visible rows; recompute so the group-header rows are
        // counted in but member rows pre-paged.
        _copilotTableRenderPage(wrap);
    }

    function copilotTableToggleGroup(headerTr) {
        const key = headerTr.dataset.groupKey;
        const tbody = headerTr.parentElement;
        const collapsed = headerTr.classList.toggle('copilot-group-collapsed');
        // Toggle the chevron rotation.
        const chev = headerTr.querySelector('.copilot-group-chevron');
        if (chev) chev.className = collapsed
            ? 'bi bi-chevron-right copilot-group-chevron'
            : 'bi bi-chevron-down copilot-group-chevron';
        tbody.querySelectorAll(`tr.copilot-group-member[data-group-key="${CSS.escape(key)}"]`).forEach(tr => {
            tr.classList.toggle('copilot-group-collapsed', collapsed);
        });
    }

    // ────────────────────────────────────────────────────────────────────────
    // Pivot — transpose rows ↔ columns. First column of original becomes
    // header row; original headers become first-column labels. Toggle. While
    // pivoted, most other table ops (sort, filter, group) don't make sense
    // and are stripped from view. Click again to restore.
    // ────────────────────────────────────────────────────────────────────────
    function toggleCopilotPivot(menuItem) {
        const wrap = menuItem.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        document.querySelectorAll('.copilot-export-menu').forEach(m => m.setAttribute('hidden', ''));

        const isPivoted = wrap.dataset.pivoted === '1';
        if (isPivoted) {
            // Restore the cached original.
            const original = wrap._originalTableHtml;
            if (original) {
                table.innerHTML = original;
                delete wrap._originalTableHtml;
            }
            delete wrap.dataset.pivoted;
            return;
        }

        // Cache original, then build a transposed table.
        wrap._originalTableHtml = table.innerHTML;
        const origThs = Array.from(table.querySelectorAll('thead tr:first-child th'));
        const origRows = Array.from(table.querySelectorAll('tbody tr'));
        if (origRows.length === 0 || origThs.length < 2) {
            alert('Pivot needs at least 2 columns and 1 row.');
            return;
        }
        // First original column becomes the new header row's labels.
        const labelColCells = origRows.map(r => (r.children[0]?.textContent || '').trim());
        // New thead: first cell = original first header (label-of-labels), then
        // one cell per original row using its label-col value as the new header.
        const newThead = document.createElement('thead');
        const newHeaderTr = document.createElement('tr');
        const firstHeaderLabel = (origThs[0].querySelector('.copilot-th-label')?.textContent || origThs[0].textContent || '').trim();
        newHeaderTr.innerHTML = `<th class="copilot-th-sortable copilot-th-kind-text"><i class="bi bi-fonts copilot-th-type-icon"></i><span class="copilot-th-label">${escapeHtml(firstHeaderLabel)}</span></th>` +
            labelColCells.map(v => `<th class="copilot-th-sortable copilot-th-kind-text"><i class="bi bi-fonts copilot-th-type-icon"></i><span class="copilot-th-label">${escapeHtml(v)}</span></th>`).join('');
        newThead.appendChild(newHeaderTr);
        // New tbody: one row per original column (skipping col 0). The row's
        // first cell is the original column header; subsequent cells are the
        // values of that column across all original rows.
        const newTbody = document.createElement('tbody');
        for (let ci = 1; ci < origThs.length; ci++) {
            const tr = document.createElement('tr');
            const headerLabel = (origThs[ci].querySelector('.copilot-th-label')?.textContent || origThs[ci].textContent || '').trim();
            const cells = [`<td><strong>${escapeHtml(headerLabel)}</strong></td>`];
            origRows.forEach(r => cells.push(`<td>${escapeHtml((r.children[ci]?.textContent || '').trim())}</td>`));
            tr.innerHTML = cells.join('');
            newTbody.appendChild(tr);
        }
        table.innerHTML = '';
        table.appendChild(newThead);
        table.appendChild(newTbody);
        wrap.dataset.pivoted = '1';
    }

    // ────────────────────────────────────────────────────────────────────────
    // Multi-select + Diff — Ctrl+click (Cmd+click on Mac) on a body row to
    // toggle selection. When 2+ rows are selected, a floating "Diff" button
    // appears that highlights cells differing across the selected rows.
    // ────────────────────────────────────────────────────────────────────────
    document.addEventListener('click', e => {
        const tr = e.target.closest?.('.copilot-inline-table tbody tr');
        if (!tr || tr.classList.contains('copilot-group-header')) return;
        if (!(e.ctrlKey || e.metaKey)) return;
        e.preventDefault();
        e.stopPropagation();
        tr.classList.toggle('copilot-row-selected');
        _refreshCopilotSelectionToolbar(tr.closest('.copilot-inline-table-wrap'));
    }, true);

    function _refreshCopilotSelectionToolbar(wrap) {
        if (!wrap) return;
        const selected = wrap.querySelectorAll('tbody tr.copilot-row-selected');
        let bar = wrap.querySelector('.copilot-selection-toolbar');
        if (selected.length === 0) {
            bar?.remove();
            _copilotClearDiff(wrap);
            return;
        }
        if (!bar) {
            bar = document.createElement('div');
            bar.className = 'copilot-selection-toolbar';
            bar.innerHTML = `
                <span class="copilot-selection-count"><i class="bi bi-check2-square"></i> <span></span> rows selected</span>
                <button type="button" onclick="copilotDiffSelection(this)" title="Highlight cells that differ across selected rows"><i class="bi bi-columns-gap me-1"></i>Diff</button>
                <button type="button" onclick="copilotClearSelection(this)" title="Clear selection"><i class="bi bi-x-lg me-1"></i>Clear</button>`;
            wrap.appendChild(bar);
        }
        bar.querySelector('.copilot-selection-count span').textContent = selected.length;
    }

    function copilotDiffSelection(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const selected = Array.from(wrap.querySelectorAll('tbody tr.copilot-row-selected'));
        if (selected.length < 2) { alert('Select at least 2 rows to diff (Ctrl+click).'); return; }
        _copilotClearDiff(wrap);
        // For each column, check if the value varies across selected rows.
        const ths = wrap.querySelectorAll('table.copilot-inline-table thead tr:first-child th');
        for (let ci = 0; ci < ths.length; ci++) {
            const values = selected.map(tr => (tr.children[ci]?.textContent || '').trim());
            const allSame = values.every(v => v === values[0]);
            if (!allSame) {
                selected.forEach(tr => tr.children[ci]?.classList.add('copilot-cell-diff'));
            }
        }
    }

    function _copilotClearDiff(wrap) {
        wrap?.querySelectorAll('.copilot-cell-diff').forEach(td => td.classList.remove('copilot-cell-diff'));
    }

    function copilotClearSelection(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        wrap?.querySelectorAll('tr.copilot-row-selected').forEach(tr => tr.classList.remove('copilot-row-selected'));
        _refreshCopilotSelectionToolbar(wrap);
    }

    // % of total — for each numeric column, augment every cell with its
    // share of the column sum: "287 (12.3%)". Original text is stashed in
    // dataset.origVal so a second click restores cleanly. Works alongside
    // Heat (which only paints backgrounds, doesn't touch text content).
    function toggleCopilotPctOfTotal(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const on = btn.classList.toggle('is-active');
        if (!on) {
            table.querySelectorAll('tbody td[data-orig-val]').forEach(td => {
                td.textContent = td.dataset.origVal;
                delete td.dataset.origVal;
            });
            return;
        }
        const ths = table.querySelectorAll('thead tr:first-child th');
        ths.forEach((th, colIdx) => {
            if (!th.classList.contains('copilot-th-kind-numeric')) return;
            const cells = Array.from(table.querySelectorAll('tbody tr'))
                .map(tr => tr.children[colIdx]).filter(Boolean);
            const total = cells.reduce((s, td) => {
                const n = Number((td.textContent || '').replace(/,/g, ''));
                return s + (isNaN(n) ? 0 : n);
            }, 0);
            if (total === 0) return;
            cells.forEach(td => {
                const orig = (td.textContent || '').trim();
                const n = Number(orig.replace(/,/g, ''));
                if (isNaN(n)) return;
                td.dataset.origVal = orig;
                const pct = (n / total * 100).toFixed(1);
                td.innerHTML = `${escapeHtml(orig)} <span class="copilot-pct-of-total">(${pct}%)</span>`;
            });
        });
    }

    // Column show/hide — opens the per-column checklist next to the table.
    // Each checkbox toggles the corresponding column's th + every body td at
    // that index by setting `display: none`. Pure DOM, no re-render needed.
    function toggleCopilotColsMenu(btn) {
        const menu = btn.parentElement?.querySelector('.copilot-cols-menu');
        if (!menu) return;
        document.querySelectorAll('.copilot-export-menu').forEach(m => { if (m !== menu) m.setAttribute('hidden', ''); });
        if (menu.hasAttribute('hidden')) menu.removeAttribute('hidden');
        else menu.setAttribute('hidden', '');
    }
    function toggleCopilotColumnVisibility(input) {
        const wrap = input.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const colIdx = parseInt(input.dataset.col, 10);
        const display = input.checked ? '' : 'none';
        // Apply to every row in thead + tbody so the column collapses cleanly.
        table.querySelectorAll('thead tr, tbody tr, tfoot tr').forEach(tr => {
            const cells = tr.children;
            if (cells[colIdx]) cells[colIdx].style.display = display;
        });
    }

    // Toggle the export-format dropdown (CSV / Excel-compatible / JSON).
    function toggleExportMenu(btn) {
        const menu = btn.parentElement.querySelector('.copilot-export-menu');
        if (!menu) return;
        const isHidden = menu.hasAttribute('hidden');
        document.querySelectorAll('.copilot-export-menu').forEach(m => m.setAttribute('hidden', ''));
        if (isHidden) menu.removeAttribute('hidden');
    }
    // Click outside to close any open menu.
    document.addEventListener('click', e => {
        if (!e.target.closest('.copilot-export-dropdown'))
            document.querySelectorAll('.copilot-export-menu').forEach(m => m.setAttribute('hidden', ''));
    });

    // Convert a rendered table to a downloadable file. Three formats:
    //   csv  — RFC-4180 quoting, UTF-8 BOM so Excel opens it right
    //   xlsx — same as csv but with .xls extension; Excel parses CSV-as-Excel happily
    //          (true XLSX would need SheetJS — bigger than the value for this scope)
    //   json — full array-of-objects, key = header
    function exportCopilotTable(btn, format = 'csv') {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const headers = Array.from(table.querySelectorAll('thead tr:first-child th')).map(th => th.textContent.trim());
        const rows = Array.from(table.querySelectorAll('tbody tr')).map(tr =>
            Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim()));
        const stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
        let blob, ext;
        if (format === 'json') {
            const objects = rows.map(r => Object.fromEntries(headers.map((h, i) => [h, r[i] ?? ''])));
            blob = new Blob([JSON.stringify(objects, null, 2)], { type: 'application/json' });
            ext = 'json';
        } else if (format === 'md') {
            // GFM markdown table — paste-ready into GitHub / Slack / Notion / wiki.
            // Pipes and backslashes inside cells are escaped to keep the table intact.
            const mdEsc = v => String(v ?? '').replace(/\\/g, '\\\\').replace(/\|/g, '\\|').replace(/\r?\n/g, '<br>');
            const lines = [];
            lines.push('| ' + headers.map(mdEsc).join(' | ') + ' |');
            lines.push('| ' + headers.map(() => '---').join(' | ') + ' |');
            rows.forEach(r => lines.push('| ' + r.map(mdEsc).join(' | ') + ' |'));
            blob = new Blob([lines.join('\n')], { type: 'text/markdown;charset=utf-8' });
            ext = 'md';
        } else {
            const esc = v => /[",\n\r]/.test(v) ? `"${(v ?? '').replace(/"/g, '""')}"` : (v ?? '');
            const lines = [headers.map(esc).join(',')];
            rows.forEach(r => lines.push(r.map(esc).join(',')));
            blob = new Blob(['﻿', lines.join('\r\n')], { type: 'text/csv;charset=utf-8' });
            ext = format === 'xlsx' ? 'xls' : 'csv';
        }
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `copilot-result-${stamp}.${ext}`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        // Auto-close the dropdown after a click.
        document.querySelectorAll('.copilot-export-menu').forEach(m => m.setAttribute('hidden', ''));
    }

    // Anomaly flag — for each numeric column, mark cells that stand out from the rest.
    // Two detection rules combined so something visible fires on typical business data
    // (which is rarely Gaussian):
    //   1. z-score > 1.5  — mild outlier in the statistical sense
    //   2. col MIN or MAX — when (max - min) / mean > 0.5, the extremes count too
    // Flagged cells get a red 🚩 icon AND the whole row gets a tinted background so the
    // outlier rows pop visually. A status banner above the table always tells the user
    // what happened (flagged N rows / found no outliers), so the click never feels invisible.
    function toggleAnomalyFlag(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const isOn = table.classList.toggle('copilot-table-anomalies');
        // Idempotent teardown so re-toggling works cleanly.
        table.querySelectorAll('.copilot-anomaly-flag').forEach(el => el.remove());
        table.querySelectorAll('tr.copilot-anomaly-row-high, tr.copilot-anomaly-row-low').forEach(tr => {
            tr.classList.remove('copilot-anomaly-row-high', 'copilot-anomaly-row-low');
        });
        wrap.querySelector('.copilot-anomaly-banner')?.remove();
        if (!isOn) { btn.classList.remove('is-active'); return; }
        btn.classList.add('is-active');

        const bodyRows = Array.from(table.querySelectorAll('tbody tr'));
        const headerCells = Array.from(table.querySelectorAll('thead tr:first-child th'));
        let flaggedCount = 0;
        const flaggedDetails = [];
        headerCells.forEach((th, colIdx) => {
            const colName = (th.textContent || '').trim();
            const vals = bodyRows
                .map(tr => Number((tr.querySelectorAll('td')[colIdx]?.textContent || '').trim().replace(/,/g, '')))
                .filter(n => !isNaN(n));
            if (vals.length < 2) return;
            const mean = vals.reduce((a, b) => a + b, 0) / vals.length;
            const variance = vals.reduce((a, b) => a + (b - mean) ** 2, 0) / vals.length;
            const std = Math.sqrt(variance);
            const maxV = Math.max(...vals);
            const minV = Math.min(...vals);
            const spreadVsMean = mean === 0 ? 0 : (maxV - minV) / Math.abs(mean);
            bodyRows.forEach(tr => {
                const td = tr.querySelectorAll('td')[colIdx];
                if (!td) return;
                const n = Number((td.textContent || '').trim().replace(/,/g, ''));
                if (isNaN(n)) return;
                let reason = null, direction = null;
                // Rule 1: statistical outlier (mild — z>1.5).
                if (std > 0) {
                    const z = (n - mean) / std;
                    if (Math.abs(z) > 1.5) {
                        reason = `z = ${z.toFixed(2)}`;
                        direction = z > 0 ? 'high' : 'low';
                    }
                }
                // Rule 2: noticeably above / below mean by percentage. Catches the
                // "obviously high" rows business users expect to see flagged but z-score
                // misses in heavy-tailed distributions. Example: value=67, mean=35,
                // z≈1.36 below the z-threshold, but it IS 88% above the mean → flag.
                if (!reason && mean !== 0) {
                    const pct = (n - mean) / Math.abs(mean);
                    if (Math.abs(pct) > 0.5) {
                        reason = `${(pct * 100).toFixed(0)}% ${pct > 0 ? 'above' : 'below'} mean`;
                        direction = pct > 0 ? 'high' : 'low';
                    }
                }
                // Rule 3: column max / min when the column is spread out. Last-resort
                // catch for cases where neither z nor % deviation tripped.
                if (!reason && spreadVsMean > 0.5 && vals.length >= 3) {
                    if (n === maxV) { reason = `column max`; direction = 'high'; }
                    else if (n === minV) { reason = `column min`; direction = 'low'; }
                }
                if (reason) {
                    const tag = document.createElement('span');
                    tag.className = 'copilot-anomaly-flag';
                    tag.innerHTML = `<i class="bi bi-flag-fill" title="${colName} — ${reason} (${direction})"></i>`;
                    td.appendChild(tag);
                    tr.classList.add(direction === 'high' ? 'copilot-anomaly-row-high' : 'copilot-anomaly-row-low');
                    flaggedCount++;
                    flaggedDetails.push(`${colName} ${direction}`);
                }
            });
        });

        // Always show a status banner — even when no outliers — so the user sees the click did something.
        const banner = document.createElement('div');
        banner.className = 'copilot-anomaly-banner';
        if (flaggedCount === 0) {
            banner.innerHTML = `<i class="bi bi-check-circle me-1 text-success"></i>
                <strong>No outliers detected.</strong> All values stay within 1.5σ of the mean and no column is dominated by a single row.`;
            banner.classList.add('copilot-anomaly-banner-ok');
        } else {
            const summary = [...new Set(flaggedDetails)].slice(0, 5).join(', ');
            banner.innerHTML = `<i class="bi bi-flag-fill me-1 text-danger"></i>
                <strong>${flaggedCount} outlier value${flaggedCount === 1 ? '' : 's'} flagged.</strong>
                Rows tinted <span class="copilot-anomaly-legend high">red (high)</span> /
                <span class="copilot-anomaly-legend low">blue (low)</span>. Hover a 🚩 for the reason. <span class="text-muted">${summary}</span>`;
        }
        const insertBefore = wrap.querySelector('.copilot-inline-table-scroll') || wrap.firstChild;
        wrap.insertBefore(banner, insertBefore);
    }

    // Summary row — append a footer row with sum/avg/min/max per numeric column. Toggle
    // adds/removes the row. Non-numeric columns get an empty cell; the first non-numeric
    // gets a "Summary" label so the row reads cleanly.
    function toggleSummaryRow(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const existing = table.querySelector('tfoot.copilot-summary-row');
        if (existing) { existing.remove(); btn.classList.remove('is-active'); return; }
        btn.classList.add('is-active');
        const headerCells = Array.from(table.querySelectorAll('thead tr:first-child th'));
        const bodyRows = Array.from(table.querySelectorAll('tbody tr')).filter(r => !r.classList.contains('copilot-row-hidden') && !r.classList.contains('copilot-row-filtered-out'));
        let labelPlaced = false;
        const cells = headerCells.map((_, colIdx) => {
            const vals = bodyRows
                .map(tr => Number((tr.querySelectorAll('td')[colIdx]?.textContent || '').trim().replace(/,/g, '')))
                .filter(n => !isNaN(n));
            if (vals.length < 2) {
                const placeholder = !labelPlaced ? '<strong>Summary</strong>' : '';
                if (!labelPlaced) labelPlaced = true;
                return `<td class="text-muted">${placeholder}</td>`;
            }
            const sum = vals.reduce((a, b) => a + b, 0);
            const avg = sum / vals.length;
            const min = Math.min(...vals);
            const max = Math.max(...vals);
            return `<td class="copilot-summary-cell">
                <div class="copilot-summary-stat" title="Sum"><b>Σ</b> ${sum.toLocaleString()}</div>
                <div class="copilot-summary-stat" title="Average"><b>x̄</b> ${(Math.round(avg * 100) / 100).toLocaleString()}</div>
                <div class="copilot-summary-stat" title="Min / Max">${min.toLocaleString()} – ${max.toLocaleString()}</div>
            </td>`;
        });
        const tfoot = document.createElement('tfoot');
        tfoot.className = 'copilot-summary-row';
        tfoot.innerHTML = `<tr>${cells.join('')}</tr>`;
        table.appendChild(tfoot);
    }

    // LLM "Follow-up questions" — sends the question + result shape to a new endpoint
    // that asks the model for 3 likely next questions, rendered as chips. Clicking a chip
    // submits it as a new question.
    async function suggestFollowUps(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const bubble = btn.closest('.copilot-message-assistant');
        let question = '';
        if (bubble) {
            let n = bubble.previousElementSibling;
            while (n && !n.classList.contains('copilot-message-user')) n = n.previousElementSibling;
            if (n) question = (n.querySelector('.copilot-message-body')?.textContent || n.textContent || '').trim();
        }
        if (!question) question = ([...copilotHistory].reverse().find(m => m.role === 'user' && !m.isQueued))?.content || '';
        const columns = Array.from(table.querySelectorAll('thead tr:first-child th')).map(th => th.textContent.trim());
        const rows = Array.from(table.querySelectorAll('tbody tr')).slice(0, 5).map(tr =>
            Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim()));

        let panel = wrap.querySelector('.copilot-followup-panel');
        if (!panel) {
            panel = document.createElement('div');
            panel.className = 'copilot-followup-panel';
            wrap.appendChild(panel);
        }
        panel.innerHTML = `<div class="copilot-explain-loading"><i class="bi bi-lightbulb me-1"></i>Thinking of related questions…</div>`;
        btn.disabled = true;
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const res = await fetch('@Url.Action("SuggestFollowUps", "AiAnalysis")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ question, columns, rows }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data?.message || 'Suggestion failed');
            const suggestions = Array.isArray(data.suggestions) ? data.suggestions : [];
            if (suggestions.length === 0) {
                panel.innerHTML = `<div class="copilot-explain-error">No follow-up suggestions returned.</div>`;
                return;
            }
            const chips = suggestions.slice(0, 5).map(s =>
                `<button type="button" class="copilot-followup-chip" onclick="askCopilotFollowUp(this)" data-q="${escapeHtml(s)}">
                    <i class="bi bi-arrow-right-circle me-1"></i>${escapeHtml(s)}
                </button>`).join('');
            panel.innerHTML = `
                <div class="copilot-followup-header">
                    <i class="bi bi-lightbulb"></i><span>You might also ask</span>
                    <button type="button" class="copilot-explain-close" onclick="this.closest('.copilot-followup-panel').remove()" title="Dismiss">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
                <div class="copilot-followup-chips">${chips}</div>`;
        } catch (e) {
            panel.innerHTML = `<div class="copilot-explain-error"><i class="bi bi-exclamation-triangle me-1"></i>${escapeHtml(e.message || String(e))}</div>`;
        } finally { btn.disabled = false; }
    }

    function askCopilotFollowUp(chipBtn) {
        const q = chipBtn.getAttribute('data-q');
        if (!q) return;
        const inputEl = document.getElementById('copilot-question');
        const sendBtn = document.getElementById('copilot-ask-btn');
        if (!inputEl || !sendBtn) return;
        inputEl.value = q;
        inputEl.focus();
        sendBtn.click();
    }

    // Inspect the rendered table; if it has a chartable shape, build the chart controls
    // (View-as-chart button + type selector) and an empty <canvas> panel below the table.
    // Returns a DocumentFragment ready to append to .copilot-inline-table-wrap, or null
    // when the table isn't chartable (single column / single row / no numeric column).
    function buildCopilotChartControls(table, totalRows) {
        if (typeof Chart === 'undefined' || !table || totalRows < 2) return null;
        const ths = table.querySelectorAll('thead tr:first-child th');
        if (ths.length < 2) return null;
        const sampleRow = table.querySelector('tbody tr');
        if (!sampleRow) return null;
        const cells = sampleRow.querySelectorAll('td');
        // Detect column kinds. For each column, "numeric" when the sample cell parses as
        // a number. We collect ALL numeric indices (multiple measures) and ALL non-numeric
        // indices (the dimension + any secondary dimension that enables stacked bars).
        //   measureIdxs  = every numeric column   → one chart dataset per measure
        //   labelIdx     = first non-numeric col  → x-axis labels
        //   secondaryDimIdx = second non-numeric  → secondary dimension (stacked bar)
        // Example: entity | last_year | current_year →
        //   labelIdx=0, measureIdxs=[1,2], secondaryDimIdx=-1
        //   → grouped bar chart with two series, one per year.
        const measureIdxs = [];
        let labelIdx = -1, secondaryDimIdx = -1;
        cells.forEach((td, i) => {
            const v = td.textContent.trim();
            const n = Number(v.replace(/,/g, ''));
            const isNum = !isNaN(n) && v !== '';
            if (isNum) measureIdxs.push(i);
            else if (labelIdx === -1) labelIdx = i;
            else if (secondaryDimIdx === -1) secondaryDimIdx = i;
        });
        if (measureIdxs.length === 0 || labelIdx === -1) return null;
        // First numeric column stays the primary measure for compatibility with chart
        // types that only consume one (treemap, funnel, gauge, etc.).
        const measureIdx = measureIdxs[0];

        const canStack = secondaryDimIdx !== -1;
        const hasMultipleMeasures = measureIdxs.length > 1;

        const wrap = document.createElement('div');
        wrap.className = 'copilot-chart-panel';
        wrap.setAttribute('data-measure-idx', String(measureIdx));
        wrap.setAttribute('data-measure-idxs', measureIdxs.join(','));
        wrap.setAttribute('data-label-idx', String(labelIdx));
        if (canStack) wrap.setAttribute('data-secondary-dim-idx', String(secondaryDimIdx));
        // Default chart suggestion based on the data shape — but ALL chart types stay
        // available in the dropdown regardless. When a type doesn't fit the data the
        // renderer shows a friendly "needs N columns" hint instead of a broken canvas.
        // Multi-measure data (e.g. "entity | last_year | current_year") defaults to a
        // grouped bar so both series are visible side-by-side — that's the most common
        // intent when a user asks for two metrics over the same dimension.
        const labelHeader = (ths[labelIdx]?.textContent || '').toLowerCase();
        const looksDate = /date|month|year|day|week|quarter|created|resolved|at$/.test(labelHeader);
        const defaultType = hasMultipleMeasures ? 'bar'
                          : canStack ? 'stacked-bar'
                          : looksDate ? 'area'
                          : (totalRows <= 8 ? 'pie' : 'bar');
        // Single source of truth for the dropdown — change this list and everything updates.
        // Grouped by family so the user finds what they want quickly.
        const allTypes = [
            { group: 'Bars',     value: 'bar',           label: 'Bar' },
            { group: 'Bars',     value: 'hbar',          label: 'Horizontal bar' },
            { group: 'Bars',     value: 'stacked-bar',   label: 'Stacked bar' },
            { group: 'Bars',     value: 'funnel',        label: 'Funnel' },
            { group: 'Bars',     value: 'waterfall',     label: 'Waterfall' },
            { group: 'Bars',     value: 'bullet',        label: 'Bullet (KPI vs target)' },
            { group: 'Bars',     value: 'pareto',        label: 'Pareto (80/20)' },
            { group: 'Bars',     value: 'histogram',     label: 'Histogram' },
            { group: 'Lines',    value: 'line',          label: 'Line' },
            { group: 'Lines',    value: 'area',          label: 'Area' },
            { group: 'Lines',    value: 'step',          label: 'Step' },
            { group: 'Lines',    value: 'slope',         label: 'Slope (before/after)' },
            { group: 'Radial',   value: 'pie',           label: 'Pie' },
            { group: 'Radial',   value: 'doughnut',      label: 'Donut' },
            { group: 'Radial',   value: 'polarArea',     label: 'Polar area' },
            { group: 'Radial',   value: 'radar',         label: 'Radar' },
            { group: 'Radial',   value: 'gauge',         label: 'Gauge' },
            { group: 'Spatial',  value: 'heatmap',       label: 'Heatmap' },
            { group: 'Spatial',  value: 'calendar-heatmap', label: 'Calendar heatmap' },
            { group: 'Spatial',  value: 'treemap',       label: 'Treemap' },
            { group: 'Points',   value: 'scatter',       label: 'Scatter' },
            { group: 'Points',   value: 'bubble',        label: 'Bubble' },
        ];
        const optionsHtml = (() => {
            const groups = {};
            allTypes.forEach(t => { (groups[t.group] = groups[t.group] || []).push(t); });
            return Object.entries(groups).map(([g, items]) =>
                `<optgroup label="${g}">` +
                items.map(t => `<option value="${t.value}"${t.value === defaultType ? ' selected' : ''}>${t.label}</option>`).join('') +
                `</optgroup>`
            ).join('');
        })();
        // Label-selector — every column is a candidate X-axis dimension. Auto-picked
        // labelIdx is the default; users can switch to any other column (including a
        // numeric one — e.g. "AgeDays" on the X axis if that's what they want).
        const labelOpts = Array.from(ths).map((th, i) =>
            `<option value="${i}"${i === labelIdx ? ' selected' : ''}>${(th.textContent || `Col ${i}`).trim()}</option>`
        ).join('');
        const labelSelectorHtml = `
            <label class="copilot-chart-typelabel copilot-chart-measurelabel">Label:</label>
            <select class="copilot-chart-label" onchange="renderCopilotChart(this.closest('.copilot-chart-panel'))" title="Column used for the X-axis / category labels — change to re-plot against a different dimension">
                ${labelOpts}
            </select>`;

        // Measure-selector — always emitted. Lists every numeric column so the user
        // can pick WHICH measure to chart. When 2+ numerics, an "All measures
        // (combined)" option keeps the grouped/stacked multi-series rendering for
        // cartesian chart types (bar/line/area/stacked-bar); selecting a specific
        // measure collapses to single-series. With 1 numeric the dropdown just
        // surfaces the auto-picked column so the user can see what's being plotted.
        const measureOpts = measureIdxs.map(mi =>
            `<option value="${mi}"${(!hasMultipleMeasures && mi === measureIdx) ? ' selected' : ''}>${(ths[mi]?.textContent || `Col ${mi}`).trim()}</option>`
        ).join('');
        const measureSelectorHtml = `
            <label class="copilot-chart-typelabel copilot-chart-measurelabel">Measure:</label>
            <select class="copilot-chart-measure" onchange="renderCopilotChart(this.closest('.copilot-chart-panel'))" title="Numeric column used for the Y-axis / values — change to plot a different metric">
                ${hasMultipleMeasures ? '<option value="all" selected>All measures (combined)</option>' : ''}
                ${measureOpts}
            </select>`;

        // Option buttons row — sort-by-value / data labels / swap / threshold /
        // colorblind palette / fullscreen / PNG / add+remove panel. State for the
        // toggleable options lives on panel.dataset (sortByValue, dataLabels,
        // cbPalette, threshold). The "Remove" button stays hidden on the original
        // panel; cloned panels (Add chart) un-hide it.
        const optsHtml = `
            <span class="copilot-chart-divider" aria-hidden="true"></span>
            <button type="button" class="copilot-chart-opt" title="Sort categories by value (desc)" onclick="toggleCopilotChartOpt(this, 'sortByValue')">
                <i class="bi bi-sort-down"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Show data labels on bars/slices" onclick="toggleCopilotChartOpt(this, 'dataLabels')">
                <i class="bi bi-tag"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Swap axes (bar ↔ horizontal bar)" onclick="swapCopilotChartAxes(this)">
                <i class="bi bi-arrow-left-right"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Logarithmic y-axis (useful for long-tail / skewed data)" onclick="toggleCopilotChartOpt(this, 'logScale')">
                <i class="bi bi-graph-up-arrow"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Smooth line curves (bezier tension)" onclick="toggleCopilotChartOpt(this, 'smoothing')">
                <i class="bi bi-bezier2"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Overlay best-fit trend line (linear regression)" onclick="toggleCopilotChartOpt(this, 'trendLine')">
                <i class="bi bi-graph-up"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Overlay 7-period moving average (time-series)" onclick="toggleCopilotChartOpt(this, 'movingAvg')">
                <i class="bi bi-activity"></i>
            </button>
            <span class="copilot-chart-threshold-wrap">
                <label class="copilot-chart-typelabel">Target:</label>
                <input class="copilot-chart-threshold" type="number" step="any" placeholder="value" oninput="copilotChartThresholdChanged(this)" title="Draw a horizontal target line at this value">
            </span>
            <button type="button" class="copilot-chart-opt" title="Colorblind-safe palette (Okabe–Ito)" onclick="toggleCopilotChartOpt(this, 'cbPalette')">
                <i class="bi bi-universal-access"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Fullscreen" onclick="fullscreenCopilotChart(this)">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>
            <button type="button" class="copilot-chart-opt" title="Download chart as PNG" onclick="downloadCopilotChartPng(this)">
                <i class="bi bi-download"></i>
            </button>
            <button type="button" class="copilot-chart-opt copilot-chart-add-btn" title="Add another chart of this data" onclick="addCopilotChartPanel(this)">
                <i class="bi bi-plus-square"></i>
            </button>
            <button type="button" class="copilot-chart-opt copilot-chart-remove-btn" title="Remove this chart" onclick="removeCopilotChartPanel(this)" hidden>
                <i class="bi bi-x-square"></i>
            </button>`;

        wrap.innerHTML = `
            <div class="copilot-chart-controls">
                <button type="button" class="copilot-chart-toggle" onclick="toggleCopilotChart(this)">
                    <i class="bi bi-bar-chart-line me-1"></i>View as chart
                </button>
                <div class="copilot-chart-typewrap" hidden>
                    <label class="copilot-chart-typelabel">Chart:</label>
                    <select class="copilot-chart-type" onchange="renderCopilotChart(this.closest('.copilot-chart-panel'))" title="Chart type">
                        ${optionsHtml}
                    </select>
                    ${labelSelectorHtml}
                    ${measureSelectorHtml}
                    ${optsHtml}
                </div>
            </div>
            <div class="copilot-chart-canvas-wrap" hidden>
                <canvas class="copilot-chart-canvas"></canvas>
                <div class="copilot-chart-empty" hidden></div>
            </div>`;
        return wrap;
    }

    // ────────────────────────────────────────────────────────────────────────
    // Chart.js plugins — registered once, applied globally. Each plugin reads
    // its per-chart state from chart.canvas.closest('.copilot-chart-panel'),
    // so a single registration covers every chart panel without per-instance
    // wiring. Plugins no-op gracefully on non-copilot charts.
    // ────────────────────────────────────────────────────────────────────────
    let _copilotChartPluginsRegistered = false;
    function ensureCopilotChartPlugins() {
        if (_copilotChartPluginsRegistered || typeof Chart === 'undefined') return;

        // Data labels — paint the numeric value on each bar / slice / point.
        // Skips chart types that already render their own labels (treemap),
        // or where labels add visual noise (radar, scatter, bubble).
        const dataLabelsPlugin = {
            id: 'copilot-data-labels',
            afterDatasetsDraw(chart) {
                const panel = chart.canvas?.closest('.copilot-chart-panel');
                if (!panel || panel.dataset.dataLabels !== '1') return;
                const skip = new Set(['treemap', 'radar', 'scatter', 'bubble']);
                if (skip.has(chart.config?.type)) return;
                const { ctx } = chart;
                ctx.save();
                ctx.font = '600 11px system-ui, sans-serif';
                ctx.fillStyle = 'rgba(226,232,240,0.95)';
                chart.data.datasets.forEach((ds, dsi) => {
                    const meta = chart.getDatasetMeta(dsi);
                    if (!meta || meta.hidden) return;
                    meta.data.forEach((el, i) => {
                        const v = ds.data[i];
                        if (v == null) return;
                        const num = typeof v === 'object' ? (v.v ?? v.y ?? null) : v;
                        if (num == null || isNaN(num)) return;
                        const text = typeof num === 'number' ? num.toLocaleString() : String(num);
                        const pos = el.getCenterPoint ? el.getCenterPoint() : { x: el.x, y: el.y };
                        const isHbar = chart.config?.type === 'bar' && chart.options?.indexAxis === 'y';
                        if (chart.config?.type === 'bar' && !isHbar) {
                            // Vertical bar — label above the top edge.
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'bottom';
                            ctx.fillText(text, pos.x, el.y - 4);
                        } else if (isHbar) {
                            // Horizontal bar — label inside the right edge.
                            ctx.textAlign = 'left';
                            ctx.textBaseline = 'middle';
                            ctx.fillText(text, el.x + 6, pos.y);
                        } else {
                            // Pie/donut/polar — centred in the segment.
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';
                            ctx.fillText(text, pos.x, pos.y);
                        }
                    });
                });
                ctx.restore();
            }
        };

        // Threshold / target line — draws a horizontal dashed line at the
        // user-entered value (panel.dataset.threshold). Requires a cartesian
        // y-axis, so it no-ops on pie/donut/polar/radar/treemap.
        const thresholdPlugin = {
            id: 'copilot-threshold-line',
            afterDraw(chart) {
                const panel = chart.canvas?.closest('.copilot-chart-panel');
                if (!panel) return;
                const t = parseFloat(panel.dataset.threshold);
                if (!isFinite(t)) return;
                const isHbar = chart.config?.type === 'bar' && chart.options?.indexAxis === 'y';
                const scale = isHbar ? chart.scales?.x : chart.scales?.y;
                if (!scale) return;
                const coord = scale.getPixelForValue(t);
                const { ctx, chartArea } = chart;
                if (!chartArea) return;
                ctx.save();
                ctx.strokeStyle = '#ef4444';
                ctx.lineWidth = 1.5;
                ctx.setLineDash([6, 4]);
                ctx.beginPath();
                if (isHbar) {
                    if (coord < chartArea.left || coord > chartArea.right) { ctx.restore(); return; }
                    ctx.moveTo(coord, chartArea.top);
                    ctx.lineTo(coord, chartArea.bottom);
                } else {
                    if (coord < chartArea.top || coord > chartArea.bottom) { ctx.restore(); return; }
                    ctx.moveTo(chartArea.left, coord);
                    ctx.lineTo(chartArea.right, coord);
                }
                ctx.stroke();
                ctx.setLineDash([]);
                ctx.fillStyle = '#ef4444';
                ctx.font = '600 11px system-ui, sans-serif';
                if (isHbar) {
                    ctx.textAlign = 'left'; ctx.textBaseline = 'top';
                    ctx.fillText(`target ${t.toLocaleString()}`, coord + 4, chartArea.top + 2);
                } else {
                    ctx.textAlign = 'right'; ctx.textBaseline = 'bottom';
                    ctx.fillText(`target ${t.toLocaleString()}`, chartArea.right - 4, coord - 4);
                }
                ctx.restore();
            }
        };

        Chart.register(dataLabelsPlugin, thresholdPlugin);
        _copilotChartPluginsRegistered = true;
    }

    // Toggle the chart panel open/closed. First open also kicks off the initial render.
    function toggleCopilotChart(btn) {
        // The button may have been relocated out of .copilot-chart-panel into the unified
        // table-actions toolbar (see renderConversation consolidation block). When detached,
        // closest() returns null, so fall back to the stamped data-panel-id link.
        const panel = btn.closest('.copilot-chart-panel')
            || (btn.dataset.panelId ? document.getElementById(btn.dataset.panelId) : null);
        if (!panel) return;
        const canvasWrap = panel.querySelector('.copilot-chart-canvas-wrap');
        const typeWrap = panel.querySelector('.copilot-chart-typewrap');
        const willShow = canvasWrap.hasAttribute('hidden');
        if (willShow) {
            canvasWrap.removeAttribute('hidden');
            typeWrap.removeAttribute('hidden');
            btn.innerHTML = '<i class="bi bi-x-lg me-1"></i>Hide chart';
            renderCopilotChart(panel);
        } else {
            canvasWrap.setAttribute('hidden', '');
            typeWrap.setAttribute('hidden', '');
            btn.innerHTML = '<i class="bi bi-bar-chart-line me-1"></i>View as chart';
        }
    }

    // ────────────────────────────────────────────────────────────────────────
    // Chart option toggles — sort-by-value / data labels / colorblind palette.
    // State flips on panel.dataset.<key>, button is-active class flips with it,
    // then a re-render picks up the new state.
    // ────────────────────────────────────────────────────────────────────────
    function toggleCopilotChartOpt(btn, key) {
        const panel = btn.closest('.copilot-chart-panel');
        if (!panel) return;
        const on = panel.dataset[key] === '1';
        panel.dataset[key] = on ? '' : '1';
        btn.classList.toggle('is-active', !on);
        renderCopilotChart(panel);
    }

    // Swap axes — flips vertical bar ↔ horizontal bar. Cheapest "reframe"
    // when category labels are long and a vertical bar's x-axis labels
    // overlap. For non-bar chart types this is a no-op.
    function swapCopilotChartAxes(btn) {
        const panel = btn.closest('.copilot-chart-panel');
        if (!panel) return;
        const sel = panel.querySelector('select.copilot-chart-type');
        if (!sel) return;
        const map = { 'bar': 'hbar', 'hbar': 'bar', 'stacked-bar': 'stacked-bar' };
        const next = map[sel.value];
        if (next && next !== sel.value) {
            sel.value = next;
            renderCopilotChart(panel);
        }
    }

    // Threshold input — re-render whenever the value changes (debounce-free is
    // fine; Chart.js destroy+reconstruct is fast at our row counts).
    function copilotChartThresholdChanged(input) {
        const panel = input.closest('.copilot-chart-panel');
        if (!panel) return;
        const v = (input.value || '').trim();
        if (v === '') delete panel.dataset.threshold;
        else panel.dataset.threshold = v;
        renderCopilotChart(panel);
    }

    // Download as PNG — Chart.js exports the canvas at the current rendered
    // resolution. We pass 1.0 quality and append a sensible filename derived
    // from the chart type + label header for the saved file.
    function downloadCopilotChartPng(btn) {
        const panel = btn.closest('.copilot-chart-panel');
        if (!panel || !panel._chart) return;
        try {
            const dataUrl = panel._chart.toBase64Image('image/png', 1.0);
            const type = panel.querySelector('select.copilot-chart-type')?.value || 'chart';
            const ts = new Date().toISOString().slice(0, 19).replace(/[T:]/g, '-');
            const a = document.createElement('a');
            a.href = dataUrl;
            a.download = `copilot-${type}-${ts}.png`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        } catch (e) {
            console.warn('PNG export failed', e);
        }
    }

    // Fullscreen — uses the native Fullscreen API on the canvas wrap so the
    // canvas can grow to fill the viewport. Resize is triggered on
    // fullscreenchange so Chart.js redraws at the new dimensions.
    function fullscreenCopilotChart(btn) {
        const panel = btn.closest('.copilot-chart-panel');
        const canvasWrap = panel?.querySelector('.copilot-chart-canvas-wrap');
        if (!canvasWrap) return;
        if (document.fullscreenElement === canvasWrap) {
            document.exitFullscreen?.();
            return;
        }
        const req = canvasWrap.requestFullscreen || canvasWrap.webkitRequestFullscreen;
        if (!req) return;
        canvasWrap.classList.add('copilot-chart-canvas-wrap-fs');
        const onChange = () => {
            if (document.fullscreenElement !== canvasWrap) {
                canvasWrap.classList.remove('copilot-chart-canvas-wrap-fs');
                document.removeEventListener('fullscreenchange', onChange);
            }
            // Trigger Chart.js to re-measure & redraw at the new viewport size.
            if (panel._chart) {
                requestAnimationFrame(() => panel._chart.resize());
            }
        };
        document.addEventListener('fullscreenchange', onChange);
        req.call(canvasWrap).catch(() => canvasWrap.classList.remove('copilot-chart-canvas-wrap-fs'));
    }

    // Add another chart panel of the same data — clones the original panel,
    // copies its current dropdown selections so the user starts from "same as
    // current" and can quickly change type/label/measure to compare. The new
    // panel opens already-visible (no toggle gate) and has the Remove button
    // un-hidden so the user can dismiss it.
    function addCopilotChartPanel(btn) {
        const panel = btn.closest('.copilot-chart-panel');
        const tableWrap = panel?.parentElement;
        if (!panel || !tableWrap) return;

        const clone = document.createElement('div');
        clone.className = 'copilot-chart-panel copilot-chart-panel-extra';
        // Copy all data-* attributes (measureIdx, labelIdx, secondaryDimIdx,
        // sortByValue, dataLabels, cbPalette, threshold) so the clone starts
        // from the same state as the source panel.
        Array.from(panel.attributes).forEach(a => {
            if (a.name.startsWith('data-')) clone.setAttribute(a.name, a.value);
        });
        clone.innerHTML = panel.innerHTML;
        // Mirror the current select values from the source — innerHTML only
        // copies markup, not the live DOM "selected" state of dropdowns.
        const copySelect = (cls) => {
            const src = panel.querySelector(`select.${cls}`);
            const dst = clone.querySelector(`select.${cls}`);
            if (src && dst) dst.value = src.value;
        };
        copySelect('copilot-chart-type');
        copySelect('copilot-chart-label');
        copySelect('copilot-chart-measure');
        // Copy threshold value too.
        const srcT = panel.querySelector('input.copilot-chart-threshold');
        const dstT = clone.querySelector('input.copilot-chart-threshold');
        if (srcT && dstT) dstT.value = srcT.value;
        // Mirror is-active state on the toggle buttons.
        panel.querySelectorAll('.copilot-chart-opt.is-active').forEach(srcBtn => {
            const onclick = srcBtn.getAttribute('onclick') || '';
            const m = onclick.match(/toggleCopilotChartOpt\(this,\s*'(\w+)'\)/);
            if (!m) return;
            const dstBtn = clone.querySelector(`button[onclick*="'${m[1]}'"]`);
            if (dstBtn) dstBtn.classList.add('is-active');
        });
        // Clone starts open (no need to click "View as chart") and shows the
        // Remove button so the user can dismiss it.
        const cloneToggle = clone.querySelector('.copilot-chart-toggle');
        if (cloneToggle) cloneToggle.hidden = true;
        clone.querySelector('.copilot-chart-canvas-wrap')?.removeAttribute('hidden');
        clone.querySelector('.copilot-chart-typewrap')?.removeAttribute('hidden');
        const removeBtn = clone.querySelector('.copilot-chart-remove-btn');
        if (removeBtn) removeBtn.hidden = false;
        // Drop the "Add" button on the clone too — adding more panels is
        // always done from the FIRST panel, which keeps the UX predictable.
        const cloneAddBtn = clone.querySelector('.copilot-chart-add-btn');
        if (cloneAddBtn) cloneAddBtn.hidden = true;
        // Insert right after the source panel and render.
        panel.parentNode.insertBefore(clone, panel.nextSibling);
        renderCopilotChart(clone);
    }

    function removeCopilotChartPanel(btn) {
        const panel = btn.closest('.copilot-chart-panel');
        if (!panel) return;
        if (panel._chart) { panel._chart.destroy(); panel._chart = null; }
        panel.remove();
    }

    // Read rows from the sibling table and render (or re-render) the chart.
    function renderCopilotChart(panel) {
        if (!panel || typeof Chart === 'undefined') return;
        ensureCopilotChartPlugins();
        const wrap = panel.closest('.copilot-inline-table-wrap');
        const table = wrap && wrap.querySelector('table.copilot-inline-table');
        const canvas = panel.querySelector('canvas.copilot-chart-canvas');
        const empty = panel.querySelector('.copilot-chart-empty');
        const typeSel = panel.querySelector('select.copilot-chart-type');
        const measureSel = panel.querySelector('select.copilot-chart-measure');
        const labelSel = panel.querySelector('select.copilot-chart-label');
        if (!table || !canvas || !typeSel) return;
        const defaultMeasureIdx = parseInt(panel.dataset.measureIdx, 10);
        // When the measure-selector exists and the user picked a specific column
        // (not "all"), override the primary measure and collapse to single-series
        // rendering — e.g. "Pie of TicketCount" or "Pie of Rank", depending on
        // the dropdown choice. "all" keeps the multi-measure dataset rendering
        // for cartesian chart types.
        const measureSelValue = measureSel ? measureSel.value : 'all';
        const measureIdx = (measureSelValue !== 'all' && !isNaN(parseInt(measureSelValue, 10)))
            ? parseInt(measureSelValue, 10)
            : defaultMeasureIdx;
        // Label (X-axis) — prefer the user's pick from the Label dropdown; fall back
        // to the auto-detected default stamped on the panel at build time.
        const labelIdx = labelSel && !isNaN(parseInt(labelSel.value, 10))
            ? parseInt(labelSel.value, 10)
            : parseInt(panel.dataset.labelIdx, 10);
        const ths = table.querySelectorAll('thead tr:first-child th');
        // Secondary dimension (used by stacked-bar and heatmap) = first non-numeric
        // column that isn't the current labelIdx. Recomputed every render so that
        // switching the Label dropdown re-picks a sensible secondary automatically.
        const sampleTr = table.querySelector('tbody tr');
        let secondaryDimIdx = -1;
        if (sampleTr) {
            const sampleTds = sampleTr.querySelectorAll('td');
            for (let i = 0; i < sampleTds.length; i++) {
                if (i === labelIdx) continue;
                const v = sampleTds[i].textContent.trim();
                const n = Number(v.replace(/,/g, ''));
                const isNum = !isNaN(n) && v !== '';
                if (!isNum) { secondaryDimIdx = i; break; }
            }
        }
        const measureLabel = (ths[measureIdx]?.textContent || '').trim();
        // Rows are now an Array (not a NodeList) so we can sort them when the
        // "Sort by value" option is on. Existing forEach / [0] / index access
        // works identically across arrays and NodeLists, so downstream code
        // doesn't need to change.
        let trs = Array.from(table.querySelectorAll('tbody tr'));
        if (panel.dataset.sortByValue === '1') {
            trs.sort((a, b) => {
                const av = Number((a.querySelectorAll('td')[measureIdx]?.textContent || '0').replace(/,/g, '')) || 0;
                const bv = Number((b.querySelectorAll('td')[measureIdx]?.textContent || '0').replace(/,/g, '')) || 0;
                return bv - av;
            });
        }
        if (panel._chart) panel._chart.destroy();
        const type = typeSel.value;
        // Light-and-dark-friendly palette; cycled when datasets exceed length.
        // Colorblind toggle swaps to the Okabe–Ito 8-colour palette which is
        // safe for protanopia, deuteranopia and tritanopia.
        const defaultPalette = ['#5b8def','#22c55e','#f59e0b','#ef4444','#a855f7','#06b6d4','#ec4899','#10b981','#f97316','#3b82f6'];
        const cbSafePalette  = ['#E69F00','#56B4E9','#009E73','#F0E442','#0072B2','#D55E00','#CC79A7','#000000'];
        const palette = panel.dataset.cbPalette === '1' ? cbSafePalette : defaultPalette;

        // Helper — show an "incompatible data shape" message instead of an empty canvas
        // when the picked chart type doesn't fit the result. Keeps the dropdown promise
        // ("all types always available") honest without rendering garbage.
        const showEmpty = (msg) => {
            canvas.style.display = 'none';
            empty.hidden = false;
            empty.innerHTML = `<i class="bi bi-info-circle me-1"></i>${msg}`;
        };
        const showCanvas = () => {
            empty.hidden = true;
            canvas.style.display = '';
        };
        showCanvas();

        // ── Treemap (chartjs-chart-treemap) ─────────────────────────────────
        // Proportional rectangles — great when 20+ categories make a pie unreadable.
        // Single-measure: each rectangle's area = its share of the total.
        if (type === 'treemap') {
            const tree = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx)) return;
                tree.push({ name: tds[labelIdx].textContent.trim(), value: Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0 });
            });
            if (tree.length === 0) { showEmpty('No data to plot.'); return; }
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'treemap',
                data: { datasets: [{
                    label: measureLabel, tree, key: 'value',
                    backgroundColor: ctx => palette[(ctx.dataIndex ?? 0) % palette.length] + 'cc',
                    borderColor: '#ffffff22', borderWidth: 1, spacing: 1,
                    labels: { display: true, color: 'white', font: { weight: 'bold', size: 12 },
                              formatter: ctx => `${ctx.raw._data.name}\n${ctx.raw._data.value.toLocaleString()}` }
                }]},
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: {
                        title: items => items[0].raw._data.name,
                        label: item => `${measureLabel}: ${item.raw._data.value.toLocaleString()}`
                    }}}
                }
            });
            return;
        }

        // ── Funnel (synthesised from horizontal bar) ────────────────────────
        // No official Chart.js funnel; we approximate with a horizontal bar where
        // bars are pre-sorted descending. Reads as a funnel for stage progression
        // (e.g. New → Open → In Progress → Resolved → Closed).
        if (type === 'funnel') {
            const pairs = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx)) return;
                pairs.push([ tds[labelIdx].textContent.trim(),
                             Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0 ]);
            });
            pairs.sort((a, b) => b[1] - a[1]);
            if (pairs.length === 0) { showEmpty('No data to plot.'); return; }
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels: pairs.map(p => p[0]), datasets: [{
                    label: measureLabel, data: pairs.map(p => p[1]),
                    backgroundColor: pairs.map((_, i) => palette[i % palette.length] + 'cc'),
                    borderRadius: 6, borderWidth: 0
                }]},
                options: {
                    responsive: true, maintainAspectRatio: false, indexAxis: 'y',
                    plugins: { legend: { display: false } },
                    scales: { x: { beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } },
                              y: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } } }
                }
            });
            return;
        }

        // ── Pareto (sorted bar + cumulative percentage line) ────────────────
        // Classic 80/20 analysis: bars sorted desc by value, line shows the
        // running cumulative %. Reveals "which N categories make up 80% of the
        // total" — the single most useful chart in support analytics for
        // prioritising fixes. Dual y-axis: left = absolute counts, right = %.
        if (type === 'pareto') {
            const pairs = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx)) return;
                pairs.push([ tds[labelIdx].textContent.trim(),
                             Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0 ]);
            });
            pairs.sort((a, b) => b[1] - a[1]);
            if (pairs.length === 0) { showEmpty('No data to plot.'); return; }
            const total = pairs.reduce((s, p) => s + p[1], 0) || 1;
            let cum = 0;
            const cumPct = pairs.map(p => { cum += p[1]; return (cum / total) * 100; });
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels: pairs.map(p => p[0]),
                    datasets: [
                        { type: 'bar', label: measureLabel, data: pairs.map(p => p[1]),
                          backgroundColor: palette[0] + 'cc', borderColor: palette[0], borderWidth: 0, yAxisID: 'y' },
                        { type: 'line', label: 'Cumulative %', data: cumPct,
                          borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.08)',
                          borderWidth: 2, fill: false, pointRadius: 3, tension: 0.25, yAxisID: 'yPct' }
                    ]},
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: true, position: 'top' },
                        tooltip: { callbacks: { label: ctx => ctx.datasetIndex === 1
                            ? `Cumulative: ${ctx.parsed.y.toFixed(1)}%`
                            : `${measureLabel}: ${ctx.parsed.y.toLocaleString()}` } } },
                    scales: {
                        x: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { position: 'left', beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' },
                             grid: { color: 'rgba(148,163,184,0.15)' }, title: { display: true, text: measureLabel, color: 'rgba(148,163,184,0.85)' } },
                        yPct: { position: 'right', beginAtZero: true, max: 100,
                                ticks: { color: 'rgba(239,68,68,0.85)', callback: v => `${v}%` },
                                grid: { display: false }, title: { display: true, text: 'Cumulative %', color: 'rgba(239,68,68,0.85)' } }
                    }
                }
            });
            return;
        }

        // ── Histogram (auto-binned distribution of a numeric column) ─────────
        // Bins the MEASURE column into ~10 equal-width buckets and renders a bar
        // per bucket. Useful when the table has many rows of a single numeric
        // value (e.g. AgeDays) and you want to see the spread. Sturges-ish bin
        // count: max(5, min(20, ceil(sqrt(n)))). Ignores the label column.
        if (type === 'histogram') {
            const nums = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                const n = Number((tds[measureIdx]?.textContent || '').trim().replace(/,/g, ''));
                if (!isNaN(n)) nums.push(n);
            });
            if (nums.length < 2) { showEmpty('Histogram needs at least 2 numeric values in the measure column.'); return; }
            const min = Math.min(...nums), max = Math.max(...nums);
            if (min === max) { showEmpty(`All values equal ${min} — nothing to bin.`); return; }
            const binCount = Math.max(5, Math.min(20, Math.ceil(Math.sqrt(nums.length))));
            const width = (max - min) / binCount;
            const bins = Array.from({ length: binCount }, (_, i) => ({
                lo: min + i * width, hi: min + (i + 1) * width, count: 0
            }));
            nums.forEach(n => {
                let idx = Math.floor((n - min) / width);
                if (idx >= binCount) idx = binCount - 1;
                bins[idx].count += 1;
            });
            const fmtBound = v => Math.abs(v) >= 100 ? Math.round(v).toLocaleString() : v.toFixed(1);
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels: bins.map(b => `${fmtBound(b.lo)}–${fmtBound(b.hi)}`),
                    datasets: [{ label: `Distribution of ${measureLabel}`, data: bins.map(b => b.count),
                        backgroundColor: palette[0] + 'cc', borderColor: palette[0], borderWidth: 0,
                        borderRadius: 2, barPercentage: 1.0, categoryPercentage: 1.0 }] },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: {
                        title: items => `${items[0].label} (${measureLabel})`,
                        label: i => `${i.parsed.y.toLocaleString()} rows`
                    }}},
                    scales: {
                        x: { ticks: { color: 'rgba(148,163,184,0.85)', maxRotation: 45, minRotation: 0 }, grid: { display: false },
                             title: { display: true, text: measureLabel, color: 'rgba(148,163,184,0.85)' } },
                        y: { beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)', stepSize: 1 },
                             grid: { color: 'rgba(148,163,184,0.15)' },
                             title: { display: true, text: 'Frequency (rows)', color: 'rgba(148,163,184,0.85)' } }
                    }
                }
            });
            return;
        }

        // ── Step chart (line with stepped: 'before') ────────────────────────
        // For discrete state changes over time (Status transitions, on/off
        // signals). Honest for non-continuous data — never interpolates between
        // points. Same data shape as a line chart.
        if (type === 'step') {
            const labels = [];
            const values = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx)) return;
                labels.push(tds[labelIdx].textContent.trim());
                values.push(Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0);
            });
            if (labels.length < 2) { showEmpty('Step chart needs at least 2 points.'); return; }
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'line',
                data: { labels, datasets: [{
                    label: measureLabel, data: values,
                    stepped: 'before', borderColor: palette[0], backgroundColor: palette[0] + '33',
                    borderWidth: 2, fill: false, pointRadius: 3, tension: 0
                }] },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } }
                    }
                }
            });
            return;
        }

        // ── Waterfall (additive/subtractive breakdown) ──────────────────────
        // Stacked-bar trick: each category gets a transparent "padding" bar plus
        // a colored "delta" bar. Pre-sum the running total to compute each bar's
        // base. Positive deltas = green, negative = red. Final "Total" bar is
        // optional — synthesised when last row's label isn't already a total.
        if (type === 'waterfall') {
            const pairs = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx)) return;
                pairs.push([ tds[labelIdx].textContent.trim(),
                             Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0 ]);
            });
            if (pairs.length === 0) { showEmpty('No data to plot.'); return; }
            let running = 0;
            const ranges = []; // each entry: [base, base+delta] for a floating bar
            const colors = [];
            pairs.forEach(([_, delta]) => {
                const start = running;
                running += delta;
                ranges.push([start, running]);
                colors.push(delta >= 0 ? '#22c55ecc' : '#ef4444cc');
            });
            // Append a final "Total" bar from 0 to the running sum.
            const labels = [...pairs.map(p => p[0]), 'Total'];
            ranges.push([0, running]);
            colors.push(palette[0] + 'cc');
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels, datasets: [{
                    label: measureLabel, data: ranges,
                    backgroundColor: colors, borderWidth: 0, borderRadius: 3
                }] },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: {
                        label: ctx => {
                            const [lo, hi] = ctx.raw;
                            const delta = hi - lo;
                            return `${ctx.label}: ${delta >= 0 ? '+' : ''}${delta.toLocaleString()} (running ${hi.toLocaleString()})`;
                        }
                    }}},
                    scales: {
                        x: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } }
                    }
                }
            });
            return;
        }

        // ── Slope chart (before/after for each category) ────────────────────
        // Best when the data is "entity | period_A | period_B" — two measure
        // columns. Each entity becomes a line connecting its two points; you
        // see which categories rose/fell at a glance. Falls back to a
        // single-measure line ranking when only one measure is available.
        if (type === 'slope') {
            const measureIdxsAll = (panel.dataset.measureIdxs || String(measureIdx)).split(',').map(s => parseInt(s, 10));
            if (measureIdxsAll.length < 2) {
                showEmpty('Slope chart needs two measure columns (e.g. "Region | last_month | this_month").');
                return;
            }
            const a = measureIdxsAll[0], b = measureIdxsAll[1];
            const aLabel = (ths[a]?.textContent || 'A').trim();
            const bLabel = (ths[b]?.textContent || 'B').trim();
            const datasets = [];
            trs.forEach((tr, i) => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(a, b, labelIdx)) return;
                const name = tds[labelIdx].textContent.trim();
                const va = Number((tds[a].textContent || '').replace(/,/g, '')) || 0;
                const vb = Number((tds[b].textContent || '').replace(/,/g, '')) || 0;
                const color = vb >= va ? '#22c55e' : '#ef4444';
                datasets.push({
                    label: name, data: [{ x: aLabel, y: va }, { x: bLabel, y: vb }],
                    borderColor: color, backgroundColor: color + '33',
                    borderWidth: 2, pointRadius: 4, pointBackgroundColor: color, fill: false, tension: 0
                });
            });
            if (datasets.length === 0) { showEmpty('No data to plot.'); return; }
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'line',
                data: { datasets },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: datasets.length <= 8, position: 'right' },
                        tooltip: { callbacks: { label: ctx => `${ctx.dataset.label} ${ctx.parsed.x === aLabel ? '@@' + aLabel : '→ ' + bLabel}: ${ctx.parsed.y.toLocaleString()}` }}},
                    scales: {
                        x: { type: 'category', labels: [aLabel, bLabel], ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { beginAtZero: false, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } }
                    }
                }
            });
            return;
        }

        // ── Bullet chart (KPI vs target with achievement bands) ─────────────
        // Per row: horizontal bar showing actual value, plus a target marker
        // line. Needs two measure columns: actual + target. Falls back to using
        // the row's label as the KPI name. Each row gets its own mini-bar
        // (stacked vertically) so you can see N KPIs at once.
        if (type === 'bullet') {
            const measureIdxsAll = (panel.dataset.measureIdxs || String(measureIdx)).split(',').map(s => parseInt(s, 10));
            if (measureIdxsAll.length < 2) {
                showEmpty('Bullet chart needs two measure columns: actual + target.');
                return;
            }
            const actualIdx = measureIdxsAll[0], targetIdx = measureIdxsAll[1];
            const labels = [];
            const actuals = [];
            const targets = [];
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(actualIdx, targetIdx, labelIdx)) return;
                labels.push(tds[labelIdx].textContent.trim());
                actuals.push(Number((tds[actualIdx].textContent || '').replace(/,/g, '')) || 0);
                targets.push(Number((tds[targetIdx].textContent || '').replace(/,/g, '')) || 0);
            });
            if (labels.length === 0) { showEmpty('No data to plot.'); return; }
            // Color each actual bar by achievement vs target — red if <80%,
            // amber if <100%, green if ≥100%.
            const colors = actuals.map((a, i) => {
                const t = targets[i] || 1;
                const ratio = a / t;
                return ratio >= 1 ? '#22c55ecc' : ratio >= 0.8 ? '#f59e0bcc' : '#ef4444cc';
            });
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels, datasets: [
                    { label: (ths[actualIdx]?.textContent || 'Actual').trim(), data: actuals,
                      backgroundColor: colors, borderWidth: 0, borderRadius: 3 },
                    { label: (ths[targetIdx]?.textContent || 'Target').trim(), data: targets,
                      type: 'scatter', backgroundColor: '#1e293b', borderColor: '#1e293b',
                      pointStyle: 'rectRot', pointRadius: 8, pointBorderWidth: 2,
                      pointBorderColor: '#fff', showLine: false }
                ]},
                options: {
                    responsive: true, maintainAspectRatio: false, indexAxis: 'y',
                    plugins: { legend: { display: true, position: 'top' },
                        tooltip: { callbacks: { label: ctx => {
                            const a = actuals[ctx.dataIndex], t = targets[ctx.dataIndex];
                            const pct = t ? ((a / t) * 100).toFixed(1) : '—';
                            return ctx.datasetIndex === 0
                                ? `${ctx.dataset.label}: ${a.toLocaleString()} (${pct}% of target)`
                                : `${ctx.dataset.label}: ${t.toLocaleString()}`;
                        }}}},
                    scales: {
                        x: { beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } },
                        y: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } }
                    }
                }
            });
            return;
        }

        // ── Gauge (doughnut variant for single percentage / metric) ─────────
        // Uses the FIRST value only — gauges show one number. When the data has multiple
        // rows we use the first; users wanting a sum / max can use KPI card or aggregate first.
        if (type === 'gauge') {
            const firstRow = trs[0];
            if (!firstRow) { showEmpty('No data to plot.'); return; }
            const tds = firstRow.querySelectorAll('td');
            const value = Number((tds[measureIdx]?.textContent || '').replace(/,/g, '')) || 0;
            // Find a sensible 100% — if measure header says "%" or "rate" / "ratio" use 100.
            // Otherwise use the max value across all rows so the gauge is informative.
            let maxV = 100;
            const hdr = measureLabel.toLowerCase();
            if (!/%|percent|rate|ratio/.test(hdr)) {
                let m = 0;
                trs.forEach(tr => {
                    const v = Number((tr.querySelectorAll('td')[measureIdx]?.textContent || '').replace(/,/g, '')) || 0;
                    if (v > m) m = v;
                });
                maxV = Math.max(value, m, 1);
            }
            const remaining = Math.max(0, maxV - value);
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'doughnut',
                data: { labels: [measureLabel, 'remaining'], datasets: [{
                    data: [value, remaining],
                    backgroundColor: ['#5b8def', 'rgba(148,163,184,0.15)'],
                    borderWidth: 0,
                }]},
                options: {
                    responsive: true, maintainAspectRatio: false,
                    rotation: -90, circumference: 180, cutout: '70%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { filter: t => t.dataIndex === 0 },
                    },
                },
                plugins: [{
                    id: 'gauge-center-text',
                    afterDraw(chart) {
                        const { ctx, chartArea } = chart;
                        if (!chartArea) return;
                        ctx.save();
                        ctx.textAlign = 'center';
                        ctx.fillStyle = '#5b8def';
                        ctx.font = '700 28px system-ui, sans-serif';
                        const cx = (chartArea.left + chartArea.right) / 2;
                        const cy = chartArea.bottom - 8;
                        const label = /%|percent|rate|ratio/.test(measureLabel.toLowerCase())
                            ? `${value.toLocaleString()}%`
                            : value.toLocaleString();
                        ctx.fillText(label, cx, cy);
                        ctx.font = '500 11px system-ui, sans-serif';
                        ctx.fillStyle = 'rgba(148,163,184,0.85)';
                        ctx.fillText(measureLabel, cx, cy + 16);
                        ctx.restore();
                    }
                }]
            });
            return;
        }

        // ── Calendar heatmap (matrix variant) ───────────────────────────────
        // Same plugin as heatmap, but with a (day, week) axis derived from the label
        // column when it parses as a date. Falls back to a regular grid layout.
        if (type === 'calendar-heatmap') {
            const data = [];
            let minDate = null, maxDate = null;
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx)) return;
                const dateStr = tds[labelIdx].textContent.trim();
                const d = new Date(dateStr);
                if (isNaN(d.getTime())) return;
                const v = Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0;
                data.push({ d, v });
                if (!minDate || d < minDate) minDate = d;
                if (!maxDate || d > maxDate) maxDate = d;
            });
            if (data.length === 0) { showEmpty('Calendar heatmap needs a date column as the first dimension.'); return; }
            // Map each entry to (week-of-year, day-of-week) so cells form a calendar grid.
            const cells = data.map(({ d, v }) => {
                const dow = d.getDay(); // 0..6
                const firstOfYear = new Date(d.getFullYear(), 0, 1);
                const week = Math.floor(((d - firstOfYear) / 86400000 + firstOfYear.getDay()) / 7);
                return { x: week, y: ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dow], v, date: d.toISOString().slice(0, 10) };
            });
            const maxV = Math.max(1, ...cells.map(c => c.v));
            const colorFor = v => {
                const t = v / maxV;
                const r = Math.round(91 + (34 - 91) * t);
                const g = Math.round(141 + (197 - 141) * t);
                const b = Math.round(239 + (94 - 239) * t);
                return `rgba(${r},${g},${b},${0.2 + 0.7 * t})`;
            };
            const weekRange = [...new Set(cells.map(c => c.x))].sort((a, b) => a - b);
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'matrix',
                data: { datasets: [{
                    label: measureLabel,
                    data: cells,
                    backgroundColor: ctx => colorFor(ctx.raw?.v ?? 0),
                    borderWidth: 1, borderColor: 'rgba(148,163,184,0.12)',
                    width: ({ chart }) => (chart.chartArea?.width ?? 100) / Math.max(1, weekRange.length) - 2,
                    height: ({ chart }) => (chart.chartArea?.height ?? 100) / 7 - 2,
                }]},
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: {
                        callbacks: { title: items => items[0].raw.date, label: i => `${measureLabel}: ${i.raw.v.toLocaleString()}` }
                    }},
                    scales: {
                        x: { type: 'linear', ticks: { color: 'rgba(148,163,184,0.85)', stepSize: 4 }, grid: { display: false } },
                        y: { type: 'category', labels: ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'], offset: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } }
                    }
                }
            });
            return;
        }

        // ── Heatmap (chartjs-chart-matrix) ──────────────────────────────────
        // Same 3-column input as stacked-bar but rendered as a 2D matrix: x = primary dim,
        // y = secondary dim, cell color = measure. Best for "tickets by day-of-week × hour"
        // or "status × priority" — distribution patterns pop out visually instead of being
        // buried in stacked-bar segments. Color scale = perceptual gradient (low → high).
        // Heatmap / stacked-bar require a secondary dimension — show a helpful empty state otherwise.
        if ((type === 'heatmap' || type === 'stacked-bar') && secondaryDimIdx === -1) {
            showEmpty(`${type === 'heatmap' ? 'Heatmap' : 'Stacked bar'} needs two non-numeric columns plus a numeric measure (e.g. "tickets per <em>category</em> and <em>status</em>").`);
            return;
        }
        if (type === 'heatmap' && secondaryDimIdx !== -1) {
            const xs = []; const ys = [];
            const cellMap = new Map();
            let maxV = 0, minV = Infinity;
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx, secondaryDimIdx)) return;
                const x = tds[labelIdx].textContent.trim();
                const y = tds[secondaryDimIdx].textContent.trim();
                const v = Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0;
                if (!xs.includes(x)) xs.push(x);
                if (!ys.includes(y)) ys.push(y);
                cellMap.set(`${x}||${y}`, v);
                if (v > maxV) maxV = v;
                if (v < minV) minV = v;
            });
            const data = [];
            xs.forEach(x => ys.forEach(y => {
                data.push({ x, y, v: cellMap.get(`${x}||${y}`) ?? 0 });
            }));
            // Color gradient: dim blue for low, vivid for high. Null/0 cells render faint.
            const colorFor = v => {
                if (maxV === 0) return 'rgba(91,141,239,0.05)';
                const t = (v - 0) / (maxV - 0); // 0..1
                const alpha = 0.15 + 0.7 * t;
                const r = Math.round(91 + (168 - 91) * t);    // 5b → a8
                const g = Math.round(141 + (85 - 141) * t);   // 8d → 55
                const b = Math.round(239 + (247 - 239) * t);  // ef → f7
                return `rgba(${r},${g},${b},${alpha})`;
            };
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'matrix',
                data: {
                    datasets: [{
                        label: measureLabel,
                        data,
                        backgroundColor: ctx => colorFor(ctx.raw?.v ?? 0),
                        borderWidth: 1,
                        borderColor: 'rgba(148,163,184,0.15)',
                        width: ({ chart }) => (chart.chartArea?.width ?? 100) / Math.max(1, xs.length) - 2,
                        height: ({ chart }) => (chart.chartArea?.height ?? 100) / Math.max(1, ys.length) - 2,
                    }],
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                title: items => `${items[0].raw.x} × ${items[0].raw.y}`,
                                label: item => `${measureLabel}: ${item.raw.v.toLocaleString()}`,
                            }
                        }
                    },
                    scales: {
                        x: { type: 'category', labels: xs, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { type: 'category', labels: ys, offset: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } }
                    }
                }
            });
            return;
        }

        // ── Stacked-bar from multi-measure columns ──────────────────────────
        // Wide-format multi-measure data (e.g. `entity | last_year | current_year`) is
        // already in dataset-per-measure shape — just stack instead of group. Each
        // measure column becomes its own stacked dataset along the primary dim.
        // Only applies when "All measures" is selected — if the user picked one
        // specific measure we fall through to the normal single-series stacked bar.
        if (type === 'stacked-bar'
            && measureSelValue === 'all'
            && (panel.dataset.measureIdxs || '').split(',').length > 1) {
            const mIdxs = panel.dataset.measureIdxs.split(',').map(s => parseInt(s, 10));
            const stackLabels = [];
            const stackData = mIdxs.map(() => []);
            const stackHeaders = mIdxs.map(mi => (ths[mi]?.textContent || '').trim());
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(labelIdx, ...mIdxs)) return;
                stackLabels.push(tds[labelIdx].textContent.trim());
                mIdxs.forEach((mi, m) => {
                    stackData[m].push(Number((tds[mi]?.textContent || '').replace(/,/g, '')) || 0);
                });
            });
            const datasets = stackData.map((vals, m) => ({
                label: stackHeaders[m] || `Series ${m + 1}`,
                data: vals,
                backgroundColor: palette[m % palette.length] + 'cc',
                borderWidth: 0,
            }));
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels: stackLabels, datasets },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: true, position: 'right' }, tooltip: { enabled: true } },
                    scales: {
                        x: { stacked: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { stacked: true, beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } }
                    }
                }
            });
            return;
        }

        // ── Stacked-bar pivot ───────────────────────────────────────────────
        // Three-column input: (primary dim, secondary dim, measure). Pivot rows into
        // chart datasets — one dataset per secondary-dim value, stacked along primary-dim.
        // Example: rows ("Network","Open",12), ("Network","Closed",3), ("Auth","Open",8)
        // → labels=["Network","Auth"], datasets=[{label:"Open",data:[12,8]}, {label:"Closed",data:[3,0]}]
        if (type === 'stacked-bar' && secondaryDimIdx !== -1) {
            const labelSet = [];   // primary dim values, insertion order
            const seriesSet = [];  // secondary dim values, insertion order
            const cellMap = new Map(); // "primary||secondary" -> measure
            trs.forEach(tr => {
                const tds = tr.querySelectorAll('td');
                if (tds.length <= Math.max(measureIdx, labelIdx, secondaryDimIdx)) return;
                const primary = tds[labelIdx].textContent.trim();
                const secondary = tds[secondaryDimIdx].textContent.trim();
                const v = Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0;
                if (!labelSet.includes(primary)) labelSet.push(primary);
                if (!seriesSet.includes(secondary)) seriesSet.push(secondary);
                cellMap.set(`${primary}||${secondary}`, v);
            });
            const datasets = seriesSet.map((s, i) => ({
                label: s,
                data: labelSet.map(p => cellMap.get(`${p}||${s}`) ?? 0),
                backgroundColor: palette[i % palette.length],
                borderWidth: 0,
            }));
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: { labels: labelSet, datasets },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: true, position: 'right' }, tooltip: { enabled: true } },
                    scales: {
                        x: { stacked: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } },
                        y: { stacked: true, beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } }
                    }
                }
            });
            return;
        }

        // ── Single-measure chart (bar / hbar / area / line / pie / doughnut / polarArea / radar / scatter / bubble) ──
        // For multi-measure data (e.g. entity | last_year | current_year), we also build a
        // `multiValues[m]` array per measure column. Cartesian chart types (bar / hbar /
        // line / area) consume all measures as separate datasets below; radial chart types
        // (pie / doughnut / polarArea / radar) can't render two series side-by-side and
        // fall back to the first measure only.
        //
        // When the user picked a specific measure from the Measure dropdown (i.e. NOT
        // "all"), shrink the list to just that one — even cartesian types then render
        // as single-series of the chosen measure. Lets the user say "show me a pie of
        // TicketCount" or "show me a bar of Rank only" without changing the table.
        const allMeasureIdxs = (panel.dataset.measureIdxs || String(measureIdx)).split(',').map(s => parseInt(s, 10));
        const measureIdxList = (measureSelValue !== 'all') ? [measureIdx] : allMeasureIdxs;
        const isMultiMeasure = measureIdxList.length > 1;
        const labels = [];
        const values = [];                          // primary measure values (back-compat)
        const multiValues = measureIdxList.map(() => []); // values per measure column
        trs.forEach(tr => {
            const tds = tr.querySelectorAll('td');
            if (tds.length <= Math.max(measureIdx, labelIdx)) return;
            labels.push(tds[labelIdx].textContent.trim());
            values.push(Number((tds[measureIdx].textContent || '').replace(/,/g, '')) || 0);
            measureIdxList.forEach((mi, m) => {
                multiValues[m].push(Number((tds[mi]?.textContent || '').replace(/,/g, '')) || 0);
            });
        });
        const labelHeader = (ths[labelIdx]?.textContent || '').trim();
        const measureLabels = measureIdxList.map(mi => (ths[mi]?.textContent || '').trim());

        // Type-shape adapters — translate our dropdown values into Chart.js native
        // type + the right dataset shape for that type.
        const isRadial = (type === 'pie' || type === 'doughnut' || type === 'polarArea' || type === 'radar');
        let chartType = type;
        let datasetOverrides = {};
        let optionOverrides = {};

        if (type === 'hbar') { chartType = 'bar'; optionOverrides = { indexAxis: 'y' }; }
        else if (type === 'area') { chartType = 'line'; datasetOverrides = { fill: true, backgroundColor: 'rgba(91,141,239,0.18)' }; }
        else if (type === 'scatter' || type === 'bubble') {
            // Scatter / bubble need numeric x. When the label column isn't numeric we render
            // index→value (still useful for a "rank" view). Bubble adds radius from the same measure.
            const xs = labels.map((l, i) => {
                const n = Number(String(l).replace(/,/g, ''));
                return isNaN(n) ? i : n;
            });
            const pts = type === 'bubble'
                ? xs.map((x, i) => ({ x, y: values[i], r: Math.max(4, Math.min(20, Math.sqrt(values[i]) || 4)) }))
                : xs.map((x, i) => ({ x, y: values[i] }));
            panel._chart = new Chart(canvas.getContext('2d'), {
                type: type === 'bubble' ? 'bubble' : 'scatter',
                data: { datasets: [{ label: measureLabel, data: pts, backgroundColor: 'rgba(91,141,239,0.6)', borderColor: '#5b8def' }] },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: {
                        label: i => `${labels[i.dataIndex]}: ${i.raw.y.toLocaleString()}`
                    }}},
                    scales: {
                        x: { type: 'linear', title: { display: true, text: labelHeader, color: 'rgba(148,163,184,0.85)' }, ticks: { color: 'rgba(148,163,184,0.85)' } },
                        y: { beginAtZero: true, title: { display: true, text: measureLabel, color: 'rgba(148,163,184,0.85)' }, ticks: { color: 'rgba(148,163,184,0.85)' } }
                    }
                }
            });
            return;
        }

        const backgroundColor = isRadial
            ? labels.map((_, i) => palette[i % palette.length])
            : (datasetOverrides.backgroundColor || 'rgba(91,141,239,0.6)');
        const borderColor = isRadial ? '#ffffff22' : '#5b8def';

        // Option toggles — read from panel.dataset so user choices persist across re-renders.
        //   smoothing → bumps line tension from 0.25 to 0.4 (more curve)
        //   logScale  → swaps y-axis to logarithmic (long-tail data legibility)
        //   trendLine → appends a linear-regression dataset over the primary measure
        //   movingAvg → appends a 7-point trailing average over the primary measure
        const smoothing = panel.dataset.smoothing === '1';
        const logScale  = panel.dataset.logScale === '1';
        const trendLine = panel.dataset.trendLine === '1';
        const movingAvg = panel.dataset.movingAvg === '1';
        const tensionVal = smoothing ? 0.4 : 0.25;

        // Build the dataset(s). Cartesian types with multiple measure columns render
        // one dataset per measure (grouped bars, multi-line). Radial types collapse to
        // the first measure since pie/doughnut/polar/radar can only encode one series.
        let datasets;
        if (isMultiMeasure && !isRadial) {
            datasets = multiValues.map((vals, m) => Object.assign({
                label: measureLabels[m] || `Series ${m + 1}`,
                data: vals,
                backgroundColor: palette[m % palette.length] + 'cc',
                borderColor: palette[m % palette.length],
                borderWidth: 2,
                tension: tensionVal
            }, datasetOverrides));
        } else {
            datasets = [Object.assign({
                label: measureLabel, data: values, backgroundColor, borderColor,
                borderWidth: isRadial ? 1 : 2, tension: tensionVal
            }, datasetOverrides)];
        }

        // Trend line — simple linear regression (least squares) on the primary measure.
        // Only meaningful on cartesian charts where there's a defined x progression.
        if (trendLine && !isRadial && values.length >= 2) {
            const n = values.length;
            const xs = values.map((_, i) => i);
            const meanX = xs.reduce((s, x) => s + x, 0) / n;
            const meanY = values.reduce((s, y) => s + y, 0) / n;
            let num = 0, den = 0;
            for (let i = 0; i < n; i++) {
                num += (xs[i] - meanX) * (values[i] - meanY);
                den += (xs[i] - meanX) ** 2;
            }
            const slope = den === 0 ? 0 : num / den;
            const intercept = meanY - slope * meanX;
            const trendData = xs.map(x => slope * x + intercept);
            datasets.push({
                type: 'line', label: 'Trend (linear)', data: trendData,
                borderColor: '#ef4444', borderDash: [6, 4], borderWidth: 2,
                pointRadius: 0, fill: false, tension: 0
            });
        }

        // Moving average — 7-point trailing window. Smooths short-term spikes
        // so the underlying trend pops out. Skips the first few points (not
        // enough history) by setting them to null.
        if (movingAvg && !isRadial && values.length >= 3) {
            const W = Math.min(7, Math.max(3, Math.ceil(values.length / 5)));
            const ma = values.map((_, i) => {
                if (i < W - 1) return null;
                let s = 0;
                for (let j = i - W + 1; j <= i; j++) s += values[j];
                return s / W;
            });
            datasets.push({
                type: 'line', label: `${W}-pt moving avg`, data: ma,
                borderColor: '#f59e0b', borderWidth: 2, borderDash: [],
                pointRadius: 0, fill: false, tension: 0.4
            });
        }

        panel._chart = new Chart(canvas.getContext('2d'), {
            type: chartType,
            data: { labels, datasets },
            options: Object.assign({
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    // Show the legend whenever there are multiple datasets so the user can
                    // tell which colour is which measure (last_year vs current_year, etc.).
                    legend: { display: isRadial || isMultiMeasure || trendLine || movingAvg, position: 'right' },
                    tooltip: { enabled: true }
                },
                scales: isRadial ? (type === 'radar' ? { r: { beginAtZero: true, ticks: { color: 'rgba(148,163,184,0.85)' } } } : {}) : {
                    y: Object.assign(
                        { beginAtZero: !logScale, ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { color: 'rgba(148,163,184,0.15)' } },
                        logScale ? { type: 'logarithmic' } : {}
                    ),
                    x: { ticks: { color: 'rgba(148,163,184,0.85)' }, grid: { display: false } }
                },
                onClick: (_, elements) => {
                    if (!elements.length) return;
                    const idx = elements[0].index;
                    drillIntoCopilotChart(labelHeader, labels[idx]);
                }
            }, optionOverrides)
        });
    }

    // Drill-down — when the user clicks a bar / pie segment, generate a follow-up
    // question that filters the original on the clicked label, then submit it through
    // the normal chat path. The dimension header (e.g. "Status", "Priority") + clicked
    // value give the question its filter ("show me the records where status = 'Open'").
    function drillIntoCopilotChart(dimensionName, value) {
        if (!value) return;
        // Normalise the dimension header — strip a leading "Ticket" prefix and trailing
        // "Name" so "TicketStatuses_Name" reads as "status" and "Status Name" as "status".
        const dim = String(dimensionName)
            .replace(/^Ticket/i, '')
            .replace(/[_\s]*Name$/i, '')
            .replace(/s$/, '')
            .toLowerCase()
            .trim() || 'value';
        const q = `show me the records where ${dim} = "${value}"`;
        const inputEl = document.getElementById('copilot-question');
        const sendBtn = document.getElementById('copilot-ask-btn');
        if (!inputEl || !sendBtn) {
            // No chat input visible (e.g. embedded preview) — copy the question to clipboard as a fallback.
            try { navigator.clipboard?.writeText(q); } catch { /* best-effort */ }
            alert(`Drill-down question (copied to clipboard):\n${q}`);
            return;
        }
        inputEl.value = q;
        inputEl.focus();
        // Use the existing send path so history / progress timeline / persistence all work.
        sendBtn.click();
    }

    // Collapse / expand a single assistant response. Default state is expanded; clicking the
    // chevron in the message header hides the body so the user can quickly skim past long
    // answers and jump to a more recent response. Toggled in-place via classList — re-rendering
    // the whole thread would lose scroll position and re-mount the inline tables.
    function toggleAssistantCollapse(idx) {
        const m = copilotHistory[idx];
        if (!m || m.role !== 'assistant') return;
        m.isCollapsed = !m.isCollapsed;
        persistCopilotState();
        const msg = document.querySelector(`.copilot-message-assistant[data-msg-idx="${idx}"]`);
        if (!msg) { renderConversation(); return; }
        msg.classList.toggle('copilot-message-collapsed', !!m.isCollapsed);
        const btn = msg.querySelector('.copilot-collapse-btn');
        if (btn) {
            const title = m.isCollapsed ? 'Expand response' : 'Collapse response';
            btn.setAttribute('aria-expanded', String(!m.isCollapsed));
            btn.setAttribute('title', title);
            btn.setAttribute('aria-label', title);
            btn.innerHTML = `<i class="bi bi-chevron-${m.isCollapsed ? 'down' : 'up'}"></i>`;
        }
    }

    // Pager — page-size dropdown + prev/next buttons. State (page, pageSize, total)
    // lives in wrap.dataset so both handlers stay stateless. Page size "all" hides
    // the prev/next buttons (single page = whole dataset) and bumps the scroll
    // viewport via .copilot-inline-table-expanded so the user gets real estate.
    function copilotTableSetPageSize(sel) {
        const wrap = sel.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        wrap.dataset.pageSize = sel.value;       // '10' | '25' | '50' | '100' | 'all'
        wrap.dataset.page = '1';                 // size change resets to first page
        _copilotTableRenderPage(wrap);
    }

    function copilotTablePage(btn, action) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        const total = parseInt(wrap.dataset.total, 10) || 0;
        const size = wrap.dataset.pageSize === 'all'
            ? total
            : (parseInt(wrap.dataset.pageSize, 10) || COPILOT_TABLE_PREVIEW);
        const lastPage = Math.max(1, Math.ceil(total / Math.max(1, size)));
        let page = parseInt(wrap.dataset.page, 10) || 1;
        if (action === 'prev') page = Math.max(1, page - 1);
        else if (action === 'next') page = Math.min(lastPage, page + 1);
        wrap.dataset.page = String(page);
        _copilotTableRenderPage(wrap);
    }

    // Single source of truth for applying pager state to the DOM — toggles
    // .copilot-row-hidden on out-of-page rows, updates the "Showing X–Y of N"
    // text, sets prev/next disabled state, and resets the internal scroll.
    // Filter-aware: rows already marked .copilot-row-filtered-out are excluded
    // from the page count and never become visible via the pager.
    function _copilotTableRenderPage(wrap) {
        const tbody = wrap.querySelector('table.copilot-inline-table tbody');
        if (!tbody) return;
        const originalTotal = parseInt(wrap.dataset.total, 10) || 0;
        const allRows = Array.from(tbody.querySelectorAll('tr'));
        const visibleRows = allRows.filter(r => !r.classList.contains('copilot-row-filtered-out'));
        const total = visibleRows.length;
        const filterActive = total !== originalTotal;
        const sizeRaw = wrap.dataset.pageSize || String(COPILOT_TABLE_PREVIEW);
        const showAll = sizeRaw === 'all';
        const size = showAll ? Math.max(1, total) : (parseInt(sizeRaw, 10) || COPILOT_TABLE_PREVIEW);
        const lastPage = Math.max(1, Math.ceil(Math.max(1, total) / Math.max(1, size)));
        let page = parseInt(wrap.dataset.page, 10) || 1;
        if (page > lastPage) { page = lastPage; wrap.dataset.page = String(page); }
        const startIdx = (page - 1) * size;
        const endIdx   = Math.min(total, startIdx + size);

        // Filtered-out rows stay hidden via their own class; visible rows are paged.
        visibleRows.forEach((r, i) => {
            r.classList.toggle('copilot-row-hidden', i < startIdx || i >= endIdx);
        });

        wrap.classList.toggle('copilot-inline-table-expanded', showAll);
        wrap.classList.toggle('copilot-inline-table-collapsed', !showAll);

        const count = wrap.querySelector('.copilot-table-count');
        if (count) {
            const filterSuffix = filterActive ? ` <span class="copilot-table-filter-note">(filtered from ${originalTotal})</span>` : '';
            if (total === 0) {
                count.innerHTML = `No rows match the current filter${filterSuffix}`;
            } else if (showAll) {
                count.innerHTML = `Showing <strong>${total}</strong> of <strong>${total}</strong> rows${filterSuffix}`;
            } else {
                count.innerHTML = `Showing <strong>${startIdx + 1}–${endIdx}</strong> of <strong>${total}</strong> rows${filterSuffix}`;
            }
        }
        const pageInfo = wrap.querySelector('.copilot-table-page-info');
        if (pageInfo) pageInfo.innerHTML = `<strong>${page}</strong> / <strong>${lastPage}</strong>`;
        const prevBtn = wrap.querySelector('.copilot-table-pager-btn[onclick*="\'prev\'"]');
        const nextBtn = wrap.querySelector('.copilot-table-pager-btn[onclick*="\'next\'"]');
        if (prevBtn) { prevBtn.disabled = showAll || page <= 1; prevBtn.style.display = showAll ? 'none' : ''; }
        if (nextBtn) { nextBtn.disabled = showAll || page >= lastPage; nextBtn.style.display = showAll ? 'none' : ''; }
        if (pageInfo) pageInfo.style.display = showAll ? 'none' : '';

        const scroll = wrap.querySelector('.copilot-inline-table-scroll');
        if (scroll) scroll.scrollTop = 0;
    }

    // ────────────────────────────────────────────────────────────────────────
    // Sort — click on a <th> cycles its sort: none → asc → desc → none. The
    // active column's arrow icon flips; other columns reset to neutral. After
    // sorting the row order in tbody, _copilotTableRenderPage re-applies the
    // pager so visible rows reflect the new order.
    // ────────────────────────────────────────────────────────────────────────
    function copilotTableSort(th) {
        const wrap = th.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        const colIdx = parseInt(th.dataset.col, 10);
        const tbody = wrap.querySelector('table.copilot-inline-table tbody');
        if (!tbody || isNaN(colIdx)) return;
        const current = th.dataset.sort || 'none';
        const next = current === 'none' ? 'asc' : current === 'asc' ? 'desc' : 'none';
        // Clear sort state on every header, then set this one.
        wrap.querySelectorAll('th.copilot-th-sortable').forEach(h => {
            h.dataset.sort = '';
            const arrow = h.querySelector('.copilot-sort-arrow');
            if (arrow) arrow.className = 'bi bi-arrow-down-up copilot-sort-arrow';
        });
        th.dataset.sort = next;
        const arrow = th.querySelector('.copilot-sort-arrow');
        if (arrow) {
            arrow.className = next === 'asc' ? 'bi bi-sort-down-alt copilot-sort-arrow copilot-sort-active'
                             : next === 'desc' ? 'bi bi-sort-up copilot-sort-arrow copilot-sort-active'
                             : 'bi bi-arrow-down-up copilot-sort-arrow';
        }

        const kinds = (wrap.dataset.colKinds || '').split(',');
        const kind = kinds[colIdx] || 'text';
        const rows = Array.from(tbody.querySelectorAll('tr'));
        if (next === 'none') {
            // Restore original DOM order via the stamped index (set lazily on first sort).
            rows.forEach((r, i) => { if (!r.dataset.origIdx) r.dataset.origIdx = String(i); });
            rows.sort((a, b) => parseInt(a.dataset.origIdx, 10) - parseInt(b.dataset.origIdx, 10));
        } else {
            // Capture original index once so "none" can restore later.
            rows.forEach((r, i) => { if (!r.dataset.origIdx) r.dataset.origIdx = String(i); });
            const dir = next === 'asc' ? 1 : -1;
            rows.sort((a, b) => {
                const av = (a.querySelectorAll('td')[colIdx]?.textContent || '').trim();
                const bv = (b.querySelectorAll('td')[colIdx]?.textContent || '').trim();
                if (kind === 'numeric') {
                    return (Number(av.replace(/,/g, '')) - Number(bv.replace(/,/g, ''))) * dir;
                }
                if (kind === 'date') {
                    return (new Date(av).getTime() - new Date(bv).getTime()) * dir;
                }
                return av.localeCompare(bv, undefined, { numeric: true, sensitivity: 'base' }) * dir;
            });
        }
        const frag = document.createDocumentFragment();
        rows.forEach(r => frag.appendChild(r));
        tbody.appendChild(frag);
        wrap.dataset.page = '1';
        _copilotTableRenderPage(wrap);
    }

    // ────────────────────────────────────────────────────────────────────────
    // Filter — "Filter" button toggles the filter row in the table head; each
    // input live-filters its column. String columns do case-insensitive
    // "contains". Numeric columns also recognise comparator + range syntax:
    //   >100  <50  >=0  <=99  10-50
    // ────────────────────────────────────────────────────────────────────────
    function toggleCopilotFilterRow(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        const filterRow = wrap.querySelector('tr.copilot-filter-row');
        if (!filterRow) return;
        const willShow = filterRow.hasAttribute('hidden');
        filterRow.toggleAttribute('hidden', !willShow);
        btn.classList.toggle('is-active', willShow);
        if (!willShow) {
            // Hiding the filter row → clear all filters too, so the user isn't left
            // with invisible "why are rows missing?" state.
            filterRow.querySelectorAll('input.copilot-filter-input').forEach(inp => inp.value = '');
            _copilotTableApplyAllFilters(wrap);
        } else {
            // First input gets focus so the user can start typing immediately.
            filterRow.querySelector('input.copilot-filter-input')?.focus();
        }
    }

    function copilotTableApplyFilter(input) {
        const wrap = input.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        _copilotTableApplyAllFilters(wrap);
    }

    function _copilotTableApplyAllFilters(wrap) {
        const tbody = wrap.querySelector('table.copilot-inline-table tbody');
        if (!tbody) return;
        const inputs = wrap.querySelectorAll('input.copilot-filter-input');
        const filters = Array.from(inputs)
            .map(inp => ({ col: parseInt(inp.dataset.col, 10), kind: inp.dataset.kind, raw: (inp.value || '').trim() }))
            .filter(f => f.raw !== '');
        tbody.querySelectorAll('tr').forEach(tr => {
            const tds = tr.querySelectorAll('td');
            const pass = filters.every(f => _copilotMatchOne(tds[f.col]?.textContent || '', f));
            tr.classList.toggle('copilot-row-filtered-out', !pass);
        });
        wrap.dataset.page = '1';
        _copilotTableRenderPage(wrap);
    }

    function _copilotMatchOne(cellText, f) {
        const cell = cellText.trim();
        if (f.kind === 'numeric') {
            const cmp = f.raw.match(/^(>=|<=|>|<)\s*(-?\d+(?:\.\d+)?)$/);
            if (cmp) {
                const n = Number(cell.replace(/,/g, ''));
                if (isNaN(n)) return false;
                const t = Number(cmp[2]);
                return cmp[1] === '>' ? n > t : cmp[1] === '<' ? n < t : cmp[1] === '>=' ? n >= t : n <= t;
            }
            const range = f.raw.match(/^(-?\d+(?:\.\d+)?)\s*-\s*(-?\d+(?:\.\d+)?)$/);
            if (range) {
                const n = Number(cell.replace(/,/g, ''));
                return !isNaN(n) && n >= Number(range[1]) && n <= Number(range[2]);
            }
        }
        return cell.toLowerCase().includes(f.raw.toLowerCase());
    }

    // ────────────────────────────────────────────────────────────────────────
    // Drill-down — click a row → build a follow-up that filters by that row's
    // identifying values. Picks up to 2 cells (first non-empty text + first
    // numeric, or first two non-empty) to keep the question readable.
    // ────────────────────────────────────────────────────────────────────────
    function copilotTableDrillDown(tr) {
        const wrap = tr.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!wrap || !table) return;
        const headers = Array.from(table.querySelectorAll('thead th.copilot-th-sortable'))
            .map(h => (h.querySelector('.copilot-th-label')?.textContent || h.textContent || '').trim());
        const tds = Array.from(tr.querySelectorAll('td')).map(td => (td.textContent || '').trim());
        if (tds.length === 0) return;
        const kinds = (wrap.dataset.colKinds || '').split(',');
        // Prefer one text + one numeric — that combo reads best in a follow-up
        // ("where Region='EU' and TicketCount=42"). Falls back to first two
        // non-empty cells when one kind is missing.
        const textIdx = kinds.findIndex(k => k === 'text');
        const numIdx = kinds.findIndex(k => k === 'numeric');
        const picks = [];
        if (textIdx >= 0 && tds[textIdx]) picks.push(textIdx);
        if (numIdx >= 0 && tds[numIdx] && numIdx !== textIdx) picks.push(numIdx);
        if (picks.length < 2) {
            tds.forEach((v, i) => { if (v && !picks.includes(i) && picks.length < 2) picks.push(i); });
        }
        if (picks.length === 0) return;
        const parts = picks.map(i => `${headers[i] || `column ${i + 1}`} = "${tds[i]}"`);
        const q = `Drill down: show me the underlying tickets where ${parts.join(' and ')}.`;
        const inputEl = document.getElementById('copilot-question');
        const sendBtn = document.getElementById('copilot-ask-btn');
        if (!inputEl || !sendBtn) return;
        inputEl.value = q;
        inputEl.focus();
        // Don't auto-send — let the user tweak the question first. Same UX as
        // suggested follow-ups when the chip is half-formed.
    }

    // ────────────────────────────────────────────────────────────────────────
    // Period-compare — dropdown opens via toggleCopilotPeriodMenu (reuses the
    // Export menu styling). Each option builds a question with the chosen
    // period offset and submits it as a follow-up.
    // ────────────────────────────────────────────────────────────────────────
    function toggleCopilotPeriodMenu(btn) {
        const menu = btn.parentElement?.querySelector('.copilot-export-menu');
        if (!menu) return;
        // Close any other open dropdowns first — Export shares the same class.
        document.querySelectorAll('.copilot-export-menu').forEach(m => { if (m !== menu) m.hidden = true; });
        menu.hidden = !menu.hidden;
    }

    function askPeriodCompare(menuBtn, kind) {
        // Close the dropdown first so it doesn't linger.
        menuBtn.closest('.copilot-export-menu').hidden = true;
        const label = kind === 'week' ? 'last week' : kind === 'month' ? 'last month'
                     : kind === 'quarter' ? 'last quarter' : 'last year';
        const q = `Compare the previous answer to ${label} — show both periods side by side with the delta.`;
        const inputEl = document.getElementById('copilot-question');
        const sendBtn = document.getElementById('copilot-ask-btn');
        if (!inputEl || !sendBtn) return;
        inputEl.value = q;
        inputEl.focus();
        sendBtn.click();
    }

    // ────────────────────────────────────────────────────────────────────────
    // View SQL — a collapsible panel below the table showing the generated
    // SQL. SQL is stamped onto wrap.dataset.sql by renderConversation's post-
    // pass (see stampCopilotSqlOnTables). The button stays hidden until SQL
    // is attached.
    // ────────────────────────────────────────────────────────────────────────
    function toggleCopilotSqlPanel(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        let panel = wrap.querySelector('.copilot-sql-panel');
        if (panel) { panel.remove(); btn.classList.remove('is-active'); return; }
        const sql = wrap.dataset.sql || '';
        if (!sql) return;
        panel = document.createElement('div');
        panel.className = 'copilot-sql-panel';
        panel.innerHTML = `
            <div class="copilot-sql-panel-header">
                <span><i class="bi bi-code-slash me-1"></i>Generated SQL</span>
                <button type="button" class="copilot-sql-copy" onclick="copyCopilotSql(this)" title="Copy SQL">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
            <pre class="copilot-sql-code"><code>${escapeHtml(sql)}</code></pre>`;
        wrap.appendChild(panel);
        btn.classList.add('is-active');
    }

    function copyCopilotSql(btn) {
        const panel = btn.closest('.copilot-sql-panel');
        const code = panel?.querySelector('code')?.textContent || '';
        if (!code) return;
        navigator.clipboard?.writeText(code).then(() => {
            const i = btn.querySelector('i');
            const prev = i.className;
            i.className = 'bi bi-check2';
            setTimeout(() => i.className = prev, 1200);
        });
    }

    // Called by renderConversation after writing the message HTML into the DOM.
    // Links each assistant message's structured SQL (carried on the message
    // object) to the table wraps inside the message body, in order. Unhides
    // the "SQL" + "Trust" action buttons when a SQL string is attached.
    // Also stamps the originating user question so the Trust dialog can pre-fill it.
    function stampCopilotSqlOnTables(messageEl, sqlList, originatingQuestion) {
        if (!messageEl || !sqlList || sqlList.length === 0) return;
        const wraps = messageEl.querySelectorAll('.copilot-inline-table-wrap');
        wraps.forEach((wrap, i) => {
            const sql = sqlList[i] || sqlList[sqlList.length - 1];
            if (!sql) return;
            wrap.dataset.sql = sql;
            if (originatingQuestion) wrap.dataset.originatingQuestion = originatingQuestion;
            const sqlBtn = wrap.querySelector('.copilot-view-sql-btn');
            if (sqlBtn) sqlBtn.hidden = false;
            const trustBtn = wrap.querySelector('.copilot-trust-btn');
            if (trustBtn) trustBtn.hidden = false;
        });
    }

    // ────────────────────────────────────────────────────────────────────────
    // Promote-to-Trusted dialog — analyst reviews the (question, SQL) pair
    // before submitting it to the Trusted Query store. Pre-fills question +
    // SQL from the wrap dataset, lets the user add paraphrases / description /
    // shape, and POSTs to /AiAnalysis/PromoteToTrusted.
    // ────────────────────────────────────────────────────────────────────────
    function openCopilotTrustDialog(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        if (!wrap) return;
        const sql = wrap.dataset.sql || '';
        const question = wrap.dataset.originatingQuestion || '';
        if (!sql) {
            alert('No generated SQL is attached to this answer — nothing to promote.');
            return;
        }
        // Reuse the pin-modal backdrop pattern so the UX feels consistent.
        let modal = document.getElementById('copilot-trust-modal');
        if (modal) modal.remove();
        modal = document.createElement('div');
        modal.id = 'copilot-trust-modal';
        modal.className = 'copilot-pin-modal-backdrop';
        modal.addEventListener('click', e => { if (e.target === modal) modal.remove(); });
        modal.innerHTML = `
            <div class="copilot-pin-modal copilot-trust-modal">
                <div class="copilot-pin-modal-header">
                    <div>
                        <i class="bi bi-shield-check text-success"></i>
                        <strong>Promote to Trusted Query</strong>
                        <span class="text-muted ms-2">Save (question + SQL) so future asks skip the LLM</span>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('copilot-trust-modal').remove()">Close</button>
                </div>
                <div class="copilot-trust-modal-body">
                    <label class="copilot-trust-field-label">Question (canonical phrasing)</label>
                    <textarea class="copilot-trust-input" id="copilot-trust-question" rows="2" placeholder="e.g. how many tickets are currently still open">${escapeHtml(question)}</textarea>

                    <label class="copilot-trust-field-label">Generated SQL <span class="copilot-trust-readonly">(read-only)</span></label>
                    <pre class="copilot-trust-sql"><code>${escapeHtml(sql)}</code></pre>

                    <label class="copilot-trust-field-label">Paraphrases / variants <span class="copilot-trust-hint">(one per line — each is embedded separately, so the same SQL covers many phrasings)</span></label>
                    <textarea class="copilot-trust-input" id="copilot-trust-variants" rows="4" placeholder="open tickets count&#10;how many tickets are open&#10;currently-open ticket total"></textarea>

                    <div class="copilot-trust-row">
                        <div class="copilot-trust-col">
                            <label class="copilot-trust-field-label">Shape</label>
                            <select class="copilot-trust-input" id="copilot-trust-shape">
                                <option value="">(auto)</option>
                                <option value="SEL">SEL — single-table retrieval</option>
                                <option value="FLT">FLT — filter</option>
                                <option value="CNT">CNT — count</option>
                                <option value="AGG">AGG — aggregate (sum/avg/min/max)</option>
                                <option value="GRP">GRP — group-by + aggregate</option>
                                <option value="TOP">TOP — top-N with order-by</option>
                                <option value="JOI">JOI — inner-join projection</option>
                                <option value="ANT">ANT — anti-join</option>
                                <option value="PER">PER — period comparison</option>
                            </select>
                        </div>
                        <div class="copilot-trust-col">
                            <label class="copilot-trust-field-label">Tags <span class="copilot-trust-hint">(comma-separated)</span></label>
                            <input class="copilot-trust-input" id="copilot-trust-tags" placeholder="count, tickets, kpi">
                        </div>
                    </div>

                    <label class="copilot-trust-field-label">Description <span class="copilot-trust-hint">(optional — why this entry exists)</span></label>
                    <textarea class="copilot-trust-input" id="copilot-trust-description" rows="2" placeholder="Canonical open-tickets count — covers the standard 'how many open?' question."></textarea>

                    <div class="copilot-trust-actions">
                        <div id="copilot-trust-feedback" class="copilot-trust-feedback" hidden></div>
                        <button class="btn btn-success" onclick="submitCopilotTrust(this)">
                            <i class="bi bi-shield-check me-1"></i>Save to Trusted store
                        </button>
                    </div>
                </div>
            </div>`;
        document.body.appendChild(modal);
        document.getElementById('copilot-trust-question')?.focus();
    }

    async function submitCopilotTrust(btn) {
        const modal = document.getElementById('copilot-trust-modal');
        if (!modal) return;
        const fb = document.getElementById('copilot-trust-feedback');
        const showFb = (kind, msg) => {
            if (!fb) return;
            fb.hidden = false;
            fb.className = `copilot-trust-feedback is-${kind}`;
            fb.textContent = msg;
        };
        const question = document.getElementById('copilot-trust-question').value.trim();
        const sqlEl = modal.querySelector('.copilot-trust-sql code');
        const sql = (sqlEl?.textContent || '').trim();
        if (!question || !sql) { showFb('error', 'Question and SQL are both required.'); return; }
        const variants = document.getElementById('copilot-trust-variants').value
            .split('\n').map(v => v.trim()).filter(v => v && v !== question);
        const shape = document.getElementById('copilot-trust-shape').value || null;
        const description = document.getElementById('copilot-trust-description').value.trim() || null;
        const tags = document.getElementById('copilot-trust-tags').value
            .split(',').map(t => t.trim()).filter(Boolean);

        btn.disabled = true;
        showFb('info', 'Saving…');
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const res = await fetch('@Url.Action("PromoteToTrusted", "AiAnalysis")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ question, sql, shape, description, questionVariants: variants, tags })
            });
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data?.message || 'Promote failed');
            showFb('success', data.message || 'Saved. The Trusted Query store now has more coverage.');
            // Flip the originating Trust button to a "promoted" state.
            document.querySelectorAll('.copilot-trust-btn').forEach(b => {
                const w = b.closest('.copilot-inline-table-wrap');
                if (w?.dataset.originatingQuestion === question) {
                    b.classList.add('is-active');
                    b.innerHTML = '<i class="bi bi-shield-fill-check me-1"></i>Trusted';
                    b.setAttribute('title', `Promoted as ${data.id || ''} — Trusted store has ${data.storeCount || '?'} entries`);
                }
            });
            // Auto-dismiss after 2s.
            setTimeout(() => modal.remove(), 1800);
        } catch (e) {
            showFb('error', e.message || 'Save failed.');
            btn.disabled = false;
        }
    }

    // ────────────────────────────────────────────────────────────────────────
    // Column profiler — hover a column header → popover with quick stats. For
    // numerics: count, distinct, nulls, min/max/mean/median. For text: count,
    // distinct, nulls, top-5 most frequent values. Cheap, local-only.
    // ────────────────────────────────────────────────────────────────────────
    // Popover lives on document.body (not appended to the <th>) so it isn't
    // clipped by the table-scroll container's overflow:auto. We hand-position
    // it under the hovered th using getBoundingClientRect → position:fixed.
    let _copilotProfilerEl = null;
    document.addEventListener('mouseover', e => {
        const th = e.target.closest('th.copilot-th-sortable');
        if (!th || th.dataset.profilerOpen === '1') return;
        clearTimeout(th._profilerTimer);
        th._profilerTimer = setTimeout(() => _copilotShowProfilerPopover(th), 350);
    });
    document.addEventListener('mouseout', e => {
        const th = e.target.closest('th.copilot-th-sortable');
        if (!th) return;
        clearTimeout(th._profilerTimer);
        if (_copilotProfilerEl && _copilotProfilerEl._anchorTh === th) {
            _copilotProfilerEl.remove();
            _copilotProfilerEl = null;
            th.dataset.profilerOpen = '';
        }
    });

    function _copilotShowProfilerPopover(th) {
        const wrap = th.closest('.copilot-inline-table-wrap');
        const tbody = wrap?.querySelector('table.copilot-inline-table tbody');
        if (!wrap || !tbody) return;
        const colIdx = parseInt(th.dataset.col, 10);
        const kinds = (wrap.dataset.colKinds || '').split(',');
        const kind = kinds[colIdx] || 'text';
        const cells = Array.from(tbody.querySelectorAll('tr')).map(tr =>
            (tr.querySelectorAll('td')[colIdx]?.textContent || '').trim()
        );
        const total = cells.length;
        const nulls = cells.filter(v => v === '' || v.toLowerCase() === 'null').length;
        const nonNull = cells.filter(v => v !== '' && v.toLowerCase() !== 'null');
        const distinct = new Set(nonNull).size;
        let detailHtml = '';
        if (kind === 'numeric') {
            const nums = nonNull.map(v => Number(v.replace(/,/g, ''))).filter(n => !isNaN(n));
            if (nums.length > 0) {
                const sorted = [...nums].sort((a, b) => a - b);
                const sum = nums.reduce((a, b) => a + b, 0);
                const mean = sum / nums.length;
                const median = sorted.length % 2 === 0
                    ? (sorted[sorted.length / 2 - 1] + sorted[sorted.length / 2]) / 2
                    : sorted[Math.floor(sorted.length / 2)];
                const fmt = n => Math.abs(n) >= 1000 ? n.toLocaleString(undefined, { maximumFractionDigits: 2 })
                                 : n.toLocaleString(undefined, { maximumFractionDigits: 3 });
                detailHtml = `
                    <div class="copilot-profiler-stat"><span>min</span><strong>${fmt(sorted[0])}</strong></div>
                    <div class="copilot-profiler-stat"><span>max</span><strong>${fmt(sorted[sorted.length - 1])}</strong></div>
                    <div class="copilot-profiler-stat"><span>mean</span><strong>${fmt(mean)}</strong></div>
                    <div class="copilot-profiler-stat"><span>median</span><strong>${fmt(median)}</strong></div>`;
            }
        } else {
            // Top-5 frequency. Collapses long-tail categoricals to "+N more".
            const freq = new Map();
            nonNull.forEach(v => freq.set(v, (freq.get(v) || 0) + 1));
            const top = Array.from(freq.entries()).sort((a, b) => b[1] - a[1]).slice(0, 5);
            detailHtml = top.map(([v, c]) =>
                `<div class="copilot-profiler-stat"><span>${escapeHtml(v.length > 28 ? v.slice(0, 27) + '…' : v)}</span><strong>${c}</strong></div>`
            ).join('');
            if (freq.size > 5) detailHtml += `<div class="copilot-profiler-more">+${freq.size - 5} more</div>`;
        }
        // Remove any previous popover before opening a new one.
        if (_copilotProfilerEl) { _copilotProfilerEl.remove(); _copilotProfilerEl = null; }
        const pop = document.createElement('div');
        pop.className = 'copilot-profiler-popover';
        pop.innerHTML = `
            <div class="copilot-profiler-header">${escapeHtml((th.querySelector('.copilot-th-label')?.textContent || th.textContent || '').trim())} <span class="copilot-profiler-kind">${kind}</span></div>
            <div class="copilot-profiler-stat"><span>rows</span><strong>${total}</strong></div>
            <div class="copilot-profiler-stat"><span>distinct</span><strong>${distinct}</strong></div>
            <div class="copilot-profiler-stat"><span>nulls</span><strong>${nulls}</strong></div>
            ${detailHtml ? `<div class="copilot-profiler-divider"></div>${detailHtml}` : ''}`;
        // Position under the th using fixed coords so the popover escapes the
        // table-scroll container's overflow:auto clip.
        const rect = th.getBoundingClientRect();
        pop.style.left = `${rect.left}px`;
        pop.style.top = `${rect.bottom + 4}px`;
        pop._anchorTh = th;
        document.body.appendChild(pop);
        _copilotProfilerEl = pop;
        th.dataset.profilerOpen = '1';
    }
    // Parses the "N LLM calls, P+C tokens, ~$X" tail that HostTraceSink stitches onto the
    // ExecutionDetails.Summary string. Surfacing as compact badges below the assistant
    // message — same numbers also live on the trace row (LlmCallCount / TotalPromptTokens /
    // TotalCompletionTokens / EstimatedCostUsd) for DB-side queries.
    function renderCostBadges(executionDetails) {
        if (!executionDetails) return '';
        const summary = executionDetails.summary || executionDetails.Summary || '';
        const m = summary.match(/(\d+)\s+LLM\s+calls?,\s*(\d+)\+(\d+)\s+tokens?,\s*~\$([0-9.]+)/i);
        const trustBadge = renderTrustBadge(executionDetails);

        if (!m) return trustBadge;
        const [, calls, promptToks, completionToks, costUsd] = m;
        const costNum = parseFloat(costUsd);
        const costStr = costNum >= 0.01 ? `$${costNum.toFixed(4)}` :
                        costNum > 0     ? `$${costNum.toFixed(6)}` : 'free';
        return `
            ${trustBadge}
            <span class="copilot-cost-badge" title="LLM calls fired for this question">
                <i class="bi bi-cpu"></i> ${calls}
            </span>
            <span class="copilot-cost-badge" title="Prompt + completion tokens">
                <i class="bi bi-hash"></i> ${Number(promptToks).toLocaleString()}+${Number(completionToks).toLocaleString()}
            </span>
            <span class="copilot-cost-badge ${costNum === 0 ? 'copilot-cost-free' : ''}" title="Estimated cost from ModelPricing rates">
                <i class="bi bi-currency-dollar"></i> ${costStr}
            </span>`;
    }

    // Phase 1 Step 7 — trust badge. Reads ExecutionDetails.Provenance + Confidence (the new
    // backend-authoritative fields) and renders a colored label so the user sees at a glance
    // where the answer came from: a verified-query catalog hit (highest trust), a fresh LLM
    // generation, a self-corrected retry, or the escape valve. No UI knowledge of stages —
    // the backend tells the UI what label to show.
    function renderTrustBadge(executionDetails) {
        if (!executionDetails) return '';
        const provenance = executionDetails.provenance || executionDetails.Provenance || null;
        if (!provenance) return '';
        const confidence = executionDetails.confidence ?? executionDetails.Confidence ?? null;
        const styles = {
            'verified':       { cls: 'copilot-trust-verified',     icon: 'patch-check-fill', label: 'Verified' },
            'llm-cold':       { cls: 'copilot-trust-llm',          icon: 'cpu',              label: 'LLM' },
            'self-corrected': { cls: 'copilot-trust-corrected',    icon: 'arrow-repeat',     label: 'Self-corrected' },
            'direct-emit':    { cls: 'copilot-trust-direct',       icon: 'lightning-charge', label: 'Escape valve' },
            'conversational': { cls: 'copilot-trust-other',        icon: 'chat-dots',        label: 'Chat' },
            'knowledge':      { cls: 'copilot-trust-other',        icon: 'book',             label: 'Knowledge' },
            'tool':           { cls: 'copilot-trust-other',        icon: 'plug',             label: 'Tool' },
            'semantic':       { cls: 'copilot-trust-other',        icon: 'search',           label: 'Semantic' },
            'refusal':        { cls: 'copilot-trust-refusal',      icon: 'slash-circle',     label: 'Refused' }
        };
        const s = styles[provenance] || { cls: 'copilot-trust-other', icon: 'question-circle', label: provenance };
        const confTxt = confidence != null ? ` (${Math.round(confidence * 100)}%)` : '';
        return `<span class="copilot-cost-badge ${s.cls}" title="Source: ${provenance}${confTxt}">
            <i class="bi bi-${s.icon}"></i> ${s.label}${confTxt}
        </span>`;
    }

    function escapeHtml(v) { return String(v).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
    function escapeJs(v) { return String(v).replace(/'/g, "\\'"); }
    function showGlobalStory() {
        const last = [...copilotHistory].reverse().find(m => m.role === 'assistant' && m.id);
        if (last) openInvestigationTracePage(last.id); else alert("No stories in this session.");
    }

    // Pinned dashboard — overlay listing every chart the user has pinned. Each card has the
    // question, a mini table (first 5 rows), and remove/re-ask buttons. localStorage-backed,
    // no server round-trip. Renders into a modal so it doesn't disrupt the chat thread.
    function openCopilotPinDashboard() {
        const pins = readCopilotPins();
        let modal = document.getElementById('copilot-pin-modal');
        if (!modal) {
            modal = document.createElement('div');
            modal.id = 'copilot-pin-modal';
            modal.className = 'copilot-pin-modal-backdrop';
            modal.addEventListener('click', e => { if (e.target === modal) modal.remove(); });
            document.body.appendChild(modal);
        }
        modal.innerHTML = `
            <div class="copilot-pin-modal">
                <div class="copilot-pin-modal-header">
                    <div>
                        <i class="bi bi-pin-angle-fill"></i>
                        <strong>Pinned charts</strong>
                        <span class="text-muted ms-2">${pins.length} pinned</span>
                    </div>
                    <div class="d-flex gap-2">
                        ${pins.length > 0 ? `<button class="btn btn-sm btn-outline-danger" onclick="clearCopilotPins()">Clear all</button>` : ''}
                        <button class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('copilot-pin-modal').remove()">Close</button>
                    </div>
                </div>
                <div class="copilot-pin-grid">
                    ${pins.length === 0
                        ? '<div class="text-muted text-center py-5">No pinned charts yet. Click the <i class="bi bi-pin-angle"></i> Pin button under any answer.</div>'
                        : pins.map(renderCopilotPinCard).join('')}
                </div>
            </div>`;
    }

    function renderCopilotPinCard(pin) {
        const headers = pin.columns.map(c => `<th>${escapeHtml(c)}</th>`).join('');
        const rows = pin.rows.slice(0, 5).map(r =>
            `<tr>${r.map(c => `<td>${escapeHtml(c)}</td>`).join('')}</tr>`).join('');
        const moreNote = pin.rows.length > 5 ? `<div class="small text-muted">+ ${pin.rows.length - 5} more rows</div>` : '';
        return `
            <div class="copilot-pin-card" data-pin-id="${pin.id}">
                <div class="copilot-pin-card-head">
                    <span class="copilot-pin-card-q" title="${escapeHtml(pin.question)}">${escapeHtml(pin.question)}</span>
                    <span class="copilot-pin-card-meta">${pin.rows.length} rows · ${escapeHtml(pin.chartType)}</span>
                </div>
                <table class="copilot-pin-card-table"><thead><tr>${headers}</tr></thead><tbody>${rows}</tbody></table>
                ${moreNote}
                <div class="copilot-pin-card-actions">
                    <button class="btn btn-sm btn-outline-primary" onclick="reAskCopilotPin('${pin.id}')"><i class="bi bi-arrow-clockwise me-1"></i>Re-ask</button>
                    <button class="btn btn-sm btn-outline-success" onclick="copilotEmbedPin('${pin.id}', this)" title="Copy a deep-link to this pinned answer"><i class="bi bi-link-45deg me-1"></i>Embed link</button>
                    <button class="btn btn-sm btn-outline-danger" onclick="removeCopilotPin('${pin.id}')"><i class="bi bi-trash me-1"></i>Remove</button>
                </div>
            </div>`;
    }

    function removeCopilotPin(id) {
        writeCopilotPins(readCopilotPins().filter(p => p.id !== id));
        openCopilotPinDashboard();   // re-render
        refreshCopilotPinButton();
    }

    function clearCopilotPins() {
        if (!confirm('Remove all pinned charts?')) return;
        writeCopilotPins([]);
        openCopilotPinDashboard();
        refreshCopilotPinButton();
    }

    // 📡 Embed pin — copies a deep-link URL to clipboard. The URL carries
    // the pin id; opening it re-hydrates the pinned question into the
    // composer so the recipient runs the question against fresh data.
    function copilotEmbedPin(id, btn) {
        const pin = readCopilotPins().find(p => p.id === id);
        if (!pin) return;
        const base = window.location.origin + window.location.pathname;
        const url = `${base}?pin=${encodeURIComponent(id)}&q=${encodeURIComponent(pin.question)}`;
        const fallback = () => {
            const ta = document.createElement('textarea');
            ta.value = url; ta.style.position = 'fixed'; ta.style.opacity = '0';
            document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); } catch {}
            document.body.removeChild(ta);
        };
        if (navigator.clipboard?.writeText) navigator.clipboard.writeText(url).catch(fallback);
        else fallback();
        const icon = btn?.querySelector('i');
        if (icon) {
            const prev = icon.className;
            icon.className = 'bi bi-check2 me-1';
            setTimeout(() => icon.className = prev, 1500);
        }
        _showCopilotToast('Embed link copied — paste into Slack / wiki / email. The recipient sees the question pre-filled and can re-run it against fresh data.', 'success');
    }

    // On page load, check for ?pin= or ?q= deep-link params and pre-fill the
    // composer. Lets recipients of an Embed link land on the question
    // hydrated and ready to send.
    document.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const q = params.get('q');
        if (q) {
            const input = document.getElementById('copilot-question');
            if (input) {
                input.value = q;
                _showCopilotToast('Question pre-filled from a shared link. Press Send to run it against fresh data.', 'info');
                input.focus();
            }
        }
    });

    function reAskCopilotPin(id) {
        const pin = readCopilotPins().find(p => p.id === id);
        if (!pin) return;
        document.getElementById('copilot-pin-modal')?.remove();
        const inputEl = document.getElementById('copilot-question');
        const sendBtn = document.getElementById('copilot-ask-btn');
        if (inputEl && sendBtn) {
            inputEl.value = pin.question;
            inputEl.focus();
            sendBtn.click();
        }
    }

    // Small floating button visible whenever there's at least one pinned chart. Click → dashboard.
    function refreshCopilotPinButton() {
        const pins = readCopilotPins();
        let btn = document.getElementById('copilot-pin-fab');
        if (pins.length === 0) { btn?.remove(); return; }
        if (!btn) {
            btn = document.createElement('button');
            btn.id = 'copilot-pin-fab';
            btn.className = 'copilot-pin-fab';
            btn.onclick = openCopilotPinDashboard;
            document.body.appendChild(btn);
        }
        btn.innerHTML = `<i class="bi bi-pin-angle-fill"></i><span>${pins.length}</span>`;
        btn.title = `${pins.length} pinned chart${pins.length === 1 ? '' : 's'}`;
    }
    document.addEventListener('DOMContentLoaded', refreshCopilotPinButton);

    // "Back to start of conversation" pill — appears once the thread is scrolled
    // below the top, hides at the top. Click smoothly returns to the first message.
    // Threshold is generous (160px) so the button isn't flashing during the first
    // tiny scroll wobbles after a render.
    function scrollCopilotThreadToTop() {
        const t = document.getElementById('copilot-thread');
        if (t) t.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function updateCopilotScrollTopBtn() {
        const t = document.getElementById('copilot-thread');
        const btn = document.getElementById('copilot-scroll-top-btn');
        if (!t || !btn) return;
        if (t.scrollTop > 160) btn.removeAttribute('hidden');
        else btn.setAttribute('hidden', '');
    }
    document.addEventListener('DOMContentLoaded', () => {
        const t = document.getElementById('copilot-thread');
        if (!t) return;
        t.addEventListener('scroll', updateCopilotScrollTopBtn, { passive: true });
        updateCopilotScrollTopBtn();
    });

    let rec;
    if ('webkitSpeechRecognition' in window) {
        rec = new webkitSpeechRecognition();
        rec.onresult = (e) => {
            let t = ''; for (let i = e.resultIndex; i < e.results.length; ++i) if (e.results[i].isFinal) t += e.results[i][0].transcript;
            if (t) { const i = document.getElementById('copilot-question'); i.value += t; i.dispatchEvent(new Event('input')); }
        };
    }
    function toggleSpeechRecognition() { if (rec) rec.start(); }
</script>
