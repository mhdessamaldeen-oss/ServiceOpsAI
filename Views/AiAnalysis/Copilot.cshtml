    // ── 🗣 Data debate — uses ExplainResult with counter-arguments framing
    async function copilotDataDebate(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        document.querySelectorAll('.copilot-export-menu').forEach(m => m.setAttribute('hidden', ''));
        const headers = Array.from(table.querySelectorAll('thead tr:first-child th')).map(th => th.textContent.trim());
        const rows = Array.from(table.querySelectorAll('tbody tr')).slice(0, 20).map(tr =>
            Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim()));
        const question = wrap.dataset.originatingQuestion || '(this result)';
        _showCopilotToast('Generating counter-arguments…', 'info');
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const res = await fetch('@Url.Action("ExplainResult", "AiAnalysis")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({
                    question: `DEBATE MODE — challenge this answer. The original question was: "${question}". Identify 3-5 reasons this number might be misleading or wrong: sample bias, missing filter, stale join, definition ambiguity, edge cases not handled, data quality issues. Be specific. For each, suggest the follow-up query that would confirm or rule it out. Don't be reassuring — assume the analyst will publish this number and you're their adversarial reviewer.`,
                    columns: headers,
                    rows
                }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data?.message || 'Debate failed');
            _showCopilotNarrativeModal(data.explanation || '(no debate returned)', 1);
        } catch (e) {
