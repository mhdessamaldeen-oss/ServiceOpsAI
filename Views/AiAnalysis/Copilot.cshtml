@model ServiceOpsAI.Models.AI.CopilotChatViewModel

@{
    var pageTitle = ViewData["CopilotPageTitle"] as string ?? Loc.Get("CopilotEngine");
    var headerTitle = ViewData["CopilotHeaderTitle"] as string ?? Loc.Get("CopilotEngine");
    var headerBadge = ViewData["CopilotHeaderBadge"] as string ?? Loc.Get("AdminEnterpriseBadge");
    var exitController = ViewData["CopilotExitController"] as string ?? "AiAnalysis";
    var exitAction = ViewData["CopilotExitAction"] as string ?? "Hub";
    var initialPrompt = Model.InitialPrompt;
    var copilotSurface = ViewData["CopilotSurface"] as string ?? "default";
    var copilotReportStartDate = ViewData["CopilotReportStartDate"] as string ?? string.Empty;
    var copilotReportEndDate = ViewData["CopilotReportEndDate"] as string ?? string.Empty;
    var initialCaseCode = Model.InitialCaseCode;
    var initialSourceSuite = Model.InitialSourceSuite;
    var capabilitiesLabel = Loc.Get("CopilotCapabilities");
    var standardLogicLabel = Loc.Get("StandardLogic");
    ViewData["Title"] = pageTitle;

    var copilotHeader = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = headerTitle,
        IconClass = "bi bi-chat-square-text",
        Actions = new()
        {
            new() {
                Text = Loc.Get("Exit"),
                Href = Url.Action(exitAction, exitController) ?? "#",
                IconClass = "bi bi-grid",
                CssClass = "btn-action-soft btn-action-sm"
            }
        },
        ToolbarPartialName = "_CopilotToolbar"
    };
}

<link rel="stylesheet" href="~/css/copilot.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/copilot-uhub-restyle.css" asp-append-version="true" />
<!-- Pinned to marked@4 because our renderer.table uses the (header, body) signature.
     marked@5+ changed table() to receive a single token object, which produced "[object Object]undefined" in responses. -->
<script src="https://cdn.jsdelivr.net/npm/marked@4.3.0/marked.min.js"></script>
<!-- Chart.js for the optional "View as chart" panel under each data table. CDN script — no build step. -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<!-- Plugin: matrix (heatmap / calendar heatmap) -->
<script src="https://cdn.jsdelivr.net/npm/chartjs-chart-matrix@2.0.1/dist/chartjs-chart-matrix.umd.min.js"></script>
<!-- Plugin: treemap (proportional area chart for many categories) -->
<script src="https://cdn.jsdelivr.net/npm/chartjs-chart-treemap@2.3.1/dist/chartjs-chart-treemap.umd.min.js"></script>
<form id="csrf-form">@Html.AntiForgeryToken()</form>

<div class="copilot-shell @(copilotSurface == "reports" ? "copilot-shell-reporting" : "")">
    @* No top bar above the chat. The status pills and conversation actions
       (Investigation Stories / Clear current / Assessment Lab / Clear all / Exit)
       are rendered inside the left history pane footer instead, so the chat
       thread can extend from the global app header all the way to the composer
       without anything between. *@

    <div class="copilot-workspace" id="copilot-workspace">
        <aside class="copilot-history-pane">
            <button type="button" class="copilot-pane-toggle copilot-pane-toggle-history"
                    onclick="toggleCopilotPane('history')"
                    data-collapse-title="@Loc.Get("CollapseHistoryPane")"
                    data-expand-title="@Loc.Get("ExpandHistoryPane")"
                    title="@Loc.Get("CollapseHistoryPane")">
                <i class="bi bi-chevron-double-left"></i>
            </button>
            <div class="d-flex flex-column h-100">
                <div class="p-3 border-bottom border-secondary border-opacity-10">
                    <button type="button" class="btn btn-primary w-100 fw-bold" onclick="clearChat()">
                        <i class="bi bi-plus-lg"></i>@Loc.Get("NewChat")
                    </button>
                </div>
                <div class="flex-grow-1 overflow-y-auto p-3" style="min-height: 0;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="small fw-bold text-muted text-uppercase" style="letter-spacing: 0.1em; font-size: 0.7rem;">
                            @Loc.Get("Recent")
                        </div>
                        @* Live SignalR connection dot. Replaces the noisy "SignalR: Connected" pill
                           that used to live in the footer next to the (now-removed) "Admin Enterprise"
                           badge. JS in initCopilotSignalR / updateSignalRStatus toggles the
                           copilot-signalr-dot-{state} class and refreshes the title. *@
                        <span id="copilot-signalr-status"
                              class="copilot-signalr-dot copilot-signalr-dot-offline"
                              title="@Loc.Get("SignalROffline")"
                              aria-label="@Loc.Get("SignalROffline")"></span>
                    </div>
                    <div class="copilot-history-list" id="copilot-session-list">
                        @foreach (var session in Model.RecentSessions)
                        {
                            <div class="copilot-history-item-wrap position-relative" data-session-id="@session.Id">
                                <a href="javascript:void(0)" class="copilot-history-item @(Model.RecentSessions.First() == session ? "active" : "")" onclick="loadSession('@session.Id')">
                                    <i class="bi bi-chat-left-text me-2"></i>
                                    <div class="text-truncate">
                                        <div class="fw-bold" style="font-size: 0.8rem;">@session.Title</div>
                                        <div class="small opacity-75">@session.LastInteractionAt.ToString("MMM dd, HH:mm")</div>
                                    </div>
                                </a>
                                <button type="button" class="btn btn-link text-danger p-0 position-absolute top-50 translate-middle-y end-0 me-2 copilot-delete-trace-btn"
                                        onclick="event.stopPropagation(); deleteSession('@session.Id', this)" title="@Loc.Get("DeleteSession")">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                        @if (!Model.RecentSessions.Any())
                        {
                            <div class="text-center py-4 opacity-25" id="copilot-no-sessions">
                                <span class="small">@Loc.Get("NoRecentChats")</span>
                            </div>
                        }
                    </div>

                    @* Investigation History section removed at user request — recent
                       traces are still surfaced via the dedicated Archive page (see the
                       "Investigation Stories" button in the sidebar footer). *@
                </div>

                @* Conversation actions footer — used to live in a top bar above the chat;
                   moved here so the chat thread can claim every available vertical pixel.
                   Buttons stack and wrap inside the narrow sidebar so they always fit. *@
                <div class="copilot-history-actions">
                    <partial name="_CopilotToolbar" />
                    <a href="@(Url.Action(exitAction, exitController) ?? "#")" class="btn-action-ghost btn-action-sm w-100" title="@Loc.Get("Exit")">
                        <i class="bi bi-grid"></i><span>@Loc.Get("Exit")</span>
                    </a>
                </div>
            </div>
        </aside>

        <main class="copilot-chat-pane">
            @* Removed the "Current conversation" sub-header — the page header above already
               communicates context, and the user wants the chat thread to claim the full
               vertical space so question/answer history stays readable on small heights. *@
            <div id="copilot-thread" class="copilot-thread">
                <div class="copilot-empty">
                    <h4 class="fw-bold text-main mb-3">@Loc.Get("CopilotEmptyState")</h4>
                    <p class="text-muted mx-auto" style="max-width: 25rem; font-size: 0.9rem;">@Loc.Get("CopilotConversationHint")</p>
                </div>
            </div>

            @* Floating "jump to start of conversation" button. The thread keeps the
               newest messages near the bottom and pushes older Q/A pairs up, so when
               the operator scrolls past the start they lose the original question.
               This pill sits over the thread and only reveals itself once the thread
               is scrolled below the top — wiring is in the script block below. *@
            <button type="button" id="copilot-scroll-top-btn" class="copilot-scroll-top-fab"
                    onclick="scrollCopilotThreadToTop()"
                    title="@Loc.Get("BackToConversationStart")"
                    aria-label="@Loc.Get("BackToConversationStart")"
                    hidden>
                <i class="bi bi-arrow-up"></i>
                <span>@Loc.Get("BackToConversationStart")</span>
            </button>

            <div class="copilot-composer">
                <div class="copilot-input-container">
                    <div id="copilot-autocomplete-list" class="copilot-autocomplete-wrap"></div>
                    <textarea id="copilot-question" class="form-control copilot-textarea"
                              placeholder="@Loc.Get("CopilotQuestionHint")" style="padding-inline-end: 8rem !important;"
                              data-initial-prompt="@initialPrompt"
                              autocomplete="off"
                              spellcheck="true"
                              autocapitalize="sentences"
                              onkeydown="handleCopilotKeyDown(event)"></textarea>
                    <button id="copilot-lab-btn" class="copilot-mic-btn shadow-sm" type="button" onclick="toggleCopilotLabMenu(this)" title="Lab tools — narrative, replay, reverse-find, lenses">
                        <i class="bi bi-flask fs-5"></i>
                    </button>
                    <div id="copilot-lab-menu" class="copilot-lab-menu" hidden>
                        <button type="button" onclick="generateCopilotNarrative(this)"><i class="bi bi-file-earmark-text me-2"></i>Generate analyst narrative</button>
                        <button type="button" onclick="replayCopilotConversation(this)"><i class="bi bi-play-circle me-2"></i>Replay conversation</button>
                        <button type="button" onclick="openCopilotReverseFind(this)"><i class="bi bi-search me-2"></i>Reverse-find (number → question)</button>
                        <div class="copilot-lab-menu-divider"></div>
                        <button type="button" onclick="openCopilotLensLibrary(this)"><i class="bi bi-eyeglasses me-2"></i>My saved lenses</button>
                    </div>
                    <button id="copilot-mic-btn" class="copilot-mic-btn shadow-sm" type="button" onclick="toggleSpeechRecognition()">
                        <i class="bi bi-mic fs-5"></i>
                    </button>
                    <button id="copilot-ask-btn" class="copilot-send-btn shadow-sm" type="button" onclick="askCopilot()">
                        <i class="bi bi-arrow-up-short fs-3"></i>
                    </button>
                </div>
                <div class="mt-2 text-center">
                    <span class="small text-muted">@Loc.Get("CopilotSendHint")</span>
                </div>
            </div>
        </main>

        <aside class="copilot-side-shell">
            <button type="button" class="copilot-pane-toggle copilot-pane-toggle-side"
                    onclick="toggleCopilotPane('side')"
                    data-collapse-title="@Loc.Get("CollapseCapabilitiesPane")"
                    data-expand-title="@Loc.Get("ExpandCapabilitiesPane")"
                    title="@Loc.Get("CollapseCapabilitiesPane")">
                <i class="bi bi-chevron-double-right"></i>
            </button>
            <div class="copilot-side-card p-3 mb-0">
                <div class="copilot-panel-heading">@capabilitiesLabel</div>
                <div class="d-grid gap-3 mb-3">
                    @foreach (var capability in Model.ExternalCapabilities)
                    {
                        var primaryPrompt = capability.Prompts.FirstOrDefault();
                        var primaryPromptText = primaryPrompt?.Text ?? capability.ToolDescription;
                        var secondaryPrompts = capability.Prompts.Skip(1).ToList();
                        <div class="copilot-capability-group">
                            <div class="copilot-capability-head">
                                <div class="copilot-capability-title-wrap">
                                    <div class="copilot-capability-title">@Loc.Get(capability.ToolTitle)</div>
                                    <div class="copilot-capability-subtitle">@Loc.Get("ExternalUtilityTool")</div>
                                </div>
                                <span class="copilot-capability-badge">@Loc.Get("ExternalBadge")</span>
                            </div>
                            <button type="button" class="btn btn-soft-primary btn-sm text-start py-2 px-3 w-100 copilot-capability-action"
                                    onclick='applyPrompt(@Html.Raw(Json.Serialize(primaryPrompt ?? new ServiceOpsAI.Models.AI.CopilotSamplePrompt { Text = capability.ToolDescription })), false)'>
                                <i class="bi bi-link-45deg me-1"></i>@Loc.Get(primaryPromptText)
                            </button>
                            <details class="copilot-capability-details mt-2">
                                <summary class="copilot-capability-summary">
                                    <span>@Loc.Get("AboutThisTool")</span>
                                    @if (secondaryPrompts.Any())
                                    {
                                        <span class="copilot-capability-summary-count">+@secondaryPrompts.Count @Loc.Get("MoreSuffix")</span>
                                    }
                                </summary>
                                <div class="copilot-capability-description">@capability.ToolDescription</div>
                                @if (secondaryPrompts.Any())
                                {
                                    <div class="d-grid gap-2 mt-2">
                                        @foreach (var prompt in secondaryPrompts)
                                        {
                                            <button type="button" class="btn btn-soft-secondary btn-sm text-start py-2 px-3 w-100 copilot-capability-secondary-action"
                                                    onclick='applyPrompt(@Html.Raw(Json.Serialize(prompt)), false)'>
                                                <i class="bi bi-arrow-return-right me-1"></i>@Loc.Get(prompt.Text)
                                            </button>
                                        }
                                    </div>
                                }
                            </details>
                        </div>
                    }
                </div>

                <div class="copilot-panel-heading mt-4">@standardLogicLabel</div>
                <div class="d-grid gap-3">
                    @foreach (var group in Model.StandardPromptGroups)
                    {
                        <div class="copilot-standard-group">
                            <div class="copilot-standard-title">@Loc.Get(group.Title)</div>
                            <div class="d-grid gap-2">
                                @foreach (var prompt in group.Prompts)
                                {
                                    <button type="button" class="btn btn-soft-secondary btn-sm text-start py-2 px-3 copilot-standard-action" onclick='applyPrompt(@Html.Raw(Json.Serialize(prompt)), true)'>
                                        <i class="bi bi-chat-text"></i>@Loc.Get(prompt.Text)
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div id="copilot-result-card" class="copilot-side-card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="small fw-bold text-uppercase text-muted letter-spacing-1">@Loc.Get("ResultsReasoningStory")</div>
                    <span id="copilot-strength" class="badge rounded-pill">-</span>
                </div>
                <div id="copilot-result-empty" class="text-center py-4 text-muted small">
                    <i class="bi bi-stars d-block fs-2 mb-2 opacity-25"></i>
                    @Loc.Get("ResultsDetailPanel")
                </div>
                <div id="copilot-result-body" class="d-none">
                    <div id="copilot-model" class="small text-muted mb-2 text-nowrap overflow-hidden text-truncate"></div>
                    <div id="copilot-notes" class="alert alert-warning p-1 small border-0 d-none mb-3"></div>
                    <div id="copilot-execution-wrap" class="d-none mb-4"><div id="copilot-execution"></div></div>
                    <div id="copilot-query-wrap" class="d-none mb-4">
                        <div class="small fw-bold text-uppercase text-muted letter-spacing-1 mb-2">@Loc.Get("CopilotQueryResults")</div>
                        <div id="copilot-query-results" class="d-grid gap-2"></div>
                    </div>
                    <div id="copilot-suggestions-wrap" class="d-none mb-4">
                        <div class="small fw-bold text-uppercase text-muted letter-spacing-1 mb-2">@Loc.Get("NextSteps")</div>
                        <div id="copilot-suggestions" class="d-flex flex-wrap gap-2"></div>
                    </div>
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="small fw-bold text-uppercase text-muted letter-spacing-1">@Loc.Get("SimilarTickets")</div>
                            <span id="copilot-ticket-count" class="badge bg-dark rounded-pill">0</span>
                        </div>
                        <div id="copilot-ticket-evidence" class="d-grid gap-2"></div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

<script>
    // Pane collapse: lets the operator hide the left history pane and/or the
    // right capabilities/results pane to give the active chat thread more
    // horizontal room. State is persisted per-browser so the choice survives
    // navigation and reload. CSS in copilot.css handles the visual collapse;
    // this just toggles the class and updates the toggle button's title.
    const COPILOT_PANE_STORAGE_KEYS = {
        history: 'copilot-history-pane-collapsed',
        side: 'copilot-side-pane-collapsed'
    };

    function toggleCopilotPane(which) {
        const ws = document.getElementById('copilot-workspace');
        if (!ws) return;
        const cls = which === 'history' ? 'history-collapsed' : 'side-collapsed';
        const collapsed = ws.classList.toggle(cls);
        try { localStorage.setItem(COPILOT_PANE_STORAGE_KEYS[which], collapsed ? '1' : '0'); } catch { /* quota; ignore */ }
        updateCopilotPaneToggleTitle(which, collapsed);
    }

    function updateCopilotPaneToggleTitle(which, collapsed) {
        const btn = document.querySelector(which === 'history' ? '.copilot-pane-toggle-history' : '.copilot-pane-toggle-side');
        if (!btn) return;
        const title = collapsed ? btn.dataset.expandTitle : btn.dataset.collapseTitle;
        if (title) btn.setAttribute('title', title);
    }

    // Restore the collapsed state from localStorage as soon as the workspace
    // exists in the DOM. Done inline (not on DOMContentLoaded) so the panes
    // never flash open before snapping closed on reload.
    (function restoreCopilotPaneState() {
        const ws = document.getElementById('copilot-workspace');
        if (!ws) return;
        for (const which of ['history', 'side']) {
            let stored = null;
            try { stored = localStorage.getItem(COPILOT_PANE_STORAGE_KEYS[which]); } catch { /* ignore */ }
            if (stored === '1') {
                ws.classList.add(which === 'history' ? 'history-collapsed' : 'side-collapsed');
                updateCopilotPaneToggleTitle(which, true);
            }
        }
    })();

    function openInvestigationTracePage(id, view = 'tree') {
        if (!id || id === '0' || id === 0) return;
        // Open in a new tab so the operator keeps their copilot conversation
        // intact while reviewing the trace. noopener prevents the new tab from
        // having access back to this window.
        const url = `/AiAnalysis/Investigation/${encodeURIComponent(id)}?view=${encodeURIComponent(view)}`;
        window.open(url, '_blank', 'noopener');
    }

    async function deleteTraceById(id) {
        const token = document.querySelector('#csrf-form input[name="__RequestVerificationToken"]').value;
        const res = await fetch(`@Url.Action("DeleteTrace", "AiAnalysis")?id=${encodeURIComponent(id)}`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'RequestVerificationToken': token,
                'X-Requested-With': 'XMLHttpRequest'
            }
        });
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch { }
        const ok = data.success || data.Success;
        const deletedCount = data.data?.deletedCount || data.Data?.deletedCount || 0;
        if (!res.ok || !ok || deletedCount <= 0) {
            throw new Error(data.message || data.Message || data.error || data.Error || text || "Failed to delete trace.");
        }
        return data;
    }

    async function deleteHistoryItem(id, btn) {
        if (!confirm("Delete this investigation story?")) return;
        
        try {
            await deleteTraceById(id);
            const wrap = btn.closest('.copilot-history-item-wrap');
            wrap.style.opacity = '0';
            setTimeout(() => {
                wrap.remove();
                renderEmptyArchiveIfNeeded();
            }, 300);
            if (typeof copilotHistory !== 'undefined') {
                copilotHistory = copilotHistory.filter(m => String(m.id || '') !== String(id));
                persistCopilotState();
                renderConversation();
            }
        } catch (e) {
            console.error("Delete failed", e);
            alert("Delete failed: " + e.message);
        }
    }

    function renderEmptyArchiveIfNeeded() {
        const archive = document.getElementById('copilot-story-archive');
        if (!archive || archive.querySelector('.copilot-history-item-wrap')) return;
        archive.innerHTML = `<div class="text-center py-4 opacity-25">
            <i class="bi bi-clock-history fs-2 d-block mb-2"></i>
            <span class="small">@Loc.Get("NoTracesArchived")</span>
        </div>`;
    }
</script>

<script>
    let currentSessionId = null;
    let currentCaseCode = null;
    let currentSourceSuite = null;
    let copilotHistory = [];
    let copilotQueue = [];
    let copilotPending = false;
    let copilotConversationVersion = 0;
    let currentThinkingStatus = 'Thinking';
    let copilotSignalRConnection = null;
    let copilotSignalRConnectionId = null;

    // ── Live progress timeline (Claude-style) ────────────────────────────────────────────
    // Instead of bucketing the orchestrator's progress events into a fixed 4-step checklist,
    // we keep the raw stream of statuses and surface them as Claude does:
    //   • a single live line shows the CURRENT activity
    //   • a disclosure (▸) reveals the full timeline of every status received
    //   • when the answer arrives, the bubble collapses into "Thought for N.Ns · K steps"
    let copilotProgressLog = [];          // [{ status, at, doneAt? }]
    let copilotProgressStartedAt = null;
    let copilotProgressFinishedAt = null;
    let copilotProgressExpanded = false;  // user toggle — sticky across re-renders
    let copilotProgressDone = false;

    function resetProgressLog() {
        copilotProgressLog = [];
        copilotProgressStartedAt = Date.now();
        copilotProgressFinishedAt = null;
        copilotProgressDone = false;
        // Don't reset the expanded flag — if the user opened the previous one, respect their preference.
    }

    function pushProgressStatus(status) {
        const trimmed = (status || '').trim();
        if (!trimmed) return;
        const now = Date.now();
        if (!copilotProgressStartedAt) copilotProgressStartedAt = now;
        // Close out the previous entry's duration so each row can show "in 320ms" once it's no longer current.
        const prev = copilotProgressLog[copilotProgressLog.length - 1];
        if (prev && !prev.doneAt) prev.doneAt = now;
        copilotProgressLog.push({ status: trimmed, at: now });
    }

    function finishProgressLog() {
        const now = Date.now();
        const prev = copilotProgressLog[copilotProgressLog.length - 1];
        if (prev && !prev.doneAt) prev.doneAt = now;
        copilotProgressFinishedAt = now;
        copilotProgressDone = true;
    }

    function formatProgressDuration(ms) {
        if (ms < 1000) return `${ms} ms`;
        return `${(ms / 1000).toFixed(1)} s`;
    }

    // Render the Claude-style timeline. Header always visible; body collapsed by default and
    // toggled by the user via the chevron. Updates in-place so the bubble doesn't jump.
    // Map a free-text pipeline stage name to a Bootstrap icon + category class.
    // Match more-specific terms first (verifiedquery before "query", writeintent
    // before "intent"). Falls back to a neutral chevron icon so unknown stages
    // still render cleanly. The category drives both the icon hue and the badge
    // tint via .copilot-step-cat-<name> CSS classes.
    function _copilotStageIconFor(stage) {
        const s = (stage || '').toLowerCase();
        if (s.includes('refusal') || s.includes('reject') || s.includes('blocked')) return { icon: 'bi-x-octagon', cat: 'refusal' };
        if (s.includes('verifiedquery') || s.includes('verified-query') || s.includes('verified query')) return { icon: 'bi-shield-check', cat: 'verified' };
        if (s.includes('writeintent') || s.includes('write-intent') || s.includes('write intent')) return { icon: 'bi-pencil-square', cat: 'writeintent' };
        if (s.includes('operationalguard') || s.includes('operational-guard') || s.includes('operational guard') || (s.includes('guard') && !s.includes('shield'))) return { icon: 'bi-shield-exclamation', cat: 'guard' };
        if (s.includes('semantic') || s.includes('search')) return { icon: 'bi-search-heart', cat: 'search' };
        if (s.includes('retriev') || s.includes('embed') || s.includes('vector')) return { icon: 'bi-database', cat: 'retrieve' };
        if (s.includes('classif') || s.includes('intent') || s.includes('shape')) return { icon: 'bi-tags', cat: 'classify' };
        if (s.includes('schema') || s.includes('link')) return { icon: 'bi-diagram-2', cat: 'schema' };
        if (s.includes('plan')) return { icon: 'bi-diagram-3', cat: 'plan' };
        if (s.includes('dispatch') || s.includes('router')) return { icon: 'bi-signpost-split', cat: 'dispatch' };
        if (s.includes('tool')) return { icon: 'bi-tools', cat: 'tool' };
        if (s.includes('explain')) return { icon: 'bi-chat-square-text', cat: 'explain' };
        if (s.includes('aggregat') || s.includes('summar')) return { icon: 'bi-calculator', cat: 'aggregate' };
        if (s.includes('compos') || s.includes('build') || s.includes('assembl')) return { icon: 'bi-puzzle', cat: 'compose' };
        if (s.includes('normaliz') || s.includes('clean')) return { icon: 'bi-funnel', cat: 'normalize' };
        if (s.includes('validat') || s.includes('check') || s.includes('ast')) return { icon: 'bi-check2-circle', cat: 'validate' };
        if (s.includes('parse') || s.includes('nl2sql') || s.includes('sql')) return { icon: 'bi-braces', cat: 'parse' };
        if (s.includes('render') || s.includes('format')) return { icon: 'bi-display', cat: 'render' };
        if (s.includes('think') || s.includes('reason')) return { icon: 'bi-lightbulb', cat: 'reason' };
        if (s.includes('llm') || s.includes('model') || s.includes('completion')) return { icon: 'bi-cpu', cat: 'llm' };
        if (s.includes('rag') || s.includes('knowledge')) return { icon: 'bi-book', cat: 'rag' };
        if (s.includes('cache') || s.includes('hit')) return { icon: 'bi-lightning-charge', cat: 'cache' };
        if (s.includes('history') || s.includes('memory')) return { icon: 'bi-clock-history', cat: 'history' };
        if (s.includes('cost') || s.includes('token')) return { icon: 'bi-coin', cat: 'cost' };
        return { icon: 'bi-arrow-right-circle', cat: 'other' };
    }

    function renderProgressTimeline() {
        const inProgress = !copilotProgressDone;
        const log = copilotProgressLog;
        const last = log[log.length - 1];
        const elapsed = (copilotProgressFinishedAt || Date.now()) - (copilotProgressStartedAt || Date.now());
        const elapsedLabel = formatProgressDuration(elapsed);

        // Header — single live line summarising current state. Spinner while
        // in progress, success check once complete.
        const headerIcon = inProgress
            ? '<span class="copilot-live-spinner" aria-hidden="true"></span>'
            : '<i class="bi bi-check2-circle" style="color: var(--success-color);"></i>';
        const headerText = inProgress
            ? (last ? escapeHtml(last.status) : 'Thinking…')
            : `Thought for ${elapsedLabel}${log.length ? ` · ${log.length} step${log.length === 1 ? '' : 's'}` : ''}`;
        const chevron = log.length
            ? `<button type="button" class="copilot-live-toggle" onclick="toggleProgressTimeline()" aria-expanded="${copilotProgressExpanded}" aria-label="Show details">
                   <i class="bi bi-chevron-${copilotProgressExpanded ? 'up' : 'down'}"></i>
               </button>`
            : '';

        // Body — full timeline, only rendered when expanded so collapsed view stays compact.
        let bodyHtml = '';
        if (copilotProgressExpanded && log.length) {
            // Detect consecutive duplicates so a 2-pass / retry pipeline doesn't
            // produce a wall of identical rows. Each "run" of the same stage is
            // collapsed into one row with a count badge ×N. The summed duration
            // is shown in meta so timing info isn't lost.
            const runs = [];
            log.forEach((entry, i) => {
                const prev = runs[runs.length - 1];
                const ms = entry.doneAt ? entry.doneAt - entry.at : 0;
                if (prev && prev.status === entry.status && !prev.isCurrent && !(i === log.length - 1 && inProgress)) {
                    prev.count += 1;
                    prev.ms += ms;
                } else {
                    runs.push({ status: entry.status, count: 1, ms, isCurrent: i === log.length - 1 && inProgress });
                }
            });
            const rows = runs.map(run => {
                const info = _copilotStageIconFor(run.status);
                const stepIcon = run.isCurrent
                    ? '<span class="copilot-live-spinner copilot-live-spinner-sm"></span>'
                    : `<i class="bi ${info.icon}"></i>`;
                const meta = run.ms ? `<span class="copilot-progress-step-meta">${formatProgressDuration(run.ms)}</span>` : '';
                const countBadge = run.count > 1 ? `<span class="copilot-progress-step-count" title="${run.count} consecutive runs of this stage">×${run.count}</span>` : '';
                return `
                    <li class="copilot-progress-step ${run.isCurrent ? 'is-current' : 'is-done'} copilot-step-cat-${info.cat}">
                        <span class="copilot-progress-step-icon">${stepIcon}</span>
                        <span class="copilot-progress-step-text">${escapeHtml(run.status)}${countBadge}</span>
                        ${meta}
                    </li>`;
            }).join('');
            bodyHtml = `<ol class="copilot-progress-steps" aria-label="Detailed progress">${rows}</ol>`;
        }

        return `
            <div class="copilot-live-progress ${inProgress ? 'is-active' : 'is-complete'}" aria-live="polite">
                <div class="copilot-live-header">
                    <span class="copilot-live-icon">${headerIcon}</span>
                    <span class="copilot-live-text">${headerText}</span>
                    ${chevron}
                </div>
                ${bodyHtml}
            </div>`;
    }

    function toggleProgressTimeline() {
        copilotProgressExpanded = !copilotProgressExpanded;
        updateProgressTimeline();
    }

    // Compute the collapsed-duplicates run list once (shared by render + patch).
    function _copilotProgressRuns() {
        const inProgress = !copilotProgressDone;
        const log = copilotProgressLog;
        const runs = [];
        log.forEach((entry, i) => {
            const prev = runs[runs.length - 1];
            const ms = entry.doneAt ? entry.doneAt - entry.at : 0;
            const isCurrent = i === log.length - 1 && inProgress;
            if (prev && prev.status === entry.status && !prev.isCurrent && !isCurrent) {
                prev.count += 1;
                prev.ms += ms;
            } else {
                runs.push({ status: entry.status, count: 1, ms, isCurrent });
            }
        });
        return runs;
    }

    // Surgical in-place update of the live-progress widget. Called on every
    // SignalR ProgressUpdate event and on chevron toggles. Avoids the
    // outerHTML-replace flicker that previously re-fired the fade-in animation
    // on every existing step every time a new event arrived.
    function updateProgressTimeline() {
        const live = document.querySelector('.copilot-live-progress');
        if (!live) { renderConversation(); return; }

        const inProgress = !copilotProgressDone;
        const log = copilotProgressLog;
        const last = log[log.length - 1];
        const elapsed = (copilotProgressFinishedAt || Date.now()) - (copilotProgressStartedAt || Date.now());
        const elapsedLabel = formatProgressDuration(elapsed);

        // Top-level active/complete class swap. Toggling classes is cheap and
        // doesn't repaint the children.
        live.classList.toggle('is-active', inProgress);
        live.classList.toggle('is-complete', !inProgress);

        // ── Header (icon + text + chevron) — patched, not replaced ────────────
        const headerIconEl = live.querySelector('.copilot-live-icon');
        if (headerIconEl) {
            const wantSpinner = inProgress;
            const hasSpinner = !!headerIconEl.querySelector('.copilot-live-spinner');
            // Only swap the inner HTML when the icon kind actually flips
            // (spinner ↔ check). Avoids reflow on every text update.
            if (wantSpinner !== hasSpinner) {
                headerIconEl.innerHTML = wantSpinner
                    ? '<span class="copilot-live-spinner" aria-hidden="true"></span>'
                    : '<i class="bi bi-check2-circle" style="color: var(--success-color);"></i>';
            }
        }
        const headerTextEl = live.querySelector('.copilot-live-text');
        if (headerTextEl) {
            const wantText = inProgress
                ? (last ? last.status : 'Thinking…')
                : `Thought for ${elapsedLabel}${log.length ? ` · ${log.length} step${log.length === 1 ? '' : 's'}` : ''}`;
            // textContent is cheaper than innerHTML for a plain string, and
            // doesn't re-trigger the shimmer animation when nothing changed.
            if (headerTextEl.textContent !== wantText) headerTextEl.textContent = wantText;
        }
        // Chevron toggle button — create/remove/update aria state.
        const headerEl = live.querySelector('.copilot-live-header');
        let chevronBtn = live.querySelector('.copilot-live-toggle');
        if (log.length && !chevronBtn && headerEl) {
            headerEl.insertAdjacentHTML('beforeend', `
                <button type="button" class="copilot-live-toggle" onclick="toggleProgressTimeline()" aria-expanded="${copilotProgressExpanded}" aria-label="Show details">
                    <i class="bi bi-chevron-${copilotProgressExpanded ? 'up' : 'down'}"></i>
                </button>`);
        } else if (!log.length && chevronBtn) {
            chevronBtn.remove();
        } else if (chevronBtn) {
            chevronBtn.setAttribute('aria-expanded', String(copilotProgressExpanded));
            const i = chevronBtn.querySelector('i');
            const want = `bi bi-chevron-${copilotProgressExpanded ? 'up' : 'down'}`;
            if (i && i.className !== want) i.className = want;
        }

        // ── Body — the <ol> of step rows, diff-patched ────────────────────────
        let ol = live.querySelector('.copilot-progress-steps');
        if (!copilotProgressExpanded || !log.length) {
            // Collapsed or empty — drop the list entirely so it doesn't take space.
            if (ol) ol.remove();
            return;
        }
        if (!ol) {
            ol = document.createElement('ol');
            ol.className = 'copilot-progress-steps';
            ol.setAttribute('aria-label', 'Detailed progress');
            live.appendChild(ol);
        }

        const runs = _copilotProgressRuns();
        const existingLis = Array.from(ol.children);

        runs.forEach((run, i) => {
            const info = _copilotStageIconFor(run.status);
            // Signature lets us skip the row entirely when nothing changed —
            // this is what stops the flicker on every SignalR tick.
            const sig = `${run.status}|${run.count}|${run.ms}|${run.isCurrent}|${info.cat}|${info.icon}`;
            let li = existingLis[i];
            if (li && li.dataset.sig === sig) return; // unchanged → leave the DOM alone

            const stepIcon = run.isCurrent
                ? '<span class="copilot-live-spinner copilot-live-spinner-sm"></span>'
                : `<i class="bi ${info.icon}"></i>`;
            const countBadge = run.count > 1
                ? `<span class="copilot-progress-step-count" title="${run.count} consecutive runs of this stage">×${run.count}</span>`
                : '';
            const meta = run.ms ? `<span class="copilot-progress-step-meta">${formatProgressDuration(run.ms)}</span>` : '';
            const cls = `copilot-progress-step ${run.isCurrent ? 'is-current' : 'is-done'} copilot-step-cat-${info.cat}`;
            const inner = `
                <span class="copilot-progress-step-icon">${stepIcon}</span>
                <span class="copilot-progress-step-text">${escapeHtml(run.status)}${countBadge}</span>
                ${meta}`;

            if (!li) {
                // New row → append. CSS fade-in fires once, only on this row.
                li = document.createElement('li');
                li.className = cls;
                li.innerHTML = inner;
                li.dataset.sig = sig;
                ol.appendChild(li);
            } else {
                // Existing row that changed (e.g. doneAt just arrived, current →
                // done, count incremented). Patch in place — no animation re-fire.
                if (li.className !== cls) li.className = cls;
                li.innerHTML = inner;
                li.dataset.sig = sig;
            }
        });
        // Defensive trim — if for some reason the run list shrunk (shouldn't
        // happen in normal flow but happens if the user clears mid-run).
        for (let i = existingLis.length - 1; i >= runs.length; i--) existingLis[i].remove();
    }

    const copilotSurfaceKey = @Html.Raw(Json.Serialize(copilotSurface));
    const copilotStorageKey = `ai-support-copilot-history-${copilotSurfaceKey}`;
    const copilotInitialPrompt = @Html.Raw(Json.Serialize(initialPrompt));
    const copilotInitialCaseCode = @Html.Raw(Json.Serialize(initialCaseCode));
    const copilotInitialSourceSuite = @Html.Raw(Json.Serialize(initialSourceSuite));
    const copilotReportStartDate = @Html.Raw(Json.Serialize(copilotReportStartDate));
    const copilotReportEndDate = @Html.Raw(Json.Serialize(copilotReportEndDate));

    window.metadataHints = { entities: [], fields: [], temporal: [], operations: [] };
    let activeHintIndex = -1;

    // SignalR status indicator — small colored dot in the history-pane header
    // (id="copilot-signalr-status"). Centralises state transitions so adding /
    // renaming states only touches one helper instead of four inline blocks.
    function updateSignalRStatus(state) {
        const el = document.getElementById('copilot-signalr-status');
        if (!el) return;
        const labels = {
            connecting: 'SignalR: Connecting…',
            connected: 'SignalR: Connected',
            reconnecting: 'SignalR: Reconnecting…',
            offline: 'SignalR: Offline'
        };
        const safeState = labels[state] ? state : 'offline';
        el.title = labels[safeState];
        el.setAttribute('aria-label', labels[safeState]);
        el.className = 'copilot-signalr-dot copilot-signalr-dot-' + safeState;
    }

    async function initCopilotSignalR() {
        updateSignalRStatus('connecting');

        copilotSignalRConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/copilotChat")
            .withAutomaticReconnect()
            .build();

        copilotSignalRConnection.onreconnecting(() => updateSignalRStatus('reconnecting'));
        copilotSignalRConnection.onreconnected(() => updateSignalRStatus('connected'));
        copilotSignalRConnection.onclose(() => updateSignalRStatus('offline'));
        copilotSignalRConnection.on("ProgressUpdate", (status) => {
            console.log("SIGNALR_PROGRESS_RECEIVED:", status);
            currentThinkingStatus = status;
            pushProgressStatus(status);

            // Diff-patch the existing widget so unchanged rows keep their DOM
            // node (no re-paint, no fade-in re-fire). Only the newly-appended
            // row animates; everything else is untouched. Falls back to a full
            // renderConversation only when the bubble doesn't exist yet (very
            // first event before the thinking bubble has mounted).
            updateProgressTimeline();
        });

        try {
            await copilotSignalRConnection.start();
            console.log("Copilot SignalR Connected. ID:", copilotSignalRConnection.connectionId);
            updateSignalRStatus('connected');

            if (currentSessionId) {
                await copilotSignalRConnection.invoke("JoinChat", currentSessionId.toString());
            }
        } catch (err) {
            console.error("SignalR Connection Error:", err);
            updateSignalRStatus('offline');
            // Try to reconnect after a delay
            setTimeout(initCopilotSignalR, 5000);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        initCopilotSignalR();
        // PRIORITY 1: Apply initial prompt from URL immediately
        try {
            if (copilotInitialPrompt && copilotInitialPrompt.trim().length > 0) {
                const input = document.getElementById('copilot-question');
                if (input) {
                    input.value = copilotInitialPrompt;
                    currentCaseCode = copilotInitialCaseCode || null;
                    currentSourceSuite = copilotInitialSourceSuite || null;
                    input.dispatchEvent(new Event('input'));
                    input.focus();
                    console.log("Copilot: Priority prompt applied", copilotInitialPrompt);
                    
                    // Backup check in case of race conditions
                    setTimeout(() => {
                        if (input.value !== copilotInitialPrompt) {
                            input.value = copilotInitialPrompt;
                            input.dispatchEvent(new Event('input'));
                        }
                    }, 200);
                }
            }
        } catch (e) { console.error("Copilot: Initial prompt error", e); }

        restoreCopilotState();
        resetResultDetails();
        loadMetadataHints();
        const input = document.getElementById('copilot-question');
        if (input) {
            input.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = Math.min(this.scrollHeight, 250) + 'px';
                this.style.overflowY = this.scrollHeight > 250 ? 'auto' : 'hidden';
                handleAutocomplete();
                const thread = document.getElementById('copilot-thread');
                if (thread) thread.scrollTop = thread.scrollHeight;
            });
            input.focus();
        }
    });

    function applyPrompt(prompt, autoSend = false) {
        const input = document.getElementById('copilot-question');
        if (!input) return;
        
        if (typeof prompt === 'object' && prompt !== null) {
            input.value = prompt.text || prompt.Text || "";
            currentCaseCode = prompt.code || prompt.Code || null;
            currentSourceSuite = prompt.sourceSuite || prompt.SourceSuite || null;
        } else {
            input.value = prompt;
            currentCaseCode = null;
            currentSourceSuite = null;
        }

        input.dispatchEvent(new Event('input'));
        if (autoSend) askCopilot(); else input.focus();
    }

    function clearLocalCopilotConversation(keepSessionId = false) {
        copilotConversationVersion += 1;
        if (!keepSessionId) currentSessionId = null;
        copilotHistory = [];
        copilotQueue = [];
        copilotPending = false;
        localStorage.removeItem(copilotStorageKey);
        const input = document.getElementById('copilot-question');
        if (input) { input.value = ''; input.style.height = 'auto'; }
        renderConversation();
        resetResultDetails();
        const btn = document.getElementById('copilot-ask-btn');
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-up-short fs-3"></i>';
        }
        if (!keepSessionId) {
            document.querySelectorAll('#copilot-session-list .copilot-history-item').forEach(el => el.classList.remove('active'));
        }
    }

    async function clearChat() {
        clearLocalCopilotConversation();
        try {
            const res = await postCopilotJson('@Url.Action("CreateSession", "AiAnalysis")', "New Chat");
            if (res && res.data) {
                currentSessionId = res.data.id;
                // Add to session list UI
                const list = document.getElementById('copilot-session-list');
                const noSessions = document.getElementById('copilot-no-sessions');
                if (noSessions) noSessions.remove();
                
                const html = `
                    <div class="copilot-history-item-wrap position-relative" data-session-id="${res.data.id}">
                        <a href="javascript:void(0)" class="copilot-history-item active" onclick="loadSession('${res.data.id}')">
                            <i class="bi bi-chat-left-text me-2"></i>
                            <div class="text-truncate">
                                <div class="fw-bold" style="font-size: 0.8rem;">${res.data.title}</div>
                                <div class="small opacity-75">Just now</div>
                            </div>
                        </a>
                        <button type="button" class="btn btn-link text-danger p-0 position-absolute top-50 translate-middle-y end-0 me-2 copilot-delete-trace-btn" 
                                onclick="event.stopPropagation(); deleteSession('${res.data.id}', this)" title="Delete Session">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>`;
                if (list) list.insertAdjacentHTML('afterbegin', html);
            }
        } catch (e) {
            console.error(e);
        }
    }

    async function loadSession(id) {
        try {
            const res = await fetch(`@Url.Action("LoadSession", "AiAnalysis")?id=${id}`);
            const text = await res.text();
            let result = JSON.parse(text);
            if (result && result.success && result.data) {
                clearLocalCopilotConversation();
                currentSessionId = result.data.id;
                copilotHistory = result.data.messages || [];
                renderConversation();
                
                document.querySelectorAll('#copilot-session-list .copilot-history-item').forEach(el => el.classList.remove('active'));
                const sessionWrap = document.querySelector(`.copilot-history-item-wrap[data-session-id='${id}'] a`);
                if (sessionWrap) sessionWrap.classList.add('active');

                if (copilotSignalRConnection && copilotSignalRConnection.state === signalR.HubConnectionState.Connected) {
                    await copilotSignalRConnection.invoke("JoinChat", id.toString());
                }
            }
        } catch (e) {
            console.error("Failed to load session", e);
            alert("Failed to load session");
        }
    }

    async function deleteSession(id, btn) {
        if (!confirm("Delete this session?")) return;
        try {
            const token = document.querySelector('#csrf-form input[name="__RequestVerificationToken"]')?.value || '';
            const res = await fetch(`@Url.Action("DeleteSession", "AiAnalysis")?id=${encodeURIComponent(id)}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            const text = await res.text();
            let data = JSON.parse(text);
            if (data && data.success) {
                const wrap = btn.closest('.copilot-history-item-wrap');
                wrap.style.opacity = '0';
                setTimeout(() => { wrap.remove(); }, 300);
                if (currentSessionId == id) {
                    clearChat();
                }
            }
        } catch(e) {
            console.error("Delete session failed", e);
        }
    }

    function getCurrentConversationTraceIds() {
        return [...new Set(copilotHistory
            .filter(m => m.role === 'assistant' && m.id && Number.isFinite(Number(m.id)))
            .map(m => Number(m.id)))];
    }

    function removeArchiveItemsByTraceIds(traceIds) {
        const ids = new Set((traceIds || []).map(id => String(id)));
        document.querySelectorAll('.copilot-history-item-wrap').forEach(item => {
            if (ids.has(String(item.dataset.traceId || ''))) {
                item.remove();
            }
        });
        renderEmptyArchiveIfNeeded();
    }

    async function postCopilotJson(url, body) {
        const token = document.querySelector('#csrf-form input[name="__RequestVerificationToken"]')?.value || '';
        const res = await fetch(url, {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token,
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(body)
        });
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch { }
        if (!res.ok || !(data.success || data.Success)) {
            throw new Error(data.message || data.Message || data.error || data.Error || text || 'Request failed.');
        }
        return data;
    }

    async function deleteCurrentConversation() {
        if (!currentSessionId) {
            clearLocalCopilotConversation();
            return;
        }

        if (!confirm("Clear the current session questions and responses?")) return;

        try {
            const data = await postCopilotJson('@Url.Action("ClearSessionMessages", "AiAnalysis")', { sessionId: currentSessionId });
            clearLocalCopilotConversation();
            alert(data.message || data.Message || 'Current session cleared.');
        } catch (e) {
            alert("Clear failed: " + e.message);
        }
    }

    async function deleteAllConversations() {
        if (!confirm("Delete all Copilot sessions and their chat history? This cannot be undone.")) return;

        try {
            const data = await postCopilotJson('@Url.Action("DeleteAllSessions", "AiAnalysis")', null);
            clearLocalCopilotConversation();
            const sessionList = document.getElementById('copilot-session-list');
            if (sessionList) sessionList.innerHTML = `<div class="text-center py-4 opacity-25" id="copilot-no-sessions"><span class="small">No recent chats</span></div>`;
            alert(data.message || data.Message || 'All sessions deleted.');
        } catch (e) {
            alert("Delete failed: " + e.message);
        }
    }

    function handleCopilotKeyDown(e) {
        const list = document.getElementById('copilot-autocomplete-list');
        const isVisible = list && list.style.display === 'block';
        if (isVisible) {
            const items = list.querySelectorAll('.copilot-autocomplete-item');
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                activeHintIndex = (activeHintIndex + 1) % items.length;
                updateAutocompleteActiveItem();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                activeHintIndex = (activeHintIndex - 1 + items.length) % items.length;
                updateAutocompleteActiveItem();
            } else if (e.key === 'Enter' || e.key === 'Tab') {
                if (activeHintIndex >= 0) {
                    e.preventDefault();
                    applyAutocomplete(items[activeHintIndex].querySelector('.copilot-hint-name').innerText);
                } else if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    askCopilot();
                }
            } else if (e.key === 'Escape') hideAutocomplete();
        } else if ((e.key === 'Enter' || e.keyCode === 13) && !e.shiftKey) {
            e.preventDefault();
            askCopilot();
        }
    }

    function updateAutocompleteActiveItem() {
        const items = document.querySelectorAll('.copilot-autocomplete-item');
        items.forEach((item, idx) => item.classList.toggle('active', idx === activeHintIndex));
    }

    async function askCopilot() {
        const input = document.getElementById('copilot-question');
        const question = input.value.trim();
        if (!question) return;
        // Track repeat frequency — surfaces an auto-promote-to-Trusted banner
        // once a question crosses the threshold (currently 3 asks). Closes the
        // loop on the Trust feature: analysts don't have to remember to click.
        _autoPromoteTrack(question);

        currentThinkingStatus = '🔍 Initializing Agentic Pipeline...';
        // Fresh live-progress timeline for the new question — old durations shouldn't leak in.
        resetProgressLog();
        const codeToUse = currentCaseCode;
        const sourceSuiteToUse = currentSourceSuite;
        currentCaseCode = null; // Reset for next interaction
        currentSourceSuite = null;

        input.value = '';
        hideAutocomplete();
        resetComposerInput();
        copilotQueue.push({ question: question, caseCode: codeToUse, sourceSuite: sourceSuiteToUse });
        copilotHistory.push({ role: 'user', content: question, isQueued: true });
        renderConversation();
        persistCopilotState();
        // Ensure SignalR is connected before starting
        if (!copilotSignalRConnection || copilotSignalRConnection.state !== signalR.HubConnectionState.Connected) {
            console.log("Copilot: Waiting for SignalR connection...");
            try {
                await initCopilotSignalR();
            } catch(e) {
                console.error("SignalR failed, proceeding without it", e);
            }
        }

        if (!copilotPending) processCopilotQueue();
    }

    async function processCopilotQueue() {
        if (copilotQueue.length === 0) {
            copilotPending = false;
            renderConversation();
            return;
        }
        copilotPending = true;
        resetProgressLog();
        const requestVersion = copilotConversationVersion;
        const task = copilotQueue.shift();
        const currentQuestion = task.question;
        const currentQuestionCode = task.caseCode;
        const currentSourceSuite = task.sourceSuite;

        const msg = copilotHistory.find(m => m.role === 'user' && m.content === currentQuestion && m.isQueued);
        if (msg) { msg.isQueued = false; msg.isActive = true; }
        const btn = document.getElementById('copilot-ask-btn');
        if (!btn) {
            copilotPending = false;
            return;
        }
        const prevHtml = btn.innerHTML;
        btn.disabled = true; btn.innerHTML = '<div class="copilot-spinner"></div>';
        renderConversation();

        const lastTraceId = [...copilotHistory].reverse().find(m => m.role === 'assistant' && m.id)?.id || null;

        try {
            const res = await fetch('@Url.Action("AskCopilot", "AiAnalysis")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    sessionId: currentSessionId,
                    surface: copilotSurfaceKey,
                    reportStartDate: copilotReportStartDate,
                    reportEndDate: copilotReportEndDate,
                    lastTraceId: lastTraceId ? parseInt(lastTraceId, 10) : null,
                    connectionId: copilotSignalRConnection ? copilotSignalRConnection.connectionId : null,
                    question: currentQuestion,
                    caseCode: currentQuestionCode,
                    sourceSuite: currentSourceSuite,
                    history: copilotHistory.filter(m => !m.isQueued && !(m.role === 'user' && m.content === currentQuestion))
                })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data?.message || 'Request failed');
            if (requestVersion !== copilotConversationVersion) return;
            
            // Generated SQL lives on structuredQueryResults[i].execution.generatedSql.
            // Surface it alongside the message so the per-table "View SQL" button can
            // light up after the message HTML is rendered.
            const sqlList = Array.isArray(data.structuredQueryResults)
                ? data.structuredQueryResults
                    .map(r => r?.execution?.generatedSql || r?.execution?.GeneratedSql || '')
                    .filter(s => typeof s === 'string' && s.trim() !== '')
                : [];
            const asstMsg = {
                role: 'assistant', content: data.answer || '', id: data.traceId || null,
                executionDetails: data.executionDetails || null, usedTool: data.usedTool || '', evidenceStrength: data.evidenceStrength || '',
                sqlList,
                isTyping: true
            };
            
            if (data.sessionId) {
                currentSessionId = data.sessionId;
            }
            
            const idx = copilotHistory.length - 1 - [...copilotHistory].reverse().findIndex(m => m.role === 'user' && m.content === currentQuestion);
            if (idx !== -1) copilotHistory.splice(idx + 1, 0, asstMsg); else copilotHistory.push(asstMsg);

            // Response is here — finalize the live timeline so it shows "Thought for X.Xs".
            finishProgressLog();

            renderCopilotResult(data);
            persistCopilotState();
        } catch (e) {
            if (requestVersion === copilotConversationVersion) alert("Error: " + e.message);
        } finally {
            const active = copilotHistory.find(m => m.role === 'user' && m.isActive);
            if (active) active.isActive = false;
            if (copilotQueue.length === 0) { btn.disabled = false; btn.innerHTML = prevHtml; }
            processCopilotQueue();
        }
    }

    function typewriterEffect(element, text, callback) {
        // The previous implementation re-parsed the ENTIRE growing markdown string every 10ms
        // (per-character) and forced a scroll on each frame. For markdown tables especially,
        // this caused the assistant card to thrash — what the user reported as "jumping".
        // Server responses arrive fully-formed, not streamed, so render once and we're done.
        element.innerHTML = formatMessageBody(text);
        const thread = document.getElementById('copilot-thread');
        if (thread) thread.scrollTop = thread.scrollHeight;
        if (callback) callback();
    }

    function renderConversation() {
        const host = document.getElementById('copilot-thread');
        if (!copilotHistory.length && !copilotPending) {
            host.innerHTML = `<div class="copilot-empty"><h4 class="fw-bold text-main mb-3">@Loc.Get("CopilotEmptyState")</h4><p class="text-muted mx-auto" style="max-width: 25rem;">@Loc.Get("CopilotConversationHint")</p></div>`;
            return;
        }

        const thinkingHtml = copilotPending ? `
            <div class="copilot-message copilot-message-assistant animate__animated animate__fadeIn">
                <div class="small fw-bold text-uppercase opacity-75 mb-2" style="letter-spacing: 0.12em; color: var(--text-muted); width: max-content; display: block;">AI COPILOT</div>
                <div class="copilot-message-body" style="width: 100%;">
                    ${renderProgressTimeline()}
                </div>
            </div>` : '';

        const messageElements = [];
        let thinkingInserted = false;
        let typingMessage = null;

        copilotHistory.forEach((m, idx) => {
            if (m.role === 'user') {
                const status = m.isQueued ? 'QUEUED' : 'YOU';
                const opacity = m.isQueued ? 'opacity-50' : '';
                messageElements.push(`<div class="copilot-message copilot-message-user ${opacity}">
                            <div class="small fw-bold text-uppercase opacity-75 mb-2 d-flex justify-content-end align-items-center gap-2" style="width: 100%;">
                                <button type="button" class="btn btn-link btn-sm p-0 lh-1 text-muted copilot-copy-btn" onclick="copyCopilotQuestion(${idx}, this)" title="Copy question" aria-label="Copy question"><i class="bi bi-clipboard"></i></button>
                                <span style="width: max-content;">${status}</span>
                            </div>
                            <div class="copilot-message-body">${formatMessageBody(m.content)}</div>
                        </div>`);
                
                if (m.isActive && copilotPending) {
                    messageElements.push(thinkingHtml);
                    thinkingInserted = true;
                }
            } else {
                const isLatest = idx === copilotHistory.length - 1;
                const bodyId = `msg-body-${idx}`;
                
                if (isLatest && m.isTyping) {
                    typingMessage = m;
                    messageElements.push(`<div class="copilot-message copilot-message-assistant animate__animated animate__fadeInUp">
                                <div class="small fw-bold text-uppercase opacity-75 mb-2" style="letter-spacing: 0.12em; color: var(--text-muted); width: max-content;">AI COPILOT</div>
                                <div class="copilot-message-body" id="${bodyId}"></div>
                            </div>`);
                } else {
                    const collapsed = !!m.isCollapsed;
                    const collapseTitle = collapsed ? 'Expand response' : 'Collapse response';
                    const chevron = collapsed ? 'down' : 'up';
                    messageElements.push(`<div class="copilot-message copilot-message-assistant ${collapsed ? 'copilot-message-collapsed' : ''}" data-msg-idx="${idx}">
                                <div class="copilot-message-header">
                                    <span class="small fw-bold text-uppercase opacity-75" style="letter-spacing: 0.12em; color: var(--text-muted);">AI COPILOT</span>
                                    <button type="button" class="copilot-collapse-btn" onclick="toggleAssistantCollapse(${idx})" aria-expanded="${!collapsed}" title="${collapseTitle}" aria-label="${collapseTitle}">
                                        <i class="bi bi-chevron-${chevron}"></i>
                                    </button>
                                </div>
                                <div class="copilot-message-body">${formatMessageBody(m.content)}</div>
                                ${m.id ? `<div class="mt-2 d-flex justify-content-between align-items-center gap-2 copilot-message-footer">
                                    <div class="copilot-cost-badges">${renderCostBadges(m.executionDetails)}</div>
                                    <button class="btn btn-outline-primary btn-sm rounded-pill" onclick="openInvestigationTracePage('${m.id}')">Open Investigation</button>
                                </div>` : ''}
                            </div>`);
                }
            }
        });

        if (copilotPending && !thinkingInserted) {
            messageElements.push(thinkingHtml);
        }

        host.innerHTML = messageElements.join('');

        // ── Consolidate per-message action buttons into a single toolbar row ─────────
        // After the message HTML is rendered, every assistant message with a result table
        // ends up with three separate action zones:
        //   1. .copilot-table-actions  (Show all / Explain / Follow-ups / Heat / … / Export)
        //   2. .copilot-chart-panel    (View as chart toggle + chart-type dropdown)
        //   3. .copilot-message-footer (Open Investigation + cost badges)
        // The user wants them visually unified — one toolbar instead of three rows.
        // Strategy: move the "View as chart" button + the "Open Investigation" button INTO
        // the existing .copilot-table-actions container. The chart canvas and the cost
        // badges stay where they are (below); only the buttons relocate.
        host.querySelectorAll('.copilot-message-assistant').forEach(msg => {
            const actions = msg.querySelector('.copilot-table-actions');
            if (!actions) return;   // no result table → nothing to consolidate

            // Move "View as chart" button. Keep the type-dropdown + canvas in the panel below.
            // The toggle handler resolves the panel via .closest() — that breaks once the
            // button is detached from the panel, so we stamp a stable id link both ways and
            // the handler falls back to a getElementById lookup when closest() returns null.
            const chartBtn = msg.querySelector('.copilot-chart-toggle');
            if (chartBtn && !actions.contains(chartBtn)) {
                const panel = msg.querySelector('.copilot-chart-panel');
                if (panel) {
                    if (!panel.id) panel.id = 'copilot-chart-panel-' + Math.random().toString(36).slice(2, 10);
                    chartBtn.dataset.panelId = panel.id;
                }
                chartBtn.classList.add('copilot-table-export');
                actions.appendChild(chartBtn);
            }

            // Move "Open Investigation" out of the bubble footer into the toolbar.
            const footer = msg.querySelector('.copilot-message-footer');
            const invBtn = footer?.querySelector('button.btn-outline-primary');
            if (invBtn && !actions.contains(invBtn)) {
                invBtn.classList.remove('btn-outline-primary', 'btn-sm', 'rounded-pill');
                invBtn.classList.add('copilot-table-export');
                actions.appendChild(invBtn);
            }
            // If the bubble footer is now empty of buttons, hide it so the cost badges
            // (which live in the same footer) move up against the table or, if no cost
            // badges, the empty row collapses entirely.
            if (footer && footer.querySelectorAll('button').length === 0
                && footer.querySelector('.copilot-cost-badges')?.children.length === 0) {
                footer.style.display = 'none';
            }

            // Stamp generated SQL onto each table wrap inside the message, in the
            // order the structured results came back. Lights up the per-table
            // "View SQL" and "Trust" action buttons (both hidden by default).
            // Also passes the user's originating question so the Trust dialog
            // can pre-fill it for editing.
            const msgIdx = parseInt(msg.dataset.msgIdx, 10);
            if (!isNaN(msgIdx)) {
                const m = copilotHistory[msgIdx];
                if (m && Array.isArray(m.sqlList) && m.sqlList.length > 0) {
                    // Walk backward to find the originating user message — pairs
                    // each assistant SQL with the question that prompted it.
                    let originatingQ = '';
                    for (let k = msgIdx - 1; k >= 0; k--) {
                        if (copilotHistory[k]?.role === 'user') {
                            originatingQ = copilotHistory[k].content || '';
                            break;
                        }
                    }
                    stampCopilotSqlOnTables(msg, m.sqlList, originatingQ);
                }
            }
        });

        if (typingMessage) {
            const el = document.getElementById(`msg-body-${copilotHistory.indexOf(typingMessage)}`);
            if (el) {
                typingMessage.isTyping = false; // Prevent re-triggering
                typewriterEffect(el, typingMessage.content, () => {
                    // Final re-render to add buttons etc.
                    renderConversation();
                    persistCopilotState();
                });
            }
        }

        host.scrollTo({ top: host.scrollHeight, behavior: 'smooth' });
    }


    async function copyCopilotQuestion(idx, btn) {
        const m = copilotHistory[idx];
        if (!m || m.role !== 'user') return;
        const text = m.content || '';
        try {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(text);
            } else {
                const ta = document.createElement('textarea');
                ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
                document.body.appendChild(ta); ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
            }
            const icon = btn.querySelector('i');
            if (!icon) return;
            const prev = icon.className;
            icon.className = 'bi bi-check2';
            btn.classList.add('text-success');
            setTimeout(() => { icon.className = prev; btn.classList.remove('text-success'); }, 1200);
        } catch (e) {
            console.warn('Copy failed', e);
        }
    }

    function resetComposerInput() { document.getElementById('copilot-question').style.height = 'auto'; }
    function persistCopilotState() { localStorage.setItem(copilotStorageKey, JSON.stringify(copilotHistory.slice(-20))); }
    function restoreCopilotState() {
        try {
            const s = localStorage.getItem(copilotStorageKey);
            if (s) copilotHistory = JSON.parse(s).map(m => { m.isQueued = false; m.isActive = false; m.isTyping = false; return m; });
            renderConversation();
        } catch {}
    }

    function renderCopilotResult(data) {
        document.getElementById('copilot-result-empty').classList.add('d-none');
        document.getElementById('copilot-result-body').classList.remove('d-none');
        document.getElementById('copilot-model').innerText = data.modelName || 'Enterprise AI';
        const s = document.getElementById('copilot-strength');
        s.textContent = data.evidenceStrength || 'Moderate';
        s.style.background = data.evidenceStrength === 'Strong' ? 'rgba(16,185,129,0.12)' : 'rgba(59,130,246,0.12)';
        s.style.color = data.evidenceStrength === 'Strong' ? '#10b981' : '#3b82f6';

        renderExecutionDetails(data.executionDetails || {});
        renderDynamicResults(data.dynamicTicketResults || [], data.structuredColumns || [], data.structuredRows || [], data.structuredQueryResults || []);
        renderSuggestionChips(data.suggestedPrompts || []);

        document.getElementById('copilot-ticket-count').textContent = (data.similarTickets || []).length;
        document.getElementById('copilot-ticket-evidence').innerHTML = (data.similarTickets || []).map(t => `<div class="copilot-evidence-item"><strong>${t.ticketNumber}</strong>: ${escapeHtml(t.title)}</div>`).join('') || 'No evidence';
    }

    // Render server-supplied suggested prompts as clickable chips. Click → fills the chat input
    // and (optionally) auto-sends. Server populates these on clarifications + system errors so the
    // user always has a copy-paste path forward instead of staring at a dead-end message.
    function renderSuggestionChips(prompts) {
        const wrap = document.getElementById('copilot-suggestions-wrap');
        const host = document.getElementById('copilot-suggestions');
        if (!wrap || !host) return;
        if (!prompts || prompts.length === 0) {
            wrap.classList.add('d-none');
            host.innerHTML = '';
            return;
        }
        wrap.classList.remove('d-none');
        host.innerHTML = prompts.map(p => {
            const safe = escapeHtml(p);
            return `<button type="button" class="btn btn-soft-info btn-sm rounded-pill copilot-suggestion-chip"
                            data-prompt="${safe}" title="Click to use this prompt">
                        <i class="bi bi-lightbulb me-1"></i>${safe}
                    </button>`;
        }).join('');
        // Bind clicks (delegation would be cleaner but the host is re-rendered each response).
        host.querySelectorAll('.copilot-suggestion-chip').forEach(btn => {
            btn.addEventListener('click', () => {
                const p = btn.getAttribute('data-prompt') || '';
                const input = document.getElementById('copilot-question');
                if (input) {
                    input.value = p;
                    input.focus();
                    // Trigger autosize like the user typed it.
                    input.dispatchEvent(new Event('input', { bubbles: true }));
                }
            });
        });
    }

    function renderExecutionDetails(e) {
        const h = document.getElementById('copilot-execution');
        const steps = e.steps || [];
        if (!steps.length) { document.getElementById('copilot-execution-wrap').classList.add('d-none'); return; }
        document.getElementById('copilot-execution-wrap').classList.remove('d-none');
        h.innerHTML = `<div class="copilot-story-timeline">${steps.map(s => `<div class="copilot-story-step"><div class="copilot-story-dot"></div><div class="copilot-story-content"><strong>${s.action}</strong><div class="small opacity-75">${s.detail}</div></div></div>`).join('')}</div>`;
    }

    function renderDynamicResults(rows, cols, sRows, sResults) {
        const wrap = document.getElementById('copilot-query-wrap');
        const host = document.getElementById('copilot-query-results');
        if (sResults.length > 0) {
            wrap.classList.remove('d-none');
            host.innerHTML = sResults.map(r => `<div class="mb-3"><strong>${r.label}</strong>${renderTable(r.execution?.structuredColumns || [], r.execution?.structuredRows || [])}</div>`).join('');
        } else if (sRows.length > 0) {
            wrap.classList.remove('d-none'); host.innerHTML = renderTable(cols, sRows);
        } else wrap.classList.add('d-none');
    }

    function renderTable(cols, rows) {
        return `<div class="table-responsive"><table class="table table-sm"><thead><tr>${cols.map(c => `<th>${c}</th>`).join('')}</tr></thead><tbody>${rows.map(r => `<tr>${cols.map(c => `<td>${r.values[c] || '-'}</td>`).join('')}</tr>`).join('')}</tbody></table></div>`;
    }

    async function loadMetadataHints() {
        try {
            console.log("Copilot: Fetching metadata hints...");
            const res = await fetch('@Url.Action("GetMetadataHints", "AiAnalysis")');
            const d = await res.json();
            const isSuccess = d.success || d.Success;
            const data = d.data || d.Data;
            
            if (isSuccess && data) {
                console.log("Copilot: Metadata API success. Raw data:", data);
                window.metadataHints = {
                    entities: data.entities || data.Entities || [],
                    fields: data.fields || data.Fields || [],
                    temporal: data.temporal || data.Temporal || [],
                    operations: data.operations || data.Operations || []
                };
                console.log("Copilot: Metadata hints parsed and attached to window:", window.metadataHints);
            } else {
                console.warn("Copilot: Metadata API returned failure or no data", d);
            }
        } catch (e) { console.error("Copilot: Metadata fetch failed", e); }
    }

    // Debounced fetch of catalog-driven question suggestions. The backend reads what the user
    // has typed so far (whole input, not just the last word) and returns up to 6 real catalog
    // questions whose tokens overlap. This is what makes the dropdown PROACTIVE: type "tickets"
    // and you see ticket-shaped questions; type "users" and you see user-shaped ones.
    let copilotQuestionSuggestions = [];
    let copilotSuggestFetchHandle = null;
    function fetchQuestionSuggestions(fullText, then) {
        if (copilotSuggestFetchHandle) clearTimeout(copilotSuggestFetchHandle);
        copilotSuggestFetchHandle = setTimeout(async () => {
            try {
                const res = await fetch(`@Url.Action("CopilotSuggest", "AiAnalysis")?q=${encodeURIComponent(fullText)}`);
                const d = await res.json();
                const data = d.data || d.Data;
                copilotQuestionSuggestions = (data && (data.suggestions || data.Suggestions)) || [];
            } catch (err) {
                console.warn('Copilot: question-suggest fetch failed', err);
                copilotQuestionSuggestions = [];
            }
            if (typeof then === 'function') then();
        }, 180); // small debounce so we don't hit the endpoint on every keystroke
    }

    function handleAutocomplete() {
        const input = document.getElementById('copilot-question');
        const list = document.getElementById('copilot-autocomplete-list');
        if (!input || !list) return;

        const val = input.value;
        const pos = input.selectionStart;
        const textBefore = val.substring(0, pos);
        // USE Unicode-aware regex to support Arabic/other scripts
        const match = textBefore.match(/[^\s]+$/);
        const word = match ? match[0].toLowerCase() : "";

        console.log("Copilot: handleAutocomplete for word:", word);

        // Trigger the catalog-question fetch on the WHOLE input (so "show me tickets" considers
        // both words, not just "tickets"). The render below picks up whatever's already cached.
        fetchQuestionSuggestions(val.trim(), () => {
            // re-render after the fetch lands, so the catalog suggestions appear without needing another keystroke
            handleAutocompleteRender();
        });

        if (word.length < 2 && copilotQuestionSuggestions.length === 0) {
            hideAutocomplete();
            return;
        }

        handleAutocompleteRender();
    }

    function handleAutocompleteRender() {
        const input = document.getElementById('copilot-question');
        if (!input) return;
        const val = input.value;
        // If the input has been cleared (e.g. user just hit Send), do not repaint the
        // dropdown — a debounced suggest response landing here would otherwise re-show it.
        if (!val || !val.trim()) { hideAutocomplete(); return; }
        const pos = input.selectionStart;
        const textBefore = val.substring(0, pos);
        const match = textBefore.match(/[^\s]+$/);
        const word = match ? match[0].toLowerCase() : "";

        activeHintIndex = -1;
        const suggestions = [];

        // (Question suggestions first — these are full, ready-to-run prompts from the catalog)
        copilotQuestionSuggestions.forEach(qs => {
            const text = qs.question || qs.Question || '';
            if (!text) return;
            suggestions.push({
                name: text,
                type: 'Question',
                meta: `${qs.category || qs.Category || 'General'} · ${qs.difficulty || qs.Difficulty || 'Medium'}`,
                isQuestion: true
            });
        });

        const ents = window.metadataHints.entities || [];
        const flds = window.metadataHints.fields || [];
        const ops = window.metadataHints.operations || [];
        const temp = window.metadataHints.temporal || [];

        // 1. Check Entities (Names & Aliases)
        ents.forEach(e => {
            const name = e.name || e.Name || "";
            const aliases = (e.aliases || e.Aliases || []);
            const matchedAlias = aliases.find(a => a.toLowerCase().includes(word));
            
            if (name.toLowerCase().includes(word) || matchedAlias) {
                suggestions.push({ 
                    name: name, 
                    type: 'Department', 
                    meta: matchedAlias ? `Alias: ${matchedAlias}` : (aliases.join(', '))
                });
            }
        });

        // 2. Check Fields (Names & Aliases)
        flds.forEach(f => {
            const name = f.name || f.Name || "";
            const aliases = (f.aliases || f.Aliases || []);
            const matchedAlias = aliases.find(a => a.toLowerCase().includes(word));
            const entity = f.entity || f.Department || "";

            if (name.toLowerCase().includes(word) || matchedAlias) {
                suggestions.push({ 
                    name: name, 
                    type: 'Field', 
                    meta: (matchedAlias ? `Alias: ${matchedAlias} • ` : '') + entity 
                });
            }
        });

        // 3. Check Operations (Case-insensitive)
        ops.forEach(o => {
            const name = typeof o === 'string' ? o : (o.name || o.Name || "");
            if (name.toLowerCase().includes(word)) {
                suggestions.push({ name: name, type: 'Operation', meta: 'Logic' });
            }
        });

        // 4. Check Temporal
        temp.forEach(t => {
            const name = t.name || t.phrase || t.Name || t.Phrase || "";
            if (name.toLowerCase().includes(word)) {
                suggestions.push({ name: name, type: 'Temporal', meta: 'Time' });
            }
        });

        console.log("Copilot: Found suggestions:", suggestions.length);

        if (suggestions.length) {
            // Question suggestions (full prompts) ALWAYS at the top — they're complete next steps,
            // not just word completions. Within question/word groups, prefer entries whose name
            // starts with the current word.
            suggestions.sort((a, b) => {
                if (a.isQuestion && !b.isQuestion) return -1;
                if (!a.isQuestion && b.isQuestion) return 1;
                const aStart = a.name.toLowerCase().startsWith(word);
                const bStart = b.name.toLowerCase().startsWith(word);
                if (aStart && !bStart) return -1;
                if (!aStart && bStart) return 1;
                return a.name.localeCompare(b.name);
            });
            renderAutocompleteSuggestions(suggestions.slice(0, 10));
        } else {
            hideAutocomplete();
        }
    }

    function renderAutocompleteSuggestions(s) {
        const list = document.getElementById('copilot-autocomplete-list');
        if (!list) return;

        const header = `
            <div class="copilot-autocomplete-header">
                <span class="copilot-autocomplete-header-label">Suggestions</span>
                <button type="button" class="copilot-autocomplete-close" aria-label="Close suggestions" onclick="hideAutocomplete()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>`;

        const items = s.map((x, i) => {
            // Question suggestions get a distinct lightbulb icon and click into the WHOLE input.
            // Word/Department/Field/etc. suggestions just replace the last typed word.
            const isQ = !!x.isQuestion;
            const onclickHandler = isQ
                ? `applyQuestionPrompt('${escapeJs(x.name)}')`
                : `applyAutocomplete('${escapeJs(x.name)}')`;
            const typeBadge = isQ
                ? `<span class="copilot-hint-type" style="background:rgba(var(--info-color-rgb),0.12);color:var(--info-color);"><i class="bi bi-lightbulb me-1"></i>Try this</span>`
                : `<span class="copilot-hint-type">${x.type}</span>`;
            return `
            <div class="copilot-autocomplete-item ${i === activeHintIndex ? 'active' : ''}" onclick="${onclickHandler}">
                ${typeBadge}
                <span class="copilot-hint-name" style="font-weight: ${isQ ? '600' : '700'};">${escapeHtml(x.name)}</span>
                <span class="copilot-hint-meta opacity-50 small ms-2">${escapeHtml(x.meta)}</span>
            </div>`;
        }).join('');

        list.innerHTML = header + items;
        list.style.display = 'block';
        console.log("Copilot: List displayed with items:", s.length);
    }

    /// Apply a full catalog question — replaces the entire input (not just the last word) and
    /// triggers an input event so the textarea autosizes. Closes the dropdown afterwards.
    function applyQuestionPrompt(text) {
        const input = document.getElementById('copilot-question');
        if (!input) return;
        input.value = text;
        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.focus();
        // Move caret to end so the user can immediately hit Enter or keep editing.
        input.setSelectionRange(text.length, text.length);
        hideAutocomplete();
    }

    function applyAutocomplete(name) {
        const input = document.getElementById('copilot-question');
        if (!input) return;
        const val = input.value;
        const pos = input.selectionStart;
        const textBefore = val.substring(0, pos);
        const textAfter = val.substring(pos);
        // Replace the last word (including non-latin) with the suggestion
        input.value = textBefore.replace(/[^\s]+$/, name + " ") + textAfter;
        input.dispatchEvent(new Event('input'));
        hideAutocomplete();
        input.focus();
    }

    function hideAutocomplete() {
        const list = document.getElementById('copilot-autocomplete-list');
        if (list) {
            list.style.display = 'none';
            list.innerHTML = '';
            activeHintIndex = -1;
        }
        // Cancel any in-flight debounced suggest fetch and drop cached results so a late
        // response can't repaint the dropdown after the user sent or dismissed it.
        if (copilotSuggestFetchHandle) {
            clearTimeout(copilotSuggestFetchHandle);
            copilotSuggestFetchHandle = null;
        }
        copilotQuestionSuggestions = [];
    }

    function resetResultDetails() {
        const empty = document.getElementById('copilot-result-empty');
        const body = document.getElementById('copilot-result-body');
        if (empty) empty.classList.remove('d-none');
        if (body) body.classList.add('d-none');
        const notes = document.getElementById('copilot-notes');
        if (notes) { notes.classList.add('d-none'); notes.innerHTML = ''; }
        const exec = document.getElementById('copilot-execution-wrap');
        if (exec) exec.classList.add('d-none');
        const query = document.getElementById('copilot-query-wrap');
        if (query) query.classList.add('d-none');
        const sug = document.getElementById('copilot-suggestions-wrap');
        if (sug) sug.classList.add('d-none');
    }

    function formatMessageBody(v) {
        if (!v) return "";
        try {
            // Configure marked for our premium UI
            const renderer = new marked.Renderer();

            // Wrap tables in our premium containers
            renderer.table = function(header, body) {
                return `<div class="copilot-inline-table-wrap">
                            <table class="copilot-inline-table">
                                <thead>${header}</thead>
                                <tbody>${body}</tbody>
                            </table>
                        </div>`;
            };

            marked.setOptions({
                renderer: renderer,
                gfm: true,
                breaks: true,
                sanitize: false // We escape before parsing if needed, but AI output is generally trusted markdown
            });

            return enhanceCopilotTables(marked.parse(v));
        } catch (e) {
            console.error("Markdown parse error", e);
            return `<p class="mb-0">${escapeHtml(v).replace(/\n/g, '<br>')}</p>`;
        }
    }

    // Wrap each inline markdown table in a height-capped scroll container and, when the
    // table has more than COPILOT_TABLE_PREVIEW rows, collapse it to the preview with a
    // "Show all / Show less" toggle so 1000-row responses don't blow up the message bubble.
    const COPILOT_TABLE_PREVIEW = 10;
    function enhanceCopilotTables(html) {
        if (!html || html.indexOf('copilot-inline-table-wrap') === -1) return html;
        const tmp = document.createElement('div');
        tmp.innerHTML = html;
        tmp.querySelectorAll('.copilot-inline-table-wrap').forEach(wrap => {
            const table = wrap.querySelector('table.copilot-inline-table');
            const tbody = table ? table.querySelector('tbody') : null;
            if (!table || !tbody) return;

            // KPI promotion — when the result is one row with one numeric column it's an
            // answer ("how many tickets?" → 1,847), not a table. Replace the table with a
            // big-number card. The original table is preserved inside details for users
            // who want to copy the raw value.
            const ths = table.querySelectorAll('thead tr:first-child th');
            const rowsForKpi = Array.from(tbody.querySelectorAll('tr'));
            if (rowsForKpi.length === 1 && ths.length === 1) {
                const cellEl = rowsForKpi[0].querySelector('td');
                const rawValue = cellEl?.textContent?.trim() ?? '';
                const isNumeric = /^-?[\d,]+(\.\d+)?$/.test(rawValue);
                if (isNumeric) {
                    renderKpiCard(wrap, ths[0].textContent?.trim() ?? 'Value', rawValue);
                    return;
                }
            }

            // Move the table into an inner scroll container so the footer (rows count +
            // toggle) stays pinned outside the scroll viewport.
            const scroll = document.createElement('div');
            scroll.className = 'copilot-inline-table-scroll';
            table.parentNode.insertBefore(scroll, table);
            scroll.appendChild(table);

            const rows = Array.from(tbody.querySelectorAll('tr'));
            const total = rows.length;
            // Detect numeric vs date vs categorical per column from the FIRST row's cells.
            // Stamped onto the wrap so sort/filter/profiler can read it without re-parsing.
            //   numeric  → sort/filter as numbers, profiler shows min/max/mean/median
            //   date     → period-compare button becomes available
            //   other    → string sort, "contains" filter, profiler shows top-5 frequency
            const sampleTr = rows[0];
            const colKinds = [];
            if (sampleTr) {
                sampleTr.querySelectorAll('td').forEach(td => {
                    const v = (td.textContent || '').trim();
                    const n = Number(v.replace(/,/g, ''));
                    if (v !== '' && !isNaN(n)) { colKinds.push('numeric'); return; }
                    const d = new Date(v);
                    if (v !== '' && !isNaN(d.getTime()) && /\d{4}|\d{1,2}[\/\-]\d{1,2}/.test(v)) { colKinds.push('date'); return; }
                    colKinds.push('text');
                });
            }
            wrap.dataset.colKinds = colKinds.join(',');
            const dateColIdx = colKinds.indexOf('date');

            // Sortable headers — wrap text + arrow icon and attach click. Click cycles
            // none → asc → desc → none. Sort indicator stays in the column header.
            // Each header also gets a small data-type icon (📅 / 🔢 / 📝) so the analyst
            // can see at a glance which columns are dates, numerics, or free text.
            // (`ths` already declared above for the KPI-promotion check; reuse it.)
            const TYPE_ICON = { numeric: 'bi-hash', date: 'bi-calendar3', text: 'bi-fonts' };
            ths.forEach((th, i) => {
                const original = th.innerHTML;
                const kind = colKinds[i] || 'text';
                th.classList.add('copilot-th-sortable', `copilot-th-kind-${kind}`);
                th.setAttribute('data-col', String(i));
                th.setAttribute('onclick', 'copilotTableSort(this)');
                th.setAttribute('title', `${kind === 'numeric' ? 'Numeric' : kind === 'date' ? 'Date' : 'Text'} column — click to sort`);
                th.innerHTML = `<i class="bi ${TYPE_ICON[kind]} copilot-th-type-icon" aria-hidden="true"></i><span class="copilot-th-label">${original}</span><i class="bi bi-arrow-down-up copilot-sort-arrow"></i>`;
            });

            // Row numbers — set as data-row-num on each row's FIRST <td>; CSS
            // renders the number via ::before on that cell. Pure CSS rendering
            // means downstream td/colIdx logic stays unchanged (no shifted
            // indices). Number reflects ORIGINAL row position so sort/filter/pager
            // don't renumber rows (the user's "row 7 is wrong" reference stays
            // stable across operations).
            tbody.querySelectorAll('tr').forEach((tr, idx) => {
                const firstTd = tr.querySelector('td');
                if (firstTd) firstTd.dataset.rowNum = String(idx + 1);
            });

            // Cell expansion — mark cells whose text content is "long" (>60 chars)
            // with a class that adds an ellipsis + click handler. Click toggles
            // expansion in place — no modal, no extra round-trip. Lets the user
            // read a long ticket Title or Description without breaking the row.
            tbody.querySelectorAll('td').forEach(td => {
                const txt = (td.textContent || '').trim();
                if (txt.length > 60) {
                    td.classList.add('copilot-cell-truncatable');
                    td.setAttribute('title', 'Click to expand');
                    td.addEventListener('click', () => td.classList.toggle('copilot-cell-expanded'));
                }
            });

            // Stamp "frozen-first-column" flag — the first data column sticks when
            // scrolling horizontally. Toggled via CSS off wrap.dataset.frozen.
            wrap.dataset.frozen = '1';

            // Data-freshness chip — shows when this answer was produced. Useful
            // when the analyst revisits a long conversation and wants to know
            // "is this number from today?". Rendered as a subtle chip above the
            // table; no polling, just a static timestamp at enhancement time.
            const ts = new Date();
            const tsLabel = ts.toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
            const metaHeader = document.createElement('div');
            metaHeader.className = 'copilot-table-meta-header';
            metaHeader.innerHTML = `<span class="copilot-table-freshness" title="When this answer was generated"><i class="bi bi-clock-history"></i> Fetched ${tsLabel}</span><span class="copilot-table-row-count-meta"><i class="bi bi-table"></i> ${total} row${total === 1 ? '' : 's'} × ${ths.length} col${ths.length === 1 ? '' : 's'}</span>`;
            wrap.insertBefore(metaHeader, wrap.firstChild);

            // Hidden filter row in <thead> — toggled by the "Filter" action button. One
            // <input> per column. Live "contains" by default; numeric columns also
            // understand >/<,>=/<=,a-b range syntax (see _copilotTableMatchesFilters).
            const filterRowTr = document.createElement('tr');
            filterRowTr.className = 'copilot-filter-row';
            filterRowTr.hidden = true;
            ths.forEach((th, i) => {
                const kind = colKinds[i] || 'text';
                const ph = kind === 'numeric' ? 'e.g. >100 or 10-50' : 'contains…';
                const cell = document.createElement('th');
                cell.className = 'copilot-filter-cell';
                cell.innerHTML = `<input type="text" class="copilot-filter-input" data-col="${i}" data-kind="${kind}" placeholder="${ph}" oninput="copilotTableApplyFilter(this)" onclick="event.stopPropagation()">`;
                filterRowTr.appendChild(cell);
            });
            table.querySelector('thead')?.appendChild(filterRowTr);

            // Drill-down: clicking a body row composes a follow-up question that filters
            // the previous dataset to that row's identifying values. The handler picks
            // the 2 most distinctive cells (first non-empty text + first numeric, or
            // any two non-empty cells) so the follow-up reads naturally.
            tbody.querySelectorAll('tr').forEach(tr => {
                tr.classList.add('copilot-row-drillable');
                tr.setAttribute('title', 'Click to drill down on this row');
                tr.setAttribute('onclick', 'copilotTableDrillDown(this)');
            });

            const footer = document.createElement('div');
            footer.className = 'copilot-table-footer';

            // Period-compare — only shown when there's a date column. Clicking opens a
            // small menu (last week / month / quarter / YoY); each option pre-fills a
            // comparison question. Architectural: maps to canonical shape #9 (period
            // comparison via UNION ALL). The UI ships now even though the backend
            // emitter is partial — the question still gets through the pipeline and
            // any rough handling surfaces as a regular answer.
            const periodCompareBtn = dateColIdx === -1 ? '' : `
                <span class="copilot-export-dropdown">
                    <button type="button" class="copilot-table-export" onclick="toggleCopilotPeriodMenu(this)" title="Compare to a previous period">
                        <i class="bi bi-arrow-left-right me-1"></i>vs. period <i class="bi bi-caret-down-fill ms-1" style="font-size:0.6em;"></i>
                    </button>
                    <div class="copilot-export-menu" hidden>
                        <button type="button" onclick="askPeriodCompare(this, 'week')"><i class="bi bi-calendar-week me-2"></i>vs. last week</button>
                        <button type="button" onclick="askPeriodCompare(this, 'month')"><i class="bi bi-calendar-month me-2"></i>vs. last month</button>
                        <button type="button" onclick="askPeriodCompare(this, 'quarter')"><i class="bi bi-calendar3 me-2"></i>vs. last quarter</button>
                        <button type="button" onclick="askPeriodCompare(this, 'year')"><i class="bi bi-calendar4 me-2"></i>vs. last year (YoY)</button>
                    </div>
                </span>`;

            // View SQL — only renders the button when SQL was stamped onto the wrap
            // from the message-level structured response (see renderConversation
            // post-pass). Avoids an empty modal for markdown-only tables.
            const viewSqlBtn = `<button type="button" class="copilot-table-export copilot-view-sql-btn" onclick="toggleCopilotSqlPanel(this)" title="Show generated SQL" hidden>
                    <i class="bi bi-code-slash me-1"></i>SQL
                </button>`;

            // Promote-to-Trusted — same gating as View-SQL: only un-hidden by the
            // SQL-stamping post-pass when generated SQL is attached to this answer.
            // Click opens a modal where the analyst reviews/edits the (question, SQL)
            // pair and submits it to the Trusted Query store. Next ask of the same
            // (or paraphrased) question hits the sub-second Trusted lane.
            const trustBtn = `<button type="button" class="copilot-table-export copilot-trust-btn" onclick="openCopilotTrustDialog(this)" title="Save this (question + SQL) to the Trusted Query store so future asks skip the LLM" hidden>
                    <i class="bi bi-shield-check me-1"></i>Trust
                </button>`;

            // Group-by submenu items — one per column, plus a "(None)" option to ungroup.
            // The handler reads the col index off the data attribute and re-flows the
            // tbody into group headers + member rows.
            const groupByItems = Array.from(ths).map((th, i) => {
                const lbl = (th.querySelector('.copilot-th-label')?.textContent || th.textContent || '').trim();
                return `<button type="button" onclick="copilotTableGroupBy(this, ${i})"><i class="bi bi-diagram-3 me-2"></i>${lbl.replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</button>`;
            }).join('');

            const actionButtons = `
                <button type="button" class="copilot-table-export" onclick="explainCopilotResult(this)" title="LLM summary of this result">
                    <i class="bi bi-stars me-1"></i>Explain
                </button>
                <button type="button" class="copilot-table-export" onclick="suggestFollowUps(this)" title="Suggest follow-up questions">
                    <i class="bi bi-lightbulb me-1"></i>Follow-ups
                </button>
                <button type="button" class="copilot-table-export" onclick="toggleCopilotFilterRow(this)" title="Filter rows by column">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <span class="copilot-export-dropdown">
                    <button type="button" class="copilot-table-export" onclick="toggleCopilotColsMenu(this)" title="Show or hide columns">
                        <i class="bi bi-layout-three-columns me-1"></i>Cols <i class="bi bi-caret-down-fill ms-1" style="font-size:0.6em;"></i>
                    </button>
                    <div class="copilot-export-menu copilot-cols-menu" hidden>
                        ${Array.from(ths).map((th, i) => {
                            const lbl = (th.querySelector('.copilot-th-label')?.textContent || th.textContent || '').trim();
                            return `<label class="copilot-cols-menu-item"><input type="checkbox" checked data-col="${i}" onchange="toggleCopilotColumnVisibility(this)" onclick="event.stopPropagation()"> <span>${lbl.replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]))}</span></label>`;
                        }).join('')}
                    </div>
                </span>
                ${periodCompareBtn}
                ${viewSqlBtn}
                ${trustBtn}
                <span class="copilot-export-dropdown">
                    <button type="button" class="copilot-table-export" onclick="toggleExportMenu(this)" title="Heat / Anomalies / Summary / Pivot / Group / % of total">
                        <i class="bi bi-tools me-1"></i>Tools <i class="bi bi-caret-down-fill ms-1" style="font-size:0.6em;"></i>
                    </button>
                    <div class="copilot-export-menu copilot-tools-menu" hidden>
                        <button type="button" onclick="toggleCopilotHeatTable(this)"><i class="bi bi-palette me-2"></i>Heat (color cells by value)</button>
                        <button type="button" onclick="toggleCopilotPctOfTotal(this)"><i class="bi bi-percent me-2"></i>% of total (per column)</button>
                        <button type="button" onclick="toggleAnomalyFlag(this)"><i class="bi bi-flag me-2"></i>Anomalies (z-score outliers)</button>
                        <button type="button" onclick="toggleSummaryRow(this)"><i class="bi bi-calculator me-2"></i>Summary row (sum/avg/min/max)</button>
                        <div class="copilot-tools-menu-divider"></div>
                        <button type="button" onclick="toggleCopilotPivot(this)"><i class="bi bi-arrow-repeat me-2"></i>Pivot (transpose rows ↔ columns)</button>
                        <button type="button" onclick="copilotDataDebate(this)"><i class="bi bi-chat-square-quote me-2"></i>Debate this answer (counter-arguments)</button>
                        <button type="button" onclick="(function(b){const p=b.closest('.copilot-inline-table-wrap').querySelector('.copilot-chart-panel'); if(p) saveCopilotLensFromPanel(p); else _showCopilotToast('Open the chart first (View as chart), then save it as a lens.', 'error');})(this)"><i class="bi bi-eyeglasses me-2"></i>Save current chart as lens</button>
                        <div class="copilot-tools-menu-divider"></div>
                        <div class="copilot-tools-menu-label">Group by column:</div>
                        ${groupByItems}
                        <button type="button" onclick="copilotTableGroupBy(this, -1)"><i class="bi bi-x-circle me-2"></i>(none — ungroup)</button>
                    </div>
                </span>
                <button type="button" class="copilot-table-export" onclick="pinCopilotChart(this)" title="Pin to dashboard">
                    <i class="bi bi-pin-angle me-1"></i>Pin
                </button>
                <span class="copilot-export-dropdown">
                    <button type="button" class="copilot-table-export" onclick="toggleExportMenu(this)" title="Download">
                        <i class="bi bi-download me-1"></i>Export <i class="bi bi-caret-down-fill ms-1" style="font-size:0.6em;"></i>
                    </button>
                    <div class="copilot-export-menu" hidden>
                        <button type="button" onclick="exportCopilotTable(this, 'csv')"><i class="bi bi-filetype-csv me-2"></i>CSV</button>
                        <button type="button" onclick="exportCopilotTable(this, 'xlsx')"><i class="bi bi-filetype-xlsx me-2"></i>Excel-compatible</button>
                        <button type="button" onclick="exportCopilotTable(this, 'json')"><i class="bi bi-filetype-json me-2"></i>JSON</button>
                        <button type="button" onclick="exportCopilotTable(this, 'md')"><i class="bi bi-markdown me-2"></i>Markdown</button>
                    </div>
                </span>`;
            if (total > COPILOT_TABLE_PREVIEW) {
                // Pager state lives on the wrap so both the page-size dropdown and the
                // prev/next buttons can read it. Default page size = COPILOT_TABLE_PREVIEW
                // so the initial render matches the previous "first 10 rows" behavior.
                wrap.dataset.pageSize = String(COPILOT_TABLE_PREVIEW);
                wrap.dataset.page = '1';
                wrap.dataset.total = String(total);
                wrap.classList.add('copilot-inline-table-collapsed');
                rows.forEach((r, i) => { if (i >= COPILOT_TABLE_PREVIEW) r.classList.add('copilot-row-hidden'); });
                // Only offer sensible page sizes that are <= total — no point showing
                // "50 per page" for a 12-row result.
                const pageSizes = [10, 25, 50, 100].filter(s => s < total);
                const sizeOpts = pageSizes.map(s =>
                    `<option value="${s}"${s === COPILOT_TABLE_PREVIEW ? ' selected' : ''}>${s}</option>`).join('') +
                    `<option value="all">All</option>`;
                const lastPage = Math.max(1, Math.ceil(total / COPILOT_TABLE_PREVIEW));
                footer.innerHTML = `
                    <span class="copilot-table-count">Showing <strong>1–${COPILOT_TABLE_PREVIEW}</strong> of <strong>${total}</strong> rows</span>
                    <span class="copilot-table-actions">
                        <label class="copilot-table-pagesize-label">Rows:</label>
                        <select class="copilot-table-pagesize" onchange="copilotTableSetPageSize(this)" title="Rows per page">
                            ${sizeOpts}
                        </select>
                        <button type="button" class="copilot-table-pager-btn" onclick="copilotTablePage(this, 'prev')" title="Previous page" disabled>
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <span class="copilot-table-page-info"><strong>1</strong> / <strong>${lastPage}</strong></span>
                        <button type="button" class="copilot-table-pager-btn" onclick="copilotTablePage(this, 'next')" title="Next page"${lastPage <= 1 ? ' disabled' : ''}>
                            <i class="bi bi-chevron-right"></i>
                        </button>
                        ${actionButtons}
                    </span>`;
            } else {
                footer.innerHTML = `
                    <span class="copilot-table-count"><strong>${total}</strong> ${total === 1 ? 'row' : 'rows'}</span>
                    <span class="copilot-table-actions">${actionButtons}</span>`;
            }
            wrap.appendChild(footer);

            // Chart panel — adds a "View as chart" toggle when the table is chartable
            // (≥2 rows, ≥2 columns, at least one numeric column). The chart renders below
            // the table from the same cells; no re-ask, no extra LLM call.
            const chartFooter = buildCopilotChartControls(table, total);
            if (chartFooter) wrap.appendChild(chartFooter);
        });
        return tmp.innerHTML;
    }

    // Replace the table inside `wrap` with a big-number KPI card. The original table is
    // collapsed into a <details> below so power users can still copy the cell contents.
    function renderKpiCard(wrap, label, value) {
        wrap.classList.add('copilot-kpi-wrap');
        const originalHtml = wrap.innerHTML;
        wrap.innerHTML = `
            <div class="copilot-kpi-card">
                <div class="copilot-kpi-label">${escapeHtml(label)}</div>
                <div class="copilot-kpi-value">${escapeHtml(value)}</div>
            </div>
            <details class="copilot-kpi-raw">
                <summary>View as table</summary>
                <div class="copilot-kpi-raw-body">${originalHtml}</div>
            </details>`;
    }

    // LLM "Explain this result" — sends the rendered table + the originating question
    // to /AiAnalysis/ExplainResult and renders the response inline below the footer.
    // The question is discovered by walking back from this assistant bubble to the prior
    // user message — same DOM the chat already maintains.
    async function explainCopilotResult(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        // Find the question — most recent .copilot-message-user before this bubble.
        const bubble = btn.closest('.copilot-message-assistant');
        let question = '';
        if (bubble) {
            let n = bubble.previousElementSibling;
            while (n && !n.classList.contains('copilot-message-user')) n = n.previousElementSibling;
            if (n) question = (n.querySelector('.copilot-message-body')?.textContent || n.textContent || '').trim();
        }
        if (!question) {
            // Fallback: pull the most recent user message from the in-memory history.
            const lastUser = [...copilotHistory].reverse().find(m => m.role === 'user' && !m.isQueued);
            question = lastUser?.content || '';
        }
        const columns = Array.from(table.querySelectorAll('thead tr:first-child th')).map(th => th.textContent.trim());
        const rows = Array.from(table.querySelectorAll('tbody tr')).map(tr =>
            Array.from(tr.querySelectorAll('td')).map(td => td.textContent.trim()));

        // Insert a placeholder panel right after the table footer so the user sees the
        // request is in flight. Re-using the panel on repeat clicks keeps the layout stable.
        let panel = wrap.querySelector('.copilot-explain-panel');
        if (!panel) {
            panel = document.createElement('div');
            panel.className = 'copilot-explain-panel';
            wrap.appendChild(panel);
        }
        panel.innerHTML = `<div class="copilot-explain-loading"><i class="bi bi-stars me-1"></i>Asking the model…</div>`;

        btn.disabled = true;
        try {
            const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            const res = await fetch('@Url.Action("ExplainResult", "AiAnalysis")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ question, columns, rows }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data?.message || 'Explain failed');
            panel.innerHTML = `
                <div class="copilot-explain-header">
                    <i class="bi bi-stars"></i><span>Explanation</span>
                    <button type="button" class="copilot-explain-close" onclick="this.closest('.copilot-explain-panel').remove()" title="Dismiss">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
                <div class="copilot-explain-body">${escapeHtml(data.explanation || '(no explanation returned)')}</div>`;
        } catch (e) {
            panel.innerHTML = `<div class="copilot-explain-error"><i class="bi bi-exclamation-triangle me-1"></i>Couldn't explain: ${escapeHtml(e.message || String(e))}</div>`;
        } finally {
            btn.disabled = false;
        }
    }

    // Conditional formatting — color each numeric column's cells along a low→high gradient
    // (per-column normalisation so a "Count" column at 287 and a "Days" column at 7 each
    // get full visual range instead of "Count" dominating). Toggles on/off via the same
    // button; on second click strips the inline styles. Pure CSS classes would be cleaner
    // for theming but inline styles are sufficient for a viz toggle.
    function toggleCopilotHeatTable(btn) {
        const wrap = btn.closest('.copilot-inline-table-wrap');
        const table = wrap?.querySelector('table.copilot-inline-table');
        if (!table) return;
        const isOn = table.classList.toggle('copilot-table-heated');
        const headerCells = Array.from(table.querySelectorAll('thead tr:first-child th'));
        const bodyRows = Array.from(table.querySelectorAll('tbody tr'));
        if (!isOn) {
            // Off — clear all inline backgrounds.
            bodyRows.forEach(tr => tr.querySelectorAll('td').forEach(td => { td.style.background = ''; td.style.color = ''; }));
            btn.classList.remove('is-active');
            return;
        }
        btn.classList.add('is-active');
        // For each column: collect numeric values, compute min/max, paint gradient.
        headerCells.forEach((_, colIdx) => {
            const vals = bodyRows
                .map(tr => tr.querySelectorAll('td')[colIdx]?.textContent?.trim() ?? '')
                .map(s => Number(s.replace(/,/g, '')))
                .filter(n => !isNaN(n));
            if (vals.length < 2) return; // not numeric or only one value — skip
            const min = Math.min(...vals);
            const max = Math.max(...vals);
            if (min === max) return;
            bodyRows.forEach(tr => {
                const td = tr.querySelectorAll('td')[colIdx];
                if (!td) return;
                const n = Number((td.textContent || '').trim().replace(/,/g, ''));
                if (isNaN(n)) return;
                const t = (n - min) / (max - min);
                // Blue (low) → purple → red (high). Soft alpha so text stays legible.
                const r = Math.round(91 + (239 - 91) * t);
                const g = Math.round(141 + (68 - 141) * t);
                const b = Math.round(239 + (68 - 239) * t);
                td.style.background = `rgba(${r},${g},${b},${0.12 + 0.35 * t})`;
            });
        });
    }

    // Pin chart / table to a localStorage-backed dashboard. v1: each pin is a serialised
    // snapshot of (question, columns, rows, default chart type) keyed by a sortable id.
    // The Dashboard page (small new partial added below the chat thread on load) reads
    // these out and re-renders them in a grid. No backend persistence — cleared by browser
    // storage policy; export to JSON if you want them to survive a cache clear.
