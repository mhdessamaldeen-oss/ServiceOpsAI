@model ServiceOpsAI.Models.Region
@{
    ViewData["Title"] = Model.NameEn;
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = Model.NameEn,
        Subtitle = $"{Model.RegionType} — {Model.NameAr}",
        IconClass = "bi bi-map",
        Actions = new()
        {
            new() { Text = "Edit", Href = Url.Action("Edit", new { id = Model.Id }) ?? "#", IconClass = "bi bi-pencil", CssClass = "btn btn-sm btn-outline-primary rounded-pill px-3" },
            new() { Text = "Back", Href = Url.Action("Index") ?? "#", IconClass = "bi bi-arrow-left", CssClass = "btn btn-sm btn-outline-secondary rounded-pill px-3" }
        }
    };
}
<partial name="_PageHeader" model="header" />

<div class="card border-0 shadow-sm mb-3" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name (EN)</dt>     <dd class="col-sm-9">@Model.NameEn</dd>
            <dt class="col-sm-3">Name (AR)</dt>     <dd class="col-sm-9" dir="rtl">@Model.NameAr</dd>
            <dt class="col-sm-3">Country</dt>       <dd class="col-sm-9">@(Model.Country?.NameEn ?? "—")</dd>
            <dt class="col-sm-3">Type</dt>          <dd class="col-sm-9">@Model.RegionType</dd>
            <dt class="col-sm-3">Parent</dt>        <dd class="col-sm-9">@(Model.ParentRegion?.NameEn ?? "—")</dd>
            <dt class="col-sm-3">Active</dt>        <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        </dl>
    </div>
</div>

@if (Model.ChildRegions != null && Model.ChildRegions.Any())
{
    <div class="card border-0 shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
        <div class="card-header bg-transparent border-0"><h6 class="mb-0 fw-bold">Districts under @Model.NameEn</h6></div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                @foreach (var child in Model.ChildRegions.OrderBy(c => c.NameEn))
                {
                    <a asp-action="Details" asp-route-id="@child.Id" class="badge text-decoration-none px-3 py-2 rounded-pill"
                       style="background: rgba(var(--primary-color-rgb), 0.08); color: var(--text-main); border: 1px solid var(--border-color);">
                        @child.NameEn / <span dir="rtl">@child.NameAr</span>
                    </a>
                }
            </div>
        </div>
    </div>
}
