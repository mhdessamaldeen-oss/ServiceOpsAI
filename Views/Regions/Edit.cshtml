@model ServiceOpsAI.Models.Region
@{
    ViewData["Title"] = $"Edit {Model.NameEn}";
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = $"Edit {Model.NameEn}",
        Subtitle = $"Region — {Model.RegionType}",
        IconClass = "bi bi-map"
    };
}
<partial name="_PageHeader" model="header" />

<div class="card border-0 shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="col-md-6">
                <label asp-for="NameEn" class="form-label small fw-bold text-muted text-uppercase">Name (English)</label>
                <input asp-for="NameEn" class="form-control bg-transparent shadow-none" style="border-color: var(--border-color); color: var(--text-main);" />
            </div>
            <div class="col-md-6">
                <label asp-for="NameAr" class="form-label small fw-bold text-muted text-uppercase">Name (Arabic)</label>
                <input asp-for="NameAr" class="form-control bg-transparent shadow-none" dir="rtl" style="border-color: var(--border-color); color: var(--text-main);" />
            </div>
            <div class="col-md-4">
                <label asp-for="CountryId" class="form-label small fw-bold text-muted text-uppercase">Country</label>
                <select asp-for="CountryId" class="form-select bg-transparent shadow-none" asp-items="ViewBag.Countries" style="border-color: var(--border-color); color: var(--text-main);"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="RegionType" class="form-label small fw-bold text-muted text-uppercase">Type</label>
                <select asp-for="RegionType" class="form-select bg-transparent shadow-none" style="border-color: var(--border-color); color: var(--text-main);">
                    @foreach (var t in Enum.GetValues<ServiceOpsAI.Models.RegionType>())
                    {
                        <option value="@t" selected="@(t == Model.RegionType)">@t</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="ParentRegionId" class="form-label small fw-bold text-muted text-uppercase">Parent Governorate</label>
                <select asp-for="ParentRegionId" class="form-select bg-transparent shadow-none" asp-items="ViewBag.ParentRegions" style="border-color: var(--border-color); color: var(--text-main);">
                    <option value="">— None —</option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label">Active</label>
                </div>
            </div>
            <div class="col-12">
                <button class="btn btn-primary" type="submit">Save</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
