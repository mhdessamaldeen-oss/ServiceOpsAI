@model List<ServiceOpsAI.Models.Region>
@{
    ViewData["Title"] = "Regions";
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Regions",
        Subtitle = "Hierarchical geography — Country → Governorate → District. Used by Customers (district), Departments (governorate), and Tickets (issue location).",
        IconClass = "bi bi-map",
        Actions = new()
        {
            new() { Text = "New Region", Href = Url.Action("Create") ?? "#", IconClass = "bi bi-plus-circle", CssClass = "btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm" }
        }
    };
    var allCountries = (List<ServiceOpsAI.Models.Country>)ViewBag.Countries;
    var selectedCountryId = (int?)ViewBag.SelectedCountryId;
    var governorates = Model.Where(r => r.RegionType == ServiceOpsAI.Models.RegionType.Governorate).OrderBy(r => r.NameEn).ToList();
    var districtsByParent = Model.Where(r => r.RegionType == ServiceOpsAI.Models.RegionType.District)
                                 .GroupBy(r => r.ParentRegionId ?? 0)
                                 .ToDictionary(g => g.Key, g => g.OrderBy(r => r.NameEn).ToList());
}

<partial name="_PageHeader" model="header" />

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]</div>
}

<div class="card border-0 shadow-sm mb-4" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-3">
        <form method="get" class="d-flex align-items-end gap-2">
            <div class="flex-grow-1">
                <label class="form-label small fw-bold text-muted text-uppercase">Filter by Country</label>
                <select name="countryId" class="form-select bg-transparent shadow-none" style="border-color: var(--border-color); color: var(--text-main);">
                    <option value="">All countries</option>
                    @foreach (var c in allCountries)
                    {
                        <option value="@c.Id" selected="@(selectedCountryId == c.Id)">@c.NameEn / @c.NameAr</option>
                    }
                </select>
            </div>
            <div><button type="submit" class="btn btn-primary"><i class="bi bi-filter"></i> Apply</button></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        @foreach (var gov in governorates)
        {
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0 fw-bold" style="color: var(--text-main) !important;">
                        <i class="bi bi-geo-alt-fill text-primary me-2"></i>@gov.NameEn
                        <span class="text-muted small" dir="rtl">@gov.NameAr</span>
                    </h6>
                    <div>
                        <a class="btn btn-sm btn-soft-info" asp-action="Details" asp-route-id="@gov.Id"><i class="bi bi-eye"></i></a>
                        <a class="btn btn-sm btn-soft-primary" asp-action="Edit" asp-route-id="@gov.Id"><i class="bi bi-pencil"></i></a>
                        <a class="btn btn-sm btn-soft-success" asp-action="Create" asp-route-parentRegionId="@gov.Id">
                            <i class="bi bi-plus-lg"></i> District
                        </a>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2 ps-4">
                    @if (districtsByParent.TryGetValue(gov.Id, out var districts))
                    {
                        @foreach (var d in districts)
                        {
                            <span class="badge px-3 py-2 rounded-pill"
                                  style="background: rgba(var(--primary-color-rgb), 0.08) !important; color: var(--text-main) !important; border: 1px solid var(--border-color) !important;">
                                <a asp-action="Edit" asp-route-id="@d.Id" class="text-decoration-none" style="color: inherit;">
                                    @d.NameEn / <span dir="rtl">@d.NameAr</span>
                                </a>
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted small">No districts</span>
                    }
                </div>
            </div>
        }
        @if (!governorates.Any())
        {
            <div class="text-center text-muted p-5">No governorates defined.</div>
        }
    </div>
</div>
