@model ServiceOpsAI.Models.Department
@{ ViewData["Title"] = $"Department #{Model.Id}"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-diagram-3"></i> @Model.NameEn <span class="text-muted small" dir="rtl">@Model.NameAr</span></h2>
    <div>
        <a class="btn btn-outline-primary" href="@Url.Action("Edit", new { id = Model.Id })"><i class="bi bi-pencil"></i> Edit</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Service Type</dt>  <dd class="col-sm-9"><span class="badge bg-info">@Model.ServiceType</span></dd>
    <dt class="col-sm-3">Region</dt>        <dd class="col-sm-9">@(Model.Region?.NameEn ?? "—") <span class="text-muted small">@(Model.Region?.NameAr ?? "")</span></dd>
    <dt class="col-sm-3">Contact Phone</dt> <dd class="col-sm-9">@(Model.ContactPhone ?? "—")</dd>
    <dt class="col-sm-3">Contact Email</dt> <dd class="col-sm-9">@(Model.ContactEmail ?? "—")</dd>
    <dt class="col-sm-3">Active</dt>        <dd class="col-sm-9">@(Model.IsActive ? "✓" : "✗")</dd>
</dl>
