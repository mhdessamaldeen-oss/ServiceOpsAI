@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.DepartmentDto>

@{
    ViewData["Title"] = "Departments Management";
    var request = Model.Request;
    var deptsTable = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Department Registry",
        Subtitle = "Regional service operators — one per (governorate, service type) pair.",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#departmentsTable",
        TablePartialName = "~/Views/Departments/_DepartmentsTable.cshtml",
        TableModel = Model,
        PaginationModel = Model
    };
    var deptsHeader = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Departments",
        Subtitle = "56 regional service departments — 14 governorates × 4 services (Electricity, Internet, Water, Gas).",
        IconClass = "bi bi-diagram-3",
        Actions = new()
        {
            new() {
                Text = "New Department",
                Href = Url.Action("Create", "Departments") ?? "#",
                IconClass = "bi bi-plus-circle",
                CssClass = "btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm"
            }
        }
    };
}

<partial name="_PageHeader" model="deptsHeader" />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger bg-danger-subtle text-danger border-0 d-flex align-items-center mb-4 rounded-3">
        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
        <div>
            <strong>Deletion Prevented:</strong> @TempData["Error"]
        </div>
    </div>
}

<div class="card border-0 shadow-sm mb-4" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-10">
                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Search Department</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--border-color) !important;"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="request.SearchString" class="form-control border-start-0 bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;" placeholder="Department name (EN/AR), or governorate..." value="@request.SearchString">
                </div>
            </div>
            <div class="col-lg-2">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="bi bi-filter"></i> Apply
                </button>
            </div>
        </form>
    </div>
</div>

<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="deptsTable" />
