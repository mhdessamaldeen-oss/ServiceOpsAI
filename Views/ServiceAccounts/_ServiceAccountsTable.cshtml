@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.ServiceAccountDto>

<div class="table-responsive">
    <table id="serviceAccountsTable" class="table table-hover align-middle mb-0 datatable-premium" data-column-search="true">
        <thead>
            <tr>
                <th class="ps-4 py-3">Account #</th>
                <th class="py-3">Customer</th>
                <th class="py-3">Service</th>
                <th class="py-3">Point</th>
                <th class="py-3">Segment</th>
                <th class="py-3">Status</th>
                <th class="py-3">Activated</th>
                <th class="text-end pe-4 py-3 no-sort">Controls</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Items)
            {
                <tr>
                    <td class="ps-4 fw-bold"><code style="color: var(--primary-color) !important;">@a.AccountNumber</code></td>
                    <td style="color: var(--text-main) !important;">@a.CustomerName</td>
                    <td>
                        @{ var (bg, fg) = a.ServiceType switch { "Electricity" => ("rgba(245,158,11,0.1)", "#f59e0b"), "Internet" => ("rgba(56,189,248,0.1)", "#38bdf8"), "Water" => ("rgba(96,165,250,0.1)", "#60a5fa"), "Gas" => ("rgba(248,113,113,0.1)", "#f87171"), _ => ("rgba(148,163,184,0.1)", "#94a3b8") }; }
                        <span class="badge px-3 py-2 rounded-pill" style="background: @bg; color: @fg; border: 1px solid @fg;">@a.ServiceType</span>
                    </td>
                    <td><code class="text-muted">@a.ServicePointCode</code></td>
                    <td class="small">@a.CustomerSegment</td>
                    <td>
                        @{ var (sbg, sfg) = a.Status switch { "Active" => ("rgba(var(--primary-color-rgb),0.1)", "var(--primary-color)"), "Suspended" => ("rgba(245,158,11,0.1)", "#f59e0b"), "Terminated" => ("rgba(var(--danger-color-rgb),0.1)", "var(--danger-color)"), _ => ("rgba(148,163,184,0.1)", "#94a3b8") }; }
                        <span class="badge px-3 py-2 rounded-pill" style="background: @sbg; color: @sfg; border: 1px solid @sfg;">@a.Status</span>
                    </td>
                    <td class="small text-muted">@a.ActivatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end pe-4">
                        <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-soft-info shadow-none"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-soft-primary shadow-none"><i class="bi bi-pencil-square"></i></a>
                        <form asp-action="Delete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Delete @a.AccountNumber?');" class="d-inline">
                            @Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-soft-danger shadow-none"><i class="bi bi-trash-fill"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any()) { <div class="text-center p-5 text-muted"><i class="bi bi-inbox fs-1 mb-3"></i><h6>No accounts match the current filter.</h6></div> }
</div>
