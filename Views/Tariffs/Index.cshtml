@model List<ServiceOpsAI.Models.Tariff>
@{
    ViewData["Title"] = "Tariffs";
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Tariffs",
        Subtitle = "Historical pricing per (ServiceType, Region). Tariff changes are what the Copilot uses to explain bill jumps.",
        IconClass = "bi bi-tag-fill"
    };
    var shell = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Tariff Registry",
        Subtitle = "Effective-from windows decide which tariff applies to a Bill's period.",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#tariffsTable",
        TablePartialName = "~/Views/Tariffs/_TariffsTable.cshtml",
        TableModel = Model
    };
}

<partial name="_PageHeader" model="header" />
<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="shell" />
