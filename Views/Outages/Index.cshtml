@model List<ServiceOpsAI.Models.Outage>
@{
    ViewData["Title"] = "Outages";
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Outages",
        Subtitle = $"Service outage events (read-only). {ViewBag.Total} total. Tickets attribute to an outage via OutageId for cluster analysis.",
        IconClass = "bi bi-exclamation-octagon-fill"
    };
    var shell = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Outage Registry",
        Subtitle = "Explicit outage events with severity, cause, MTTR, and affected-customer counts.",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#outagesTable",
        TablePartialName = "~/Views/Outages/_OutagesTable.cshtml",
        TableModel = Model
    };
}

<partial name="_PageHeader" model="header" />
<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="shell" />
