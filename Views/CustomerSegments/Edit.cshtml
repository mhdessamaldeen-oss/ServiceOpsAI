@model ServiceOpsAI.Models.CustomerSegment
@{ ViewData["Title"] = "Edit Customer Segment"; }

<h2><i class="bi bi-pencil-square"></i> Edit @Model.NameEn</h2>

<form asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-4"><label asp-for="Code" class="form-label">Code</label><input asp-for="Code" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="NameEn" class="form-label">Name (EN)</label><input asp-for="NameEn" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="NameAr" class="form-label">Name (AR)</label><input asp-for="NameAr" class="form-control" dir="rtl" /></div>
    <div class="col-md-3"><label asp-for="DefaultPriorityFloor" class="form-label">Priority Floor</label><input asp-for="DefaultPriorityFloor" type="number" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="SortOrder" class="form-label">Sort Order</label><input asp-for="SortOrder" type="number" class="form-control" /></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsSubsidyEligible" class="form-check-input" /><label asp-for="IsSubsidyEligible" class="form-check-label">Subsidy eligible</label></div></div>
    <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Active</label></div></div>
    <div class="col-12"><button type="submit" class="btn btn-primary">Save</button> <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a></div>
</form>
