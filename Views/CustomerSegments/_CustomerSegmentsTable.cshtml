@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.CustomerSegmentDto>

<div class="table-responsive">
    <table id="segmentsTable" class="table table-hover align-middle mb-0 datatable-premium" data-column-search="true">
        <thead>
            <tr>
                <th class="ps-4 py-3">Code</th>
                <th class="py-3">Name</th>
                <th class="py-3">Subsidy Eligible?</th>
                <th class="text-end py-3">Priority Floor</th>
                <th class="py-3">Order</th>
                <th class="py-3">Active</th>
                <th class="text-end pe-4 py-3 no-sort">Controls</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Items)
            {
                <tr>
                    <td class="ps-4 fw-bold"><code style="color: var(--primary-color) !important;">@s.Code</code></td>
                    <td><div style="color: var(--text-main) !important;">@s.NameEn</div><div class="small text-muted" dir="rtl">@s.NameAr</div></td>
                    <td>
                        @if (s.IsSubsidyEligible) { <span class="badge rounded-pill px-3 py-2" style="background: rgba(var(--primary-color-rgb),0.1); color: var(--primary-color); border: 1px solid var(--primary-color);">Yes</span> }
                        else { <span class="text-muted">No</span> }
                    </td>
                    <td class="text-end">@s.DefaultPriorityFloor</td>
                    <td class="small text-muted">@s.SortOrder</td>
                    <td>@(s.IsActive ? "Yes" : "No")</td>
                    <td class="text-end pe-4">
                        <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-soft-info shadow-none"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-soft-primary shadow-none"><i class="bi bi-pencil-square"></i></a>
                        <form asp-action="Delete" asp-route-id="@s.Id" method="post" onsubmit="return confirm('Delete segment @s.NameEn?');" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-soft-danger shadow-none"><i class="bi bi-trash-fill"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any()) { <div class="text-center p-5 text-muted"><i class="bi bi-inbox fs-1 mb-3"></i><h6>No segments match the current filter.</h6></div> }
</div>
