@model ServiceOpsAI.Models.ApplicationUser

@{
    ViewData["Title"] = "Create User";
    var userCreateHeader = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Provision New User",
        Subtitle = "Add a user to the access directory and assign their role",
        IconClass = "bi bi-person-plus-fill",
        Actions = new()
        {
            new() {
                Text = "Cancel",
                Href = Url.Action("Index", "Users") ?? "#",
                IconClass = "bi bi-arrow-left",
                CssClass = "btn btn-sm btn-soft-secondary rounded-pill px-3 fw-bold"
            }
        }
    };
}

<partial name="_PageHeader" model="userCreateHeader" />

<div class="row">
    <div class="col-xl-7 col-lg-9 mx-auto">
        <div class="app-card">
            <div class="app-card-body p-4 p-lg-5">
                <form asp-action="Create" class="app-form-grid">
                    <div asp-validation-summary="All" class="app-form-error mb-3"></div>

                    <div class="app-form-row">
                        <div class="app-form-field">
                            <label asp-for="Email" class="app-form-label"></label>
                            <input asp-for="Email" class="form-control" type="email" required />
                        </div>
                    </div>

                    <div class="app-form-row">
                        <div class="app-form-field app-form-field-half">
                            <label asp-for="FirstName" class="app-form-label"></label>
                            <input asp-for="FirstName" class="form-control" required />
                        </div>
                        <div class="app-form-field app-form-field-half">
                            <label asp-for="LastName" class="app-form-label"></label>
                            <input asp-for="LastName" class="form-control" required />
                        </div>
                    </div>

                    <div class="app-form-row">
                        <div class="app-form-field">
                            <label asp-for="DepartmentId" class="app-form-label">Entity</label>
                            <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId" required></select>
                        </div>
                    </div>

                    <div class="p-3 rounded-3" style="background: var(--bg-surface-alt); border: 1px solid var(--border-color);">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input @(Loc.IsRtl ? "ms-0 ms-3" : "me-3") mt-1" type="checkbox" name="isAdmin" value="true" id="isAdminCheck">
                            <label class="form-check-label fw-bold" style="color: var(--primary-color);" for="isAdminCheck">Grant Administrator Privileges</label>
                        </div>
                        <div class="text-muted small ms-4 ps-2">Checking this box explicitly promotes the user to System Administrator, overriding the standard role.</div>
                    </div>

                    <div class="app-form-row">
                        <div class="app-form-field app-form-field-half">
                            <label class="app-form-label">Standard Role (if not admin)</label>
                            <select name="role" class="form-select" asp-items="ViewBag.Roles" required></select>
                        </div>
                        <div class="app-form-field app-form-field-half">
                            <label class="app-form-label">Password</label>
                            <input type="password" name="password" class="form-control" required />
                        </div>
                    </div>

                    <div class="app-form-actions">
                        <a asp-action="Index" class="btn btn-sm btn-soft-secondary rounded-pill px-4 fw-bold app-form-actions-secondary">
                            <i class="bi bi-arrow-left @(Loc.IsRtl ? "ms-1" : "me-1")"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-person-check-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>Create User
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
