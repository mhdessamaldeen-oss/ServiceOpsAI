@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ServiceOpsAI.Data.ApplicationDbContext DbContext

@{
    var themeSetting = DbContext.SystemSettings.FirstOrDefault(s => s.Key == "DefaultTheme");
    int currentId = 1;
    if (int.TryParse(themeSetting?.Value, out int tid)) { currentId = tid; }

    var theme = DbContext.CustomThemes.FirstOrDefault(t => t.Id == currentId)
                  ?? DbContext.CustomThemes.FirstOrDefault(t => t.IsSystemTheme)
                   ?? new CustomTheme();

    // ── Helpers: hex → rgb triple, luminance test for "is this a light theme" ──
    string ToRgbTriple(string hex, string fallback)
    {
        try {
            var c = System.Drawing.ColorTranslator.FromHtml(hex);
            return $"{c.R}, {c.G}, {c.B}";
        } catch { return fallback; }
    }

    bool IsLight(string hex)
    {
        try {
            var c = System.Drawing.ColorTranslator.FromHtml(hex);
            // Relative luminance (sRGB) — > 0.5 means light surface
            double L(double v) { v /= 255.0; return v <= 0.03928 ? v/12.92 : Math.Pow((v + 0.055)/1.055, 2.4); }
            var lum = 0.2126 * L(c.R) + 0.7152 * L(c.G) + 0.0722 * L(c.B);
            return lum > 0.5;
        } catch { return false; }
    }

    var primaryRgb     = ToRgbTriple(theme.PrimaryColor, "99, 102, 241");
    var bgCardRgb      = ToRgbTriple(theme.BgCard,        "24, 24, 27");
    var bgMainRgb      = ToRgbTriple(theme.BgMain,        "10, 10, 10");
    var textMainRgb    = ToRgbTriple(theme.TextMain,      "255, 255, 255");
    var textMutedRgb   = ToRgbTriple(theme.TextMuted,     "161, 161, 170");
    var borderRgb      = ToRgbTriple(theme.BorderColor,   "39, 39, 42");

    // ── Resolve extended tokens with sensible fallbacks (per light/dark theme) ──
    var isLightTheme        = IsLight(theme.BgMain);
    var primaryContrastText = !string.IsNullOrWhiteSpace(theme.PrimaryContrastText) ? theme.PrimaryContrastText
                              : (IsLight(theme.PrimaryColor) ? "#000000" : "#ffffff");
    var bgSurfaceAlt        = !string.IsNullOrWhiteSpace(theme.BgSurfaceAlt) ? theme.BgSurfaceAlt : theme.BgCard;
    var bgElevated          = !string.IsNullOrWhiteSpace(theme.BgElevated)   ? theme.BgElevated   : theme.BgCard;
    var successColor        = !string.IsNullOrWhiteSpace(theme.SuccessColor) ? theme.SuccessColor : (isLightTheme ? "#16a34a" : "#34d399");
    var warningColor        = !string.IsNullOrWhiteSpace(theme.WarningColor) ? theme.WarningColor : (isLightTheme ? "#d97706" : "#fbbf24");
    var dangerColor         = !string.IsNullOrWhiteSpace(theme.DangerColor)  ? theme.DangerColor  : (isLightTheme ? "#dc2626" : "#f87171");
    var infoColor           = !string.IsNullOrWhiteSpace(theme.InfoColor)    ? theme.InfoColor    : (isLightTheme ? "#2563eb" : "#60a5fa");
    var shadowColor         = !string.IsNullOrWhiteSpace(theme.ShadowColor)  ? theme.ShadowColor  : (isLightTheme ? "rgba(15, 23, 42, 0.08)" : "rgba(0, 0, 0, 0.45)");

    var successRgb = ToRgbTriple(successColor, "16, 163, 74");
    var warningRgb = ToRgbTriple(warningColor, "217, 119, 6");
    var dangerRgb  = ToRgbTriple(dangerColor,  "220, 38, 38");
    var infoRgb    = ToRgbTriple(infoColor,    "37, 99, 235");

    var isLightFlag = isLightTheme ? "1" : "0";

    var themeStyles = $@"
        /* Core surfaces & text */
        --primary-color: {theme.PrimaryColor};
        --primary-color-rgb: {primaryRgb};
        --primary-contrast-text: {primaryContrastText};
        --primary-gradient: linear-gradient(135deg, {theme.PrimaryColor} 0%, {theme.PrimaryColor}CC 100%);

        --bg-main: {theme.BgMain};
        --bg-main-rgb: {bgMainRgb};
        --bg-card: {theme.BgCard};
        --bg-card-rgb: {bgCardRgb};
        --bg-surface-alt: {bgSurfaceAlt};
        --bg-elevated: {bgElevated};
        --bg-sidebar: {theme.BgSidebar};
        --bg-header: {theme.BgHeader};

        --text-main: {theme.TextMain};
        --text-main-rgb: {textMainRgb};
        --text-muted: {theme.TextMuted};
        --text-muted-rgb: {textMutedRgb};

        --border-color: {theme.BorderColor};
        --border-color-rgb: {borderRgb};

        /* Semantic state colors */
        --success-color: {successColor}; --success-color-rgb: {successRgb};
        --warning-color: {warningColor}; --warning-color-rgb: {warningRgb};
        --danger-color:  {dangerColor};  --danger-color-rgb:  {dangerRgb};
        --info-color:    {infoColor};    --info-color-rgb:    {infoRgb};

        /* Depth */
        --shadow-color: {shadowColor};
        --shadow-sm: 0 2px 8px {shadowColor};
        --shadow-md: 0 8px 20px {shadowColor};
        --shadow-lg: 0 16px 40px {shadowColor};

        /* Derived primary tints (auto from primary-color-rgb) */
        --surface-soft:   rgba(var(--primary-color-rgb), 0.06);
        --surface-medium: rgba(var(--primary-color-rgb), 0.12);
        --surface-strong: rgba(var(--primary-color-rgb), 0.18);

        /* Theme mode flag (lets CSS opt into light-vs-dark behavior) */
        --is-light-theme: {isLightFlag};

        /* Backwards-compat aliases — many older CSS files use --bg-secondary / --primary
           as fallback variables. Aliasing them here means those rules become theme-aware
           without needing to rewrite every per-page stylesheet. */
        --bg-secondary: var(--bg-surface-alt);
        --bg-primary: var(--bg-card);
        --primary: var(--primary-color);
        --primary-rgb: var(--primary-color-rgb);
        --success: var(--success-color);
        --warning: var(--warning-color);
        --danger: var(--danger-color);
        --info: var(--info-color);
        --btn-primary-text: var(--primary-contrast-text);";
}

<!DOCTYPE html>
<html lang="@Loc.CurrentLanguage" dir="@Loc.Direction">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SupportFlow AI</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Noto+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    @if (Loc.IsRtl)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/platform-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/status-badge-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme-utilities.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ui-paradigm.css" asp-append-version="true" />
    @if (Loc.IsRtl)
    {
        <link rel="stylesheet" href="~/css/rtl-overrides.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.1/css/responsive.bootstrap5.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.1/css/buttons.bootstrap5.css">
    
    <style>
        :root { @Html.Raw(themeStyles) }
        @if (Loc.IsRtl) { <text>body { font-family: 'Noto Sans Arabic', sans-serif !important; }</text> }
    </style>
    @await RenderSectionAsync("Styles", required: false)

    <script>
        // Apply persisted sidebar collapsed state BEFORE first paint so the
        // sidebar/header don't flash at full width and then snap narrow.
        (function () {
            try {
                if (localStorage.getItem('sf-sidebar-collapsed') === '1') {
                    document.documentElement.classList.add('sidebar-collapsed');
                }
            } catch (e) { /* localStorage may be unavailable in private mode */ }
        })();
    </script>
</head>
<body class="sf-body @(Loc.IsRtl ? "rtl-mode" : "")">
    <nav class="sf-sidebar">
        <div class="sidebar-brand">
            <div class="icon-shape @(Loc.IsRtl ? "ms-3" : "me-3")" style="width: 36px; height: 36px; border-radius: 8px; background: var(--primary-color); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 15px rgba(var(--primary-color-rgb), 0.2);">
                <i class="bi bi-terminal-fill fs-5 text-white"></i>
            </div>
            <span style="color: var(--text-main); letter-spacing: -1px; font-weight: 900;">Support<span style="color: var(--primary-color);">Flow</span></span>
        </div>
        @{
            // Wrap the link label in a span so the collapsed-sidebar CSS can hide it
            // (a raw text node can't be targeted by `display: none`). The data-label
            // attribute drives the hover flyout when the sidebar is collapsed.
            var labelMargin = Loc.IsRtl ? "ms-3" : "me-3";
            var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        }
        <ul class="sidebar-menu">
            <li>
                <a class="sidebar-link @(currentController == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index" data-label="@Loc.Get("Dashboard")">
                    <i class="bi bi-grid-1x2-fill @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("Dashboard")</span>
                </a>
            </li>
            <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">Ticketing</li>
            <li>
                <a class="sidebar-link @(currentController == "Tickets" ? "active" : "")" asp-controller="Tickets" asp-action="Index" data-label="@Loc.Get("Tickets")">
                    <i class="bi bi-ticket-detailed-fill @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("Tickets")</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Csat" ? "active" : "")" asp-controller="Csat" asp-action="Index" data-label="CSAT">
                    <i class="bi bi-heart-fill @labelMargin"></i><span class="sidebar-link-text">CSAT</span>
                </a>
            </li>

            <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">Billing</li>
            <li>
                <a class="sidebar-link @(currentController == "Bills" ? "active" : "")" asp-controller="Bills" asp-action="Index" data-label="Bills">
                    <i class="bi bi-receipt @labelMargin"></i><span class="sidebar-link-text">Bills</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Payments" ? "active" : "")" asp-controller="Payments" asp-action="Index" data-label="Payments">
                    <i class="bi bi-cash-coin @labelMargin"></i><span class="sidebar-link-text">Payments</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Tariffs" ? "active" : "")" asp-controller="Tariffs" asp-action="Index" data-label="Tariffs">
                    <i class="bi bi-tag-fill @labelMargin"></i><span class="sidebar-link-text">Tariffs</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "TariffTiers" ? "active" : "")" asp-controller="TariffTiers" asp-action="Index" data-label="Tariff Tiers">
                    <i class="bi bi-layers-fill @labelMargin"></i><span class="sidebar-link-text">Tariff Tiers</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "ServiceAccounts" ? "active" : "")" asp-controller="ServiceAccounts" asp-action="Index" data-label="Service Accounts">
                    <i class="bi bi-file-earmark-text-fill @labelMargin"></i><span class="sidebar-link-text">Service Accounts</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "ServicePoints" ? "active" : "")" asp-controller="ServicePoints" asp-action="Index" data-label="Service Points">
                    <i class="bi bi-geo-alt-fill @labelMargin"></i><span class="sidebar-link-text">Service Points</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Subsidies" ? "active" : "")" asp-controller="Subsidies" asp-action="Index" data-label="Subsidies">
                    <i class="bi bi-bank @labelMargin"></i><span class="sidebar-link-text">Subsidies</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "MeterReadings" ? "active" : "")" asp-controller="MeterReadings" asp-action="Index" data-label="Meter Readings">
                    <i class="bi bi-speedometer2 @labelMargin"></i><span class="sidebar-link-text">Meter Readings</span>
                </a>
            </li>

            <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">Field Operations</li>
            <li>
                <a class="sidebar-link @(currentController == "WorkOrders" ? "active" : "")" asp-controller="WorkOrders" asp-action="Index" data-label="Work Orders">
                    <i class="bi bi-clipboard-check-fill @labelMargin"></i><span class="sidebar-link-text">Work Orders</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Assets" ? "active" : "")" asp-controller="Assets" asp-action="Index" data-label="Assets">
                    <i class="bi bi-hdd-stack-fill @labelMargin"></i><span class="sidebar-link-text">Assets</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Technicians" ? "active" : "")" asp-controller="Technicians" asp-action="Index" data-label="Technicians">
                    <i class="bi bi-person-vcard-fill @labelMargin"></i><span class="sidebar-link-text">Technicians</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "MaintenanceSchedules" ? "active" : "")" asp-controller="MaintenanceSchedules" asp-action="Index" data-label="Maintenance">
                    <i class="bi bi-tools @labelMargin"></i><span class="sidebar-link-text">Maintenance</span>
                </a>
            </li>

            <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">Customer Voice</li>
            <li>
                <a class="sidebar-link @(currentController == "CallLogs" ? "active" : "")" asp-controller="CallLogs" asp-action="Index" data-label="Call Logs">
                    <i class="bi bi-telephone-fill @labelMargin"></i><span class="sidebar-link-text">Call Logs</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "OutageNotifications" ? "active" : "")" asp-controller="OutageNotifications" asp-action="Index" data-label="Notifications">
                    <i class="bi bi-bell-fill @labelMargin"></i><span class="sidebar-link-text">Outage Notifications</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "SlaPolicies" ? "active" : "")" asp-controller="SlaPolicies" asp-action="Index" data-label="SLA Policies">
                    <i class="bi bi-shield-check @labelMargin"></i><span class="sidebar-link-text">SLA Policies</span>
                </a>
            </li>

            <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">Operations</li>
            <li>
                <a class="sidebar-link @(currentController == "Customers" ? "active" : "")" asp-controller="Customers" asp-action="Index" data-label="Customers">
                    <i class="bi bi-people-fill @labelMargin"></i><span class="sidebar-link-text">Customers</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "CustomerSegments" ? "active" : "")" asp-controller="CustomerSegments" asp-action="Index" data-label="Segments">
                    <i class="bi bi-people @labelMargin"></i><span class="sidebar-link-text">Customer Segments</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Departments" ? "active" : "")" asp-controller="Departments" asp-action="Index" data-label="Departments">
                    <i class="bi bi-diagram-3 @labelMargin"></i><span class="sidebar-link-text">Departments</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Regions" ? "active" : "")" asp-controller="Regions" asp-action="Index" data-label="Regions">
                    <i class="bi bi-map @labelMargin"></i><span class="sidebar-link-text">Regions</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Outages" ? "active" : "")" asp-controller="Outages" asp-action="Index" data-label="Outages">
                    <i class="bi bi-exclamation-octagon-fill @labelMargin"></i><span class="sidebar-link-text">Outages</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Countries" ? "active" : "")" asp-controller="Countries" asp-action="Index" data-label="Countries">
                    <i class="bi bi-globe2 @labelMargin"></i><span class="sidebar-link-text">Countries</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "Currencies" ? "active" : "")" asp-controller="Currencies" asp-action="Index" data-label="Currencies">
                    <i class="bi bi-currency-exchange @labelMargin"></i><span class="sidebar-link-text">Currencies</span>
                </a>
            </li>
            <li>
                <a class="sidebar-link @(currentController == "PaymentMethods" ? "active" : "")" asp-controller="PaymentMethods" asp-action="Index" data-label="Payment Methods">
                    <i class="bi bi-credit-card-2-front-fill @labelMargin"></i><span class="sidebar-link-text">Payment Methods</span>
                </a>
            </li>
            @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
            {
                <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">AI Analysis</li>
                <li>
                    <a class="sidebar-link @(currentController == "AiAnalysis" && currentAction == "Hub" ? "active" : "")" asp-controller="AiAnalysis" asp-action="Hub" data-label="@Loc.Get("AnalysisHub")">
                        <i class="bi bi-cpu-fill @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("AnalysisHub")</span>
                    </a>
                </li>
                <li>
                    <a class="sidebar-link @(currentController == "AiAnalysis" && currentAction == "Benchmark" ? "active" : "")" asp-controller="AiAnalysis" asp-action="Benchmark" data-label="@Loc.Get("RetrievalBenchmark")">
                        <i class="bi bi-speedometer2 @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("RetrievalBenchmark")</span>
                    </a>
                </li>
                <li>
                    <a class="sidebar-link @(currentController == "AiInsights" ? "active" : "")" asp-controller="AiInsights" asp-action="Index" data-label="@Loc.Get("Insights")">
                        <i class="bi bi-lightbulb-fill @labelMargin text-warning"></i><span class="sidebar-link-text">@Loc.Get("Insights")</span>
                    </a>
                </li>
            }

            <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">Reports</li>
            <li>
                <a class="sidebar-link @(currentController == "Reports" ? "active" : "")" asp-controller="Reports" asp-action="Index" data-label="@Loc.Get("Reports")">
                    <i class="bi bi-bar-chart-fill @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("Reports")</span>
                </a>
            </li>
            @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
            {
                <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">@Loc.Get("Administration")</li>
                <li><a class="sidebar-link" asp-controller="Users" asp-action="Index" data-label="@Loc.Get("Users")"><i class="bi bi-people-fill @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("Users")</span></a></li>
                @* Legacy /Entities link removed — its controller uses Department.Name in LINQ
                   queries, but Name is now a [NotMapped] alias for NameEn so EF can't translate
                   it. Use /Departments instead. *@
                <li><a class="sidebar-link" asp-controller="ReferenceData" asp-action="Index" data-label="@Loc.Get("ReferenceData")"><i class="bi bi-database-fill @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("ReferenceData")</span></a></li>
                <li><a class="sidebar-link" asp-controller="Settings" asp-action="Index" data-label="@Loc.Get("Settings")"><i class="bi bi-gear-wide-connected @labelMargin"></i><span class="sidebar-link-text">@Loc.Get("Settings")</span></a></li>
            }
        </ul>
    </nav>

    <div class="sf-wrapper">
        <header class="sf-header sticky-top">
            <div class="container-fluid px-3 h-100 d-flex align-items-center justify-content-between flex-nowrap">
                <div class="d-flex align-items-center gap-4 flex-nowrap">
                    <button id="sidebarToggle" type="button"
                            class="sf-sidebar-toggle btn btn-sm shadow-none"
                            aria-label="@Loc.Get("ToggleSidebar")"
                            title="@Loc.Get("ToggleSidebar")">
                        <i class="bi bi-layout-sidebar-inset"></i>
                    </button>
                    <div class="header-titles text-nowrap">
                        <div class="d-flex align-items-center gap-2">
                             <span class="mb-0 fw-bold" style="color: var(--text-main); font-size: 0.95rem;">@ViewData["Title"]</span>
                             <span class="text-muted" style="opacity: 0.3;">|</span>
                             <span class="fw-semibold small" style="color: var(--primary-color);">@Loc.Get("WorkspaceTitle")</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3 flex-nowrap ms-auto">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-lang-switcher rounded-pill px-3 py-1 dropdown-toggle shadow-none text-nowrap" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-translate @(Loc.IsRtl ? "ms-2" : "me-2")" style="color: var(--primary-color);"></i>@(Loc.IsRtl ? "AR" : "EN")
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" style="background: var(--bg-card); min-width: 140px;">
                            <li><a class="dropdown-item text-main py-2" href="javascript:void(0)" onclick="changeLanguage('en')">English @(Loc.CurrentLanguage == "en" ? "✓" : "")</a></li>
                            <li><a class="dropdown-item text-main py-2" href="javascript:void(0)" onclick="changeLanguage('ar')">العربية @(Loc.CurrentLanguage == "ar" ? "✓" : "")</a></li>
                        </ul>
                    </div>
                    @if (SignInManager.IsSignedIn(User)) { @await Component.InvokeAsync("NotificationCount") }
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>

        @if (ViewData["HideBreadcrumbs"] is not true)
        {
            @await Component.InvokeAsync("Breadcrumbs")
        }
        <main role="main">@RenderBody()</main>

        <footer class="footer text-muted py-4 mt-auto">
            <div class="container-fluid px-4 @(Loc.IsRtl ? "text-end" : "text-start")">
                <div class="row align-items-center justify-content-between">
                    <div class="col-auto">&copy; 2026 - <span class="fw-bold">SupportFlow AI</span></div>
                    <div class="col-auto small text-muted">v2.1.0-PREMIUM</div>
                </div>
            </div>
        </footer>
    </div>

    <form id="selectLanguage" asp-controller="Home" asp-action="SetLanguage" method="post" class="d-none">
        <input type="hidden" name="culture" id="lang-input" />
        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
    </form>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.bootstrap5.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/app-localization.js" asp-append-version="true"></script>
    <script>
        (function () {
            var btn = document.getElementById('sidebarToggle');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var collapsed = document.documentElement.classList.toggle('sidebar-collapsed');
                try { localStorage.setItem('sf-sidebar-collapsed', collapsed ? '1' : '0'); } catch (e) { }
                btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            });
            btn.setAttribute('aria-expanded',
                document.documentElement.classList.contains('sidebar-collapsed') ? 'false' : 'true');
        })();

        // Collapsed-sidebar hover flyout: the menu UL is a scroll container so the
        // ::after flyout uses position: fixed (see site.css). Anchor it to the
        // hovered link via CSS variables from getBoundingClientRect.
        (function () {
            var isRtl = document.documentElement.getAttribute('dir') === 'rtl';
            document.querySelectorAll('.sf-sidebar .sidebar-link[data-label]').forEach(function (link) {
                link.addEventListener('mouseenter', function () {
                    if (!document.documentElement.classList.contains('sidebar-collapsed')) return;
                    var r = link.getBoundingClientRect();
                    link.style.setProperty('--flyout-top', (r.top + r.height / 2) + 'px');
                    link.style.setProperty('--flyout-left', (isRtl ? (r.left - 8) : (r.right + 8)) + 'px');
                });
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
