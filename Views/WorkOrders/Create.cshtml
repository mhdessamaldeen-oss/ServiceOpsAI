@model ServiceOpsAI.Models.WorkOrder
@{ ViewData["Title"] = "New Work Order"; }

<h2><i class="bi bi-plus-circle"></i> New Work Order</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-4"><label asp-for="OrderNumber" class="form-label">Order #</label><input asp-for="OrderNumber" class="form-control" placeholder="WO-2026-04-008711" /></div>
    <div class="col-md-4"><label asp-for="TitleEn" class="form-label">Title (EN)</label><input asp-for="TitleEn" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="TitleAr" class="form-label">Title (AR)</label><input asp-for="TitleAr" class="form-control" dir="rtl" /></div>
    <div class="col-md-3"><label asp-for="OrderType" class="form-label">Type</label><select asp-for="OrderType" class="form-select">@foreach (var v in Enum.GetValues<ServiceOpsAI.Models.WorkOrderType>()){<option value="@v">@v</option>}</select></div>
    <div class="col-md-3"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select">@foreach (var v in Enum.GetValues<ServiceOpsAI.Models.WorkOrderStatus>()){<option value="@v">@v</option>}</select></div>
    <div class="col-md-3"><label asp-for="Priority" class="form-label">Priority</label><select asp-for="Priority" class="form-select">@foreach (var v in Enum.GetValues<ServiceOpsAI.Models.WorkOrderPriority>()){<option value="@v">@v</option>}</select></div>
    <div class="col-md-3"><label asp-for="AssignedTechnicianId" class="form-label">Technician</label><select asp-for="AssignedTechnicianId" class="form-select" asp-items="ViewBag.Technicians"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="TicketId" class="form-label">Ticket</label><select asp-for="TicketId" class="form-select" asp-items="ViewBag.Tickets"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="OutageId" class="form-label">Outage</label><select asp-for="OutageId" class="form-select" asp-items="ViewBag.Outages"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="AssetId" class="form-label">Asset</label><select asp-for="AssetId" class="form-select" asp-items="ViewBag.Assets"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="ServicePointId" class="form-label">Service Point</label><select asp-for="ServicePointId" class="form-select" asp-items="ViewBag.ServicePoints"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="DepartmentId" class="form-label">Department</label><select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="RegionId" class="form-label">Region</label><select asp-for="RegionId" class="form-select" asp-items="ViewBag.Regions"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="CreatedAt" class="form-label">Created</label><input asp-for="CreatedAt" type="datetime-local" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="DispatchedAt" class="form-label">Dispatched</label><input asp-for="DispatchedAt" type="datetime-local" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="ArrivedOnSiteAt" class="form-label">Arrived</label><input asp-for="ArrivedOnSiteAt" type="datetime-local" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="CompletedAt" class="form-label">Completed</label><input asp-for="CompletedAt" type="datetime-local" class="form-control" /></div>
    <div class="col-12"><label asp-for="Description" class="form-label">Description</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
    <div class="col-12"><label asp-for="ResolutionNotes" class="form-label">Resolution Notes</label><textarea asp-for="ResolutionNotes" class="form-control" rows="2"></textarea></div>
    <div class="col-12 form-check"><input asp-for="RequiredSecondVisit" class="form-check-input" /><label asp-for="RequiredSecondVisit" class="form-check-label">Required second visit</label></div>
    <div class="col-12"><button type="submit" class="btn btn-primary">Create</button> <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a></div>
</form>
