@model List<ServiceOpsAI.Models.CsatResponse>
@{
    ViewData["Title"] = "Customer Satisfaction (CSAT)";
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Customer Satisfaction",
        Subtitle = $"{ViewBag.Total} CSAT responses · Avg score: {((double)ViewBag.AvgScore).ToString("F2")}/5 · Labeled outcomes for Copilot quality measurement.",
        IconClass = "bi bi-heart-fill"
    };
    var shell = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Satisfaction Registry",
        Subtitle = "Per-resolved-ticket scores 1-5 with bilingual comment + AI-classified sentiment.",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = "In-Depth Column Filters",
        TableSelector = "#csatTable",
        TablePartialName = "~/Views/Csat/_CsatTable.cshtml",
        TableModel = Model
    };
}

<partial name="_PageHeader" model="header" />
<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="shell" />
