@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.CurrencyDto>

@{
    ViewData["Title"] = "Currencies";
    var request = Model.Request;
    var shell = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Currency Registry",
        Subtitle = "Currencies the platform accepts. SYP is the reporting base; rates are indicative defaults — payments capture their own rate at posting time.",
        ShowColumnSearchToggle = true,
        TableSelector = "#currenciesTable",
        TablePartialName = "~/Views/Currencies/_CurrenciesTable.cshtml",
        TableModel = Model,
        PaginationModel = Model
    };
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Currencies",
        Subtitle = "SYP / USD / EUR / TRY — managed currencies for multi-currency payments.",
        IconClass = "bi bi-currency-exchange",
        Actions = new()
        {
            new() { Text = "New Currency", Href = Url.Action("Create", "Currencies") ?? "#", IconClass = "bi bi-plus-circle", CssClass = "btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm" }
        }
    };
}

<partial name="_PageHeader" model="header" />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger bg-danger-subtle text-danger border-0 mb-4 rounded-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]</div>
}

<div class="card border-0 shadow-sm mb-4" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-10">
                <label class="form-label small fw-bold text-muted text-uppercase">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="request.SearchString" class="form-control bg-transparent" placeholder="Code (SYP, USD), English or Arabic name…" value="@request.SearchString" />
                </div>
            </div>
            <div class="col-lg-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i> Apply</button></div>
        </form>
    </div>
</div>

<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="shell" />
