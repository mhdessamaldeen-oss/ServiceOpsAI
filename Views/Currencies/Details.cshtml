@model ServiceOpsAI.Models.Currency
@{ ViewData["Title"] = "Currency Details"; }

<h2><i class="bi bi-currency-exchange"></i> @Model.Code — @Model.NameEn</h2>

<div class="card shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Code</dt><dd class="col-sm-9"><code>@Model.Code</code></dd>
            <dt class="col-sm-3">Symbol</dt><dd class="col-sm-9 fs-4">@Model.Symbol</dd>
            <dt class="col-sm-3">Name (EN)</dt><dd class="col-sm-9">@Model.NameEn</dd>
            <dt class="col-sm-3">Name (AR)</dt><dd class="col-sm-9" dir="rtl">@Model.NameAr</dd>
            <dt class="col-sm-3">Rate to Base (SYP)</dt><dd class="col-sm-9 fw-bold">@Model.ExchangeRateToBase.ToString("N4")</dd>
            <dt class="col-sm-3">Base?</dt><dd class="col-sm-9">@(Model.IsBase ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Active?</dt><dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Last Rate Update</dt><dd class="col-sm-9">@Model.LastRateUpdate.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>
