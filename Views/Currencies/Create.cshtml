@model ServiceOpsAI.Models.Currency
@{ ViewData["Title"] = "New Currency"; }

<h2><i class="bi bi-plus-circle"></i> New Currency</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-3"><label asp-for="Code" class="form-label">ISO Code</label><input asp-for="Code" class="form-control" placeholder="SYP / USD / EUR / TRY" /><span asp-validation-for="Code" class="text-danger small"></span></div>
    <div class="col-md-3"><label asp-for="Symbol" class="form-label">Symbol</label><input asp-for="Symbol" class="form-control" placeholder="$ / € / ₺ / ل.س" /></div>
    <div class="col-md-3"><label asp-for="NameEn" class="form-label">Name (EN)</label><input asp-for="NameEn" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="NameAr" class="form-label">Name (AR)</label><input asp-for="NameAr" class="form-control" dir="rtl" /></div>
    <div class="col-md-4"><label asp-for="ExchangeRateToBase" class="form-label">Rate to Base (SYP)</label><input asp-for="ExchangeRateToBase" type="number" step="0.0001" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="LastRateUpdate" class="form-label">Last Updated</label><input asp-for="LastRateUpdate" type="date" class="form-control" /></div>
    <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input asp-for="IsBase" class="form-check-input" /><label asp-for="IsBase" class="form-check-label">Base Currency</label></div></div>
    <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Active</label></div></div>
    <div class="col-12"><button type="submit" class="btn btn-primary">Create</button> <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a></div>
</form>
