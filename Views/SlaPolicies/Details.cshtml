@model ServiceOpsAI.Models.SlaPolicy
@{ ViewData["Title"] = "SLA Policy Details"; }

<h2><i class="bi bi-shield-check"></i> @Model.PolicyCode</h2>

<div class="card shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Code</dt><dd class="col-sm-9"><code>@Model.PolicyCode</code></dd>
            <dt class="col-sm-3">Name (EN/AR)</dt><dd class="col-sm-9">@Model.NameEn / <span dir="rtl">@Model.NameAr</span></dd>
            <dt class="col-sm-3">Segment</dt><dd class="col-sm-9">@(Model.CustomerSegment?.NameEn ?? "Any")</dd>
            <dt class="col-sm-3">Service Type</dt><dd class="col-sm-9">@(Model.ServiceType?.NameEn ?? "Any")</dd>
            <dt class="col-sm-3">Priority</dt><dd class="col-sm-9">@(Model.Priority?.Name ?? "Any")</dd>
            <dt class="col-sm-3">First-Response Target</dt><dd class="col-sm-9 fw-bold">@Model.FirstResponseMinutes min</dd>
            <dt class="col-sm-3">Resolution Target</dt><dd class="col-sm-9 fw-bold">@Model.ResolutionMinutes min</dd>
            <dt class="col-sm-3">Business Hours Only?</dt><dd class="col-sm-9">@(Model.BusinessHoursOnly ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Effective From → To</dt><dd class="col-sm-9">@Model.EffectiveFrom.ToString("yyyy-MM-dd") → @(Model.EffectiveTo?.ToString("yyyy-MM-dd") ?? "Open-ended")</dd>
            <dt class="col-sm-3">Active?</dt><dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@Model.Notes</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>
