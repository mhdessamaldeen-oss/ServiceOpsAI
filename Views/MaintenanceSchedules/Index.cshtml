@model ServiceOpsAI.Models.Common.PagedResult<ServiceOpsAI.Models.DTOs.MaintenanceScheduleDto>

@{
    ViewData["Title"] = "Maintenance Schedules";
    var request = Model.Request;
    var shell = new ServiceOpsAI.Models.Common.FeatureTableShellViewModel
    {
        Title = "Maintenance Schedules",
        Subtitle = "Planned maintenance windows per asset / region. Outages that fall inside a window count as planned downtime.",
        ShowColumnSearchToggle = true,
        TableSelector = "#maintenanceTable",
        TablePartialName = "~/Views/MaintenanceSchedules/_MaintenanceSchedulesTable.cshtml",
        TableModel = Model, PaginationModel = Model
    };
    var header = new ServiceOpsAI.Models.Common.PageHeaderViewModel
    {
        Title = "Maintenance Schedules",
        Subtitle = "Planned outage windows — feeds proactive notifications and 'unplanned vs planned' KPIs.",
        IconClass = "bi bi-tools",
        Actions = new() { new() { Text = "New Schedule", Href = Url.Action("Create", "MaintenanceSchedules") ?? "#", IconClass = "bi bi-plus-circle", CssClass = "btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm" } }
    };
}

<partial name="_PageHeader" model="header" />
@if (TempData["Error"] != null) { <div class="alert alert-danger mb-4">@TempData["Error"]</div> }
<div class="card border-0 shadow-sm mb-4" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-10">
                <label class="form-label small fw-bold text-muted text-uppercase">Search</label>
                <div class="input-group"><span class="input-group-text bg-transparent"><i class="bi bi-search text-primary"></i></span>
                <input type="text" name="request.SearchString" class="form-control bg-transparent" placeholder="Schedule number, title…" value="@request.SearchString" /></div>
            </div>
            <div class="col-lg-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i> Apply</button></div>
        </form>
    </div>
</div>
<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="shell" />
