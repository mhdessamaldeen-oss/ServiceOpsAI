        // Populate the Quick Test panel's model dropdown for one provider tab.
        // Local providers (Ollama / Docker) draw from live discovery; cloud
        // providers draw from their curated Allowed Models list. Every available
        // model is shown — the user can pick any one and any runtime error from
        // the provider (e.g. "does not support chat") surfaces in the response panel.
        async function populateQuickTestModelSelect(providerType) {
            const lc = String(providerType).toLowerCase();
            const select = document.getElementById(`${lc}-test-model`);
            if (!select) return;
            const previous = select.value;

            select.innerHTML = '<option value="">— Loading models —</option>';
            const models = await fetchAllowedProviderModels(providerType);

            select.innerHTML = '';
            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = models.length === 0
                ? (__localDiscoveryProviders.has(providerType)
                    ? '— No models discovered —'
                    : '— No models in Allowed list. Add some above. —')
                : '— Pick a model —';
            placeholder.disabled = models.length === 0;
            select.appendChild(placeholder);

            for (const m of models) {
                const name = m.name || m.Name;
                if (!name) continue;
                const opt = document.createElement('option');
                opt.value = name;
                opt.textContent = name;
                if (name === previous) opt.selected = true;
                select.appendChild(opt);
            }
        }

        // Send a one-off prompt to a provider via the Quick Test panel. The user
        // MUST pick a model first (the selected model is also persisted as the
        // provider's default chat model). Shows raw response/error verbatim so the
        // admin can diagnose 503 / 429 / model-incompatibility issues without
        // going through the copilot pipeline.
        function askProvider(type, btn) {
            const lcType = String(type).toLowerCase();
            const ta = document.getElementById(`${lcType}-test-question`);
            const meta = document.getElementById(`${lcType}-test-meta`);
            const panel = document.getElementById(`${lcType}-test-response`);
            const pre = panel ? panel.querySelector('pre') : null;
            const modelSelect = document.getElementById(`${lcType}-test-model`);
            if (!ta || !panel || !pre) return;

            const question = (ta.value || '').trim();
            if (!question) { ta.focus(); return; }

            const model = modelSelect ? (modelSelect.value || '').trim() : '';
            if (!model) {
                showToast('Pick a model first', 'Choose a model from the dropdown before sending the test.');
                if (modelSelect) modelSelect.focus();
                return;
            }

            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';
            btn.disabled = true;
            if (meta) meta.textContent = '';
            panel.classList.add('d-none');

            const formData = new URLSearchParams();
            formData.append('providerType', type);
            formData.append('question', question);
            formData.append('model', model);

            fetch('/Settings/AskProvider', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData
            })
                .then(r => r.json())
                .then(data => {
                    panel.classList.remove('d-none');
                    const card = panel.querySelector('.card');
                    card.classList.remove('bg-soft-secondary', 'bg-soft-success', 'bg-soft-danger');
                    if (data.success) {
                        card.classList.add('bg-soft-success');
                        pre.textContent = data.response || '(empty response)';
                    } else {
                        card.classList.add('bg-soft-danger');
                        pre.textContent = '❌ ' + (data.error || 'Unknown error');
                    }
                    if (meta) {
                        meta.textContent = `Model: ${data.modelName} · ${data.latencyMs}ms`;
                    }
                })
                .catch(err => {
                    panel.classList.remove('d-none');
                    const card = panel.querySelector('.card');
                    card.classList.remove('bg-soft-secondary', 'bg-soft-success');
                    card.classList.add('bg-soft-danger');
                    pre.textContent = '❌ Network error: ' + err.message;
                })
                .finally(() => {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                });
        }

        // ─── Workload-routing model dropdown population ─────────────────────────
        // Source: each provider's curated "allowed models" list (managed in the provider
        // tab). NOT the live discovery endpoint — the curated list keeps the dropdowns
        // short and meaningful (1–3 models per provider). When the provider dropdown
        // changes we re-fetch; on first load every model select is populated from its
        // current provider value. The currently saved value is kept as a sticky option.
        const __workloadModelCache = {};

        // Local providers (Ollama / Docker) have a real-time discovery endpoint —
        // whatever models the engine has installed are eligible. Cloud providers
        // expose huge model catalogs through /models, so we keep a curated allowed
        // list per provider that the user has explicitly tagged.
        const __localDiscoveryProviders = new Set(['Ollama', 'DockerLocal']);

        async function fetchAllowedProviderModels(providerType) {
            if (!providerType) return [];
            if (__workloadModelCache[providerType]) return __workloadModelCache[providerType];
            const url = __localDiscoveryProviders.has(providerType)
                ? `/Settings/GetProviderModels?providerType=${encodeURIComponent(providerType)}`
                : `/Settings/GetAllowedProviderModels?providerType=${encodeURIComponent(providerType)}`;
            try {
                const resp = await fetch(url).then(r => r.json());
                if (!resp.success) return [];
                const data = resp.data || {};
                // GetProviderModels returns objects with {name, isActive, ...}; GetAllowedProviderModels
                // returns plain string[]. Normalise both to {name} objects.
                const list = data.models || data.Models || [];
                const models = list.map(m => (typeof m === 'string' ? { name: m } : m));
                __workloadModelCache[providerType] = models;
                return models;
            } catch (e) {
                return [];
            }
        }

        function invalidateWorkloadModelCache(providerType) {
            if (providerType && __workloadModelCache[providerType]) {
                delete __workloadModelCache[providerType];
            }
        }

        async function populateWorkloadModelSelect(modelSelect) {
            if (!modelSelect) return;
            const providerSelectId = modelSelect.dataset.providerSelectId;
            const providerSelect = providerSelectId ? document.getElementById(providerSelectId) : null;
            const providerType = providerSelect ? providerSelect.value : '';
            const currentVal = modelSelect.dataset.currentValue || modelSelect.value || '';

            // Reset options: keep "(provider default)" + the saved value as a sticky entry.
            modelSelect.innerHTML = '';
            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = '(provider default)';
            if (!currentVal) defaultOpt.selected = true;
            modelSelect.appendChild(defaultOpt);

            const seen = new Set();
            if (currentVal) {
                const stickyOpt = document.createElement('option');
                stickyOpt.value = currentVal;
                stickyOpt.textContent = currentVal;
                stickyOpt.selected = true;
                modelSelect.appendChild(stickyOpt);
                seen.add(currentVal);
            }

            if (!providerType) return; // no provider selected → only default option visible

            const models = await fetchAllowedProviderModels(providerType);
            // Show every model the user can pick — no role filtering. Picking an
            // embedding model for a chat workload will fail at runtime with the
            // provider's own error (Ollama returns 400 "does not support chat"),
            // which is the appropriate feedback channel.
            if (models.length === 0) {
                const empty = document.createElement('option');
                empty.value = '';
                empty.disabled = true;
                empty.textContent = '— No allowed models. Add some in the provider tab below. —';
                modelSelect.appendChild(empty);
                return;
            }
            for (const m of models) {
                const name = m.name || m.Name;
                if (!name || seen.has(name)) continue;
                const opt = document.createElement('option');
                opt.value = name;
                opt.textContent = name;
                modelSelect.appendChild(opt);
                seen.add(name);
            }
        }

        // Cascade contract:
        // 1. User changes the provider dropdown — we DO NOT save. We just repopulate
        //    the model dropdown from that provider's allowed-models list and prompt
        //    the user to make a selection. Provider alone is not enough to commit.
        // 2. User picks a model (or "(provider default)") — that's the explicit
        //    confirmation that submits the form.
        // The only exception is GLOBALDEFAULT, which has no model dropdown — there
        // we save on provider change because there's no follow-up step.
        function onWorkloadProviderChange(providerSelect) {
            const modelSelectId = providerSelect.dataset.modelSelectId;
            if (!modelSelectId) {
                // GLOBALDEFAULT: no cascade, save now.
                document.getElementById('workloadRoutingForm').submit();
                return;
            }
            const modelSelect = document.getElementById(modelSelectId);
            if (!modelSelect) {
                document.getElementById('workloadRoutingForm').submit();
                return;
            }
            // Switching providers invalidates the prior model — drop the sticky value.
            modelSelect.dataset.currentValue = '';
            populateWorkloadModelSelect(modelSelect);

            // Mark the slot as awaiting a model selection so the user sees what to do next.
            const slot = providerSelect.closest('.routing-slot');
            if (slot) slot.classList.add('routing-slot-pending');
            modelSelect.classList.add('workload-model-needs-selection');
            const hint = slot ? slot.querySelector('.routing-cascade-hint') : null;
            if (hint) hint.classList.remove('d-none');

            // Defer focus so populate finishes first.
            setTimeout(() => modelSelect.focus(), 50);
        }

        function onWorkloadModelChange(modelSelect) {
            // The user explicitly picked a model (or "(provider default)") — this
            // is the commit point of the cascade. Submit so the server saves both
            // provider AND model atomically. The page reload clears the pending
            // visual state automatically.
            document.getElementById('workloadRoutingForm').submit();
        }

        function refreshAllWorkloadModelSelects() {
            document.querySelectorAll('.workload-model-select').forEach(populateWorkloadModelSelect);
        }

        function clearCascadePending(modelSelect) {
            if (!modelSelect) return;
            modelSelect.classList.remove('workload-model-needs-selection');
            const slot = modelSelect.closest('.routing-slot');
            if (slot) {
                slot.classList.remove('routing-slot-pending');
                const hint = slot.querySelector('.routing-cascade-hint');
                if (hint) hint.classList.add('d-none');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            refreshAllWorkloadModelSelects();
            // Allowed-models lists are loaded lazily when the AI tab becomes active
            // (see the loadAllAllowedModelsLists call further below).

            // Delegated click handler for Add/Remove buttons in inventory cards and
            // allowed-models chips. Using data-attributes (not inline onclick) avoids
            // HTML-attribute escaping pitfalls when model names contain special chars
            // (e.g. quotes, colons in tags like "llama3.2:latest").
            document.addEventListener('click', e => {
                const addBtn = e.target.closest('[data-add-allowed]');
                if (addBtn) {
                    e.preventDefault();
                    addAllowedModel(addBtn.dataset.provider, addBtn.dataset.model);
                    return;
                }
                const removeBtn = e.target.closest('[data-remove-allowed]');
                if (removeBtn) {
                    e.preventDefault();
                    removeAllowedModel(removeBtn.dataset.provider, removeBtn.dataset.model);
                }
            });
        });

        // ─── Allowed-models curation ────────────────────────────────────────
        // Each provider tab renders the partial _AllowedModelsSection which expects
        // these helpers to manage the chip list and the manual-add input.
        const __allowedModelAccent = {
            DockerLocal: 'primary',
            Ollama:      'warning',
            OpenAI:      'primary',
            Gemini:      'info',
            Groq:        'success',
            Cloud:       'secondary'
        };

        async function loadAllowedModelsList(providerType) {
            const listEl = document.getElementById(`allowed-models-list-${providerType}`);
            const countEl = document.getElementById(`allowed-models-count-${providerType}`);
            if (!listEl) return;
            try {
                const resp = await fetch(`/Settings/GetAllowedProviderModels?providerType=${encodeURIComponent(providerType)}`)
                    .then(r => r.json());
                if (!resp.success) {
                    listEl.innerHTML = `<span class="text-danger small">${escapeHtmlSafe(resp.error || 'Failed to load.')}</span>`;
                    return;
                }
                const data = resp.data || {};
                const models = data.models || data.Models || [];
                renderAllowedModelChips(providerType, models);
                if (countEl) countEl.textContent = String(models.length);
            } catch (e) {
                listEl.innerHTML = `<span class="text-danger small">Network error: ${escapeHtmlSafe(e.message)}</span>`;
            }
        }

        function renderAllowedModelChips(providerType, models) {
            const listEl = document.getElementById(`allowed-models-list-${providerType}`);
            const countEl = document.getElementById(`allowed-models-count-${providerType}`);
            if (!listEl) return;
            const accent = __allowedModelAccent[providerType] || 'primary';
            if (!models || models.length === 0) {
                listEl.innerHTML = `<span class="text-muted small fst-italic">No models added yet. Use the field below to add one.</span>`;
                if (countEl) countEl.textContent = '0';
                return;
            }
            listEl.innerHTML = models.map(name => `
                <span class="badge bg-soft-${accent} text-${accent} border border-${accent} border-opacity-25 d-inline-flex align-items-center gap-2 px-3 py-2 fw-semibold rounded-pill" style="font-size: 0.75rem;">
                    <i class="bi bi-cpu"></i>
                    <span>${escapeHtmlSafe(name)}</span>
                    <button type="button" class="btn-close btn-close-sm p-0 ms-1" aria-label="Remove" title="Remove from allowed list" data-remove-allowed data-provider="${escapeHtmlSafe(providerType)}" data-model="${escapeHtmlSafe(name)}"></button>
                </span>
            `).join('');
            if (countEl) countEl.textContent = String(models.length);
        }

        async function addAllowedModel(providerType, modelNameOverride) {
            const inputId = `allowed-models-input-${providerType}`;
            const input = document.getElementById(inputId);
            const name = (modelNameOverride !== undefined ? modelNameOverride : (input ? input.value : '')).trim();
            if (!name) {
                if (input) input.focus();
                return;
            }
            try {
                const resp = await fetch('/Settings/AddAllowedProviderModel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ProviderType: providerType, ModelName: name })
                }).then(r => r.json());
                if (!resp.success) { showToast('Error', resp.error || 'Failed to add model.'); return; }
                if (input && modelNameOverride === undefined) input.value = '';
                const data = resp.data || {};
                renderAllowedModelChips(providerType, data.models || []);
                invalidateWorkloadModelCache(providerType);
                refreshAllWorkloadModelSelects();
                populateQuickTestModelSelect(providerType);
                showToast('Added', `'${name}' is now allowed for ${providerType}.`);
            } catch (e) {
                showToast('Error', 'Network error: ' + e.message);
            }
        }

        async function removeAllowedModel(providerType, modelName) {
            try {
                const resp = await fetch('/Settings/RemoveAllowedProviderModel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ProviderType: providerType, ModelName: modelName })
                }).then(r => r.json());
                if (!resp.success) { showToast('Error', resp.error || 'Failed to remove.'); return; }
                const data = resp.data || {};
                renderAllowedModelChips(providerType, data.models || []);
                invalidateWorkloadModelCache(providerType);
                refreshAllWorkloadModelSelects();
                populateQuickTestModelSelect(providerType);
            } catch (e) {
                showToast('Error', 'Network error: ' + e.message);
            }
        }

        function loadAllAllowedModelsLists() {
            ['DockerLocal','Ollama','OpenAI','Gemini','Groq','Cloud'].forEach(loadAllowedModelsList);
        }

        function loadProviderModels(type, containerId) {
            // Info-only inventory for local providers (Docker / Ollama). The live
            // discovery list IS the source for the workload-routing dropdowns —
            // there's no separate "allowed" list to curate. Embedding models get
            // a badge so the user can tell them apart from chat models, but they're
            // automatically excluded from chat workload dropdowns elsewhere.
            const container = document.getElementById(containerId);
            if (!container) return;
            container.innerHTML = '<div class="col-12 text-center py-4"><span class="spinner-border text-primary"></span></div>';

            fetch(`/Settings/GetProviderModels?providerType=${type}`).then(r => r.json()).then(resp => {
                if (!resp.success) {
                    container.innerHTML = `<div class="col-12 text-center py-4"><p class="text-danger small">${resp.error || "Unknown Error"}</p></div>`;
                    return;
                }

                const data = resp.data || {};
                const models = data.models || data.Models || [];

                if (models.length === 0) {
                    container.innerHTML = `<div class="col-12 text-center py-4"><p class="text-muted small">No discovered models in ${type}.</p></div>`;
                    return;
                }

                container.innerHTML = '';
                models.forEach(model => {
                    const name = model.name || model.Name || "Unknown";
                    const size = model.size || model.Size || "N/A";
                    const ctx = model.contextWindow || model.ContextWindow || "";
                    const param = model.parameterSize || model.ParameterSize || 'N/A';
                    const isEmbedding = isLikelyEmbeddingModel(name);

                    const roleBadge = isEmbedding
                        ? `<span class="badge bg-soft-warning text-warning border-0 fw-bold" style="font-size: 0.6rem;" title="Embedding model — used for semantic search / RAG retrieval. Not selectable for chat workloads."><i class="bi bi-vector-pen me-1"></i>EMBED</span>`
                        : `<span class="badge bg-soft-success text-success border-0 fw-bold" style="font-size: 0.6rem;" title="Chat-capable model — eligible for Analysis / RAG generation / Copilot / Classifier workloads."><i class="bi bi-chat-dots me-1"></i>CHAT</span>`;

                    container.innerHTML += `
                        <div class="col-md-6 col-xl-4 mb-2">
                            <div class="card h-100 border-0 shadow-sm transition-all" style="background: rgba(var(--primary-color-rgb), 0.03); border: 1px solid var(--border-color) !important; border-radius: 12px !important;">
                                <div class="card-body p-2 px-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <div class="text-truncate">
                                            <h6 class="fw-bold mb-0 text-truncate" style="font-size: 0.8rem;" title="${name}">${name}</h6>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-bold text-primary" style="font-size: 0.7rem;">${size}</div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                                        <div class="d-flex gap-1 align-items-center">
                                            ${roleBadge}
                                            ${ctx ? `<span class="badge bg-soft-primary text-primary border-0 fw-bold" style="font-size: 0.6rem;"><i class="bi bi-brain me-1"></i>${ctx}</span>` : ''}
                                            <span class="badge bg-light text-muted border-0 fw-normal" style="font-size: 0.6rem;">${param}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                });
            }).catch(err => {
                container.innerHTML = `<div class="col-12 text-center py-4"><p class="text-danger small">Network Error: ${err.message}</p></div>`;
            });
        }

        function setProviderModel(type, modelName, btnArg) {
            // btnArg is passed via onclick="setProviderModel(..., this)"; fall back
            // to event.target for older callers so nothing breaks during refresh.
            const btn = btnArg || (typeof event !== 'undefined' ? event.target.closest('button') : null);
            const originalHtml = btn ? btn.innerHTML : '';
            if (btn) {
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Activating...';
                btn.disabled = true;
            }
            const restoreBtn = () => { if (btn) { btn.innerHTML = originalHtml; btn.disabled = false; } };

            fetch('/Settings/SetProviderModel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ProviderType: type, ModelName: modelName })
            }).then(async r => {
                if (!r.ok) {
                    const text = await r.text();
                    throw new Error(`Server returned ${r.status}: ${text || 'Empty response'}`);
                }
                return r.json();
            }).then(resp => {
                try { showToast(resp.success ? 'Success' : 'Error', resp.message || resp.error || ''); } catch {}
                if (resp.success) {
                    // Re-render the matching panel — covers Docker/Ollama (the only
                    // providers SetProviderModel actually accepts today).
                    const containerId = type === 'Ollama' ? 'ollama-models-container-p' : 'models-container';
                    loadProviderModels(type, containerId);
                } else {
                    restoreBtn();
                }
            }).catch(err => {
                try { showToast('Error', 'Activation failed: ' + err.message); } catch {}
                restoreBtn();
            });
        }

        function pullProviderModel(providerType, inputId, statusId) {
            const modelName = document.getElementById(inputId).value.trim();
            if (!modelName) { alert('Specify model name'); return; }
            const statusContainer = document.getElementById(statusId);
            const progressBar = statusContainer.querySelector('.progress-bar');
            const statusText = document.getElementById(statusId.replace('status', 'text'));
            statusContainer.classList.remove('d-none');
            progressBar.style.width = '0%';
            statusText.innerText = `Pulling ${modelName}...`;

            fetch(providerType === 'Ollama' ? '/Settings/PullOllamaModel' : '/Settings/PullDockerModel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ modelName })
            }).then(async response => {
                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    const chunk = decoder.decode(value, { stream: true });
                    const lines = chunk.split('\n');
                    lines.forEach(line => {
                        if (!line.trim()) return;
                        try {
                            const data = JSON.parse(line);
                            if (data.status) {
                                statusText.innerText = data.status;
                                if (data.completed && data.total) progressBar.style.width = `${Math.round((data.completed / data.total) * 100)}%`;
                            }
                        } catch (e) { statusText.innerText = line; }
                    });
                }
                statusText.innerHTML = '<span class="text-success fw-bold">Ready!</span>';
                progressBar.style.width = '100%';
                setTimeout(() => {
                    if (providerType === 'Ollama') {
                        loadProviderModels('Ollama', 'ollama-models-container-p');
                    } else {
                        loadProviderModels(providerType, 'models-container');
                    }
                    // Re-populate Quick Test pickers so the freshly-pulled model is selectable.
                    populateQuickTestModelSelect(providerType);
                    // And refresh any workload dropdown driven by live discovery.
                    refreshAllWorkloadModelSelects();
                }, 1000);
            });
        }

        function setDatabaseServer(serverName) { document.getElementById('db-server-name').value = serverName; }
        function syncConnectionStringFromBuilder() {
            const server = document.getElementById('db-server-name').value;
            const db = document.getElementById('db-database-name').value;
            document.getElementById('db-connection-string').value = `Server=${server};Database=${db};Integrated Security=True;TrustServerCertificate=True;`;
        }
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            input.type = input.type === 'password' ? 'text' : 'password';
            btn.innerHTML = input.type === 'password' ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
        }
    </script>
}
