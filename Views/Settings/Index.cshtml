        function escapeJsAttr(v) {
            return String(v ?? '').replace(/[\\'"]/g, ch => '\\' + ch);
        }

        // ─── Groq Pool — mirrors Gemini handlers, plus shows real `x-ratelimit-*` numbers from the last call. ───

        async function loadGroqPool() {
            const tbody = document.getElementById('groq-pool-tbody');
            if (!tbody) return;
            tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted py-3">Loading…</td></tr>`;
            try {
                const res = await fetch('/Settings/ListGroqKeys');
                const d = await res.json();
                const data = d.data || d.Data;
                const keys = (data && (data.keys || data.Keys)) || [];

                if (keys.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted py-3 small">
                        No keys yet — add your first one above. The legacy single key in the form above is also still used as a fallback.
                    </td></tr>`;
                    return;
                }

                tbody.innerHTML = keys.map(k => {
                    const used = k.dailyRequestCount ?? k.DailyRequestCount ?? 0;
                    const remReq = k.remainingRequests ?? k.RemainingRequests;
                    const remTok = k.remainingTokens ?? k.RemainingTokens;
                    const limReq = k.limitRequests ?? k.LimitRequests;
                    const limTok = k.limitTokens ?? k.LimitTokens;
                    const status = (k.status || k.Status || 'ok');
                    const masked = k.maskedKey || k.MaskedKey || '—';
                    const label = k.label || k.Label || '';
                    const owner = k.ownerEmail || k.OwnerEmail || '';
                    const sharesQuota = !!(k.sharesQuotaWithSibling ?? k.SharesQuotaWithSibling);
                    const id = k.id || k.Id;
                    const isActive = !!(k.isActive ?? k.IsActive);
                    const lastUsed = k.lastUsedAtUtc || k.LastUsedAtUtc;
                    const lastErr = k.lastErrorMessage || k.LastErrorMessage;
                    const snapAt = k.quotaSnapshotAtUtc || k.QuotaSnapshotAtUtc;

                    // Live cells — these come straight from Groq's response headers, not estimates.
                    // Fade them when the snapshot is missing (key never used) or older than 90s.
                    const stale = !snapAt || (Date.now() - new Date(snapAt).getTime()) > 90_000;
                    const liveClass = stale ? 'text-muted' : 'fw-bold';
                    const remReqCell = remReq == null
                        ? `<span class="small text-muted fst-italic">—</span>`
                        : `<span class="${liveClass}">${remReq}${limReq ? ` / ${limReq}` : ''}</span>`;
                    const remTokCell = remTok == null
                        ? `<span class="small text-muted fst-italic">—</span>`
                        : `<span class="${liveClass}">${Number(remTok).toLocaleString()}${limTok ? ` / ${Number(limTok).toLocaleString()}` : ''}</span>`;

                    const ownerCell = owner
                        ? `<span class="small">${escapeHtmlSafe(owner)}</span>${sharesQuota ? ` <i class="bi bi-exclamation-triangle-fill text-warning ms-1" title="Another key uses this email — shares the same daily account quota."></i>` : ''}`
                        : `<span class="small text-muted fst-italic">(unset)</span>`;

                    return `
                        <tr>
                            <td><strong>${escapeHtmlSafe(label)}</strong></td>
                            <td>${ownerCell}</td>
                            <td><code class="small text-muted">${escapeHtmlSafe(masked)}</code></td>
                            <td>${statusBadge(status)}${lastErr ? `<div class="small text-danger mt-1" style="max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${escapeHtmlSafe(lastErr)}"><i class="bi bi-exclamation-triangle me-1"></i>${escapeHtmlSafe(lastErr)}</div>` : ''}</td>
                            <td class="text-center"><span class="small fw-bold">${used}</span></td>
                            <td class="text-center">${remReqCell}</td>
                            <td class="text-center">${remTokCell}</td>
                            <td class="small text-muted">${relativeTime(lastUsed)}</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-secondary" title="${isActive ? 'Disable' : 'Enable'}"
                                            onclick="setGroqKeyActive(${id}, ${!isActive})">
                                        <i class="bi ${isActive ? 'bi-pause' : 'bi-play'}"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" title="Reset counter"
                                            onclick="resetGroqKeyCount(${id})">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" title="Rename"
                                            onclick="renameGroqKey(${id}, '${escapeJsAttr(label)}')">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger" title="Remove"
                                            onclick="removeGroqKey(${id}, '${escapeJsAttr(label)}')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>`;
                }).join('');
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="9" class="text-center text-danger py-3 small">Failed to load: ${escapeHtmlSafe(err.message)}</td></tr>`;
            }
        }

