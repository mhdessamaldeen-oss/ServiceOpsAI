@model List<AISupportAnalysisPlatform.Models.CustomTheme>
@{
    var currentThemeId = ViewBag.CurrentThemeId as string ?? "1";
}

<div class="row g-4 animate__animated animate__fadeIn">
    <div class="col-lg-8">
        <div class="card border-0 shadow-lg mb-3" style="border-radius: 16px;">
            <div class="card-header border-0 pb-0 pt-3 px-3 bg-transparent d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="fw-bold mb-0 text-uppercase small ls-1 text-muted">@Loc.Get("IdentityRepository")</h6>
                    <p class="text-muted smaller mb-0">@Loc.Get("IdentitySubtitle")</p>
                </div>
                <button class="btn-action btn-action-sm" onclick="openArchitect('new')">
                    <i class="bi bi-plus-lg"></i><span>@Loc.Get("CreateNewArchitecture")</span>
                </button>
            </div>
            <div class="card-body p-3">
                <div class="row g-3">
                    @foreach (var theme in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="theme-card card h-100 border-0 shadow-sm transition-all @(currentThemeId == theme.Id.ToString() ? "active-theme" : "")" 
                                 style="background: @theme.BgCard !important; border: 1px solid @theme.BorderColor !important; border-radius: 16px;">
                                <div class="card-body p-3 text-center">
                                    <div class="theme-preview mb-3 rounded-3 shadow-md mx-auto" 
                                         style="background: @theme.BgMain; border: 2px solid @theme.PrimaryColor; width: 100px; height: 60px; position: relative; overflow: hidden;">
                                        <div style="position: absolute; top: 6px; inset-inline-start: 6px; width: 20px; height: 3px; background: @theme.PrimaryColor; border-radius: 1px;"></div>
                                        <div style="position: absolute; top: 12px; inset-inline-start: 6px; width: 10px; height: 3px; background: @theme.TextMuted; border-radius: 1px;"></div>
                                        <div style="position: absolute; bottom: 10px; inset-inline-end: 10px; width: 20px; height: 20px; background: @theme.PrimaryColor; border-radius: 4px; opacity: 0.2;"></div>
                                    </div>
                                    <h6 class="fw-bold mb-2" style="color: @theme.TextMain">@Loc.Get(theme.Name)</h6>
                                    <div class="d-flex gap-1 justify-content-center mb-3">
                                        <form asp-action="UpdateTheme" method="post">
                                            <input type="hidden" name="themeId" value="@theme.Id" />
                                            @if (currentThemeId == theme.Id.ToString())
                                            {
                                                <button type="button" class="btn btn-success btn-sm fw-bold px-3 disabled rounded-pill">@Loc.Get("Active")</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-outline-primary btn-sm fw-bold px-3 rounded-pill" style="border-color: @theme.PrimaryColor; color: @theme.PrimaryColor">@Loc.Get("Apply")</button>
                                            }
                                        </form>
                                        <button class="btn btn-outline-secondary btn-sm fw-bold px-2 rounded-pill refine-btn"
                                                data-theme-id="@theme.Id"
                                                data-theme-name="@theme.Name"
                                                data-theme-primary="@theme.PrimaryColor"
                                                data-theme-primarycontrast="@(theme.PrimaryContrastText ?? "#ffffff")"
                                                data-theme-bgmain="@theme.BgMain"
                                                data-theme-bgcard="@theme.BgCard"
                                                data-theme-bgsurfacealt="@(theme.BgSurfaceAlt ?? theme.BgCard)"
                                                data-theme-bgelevated="@(theme.BgElevated ?? theme.BgCard)"
                                                data-theme-bgsidebar="@theme.BgSidebar"
                                                data-theme-bgheader="@theme.BgHeader"
                                                data-theme-textmain="@theme.TextMain"
                                                data-theme-textmuted="@theme.TextMuted"
                                                data-theme-border="@theme.BorderColor"
                                                data-theme-success="@(theme.SuccessColor ?? "#16a34a")"
                                                data-theme-warning="@(theme.WarningColor ?? "#d97706")"
                                                data-theme-danger="@(theme.DangerColor ?? "#dc2626")"
                                                data-theme-info="@(theme.InfoColor ?? "#2563eb")"
                                                data-theme-shadow="@(theme.ShadowColor ?? "rgba(15, 23, 42, 0.08)")"
                                                data-theme-issystem="@theme.IsSystemTheme.ToString().ToLower()"
                                                data-theme-sysid="@theme.SystemIdentifier"
                                                onclick="openArchitect(this)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        @if (theme.IsSystemTheme)
                                        {
                                            <form asp-action="ResetTheme" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@theme.Id" />
                                                <button type="submit" class="btn btn-outline-warning btn-sm fw-bold px-2 rounded-pill" title="@Loc.Get("ResetToFactory")">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="DeleteTheme" method="post" class="d-inline" onsubmit="return confirm('@Loc.Get("PurgeConfirm")');">
                                                <input type="hidden" name="id" value="@theme.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm fw-bold px-2 rounded-pill" title="@Loc.Get("PurgeArchitecture")">
                                                    <i class="bi bi-trash3-fill"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <!-- Architect Studio Panel -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-lg sticky-top" style="top: 20px; border-radius: 16px;">
            <div class="card-header border-0 pt-3 px-3 bg-transparent">
                <h6 class="fw-bold mb-0 text-uppercase small ls-1 text-muted" id="studio-title">@Loc.Get("ArchitectStudio")</h6>
                <p class="text-muted smaller">@Loc.Get("StudioSubtitle")</p>
            </div>
            <div class="card-body p-3 pt-0">
                <form id="architectForm" asp-action="SaveTheme" method="post">
                    <input type="hidden" id="theme-id" name="Id" value="0" />
                    <input type="hidden" name="IsSystemTheme" id="theme-issystem" value="false" />
                    <input type="hidden" name="SystemIdentifier" id="theme-sysid" value="" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ArchitectureName")</label>
                        <input type="text" class="form-control bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;" id="theme-name" name="Name" required />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("PrimaryAccent")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-primary" name="PrimaryColor" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("MainBackground")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgmain" name="BgMain" />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("CardSurface")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgcard" name="BgCard" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("SidebarSurface")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgsidebar" name="BgSidebar" />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("HeaderSurface")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgheader" name="BgHeader" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("BorderToken")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-border" name="BorderColor" />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("PrimaryText")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-textmain" name="TextMain" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("MutedText")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-textmuted" name="TextMuted" />
                        </div>
                    </div>

                    <hr style="border-color: var(--border-color) !important;" />
                    <div class="small fw-bold text-muted text-uppercase ls-1 mb-2">@Loc.Get("SurfacesContrastLabel")</div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("SurfaceAltRowsLabel")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgsurfacealt" name="BgSurfaceAlt" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ElevatedModalsLabel")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgelevated" name="BgElevated" />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("TextOnPrimaryButtonsLabel")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-primarycontrast" name="PrimaryContrastText" />
                        </div>
                    </div>

                    <div class="small fw-bold text-muted text-uppercase ls-1 mb-2">@Loc.Get("SemanticStates")</div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ColorSuccess")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-success" name="SuccessColor" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ColorWarning")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-warning" name="WarningColor" />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ColorDanger")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-danger" name="DangerColor" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ColorInfo")</label>
                            <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-info" name="InfoColor" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">@Loc.Get("ShadowColorLabel")</label>
                        <input type="text" class="form-control bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;" id="theme-shadow" name="ShadowColor" placeholder="rgba(0, 0, 0, 0.45)" />
                    </div>

                    <button type="submit" class="btn-action w-100 py-2">
                        <i class="bi bi-cpu-fill"></i><span>@Loc.Get("ApplyArchitecturalChange")</span>
                    </button>
                    <button type="button" class="btn-action-ghost w-100 mt-2 py-2" onclick="openArchitect('new')">
                        <i class="bi bi-eraser"></i><span>@Loc.Get("ClearEditor")</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
