@{
    var sqlServerCandidates = ViewBag.SqlServerCandidates as List<AISupportAnalysisPlatform.Controllers.Admin.SettingsController.SqlServerCandidateInfo> ?? new();
    var dbServerName = ViewBag.DbServerName as string ?? "";
    var dbDatabaseName = ViewBag.DbDatabaseName as string ?? "";
}

<div class="row g-4 animate__animated animate__fadeIn">
    <div class="col-lg-7">
        <div class="card border-0 shadow-lg mb-3" style="border-radius: 16px;">
            <div class="card-header border-0 pb-0 pt-3 px-3 bg-transparent">
                <h6 class="fw-bold mb-1"><i class="bi bi-stack me-2 text-primary"></i>Operational Data</h6>
                <p class="text-muted smaller mb-0">Manage seeded ticket data manually.</p>
            </div>
            <div class="card-body p-3">
                <div class="row g-3 mb-4">
                    <div class="col-md-6 col-xl-4">
                        <div class="p-3 rounded-3 border h-100 bg-light bg-opacity-50">
                            <div class="small text-muted text-uppercase fw-bold">Tickets Count</div>
                            <div class="fs-4 fw-bold">@ViewBag.TicketCount</div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <div class="p-3 rounded-3 border h-100 bg-light bg-opacity-50">
                            <div class="small text-muted text-uppercase fw-bold">Comments</div>
                            <div class="fs-4 fw-bold">@ViewBag.TicketCommentCount</div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <div class="p-3 rounded-3 border h-100 bg-light bg-opacity-50">
                            <div class="small text-muted text-uppercase fw-bold">Attachments</div>
                            <div class="fs-4 fw-bold">@ViewBag.TicketAttachmentCount</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <form asp-action="SeedData" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">
                            <i class="bi bi-cloud-arrow-down-fill me-2"></i>Seed Data
                        </button>
                    </form>
                    <form asp-action="FlushData" method="post" class="m-0" onsubmit="return confirm('Purge all data?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4 fw-bold">
                            <i class="bi bi-trash3-fill me-2"></i>Flush Data
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 16px;">
            <div class="card-header border-0 px-3 pt-3 pb-2 bg-transparent">
                <h6 class="fw-bold mb-1"><i class="bi bi-diagram-3-fill me-2 text-primary"></i>Database Migration Studio</h6>
                <p class="text-muted smaller mb-0">Configure target and apply schema migrations.</p>
            </div>
            <div class="card-body p-3">
                <div class="row g-4">
                    <div class="col-xl-4">
                        <div class="p-4 rounded-4 h-100 border bg-light bg-opacity-25">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge rounded-pill bg-primary">1</span>
                                <h6 class="fw-bold mb-0">Target Server</h6>
                            </div>
                            <form asp-action="DiscoverSqlServers" method="post" class="mb-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-primary w-100 rounded-pill fw-bold">
                                    <i class="bi bi-pc-display-horizontal me-2"></i>Scan Local PC
                                </button>
                            </form>
                            @if (sqlServerCandidates.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var candidate in sqlServerCandidates)
                                    {
                                        <button type="button" class="btn btn-light btn-sm border rounded-pill px-3" onclick="setDatabaseServer('@candidate.ServerName')">@candidate.ServerName</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-xl-4">
                        <div class="p-4 rounded-4 h-100 border">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge rounded-pill bg-secondary">2</span>
                                <h6 class="fw-bold mb-0">Inspect Engine</h6>
                            </div>
                            <form asp-action="InspectSqlServer" method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">Server Name</label>
                                    <input type="text" id="db-server-name" name="serverName" value="@dbServerName" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-muted">Database Name</label>
                                    <input type="text" id="db-database-name" value="@dbDatabaseName" class="form-control" />
                                </div>
                                <button type="submit" class="btn btn-secondary w-100 rounded-pill fw-bold">Inspect</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-xl-4">
                        <div class="p-4 rounded-4 h-100 border bg-primary bg-opacity-10 border-primary border-opacity-25">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge rounded-pill bg-primary">3</span>
                                <h6 class="fw-bold mb-0">Apply Target</h6>
                            </div>
                            <form asp-action="ActivateRuntimeDatabaseTarget" method="post">
                                @Html.AntiForgeryToken()
                                <textarea id="db-connection-string" name="connectionString" rows="5" class="form-control mb-3 font-monospace smaller">@ViewBag.CurrentConnectionString</textarea>
                                <div class="d-grid gap-2">
                                    <button type="button" class="btn btn-outline-primary rounded-pill fw-bold" onclick="syncConnectionStringFromBuilder()">Generate</button>
                                    <button type="submit" class="btn btn-primary rounded-pill fw-bold">Apply Runtime Target</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
