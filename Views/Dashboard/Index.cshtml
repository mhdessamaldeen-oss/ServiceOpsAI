<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="recentTicketsTable" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const isRtl = @(Loc.IsRtl.ToString().ToLower());
        const statusData = @Html.Raw(Json.Serialize(Model.StatusBreakdown));
        const sourceData = @Html.Raw(Json.Serialize(Model.SourceBreakdown));
        const weeklyVolume = @Html.Raw(Json.Serialize(Model.WeeklyVolume));
        const productAreaData = @Html.Raw(Json.Serialize(Model.ProductAreas));

        const rootStyle = getComputedStyle(document.body);
        const primaryCol = rootStyle.getPropertyValue('--primary-color').trim();
        const mainText = rootStyle.getPropertyValue('--text-main').trim();
        const mutedText = rootStyle.getPropertyValue('--text-muted').trim();
        const borderCol = rootStyle.getPropertyValue('--border-color').trim();

        Chart.defaults.font.family = isRtl ? "'Noto Sans Arabic', sans-serif" : "'Outfit', sans-serif";
        Chart.defaults.color = mutedText;

        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            rtl: isRtl,
            plugins: {
                legend: {
                    rtl: isRtl,
                    labels: {
                        color: mainText,
                        usePointStyle: true,
                        padding: 18
                    }
                }
            },
            scales: {
                x: {
                    reverse: isRtl,
                    ticks: { color: mainText },
                    grid: { display: false }
                },
                y: {
                    position: isRtl ? 'right' : 'left',
                    beginAtZero: true,
                    ticks: { color: mutedText },
                    grid: { color: borderCol }
                }
            }
        };

        new Chart(document.getElementById('weeklyVolumeChart'), {
            type: 'line',
            data: {
                labels: weeklyVolume.map(item => item.label),
                datasets: [{
                    label: isRtl ? 'التذاكر المنشأة' : 'Tickets Created',
                    data: weeklyVolume.map(item => item.value),
                    borderColor: primaryCol,
                    backgroundColor: `${primaryCol}22`,
                    fill: true,
                    tension: 0.35,
                    pointBackgroundColor: primaryCol,
                    pointRadius: 4
                }]
            },
            options: commonOptions
        });

        new Chart(document.getElementById('statusBreakdownChart'), {
            type: 'doughnut',
            data: {
                labels: statusData.map(item => item.label),
                datasets: [{
                    data: statusData.map(item => item.value),
                    backgroundColor: [primaryCol, '#f59e0b', '#3b82f6', '#a855f7', '#10b981', '#71717a', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '72%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        rtl: isRtl,
                        labels: {
                            color: mainText,
                            usePointStyle: true,
                            padding: 16
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById('productAreaChart'), {
            type: 'bar',
            data: {
                labels: productAreaData.map(item => item.label),
                datasets: [{
                    label: isRtl ? 'التذاكر' : 'Tickets',
                    data: productAreaData.map(item => item.value),
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#a855f7', '#ef4444'],
                    borderRadius: 10
                }]
            },
            options: {
                ...commonOptions,
                indexAxis: 'y'
            }
        });

        new Chart(document.getElementById('sourceBreakdownChart'), {
            type: 'polarArea',
            data: {
                labels: sourceData.map(item => item.label),
                datasets: [{
                    data: sourceData.map(item => item.value),
                    backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#a855f7', '#ef4444']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        rtl: isRtl,
                        labels: {
                            color: mainText,
                            usePointStyle: true,
                            padding: 16
                        }
                    }
                },
                scales: {
                    r: {
                        grid: { color: borderCol },
                        ticks: { display: false }
                    }
                }
            }
        });
    </script>
}
