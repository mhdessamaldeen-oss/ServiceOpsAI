@model ServiceOpsAI.Models.Subsidy
@{ ViewData["Title"] = "New Subsidy"; }

<h2><i class="bi bi-plus-circle"></i> New Subsidy</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-4"><label asp-for="ProgramCode" class="form-label">Program Code</label><input asp-for="ProgramCode" class="form-control" placeholder="DISPLACED-2026 / LOW-INCOME-RES" /></div>
    <div class="col-md-4"><label asp-for="ProgramNameEn" class="form-label">Program Name (EN)</label><input asp-for="ProgramNameEn" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="ProgramNameAr" class="form-label">Program Name (AR)</label><input asp-for="ProgramNameAr" class="form-control" dir="rtl" /></div>
    <div class="col-md-4"><label asp-for="CustomerId" class="form-label">Customer</label><select asp-for="CustomerId" class="form-select" asp-items="ViewBag.Customers"><option value="">— Select —</option></select></div>
    <div class="col-md-4"><label asp-for="BillId" class="form-label">Bill (optional)</label><select asp-for="BillId" class="form-select" asp-items="ViewBag.Bills"><option value="">—</option></select></div>
    <div class="col-md-4"><label asp-for="CustomerSegmentId" class="form-label">Segment</label><select asp-for="CustomerSegmentId" class="form-select" asp-items="ViewBag.Segments"><option value="">—</option></select></div>
    <div class="col-md-3"><label asp-for="Amount" class="form-label">Amount (SYP)</label><input asp-for="Amount" type="number" step="0.01" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="AppliedPercent" class="form-label">Applied %</label><input asp-for="AppliedPercent" type="number" step="0.01" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="IssuedAt" class="form-label">Issued At</label><input asp-for="IssuedAt" type="date" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select">@foreach (var v in Enum.GetValues<ServiceOpsAI.Models.SubsidyStatus>()){<option value="@v">@v</option>}</select></div>
    <div class="col-12"><label asp-for="Notes" class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
    <div class="col-12"><button type="submit" class="btn btn-primary">Create</button> <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancel</a></div>
</form>
