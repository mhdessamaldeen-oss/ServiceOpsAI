@model ServiceOpsAI.Models.Subsidy
@{ ViewData["Title"] = "Subsidy Details"; }

<h2><i class="bi bi-bank"></i> @Model.ProgramCode</h2>

<div class="card shadow-sm" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Program</dt><dd class="col-sm-9"><code>@Model.ProgramCode</code> — @Model.ProgramNameEn / <span dir="rtl">@Model.ProgramNameAr</span></dd>
            <dt class="col-sm-3">Customer</dt><dd class="col-sm-9">@Model.Customer?.FullNameEn / <span dir="rtl">@Model.Customer?.FullNameAr</span></dd>
            <dt class="col-sm-3">Bill</dt><dd class="col-sm-9"><code>@Model.Bill?.BillNumber</code></dd>
            <dt class="col-sm-3">Segment</dt><dd class="col-sm-9">@Model.CustomerSegment?.NameEn</dd>
            <dt class="col-sm-3">Amount (SYP)</dt><dd class="col-sm-9 fw-bold">@Model.Amount.ToString("N2")</dd>
            <dt class="col-sm-3">Applied %</dt><dd class="col-sm-9">@(Model.AppliedPercent?.ToString("N2") ?? "—")%</dd>
            <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Issued At</dt><dd class="col-sm-9">@Model.IssuedAt.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@Model.Notes</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>
