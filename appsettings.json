{
  "ConnectionStrings": {
    "DefaultConnection": "Server=PC\\SQLEXPRESS;Database=AISupportAnalysisDB;Integrated Security=True;Trusted_Connection=True;TrustServerCertificate=true;Encrypt=false;MultipleActiveResultSets=True;Max Pool Size=200;Connect Timeout=30;"
  },
  "Seed": {
    "//": "Set ForceReseed=true to wipe seed-managed tables (Tickets/Bills/Customers/Outages/WorkOrders/etc.) on next startup so seeders repopulate from scratch. Identity, lookups, and copilot history are preserved. Remember to flip back to false after one fresh run, otherwise every app start will wipe the DB.",
    "ForceReseed": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "Server": {
    "Urls": "http://localhost:8800;https://localhost:8899"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:8800"
      },
      "Https": {
        "Url": "https://localhost:8899"
      }
    },
    "Limits": {
      "MaxRequestBodySize": 52428800,
      "RequestHeadersTimeout": "00:01:00"
    }
  },
  "Security": {
    "EnableCors": true,
    "CorsOrigins": ["http://localhost:3000", "http://localhost:8800"],
    "EnableHttpsRedirection": true,
    "EnableAntiForgery": true,
    "CookiePolicy": {
      "IsEssential": true,
      "SecurePolicy": "SameAsRequest"
    }
  },
  "Caching": {
    "EnableMemoryCache": true,
    "EnableDistributedCache": false,
    "DefaultExpirationMinutes": 30,
    "MaxCacheSize": 1000
  },
  "Localization": {
    "DefaultCulture": "en-US",
    "SupportedCultures": ["en-US", "ar-SA"],
    "EnableRequestLocalization": true,
    "ResourcePath": "Resources"
  },
  "Files": {
    "MaxFileSize": 10485760,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".pdf", ".doc", ".docx", ".txt"],
    "UploadPath": "./uploads",
    "EnableVirusScanning": false
  },
  "Email": {
    "EnableEmail": false,
    "SmtpServer": "localhost",
    "SmtpPort": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@supportflow-ai.com"
  },
  "Monitoring": {
    "EnableHealthChecks": true,
    "HealthCheckPath": "/health",
    "EnableMetrics": true,
    "MetricsPath": "/metrics",
    "EnableLogging": true,
    "LogLevel": "Information"
  },
  "SuperAdminCopilot": {
    "UsePastQuestionRag": false
  },
  "Ai": {
    "RoleBindings": {
      "QuerySpecComposer": {
        "Provider": "Ollama",
        "Model": "qwen2.5-coder:7b",
        "Temperature": 0.1
      }
    }
  }
}
